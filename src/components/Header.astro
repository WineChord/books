---
import ThemeToggle from "./ThemeToggle.astro";
import { pageUrl } from "../urls";

interface Props {
  lang?: "en" | "zh";
  alternatePath?: string;
  showMenu?: boolean;
  homePath?: string;
  brandTitle?: string;
  brandShortTitle?: string;
}

const {
  lang = "en",
  alternatePath,
  showMenu = false,
  homePath: configuredHomePath,
  brandTitle = "Codex From Source",
  brandShortTitle = "Codex",
} = Astro.props;
const base = import.meta.env.BASE_URL;
const homePath = pageUrl(
  base,
  configuredHomePath ??
    (lang === "zh" ? "zh/codex-from-source/" : "codex-from-source/"),
);
const alternate = alternatePath
  ? pageUrl(base, alternatePath)
  : lang === "zh"
    ? pageUrl(base, "codex-from-source/")
    : pageUrl(base, "zh/codex-from-source/");
---

<header class="sticky top-0 z-40 border-b border-border bg-cream/95 backdrop-blur dark:border-[#333] dark:bg-charcoal/95">
  <div class="flex h-14 items-center justify-between px-4 lg:px-6">
    <div class="flex items-center gap-3">
      {showMenu && (
        <button
          id="sidebar-toggle"
          type="button"
          aria-controls="sidebar-mobile"
          aria-expanded="false"
          aria-label="Toggle navigation"
          class="-ml-2 rounded-md p-2 transition-colors hover:bg-beige dark:hover:bg-dark-surface lg:hidden"
        >
          <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      )}
      <a href={homePath} class="site-title text-sm font-semibold tracking-tight text-charcoal transition-colors hover:text-terracotta dark:text-cream">
        <span class="site-brand-mark" aria-hidden="true">
          <svg viewBox="0 0 32 32" fill="none">
            <path class="site-brand-mark__cover" d="M7 4.5h14.5c2.2 0 4 1.8 4 4v19H11c-2.2 0-4-1.8-4-4v-19Z" />
            <path class="site-brand-mark__spine" d="M11 4.5v23" />
            <path class="site-brand-mark__line" d="M15 11h6.5M15 16h4.5M15 21h6.5" />
            <path class="site-brand-mark__fold" d="M25.5 8.5 29 11v16.5l-3.5-2.5" />
          </svg>
        </span>
        <span>
          <span class="site-title-full">{brandTitle}</span>
          <span class="site-title-short">{brandShortTitle}</span>
        </span>
      </a>
    </div>
    <div class="header-actions flex items-center gap-2">
      <button
        id="focus-toggle"
        type="button"
        aria-label="Toggle focus mode"
        title="Focus mode"
        class="hidden rounded-md p-2 text-charcoal transition-colors hover:bg-beige dark:text-cream dark:hover:bg-dark-surface lg:flex"
      >
        <svg id="focus-icon-expand" class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4h4M4 4l5 5m11-1V4h-4m4 0-5 5M4 16v4h4m-4 0 5-5m11 5v-4h-4m4 4-5-5" />
        </svg>
        <svg id="focus-icon-collapse" class="hidden size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 4H4v5m11-5h5v5M9 20H4v-5m11 5h5v-5" />
        </svg>
      </button>
      <a href={alternate} class="language-switch rounded-md px-3 py-2 text-sm text-muted transition-colors hover:bg-beige hover:text-terracotta dark:hover:bg-dark-surface">
        {lang === "zh" ? "English" : "中文"}
      </a>
      <a
        href="https://github.com/WineChord/books"
        target="_blank"
        rel="noopener noreferrer"
        class="header-github rounded-md p-2 text-charcoal transition-colors hover:bg-beige dark:text-cream dark:hover:bg-dark-surface"
        aria-label="GitHub repository"
      >
        <svg class="size-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0a12 12 0 0 0-3.8 23.39c.6.11.8-.26.8-.58v-2.23c-3.34.73-4.03-1.42-4.03-1.42-.55-1.39-1.33-1.76-1.33-1.76-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.49 1 .11-.78.42-1.31.76-1.6-2.66-.31-5.47-1.34-5.47-5.94 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.65 1.65.24 2.87.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.62-5.48 5.92.43.37.82 1.1.82 2.22v3.29c0 .32.19.69.8.58A12 12 0 0 0 12 0z" />
        </svg>
      </a>
      <ThemeToggle />
    </div>
  </div>
</header>
