          {clientText.examples.map(([value, label]) => (
            <button type="button" data-sa-example={value}>{label}</button>
          ))}
        </div>
      </div>

      <div class="sa-stage-tabs" role="tablist" aria-label={pageText.labTitle}>
        {Object.entries(pageText.stageLabels).map(([stage, label]) => (
          <button
            type="button"
            class={stage === "concept" ? "is-active" : ""}
            data-sa-stage={stage}
          >
            {label}
          </button>
        ))}
      </div>

      <div class="sa-stage-note" data-sa-stage-note>
        {clientText.stageNotes.concept}
      </div>

      <div class="sa-lesson-board">
        <article class="sa-teacher-card">
          <p class="sa-section-kicker" data-sa-step-index>00</p>
          <h2 data-sa-step-title></h2>
          <p data-sa-step-body></p>
          <ul data-sa-step-bullets></ul>
          <div class="sa-code-bridge">
            <span>{clientText.codeBridge}</span>
            <strong data-sa-code-bridge></strong>
          </div>
        </article>

        <article class="sa-focus-card">
          <p class="sa-section-kicker">{clientText.activeSuffix}</p>
          <h2 data-sa-active-title></h2>
          <div class="sa-active-suffix" data-sa-active-suffix></div>
          <div class="sa-prefix-list" data-sa-prefix-list></div>
          <div class="sa-neighbor-box" data-sa-neighbor-box></div>
        </article>

        <article class="sa-quiz-card">
          <p class="sa-section-kicker">{clientText.selfCheck}</p>
          <h2 data-sa-quiz-question></h2>
          <div class="sa-quiz-choices" data-sa-quiz-choices></div>
          <p data-sa-quiz-feedback></p>
        </article>
      </div>

      <div class="sa-round-control">
        <label for="sa-round">{pageText.roundLabel}</label>
        <input id="sa-round" type="range" min="0" max="0" value="0" />
        <span data-sa-round-label>k = 1</span>
      </div>

      <div class="sa-visual-grid">
        <section class="sa-panel sa-sequence-panel">
          <h2>{pageText.stageLabels.compress}</h2>
          <div class="sa-array-stack" data-sa-sequence></div>
          <div class="sa-suffix-picker" data-sa-suffix-picker></div>
          <p data-sa-compression-summary></p>
        </section>

        <section class="sa-panel">
          <h2>{pageText.stageLabels.doubling}</h2>
          <div class="sa-table-wrap">
            <table class="sa-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>{clientText.start}</th>
                  <th>{clientText.suffix}</th>
                  <th>{clientText.pair}</th>
                  <th>{clientText.newRank}</th>
                </tr>
              </thead>
              <tbody data-sa-round-body></tbody>
            </table>
          </div>
        </section>

        <section class="sa-panel">
          <h2>{pageText.stageLabels.lcp}</h2>
          <div class="sa-table-wrap">
            <table class="sa-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>{clientText.start}</th>
                  <th>{clientText.suffix}</th>
                  <th>{clientText.lcpWithPrevious}</th>
                </tr>
              </thead>
              <tbody data-sa-lcp-body></tbody>
            </table>
          </div>
        </section>

        <section class="sa-panel">
          <h2>{pageText.stageLabels.answer}</h2>
          <p class="sa-result" data-sa-result></p>
          <div class="sa-table-wrap">
            <table class="sa-table">
              <thead>
                <tr>
                  <th>{clientText.start}</th>
                  <th>{clientText.left}</th>
                  <th>{clientText.right}</th>
                  <th>{clientText.same}</th>
                  <th>{clientText.need}</th>
                  <th>{clientText.status}</th>
                </tr>
              </thead>
              <tbody data-sa-answer-body></tbody>
            </table>
          </div>
        </section>
      </div>
    </section>

    <section class="sa-explain-grid">
      <article>
        <p class="sa-section-kicker">{pageText.kicker}</p>
        <h2>{pageText.introTitle}</h2>
        <p>{pageText.intro}</p>
      </article>
      <article>
        <p class="sa-section-kicker">LCP</p>
        <h2>{pageText.proofTitle}</h2>
        <p>{pageText.proof}</p>
      </article>
      <article>
        <p class="sa-section-kicker">O(n)</p>
        <h2>{pageText.complexityTitle}</h2>
        <p>{pageText.complexity}</p>
      </article>
    </section>

    <section class="sa-code-section">
      <div class="sa-code-notes">
        <p class="sa-section-kicker">C++</p>
        <h2>{pageText.codeTitle}</h2>
        {pageText.codeBlocks.map(([name, body]) => (
          <details open={name === "compress"}>
            <summary>{name}</summary>
            <p>{body}</p>
          </details>
        ))}
      </div>
      <pre class="sa-code-block"><code>{solutionCode}</code></pre>
    </section>
  </main>

  <script type="application/json" id="sa-copy" set:html={JSON.stringify(clientText)}></script>
  <script>
    const suffixArrayCopy = JSON.parse(
      document.getElementById("sa-copy")?.textContent || "{}",
    );
    const maxVisualLength = 10;
    const defaultValues = [1, 2, 1, 2, 3];
    const inputNode = document.getElementById("sa-input");
    const runButton = document.querySelector("[data-sa-run]");
    const sequenceNode = document.querySelector("[data-sa-sequence]");
    const compressionSummaryNode = document.querySelector(
      "[data-sa-compression-summary]",
    );
    const roundInput = document.getElementById("sa-round");
    const roundLabel = document.querySelector("[data-sa-round-label]");
    const roundBody = document.querySelector("[data-sa-round-body]");
    const lcpBody = document.querySelector("[data-sa-lcp-body]");
    const answerBody = document.querySelector("[data-sa-answer-body]");
    const resultNode = document.querySelector("[data-sa-result]");
    const stageNote = document.querySelector("[data-sa-stage-note]");
    const suffixPickerNode = document.querySelector("[data-sa-suffix-picker]");
    const stepIndexNode = document.querySelector("[data-sa-step-index]");
    const stepTitleNode = document.querySelector("[data-sa-step-title]");
    const stepBodyNode = document.querySelector("[data-sa-step-body]");
    const stepBulletsNode = document.querySelector("[data-sa-step-bullets]");
    const codeBridgeNode = document.querySelector("[data-sa-code-bridge]");
    const activeTitleNode = document.querySelector("[data-sa-active-title]");
    const activeSuffixNode = document.querySelector("[data-sa-active-suffix]");
    const prefixListNode = document.querySelector("[data-sa-prefix-list]");
    const neighborBoxNode = document.querySelector("[data-sa-neighbor-box]");
    const quizQuestionNode = document.querySelector("[data-sa-quiz-question]");
    const quizChoicesNode = document.querySelector("[data-sa-quiz-choices]");
    const quizFeedbackNode = document.querySelector("[data-sa-quiz-feedback]");
    const stageButtons = Array.from(
      document.querySelectorAll("[data-sa-stage]"),
    );
    const exampleButtons = Array.from(
      document.querySelectorAll("[data-sa-example]"),
    );
    let state = {
      activeStart: 0,
      data: null,
      quizChoice: null,
      roundIndex: 0,
      stage: "concept",
    };

    function parseValues(raw) {
      const matches = String(raw || "").match(/-?\d+/g) || [];
      return matches.slice(0, maxVisualLength).map(Number);
    }

    function comparePairs(left, right) {
      if (left[0] !== right[0]) return left[0] - right[0];
      return left[1] - right[1];
    }

    function compressValues(nums) {
      const alphabet = [...new Set(nums)].sort((left, right) => left - right);
      const rankByValue = new Map(
        alphabet.map((value, index) => [value, index + 1]),
      );
      return {
        alphabet,
        values: nums.map((value) => rankByValue.get(value)),
      };
    }

    function buildSuffixArray(values) {
      const size = values.length;
      const sa = Array.from({ length: size }, (_, index) => index);
      let rank = values.slice();
      const rounds = [];
      for (let k = 1; k < size; k <<= 1) {
        const beforeRank = rank.slice();
        const pairAt = (index) => [
          beforeRank[index],
          index + k < size ? beforeRank[index + k] : -1,
        ];
        sa.sort((left, right) => comparePairs(pairAt(left), pairAt(right)));
        const tmp = Array(size).fill(0);
        for (let index = 1; index < size; index += 1) {
          const previous = sa[index - 1];
          const current = sa[index];
          tmp[current] = tmp[previous];
          if (comparePairs(pairAt(previous), pairAt(current)) < 0) {
            tmp[current] += 1;
          }
        }
        rounds.push({
          beforeRank,
          k,
          rows: sa.map((start, order) => ({
            newRank: tmp[start],
            order,
            pair: pairAt(start),
            start,
          })),
          sa: sa.slice(),
        });
        rank = tmp;
        if (rank[sa[size - 1]] === size - 1) break;
      }
      return {
        rounds,
        sa,
      };
    }

    function buildLcp(values, sa) {
      const size = values.length;
      const rank = Array(size);
      const lcp = Array(size).fill(0);
      for (let index = 0; index < size; index += 1) rank[sa[index]] = index;
      let height = 0;
      for (let index = 0; index < size; index += 1) {
        const position = rank[index];
        if (position === 0) continue;
        const previousStart = sa[position - 1];
        while (
          index + height < size &&
          previousStart + height < size &&
          values[index + height] === values[previousStart + height]
        ) {
          height += 1;
        }
        lcp[position] = height;
        if (height > 0) height -= 1;
      }
      return {
        lcp,
        rank,
      };
    }

    function buildAnswer(values, sa, lcp, rank) {
      const size = values.length;
      const candidates = [];
      let best = null;
      for (let start = 0; start < size; start += 1) {
        const position = rank[start];
        const left = position > 0 ? lcp[position] : 0;
        const right = position + 1 < size ? lcp[position + 1] : 0;
        const same = Math.max(left, right);
        const need = same + 1;
        const fits = need <= size - start;
        const candidate = { fits, left, need, position, right, same, start };
        candidates.push(candidate);
        if (fits && (!best || need < best.need)) best = candidate;
      }
      return { best, candidates };
    }

    function buildData(nums) {
      const compressed = compressValues(nums);
      const suffixArray = buildSuffixArray(compressed.values);
      const lcpData = buildLcp(compressed.values, suffixArray.sa);
      const answer = buildAnswer(
        compressed.values,
        suffixArray.sa,
        lcpData.lcp,
        lcpData.rank,
      );
      return {
        answer,
        compressed,
        lcp: lcpData.lcp,
        nums,
        rank: lcpData.rank,
        rounds: suffixArray.rounds,
        sa: suffixArray.sa,
        values: compressed.values,
      };
    }

    function commonPrefixLength(values, leftStart, rightStart) {
      if (leftStart === null || rightStart === null) return 0;
      let length = 0;
      while (
        leftStart + length < values.length &&
        rightStart + length < values.length &&
        values[leftStart + length] === values[rightStart + length]
      ) {
        length += 1;
      }
      return length;
    }

    function tokenList(values, activeStart, offset = 0, options = {}) {
      const matchLength = options.matchLength || 0;
      const candidateStart = options.candidateStart ?? -1;
      const candidateLength = options.candidateLength || 0;
      return values.map((value, index) => {
        const position = offset + index;
        const classes = ["sa-token"];
        if (position === activeStart) classes.push("is-active");
        if (index < matchLength) classes.push("is-match");
        if (
          position >= candidateStart &&
          position < candidateStart + candidateLength
        ) {
          classes.push("is-candidate");
        }
        return `<span class="${classes.join(" ")}">${value}</span>`;
      }).join("");
    }

    function suffixText(values, start, activeStart, options = {}) {
      return tokenList(values.slice(start), activeStart, start, options);
    }

    function renderSuffixPicker(data) {
      suffixPickerNode.innerHTML = `
        <span>${suffixArrayCopy.chooseStart}</span>
        ${data.nums.map((_, start) => `
          <button
            type="button"
            data-sa-pick-start="${start}"
            class="${start === state.activeStart ? "is-active" : ""}"
          >
            ${start}
          </button>
        `).join("")}
      `;
    }

    function renderSequence(data) {
      const original = tokenList(data.nums, state.activeStart);
      const compressed = tokenList(data.values, state.activeStart);
      sequenceNode.innerHTML = `
        <div class="sa-array-row">
          <span>${suffixArrayCopy.original}</span>
          <div>${original}</div>
        </div>
        <div class="sa-array-row">
          <span>${suffixArrayCopy.compressed}</span>
          <div>${compressed}</div>
        </div>
      `;
      compressionSummaryNode.textContent = `${suffixArrayCopy.sortedValues}: ${
        data.compressed.alphabet.join(", ")
      }`;
    }

    function renderPrefixList(data) {
      const start = state.activeStart;
      const remaining = data.nums.length - start;
      const limit = Math.min(remaining, 5);
      const rows = [];
      for (let length = 1; length <= limit; length += 1) {
        const values = data.nums.slice(start, start + length);
        rows.push(`<span>[${values.join(", ")}]</span>`);
      }
      if (remaining > limit) rows.push("<em>...</em>");
      prefixListNode.innerHTML = `
        <strong>${suffixArrayCopy.candidateSubarrays}</strong>
        <div>${rows.join("")}</div>
      `;
    }

    function renderNeighborRow(data, label, neighborStart, lcpLength) {
      if (neighborStart === null || neighborStart === undefined) {
        return `
          <div class="sa-neighbor-row">
            <span>${label}</span>
            <em>${suffixArrayCopy.noNeighbor}</em>
          </div>
        `;
      }
      return `
        <div class="sa-neighbor-row" data-sa-start="${neighborStart}">
          <span>${label}: ${neighborStart}</span>
          <div>${suffixText(data.values, neighborStart, state.activeStart, {
            matchLength: lcpLength,
          })}</div>
          <b>${suffixArrayCopy.commonPrefix}: ${lcpLength}</b>
        </div>
      `;
    }

    function renderLesson(data) {
      const lesson = suffixArrayCopy.lessons[state.stage];
      const check = suffixArrayCopy.checks[state.stage];
      const start = state.activeStart;
      const position = data.rank[start];
      const previousStart = position > 0 ? data.sa[position - 1] : null;
      const nextStart = position + 1 < data.sa.length
        ? data.sa[position + 1]
        : null;
      const leftLcp = previousStart === null
        ? 0
        : commonPrefixLength(data.values, start, previousStart);
      const rightLcp = nextStart === null
        ? 0
        : commonPrefixLength(data.values, start, nextStart);
      const candidate = data.answer.candidates[start];
      const candidateLength = candidate?.fits ? candidate.need : 0;

      stepIndexNode.textContent = lesson.step;
      stepTitleNode.textContent = lesson.title;
      stepBodyNode.textContent = lesson.body;
      stepBulletsNode.innerHTML = lesson.bullets.map((item) =>
        `<li>${item}</li>`
      ).join("");
      codeBridgeNode.textContent = lesson.code;

      activeTitleNode.textContent = `${suffixArrayCopy.activeStart} ${start}`;
      activeSuffixNode.innerHTML = `
        <div class="sa-active-line">
          <span>${suffixArrayCopy.original}</span>
          <div>${suffixText(data.nums, start, start, {
            candidateStart: start,
            candidateLength,
          })}</div>
        </div>
        <div class="sa-active-line">
          <span>${suffixArrayCopy.compressed}</span>
          <div>${suffixText(data.values, start, start, {
            candidateStart: start,
            candidateLength,
          })}</div>
        </div>
      `;
      renderPrefixList(data);
      neighborBoxNode.innerHTML = `
        <strong>${suffixArrayCopy.neighborCompare}</strong>
        ${renderNeighborRow(
          data,
          suffixArrayCopy.previousNeighbor,
          previousStart,
          leftLcp,
        )}
        <div class="sa-neighbor-row is-current">
          <span>${suffixArrayCopy.activeSuffix}: ${start}</span>
          <div>${suffixText(data.values, start, start, {
            matchLength: Math.max(leftLcp, rightLcp),
            candidateStart: start,
            candidateLength,
          })}</div>
          <b>${suffixArrayCopy.same}: ${candidate.same}; ${
            suffixArrayCopy.need
          }: ${candidate.need}</b>
        </div>
        ${renderNeighborRow(
          data,
          suffixArrayCopy.nextNeighbor,
          nextStart,
          rightLcp,
        )}
      `;

      quizQuestionNode.textContent = check.question;
      quizChoicesNode.innerHTML = check.choices.map((choice, index) => `
        <button
          type="button"
          data-sa-quiz-choice="${index}"
          class="${state.quizChoice === index ? "is-active" : ""}"
        >
          ${choice[0]}
        </button>
      `).join("");
      if (state.quizChoice === null) {
        quizFeedbackNode.textContent = "";
      } else {
        const selected = check.choices[state.quizChoice];
        const marker = selected[1]
          ? suffixArrayCopy.correct
          : suffixArrayCopy.incorrect;
        quizFeedbackNode.textContent = `${marker}: ${check.feedback}`;
      }
    }

    function currentRound(data) {
      if (!data.rounds.length) {
        return {
          k: 0,
          rows: data.sa.map((start, order) => ({
            newRank: data.values[start],
            order,
            pair: [data.values[start], -1],
            start,
          })),
        };
      }
      return data.rounds[state.roundIndex] || data.rounds[0];
    }

    function renderRound(data) {
      const round = currentRound(data);
      roundLabel.textContent = round.k ? `k = ${round.k}` : "n = 1";
      roundBody.innerHTML = round.rows.map((row) => `
        <tr data-sa-start="${row.start}" class="${
          row.start === state.activeStart ? "is-active" : ""
        }">
          <td>${row.order}</td>
          <td>${row.start}</td>
          <td><div class="sa-suffix">${suffixText(
            data.values,
            row.start,
            state.activeStart,
            {
              matchLength: row.start === state.activeStart
                ? Math.max(
                    data.answer.candidates[row.start]?.left || 0,
                    data.answer.candidates[row.start]?.right || 0,
                  )
                : 0,
            },
          )}</div></td>
          <td>(${row.pair[0]}, ${row.pair[1]})</td>
          <td>${row.newRank}</td>
        </tr>
      `).join("");
    }

    function renderLcp(data) {
      lcpBody.innerHTML = data.sa.map((start, order) => `
        <tr data-sa-start="${start}" class="${
          start === state.activeStart ? "is-active" : ""
        }">
          <td>${order}</td>
          <td>${start}</td>
          <td><div class="sa-suffix">${suffixText(
            data.values,
            start,
            state.activeStart,
            {
              matchLength: start === state.activeStart
                ? data.lcp[order]
                : 0,
            },
          )}</div></td>
          <td>${data.lcp[order]}</td>
        </tr>
      `).join("");
    }

    function renderAnswer(data) {
      const best = data.answer.best;
      if (!best) {
        resultNode.textContent = suffixArrayCopy.noAnswer;
      } else {
        const subarray = data.nums.slice(best.start, best.start + best.need);
        resultNode.textContent = `${suffixArrayCopy.answerPrefix}: ${
          best.need
        }; ${suffixArrayCopy.answerMiddle} ${best.start} ${
          suffixArrayCopy.answerSuffix
        } [${subarray.join(", ")}]`;
      }
      answerBody.innerHTML = data.answer.candidates.map((row) => `
        <tr data-sa-start="${row.start}" class="${
          row.start === state.activeStart ? "is-active" : ""
        } ${best && row.start === best.start ? "is-best" : ""}">
          <td>${row.start}</td>
          <td>${row.left}</td>
          <td>${row.right}</td>
          <td>${row.same}</td>
          <td>${row.need}</td>
          <td>${row.fits ? suffixArrayCopy.fits : suffixArrayCopy.tooLong}</td>
        </tr>
      `).join("");
    }

    function syncRoundControl(data) {
      const max = Math.max(0, data.rounds.length - 1);
      roundInput.max = String(max);
      roundInput.value = String(Math.min(state.roundIndex, max));
      roundInput.disabled = data.rounds.length <= 1;
      state.roundIndex = Number(roundInput.value);
    }

    function setStage(nextStage) {
      state.stage = nextStage;
      state.quizChoice = null;
      stageButtons.forEach((button) => {
        button.classList.toggle("is-active", button.dataset.saStage === nextStage);
      });
      stageNote.textContent = suffixArrayCopy.stageNotes[nextStage];
      document.querySelector(".sa-workspace")?.setAttribute(
        "data-active-stage",
        nextStage,
      );
      renderAll();
    }

    function renderAll() {
      const data = state.data;
      if (!data) return;
      syncRoundControl(data);
      renderSuffixPicker(data);
      renderSequence(data);
      renderRound(data);
      renderLcp(data);
      renderAnswer(data);
      renderLesson(data);
    }

    function runVisualization() {
      const parsed = parseValues(inputNode.value);
      const nums = parsed.length ? parsed : defaultValues;
      if (!parsed.length) inputNode.value = nums.join(" ");
      state.data = buildData(nums);
      state.activeStart = 0;
      state.quizChoice = null;
      state.roundIndex = 0;
      renderAll();
    }

    function activateStart(start) {
      state.activeStart = start;
      renderAll();
    }

    runButton?.addEventListener("click", runVisualization);
    inputNode?.addEventListener("keydown", (event) => {
      if (event.key === "Enter") runVisualization();
    });
    roundInput?.addEventListener("input", () => {
      state.roundIndex = Number(roundInput.value);
      renderAll();
    });
    stageButtons.forEach((button) => {
      button.addEventListener("click", () => setStage(button.dataset.saStage));
    });
    exampleButtons.forEach((button) => {
      button.addEventListener("click", () => {
        inputNode.value = button.dataset.saExample;
        runVisualization();
      });
    });
    document.addEventListener("click", (event) => {
      const pick = event.target.closest("[data-sa-pick-start]");
      if (pick) {
        activateStart(Number(pick.dataset.saPickStart));
        return;
      }
      const quizChoice = event.target.closest("[data-sa-quiz-choice]");
      if (quizChoice) {
        state.quizChoice = Number(quizChoice.dataset.saQuizChoice);
        renderAll();
        return;
      }
      const row = event.target.closest("[data-sa-start]");
      if (!row) return;
      activateStart(Number(row.dataset.saStart));
    });

    runVisualization();
    setStage("concept");
  </script>

  <style is:global>
    .leetcode-shell {
      --leetcode-kai-font: "Kaiti SC", "STKaiti", "KaiTi", "KaiTi SC",
        "楷体", serif;
      --leetcode-system-font: "PingFang SC", -apple-system,
        BlinkMacSystemFont, "Helvetica Neue", "Segoe UI", "Hiragino Sans GB",
        "Microsoft YaHei", sans-serif;
      --leetcode-page-font: var(--leetcode-system-font);
      --leetcode-display-font: var(--leetcode-system-font);
      --leetcode-code-font: Monaco, "Cascadia Code", Consolas, "Courier New",
        monospace;
      --leetcode-stack-gap: 0.48rem;
      color: var(--color-charcoal);
      font-family: var(--leetcode-page-font);
    }

    html.dark .leetcode-shell {
      color: var(--color-cream);
    }

    .leetcode-hero {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0;
      align-items: center;
