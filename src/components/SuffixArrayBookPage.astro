---
import BaseLayout from "../layouts/BaseLayout.astro";
import { suffixArrayBook } from "../book.config";
import { pageUrl } from "../urls";

interface Props {
  lang?: "en" | "zh";
}

const { lang = "zh" } = Astro.props;
const isZh = lang === "zh";
const base = import.meta.env.BASE_URL;
const title = isZh ? suffixArrayBook.zhTitle : suffixArrayBook.title;
const description = isZh
  ? suffixArrayBook.zhDescription
  : suffixArrayBook.description;
const homePath = isZh ? "sa/" : "sa/en";
const alternatePath = isZh ? "sa/en" : "sa/";
const lcpPath = isZh ? "lcp/" : "lcp/en";
const problemPath = isZh ? "sa/unique-subarray" : "sa/unique-subarray-en";
const specPath = isZh ? "zh/sa/spec" : "sa/spec";

const buildCode = `vector<int> buildSuffixArray(string s) {
    s += '$';
    int n = s.size();
    vector<int> sa(n), cls(n);

    vector<pair<char, int>> first(n);
    for (int i = 0; i < n; i++) first[i] = {s[i], i};
    sort(first.begin(), first.end());
    for (int i = 0; i < n; i++) sa[i] = first[i].second;
    cls[sa[0]] = 0;
    for (int i = 1; i < n; i++) {
        cls[sa[i]] = cls[sa[i - 1]];
        if (first[i].first != first[i - 1].first) cls[sa[i]]++;
    }

    for (int len = 1; len < n; len <<= 1) {
        sort(sa.begin(), sa.end(), [&](int a, int b) {
            if (cls[a] != cls[b]) return cls[a] < cls[b];
            return cls[(a + len) % n] < cls[(b + len) % n];
        });
        vector<int> next(n);
        next[sa[0]] = 0;
        for (int i = 1; i < n; i++) {
            pair<int, int> prev = {
                cls[sa[i - 1]], cls[(sa[i - 1] + len) % n],
            };
            pair<int, int> now = {
                cls[sa[i]], cls[(sa[i] + len) % n],
            };
            next[sa[i]] = next[sa[i - 1]] + (prev != now);
        }
        cls = next;
    }
    sa.erase(sa.begin());
    return sa;
}`;

const keywordSet = new Set([
  "auto",
  "char",
  "for",
  "if",
  "int",
  "return",
  "sort",
  "string",
  "vector",
]);

function escapeHtml(value: string) {
  return value
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;");
}

function highlightLine(line: string) {
  const tokenPattern = /([A-Za-z_]\w*|\d+|'[^']*'|"(?:\\.|[^"\\])*")/g;
  let output = "";
  let cursor = 0;
  for (const match of line.matchAll(tokenPattern)) {
    const value = match[0];
    const index = match.index || 0;
    output += escapeHtml(line.slice(cursor, index));
    if (keywordSet.has(value)) {
      output += `<span class="sa-code-keyword">${escapeHtml(value)}</span>`;
    } else if (/^\d+$/.test(value)) {
      output += `<span class="sa-code-number">${value}</span>`;
    } else if (value.startsWith("'") || value.startsWith('"')) {
      output += `<span class="sa-code-string">${escapeHtml(value)}</span>`;
    } else {
      output += escapeHtml(value);
    }
    cursor = index + value.length;
  }
  output += escapeHtml(line.slice(cursor));
  return output || " ";
}

const highlightedCode = buildCode
  .split("\n")
  .map((line) => `<span class="sa-code-line">${highlightLine(line)}</span>`)
  .join("");

const copy = isZh
  ? {
      kicker: "Suffix Array Only",
      hero:
        "这一页只讲后缀数组本身：把所有后缀排成字典序，理解 rank 为什么能代表一段前缀，理解倍增为什么每轮只看两个已经知道顺序的块。",
      alternate: "English",
      spec: "规格",
      lcp: "去学 LCP",
      problem: "看应用题解",
      inputLabel: "字符串",
      run: "重建",
      examples: [
        ["banana", "banana"],
        ["abracadabra", "abracadabra"],
        ["mississippi", "mississippi"],
      ],
      stages: {
        suffix: "后缀",
        order: "字典序",
        rank: "rank",
        doubling: "倍增",
        result: "结果",
      },
      play: "开始播放",
      pause: "暂停",
      prev: "上一步",
      next: "下一步",
      stepLabel: "步骤",
      interval: "间隔",
      ms: "毫秒",
      speeds: [
        ["900", "快"],
        ["1500", "标准"],
        ["2600", "慢"],
      ],
      panels: {
        tape: "原字符串",
        suffixes: "后缀观察台",
        round: "当前构造轮",
        why: "为什么",
        code: "核心代码",
        links: "知识互链",
      },
      table: {
        order: "#",
        start: "起点",
        suffix: "后缀",
        key: "比较键",
        rank: "新 rank",
      },
      links: [
        [
          "LCP 是什么",
          "后缀数组只负责排序；相邻后缀到底像到哪里，由 LCP 单独讲。",
          lcpPath,
        ],
        [
          "应用：最短唯一子数组",
          "这道题会把后缀数组和 LCP 拼起来，但不污染本页的基础概念。",
          problemPath,
        ],
      ],
      steps: [
        {
          stage: "suffix",
          title: "先问：我们到底要排序什么",
          body: "后缀数组排序的不是字符本身，而是每一个“从某个位置开始直到结尾”的后缀。",
          why: "一个字符串有 n 个起点，也就有 n 个后缀；把这些后缀排序后，许多字符串问题会变成相邻关系问题。",
          active: 0,
          round: 0,
        },
        {
          stage: "suffix",
          title: "后缀不是复制出来的新字符串",
          body: "后缀只需要记住起点。起点 2 的后缀，就是从第 2 个字符一路看到结尾。",
          why: "只存起点能避免大量复制；后缀数组 sa 保存的正是这些起点。",
          active: 2,
          round: 0,
        },
        {
          stage: "order",
          title: "字典序先比较第一个字符",
          body: "像查字典一样，两个后缀先看第一个字符；不同就立刻决定顺序。",
          why: "这是后缀数组的排序规则，不是算法技巧。算法只是更快地完成这个排序。",
          active: 1,
          round: 0,
        },
        {
          stage: "order",
          title: "第一个字符相同，才继续往后看",
          body: "如果两个后缀都以同一个字符开头，比较会推进到第二个字符、第三个字符。",
          why: "这也是为什么重复结构会让后缀排序变难：它们一开始看起来很像。",
          active: 3,
          round: 0,
        },
        {
          stage: "rank",
          title: "rank 是“当前看过长度”的名字",
          body: "第一轮只看 1 个字符，所以相同字符得到同一个 rank，不同字符得到不同 rank。",
          why: "rank 不是最终答案；它只是把已经比较过的一段前缀压成一个整数标签。",
          active: 1,
          round: 0,
        },
        {
          stage: "rank",
          title: "相同 rank 表示暂时分不出来",
          body: "两个后缀如果当前 rank 相同，只能说明目前看的长度内相同，不能说明完整后缀相同。",
          why: "倍增算法的核心就是：先承认自己只看了一小段，然后逐步扩大视野。",
          active: 3,
          round: 0,
        },
        {
          stage: "doubling",
          title: "为什么可以每次翻倍",
          body: "如果已经知道长度 len 的片段排名，那么长度 2len 的片段可以拆成前半段和后半段。",
          why: "两个整数 rank 就能代表两个半段；比较两个长度 2len 的片段，就变成比较两个二元组。",
          active: 0,
          round: 1,
        },
        {
          stage: "doubling",
          title: "比较键长成这样：(前半段 rank, 后半段 rank)",
          body: "前半段不同，顺序立即确定；前半段相同，再看后半段。",
          why: "这完全复刻字典序，只是把一长段字符换成了两个已经知道含义的 rank。",
          active: 1,
          round: 1,
        },
        {
          stage: "doubling",
          title: "排序后重新编号",
          body: "按二元组排完后，从上到下扫描；相同二元组拿同一个新 rank，不同二元组 rank 加一。",
          why: "新 rank 表示长度 2len 的片段类别，下一轮又可以把它当作更大块的名字。",
          active: 2,
          round: 1,
        },
        {
          stage: "doubling",
          title: "下一轮视野继续翻倍",
          body: "len 从 1 到 2，再到 4、8。每一轮都在用旧 rank 构造更长前缀的新 rank。",
          why: "当 len 覆盖整个字符串后，rank 的顺序就等于完整后缀的字典序。",
          active: 3,
          round: 2,
        },
        {
          stage: "result",
          title: "sa[i] 的含义",
          body: "最终的 sa 是一串起点：sa[0] 是字典序最小后缀的起点，sa[1] 是第二小后缀的起点。",
          why: "后缀数组不是存排序后的字符串，而是存排序后的起点列表。",
          active: 0,
          round: 99,
        },
        {
          stage: "result",
          title: "为什么这件事有用",
          body: "排序让相似后缀靠近，后续的查找、重复子串、唯一子串都能利用这种邻近性。",
          why: "本页到这里为止只负责“排好”。相似到哪里，是 LCP 的任务；怎么用于题目，是应用页的任务。",
          active: 0,
          round: 99,
        },
      ],
    }
  : {
      kicker: "Suffix Array Only",
      hero:
        "This page teaches the suffix array itself: suffixes, lexicographic order, rank classes, and why doubling can compare longer prefixes from two known halves.",
      alternate: "中文",
      spec: "Spec",
      lcp: "Learn LCP",
      problem: "Problem application",
      inputLabel: "String",
      run: "Rebuild",
      examples: [
        ["banana", "banana"],
        ["abracadabra", "abracadabra"],
        ["mississippi", "mississippi"],
      ],
      stages: {
        suffix: "Suffix",
        order: "Order",
        rank: "rank",
        doubling: "Doubling",
        result: "Result",
      },
      play: "Play",
      pause: "Pause",
      prev: "Previous",
      next: "Next",
      stepLabel: "Step",
      interval: "Interval",
      ms: "ms",
      speeds: [
        ["900", "Fast"],
        ["1500", "Normal"],
        ["2600", "Slow"],
      ],
      panels: {
        tape: "Original string",
        suffixes: "Suffix lab",
        round: "Current round",
        why: "Why",
        code: "Core code",
        links: "Knowledge links",
      },
      table: {
        order: "#",
        start: "start",
        suffix: "suffix",
        key: "key",
        rank: "new rank",
      },
      links: [
        [
          "What LCP means",
          "The suffix array only sorts suffixes. LCP explains how far adjacent suffixes match.",
          lcpPath,
        ],
        [
          "Application: shortest unique subarray",
          "The problem combines suffix arrays with LCP, but the base ideas stay separate.",
          problemPath,
        ],
      ],
      steps: [
        {
          stage: "suffix",
          title: "First ask: what are we sorting?",
          body: "A suffix array sorts every suffix, meaning every segment that starts at one position and runs to the end.",
          why: "A length-n string has n starts and therefore n suffixes. Sorting them turns many string questions into neighbor questions.",
          active: 0,
          round: 0,
        },
        {
          stage: "suffix",
          title: "A suffix is not copied",
          body: "A suffix only needs its start. The suffix at start 2 is the view from character 2 to the end.",
          why: "Keeping starts avoids copying strings; the suffix array stores exactly those starts.",
          active: 2,
          round: 0,
        },
        {
          stage: "order",
          title: "Lexicographic order checks the first character",
          body: "Like a dictionary, two suffixes first compare their first character. If it differs, the order is decided.",
          why: "This is the definition of the order. The algorithm is only a faster way to compute it.",
          active: 1,
          round: 0,
        },
        {
          stage: "order",
          title: "On ties, comparison moves right",
          body: "When two suffixes start with the same character, the comparison moves to the second and third characters.",
          why: "Repeated structure is exactly what makes suffix sorting non-trivial.",
          active: 3,
          round: 0,
        },
        {
          stage: "rank",
          title: "rank names the length seen so far",
          body: "At the first round, only one character is known, so equal characters get the same rank.",
          why: "rank is not the final answer. It is a compact label for an already-compared prefix.",
          active: 1,
          round: 0,
        },
        {
          stage: "rank",
          title: "Equal rank means not separated yet",
          body: "Equal current ranks mean only that the inspected prefix is equal, not that full suffixes are equal.",
          why: "Doubling works by honestly tracking how much has been inspected, then expanding that view.",
          active: 3,
          round: 0,
        },
        {
          stage: "doubling",
          title: "Why doubling is possible",
          body: "If length len pieces are ranked, a length 2len piece is just two known halves.",
          why: "Two integer ranks can represent those halves, so a long comparison becomes a pair comparison.",
          active: 0,
          round: 1,
        },
        {
          stage: "doubling",
          title: "The key is (left rank, right rank)",
          body: "If the left rank differs, order is decided; if it ties, compare the right rank.",
          why: "This is lexicographic order again, with long text replaced by two meaningful ranks.",
          active: 1,
          round: 1,
        },
        {
          stage: "doubling",
          title: "Sort, then re-label",
          body: "After sorting by pairs, scan from top to bottom. Equal pairs share a new rank; different pairs increment it.",
          why: "The new rank names a length 2len prefix and becomes the raw material for the next round.",
          active: 2,
          round: 1,
        },
        {
          stage: "doubling",
          title: "The view keeps doubling",
          body: "len goes 1, 2, 4, 8. Each round builds larger prefix ranks from previous ranks.",
          why: "Once len covers the whole string, rank order is full suffix order.",
          active: 3,
          round: 2,
        },
        {
          stage: "result",
          title: "What sa[i] means",
          body: "The final sa is a list of starts: sa[0] starts the smallest suffix, sa[1] starts the second smallest suffix.",
          why: "The suffix array stores sorted starts, not copied suffix strings.",
          active: 0,
          round: 99,
        },
        {
          stage: "result",
          title: "Why this is useful",
          body: "Sorting makes similar suffixes close, which later supports search, repeated substrings, and uniqueness questions.",
          why: "This page only sorts. LCP explains how far neighbors match; the application page explains one problem use.",
          active: 0,
          round: 99,
        },
      ],
    };
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={homePath}
  lang={lang}
  titleSuffix={title}
>
  <main class="leetcode-shell sa-shell mx-auto max-w-6xl px-4 pt-0 pb-8 md:px-8 md:pb-10">
    <section class="sa-hero">
      <div>
        <p class="sa-kicker">{copy.kicker}</p>
        <h1>{title}</h1>
        <p>{copy.hero}</p>
      </div>
      <nav class="sa-actions" aria-label={isZh ? "相关链接" : "Related links"}>
        <a href={pageUrl(base, lcpPath)}>{copy.lcp}</a>
        <a href={pageUrl(base, problemPath)}>{copy.problem}</a>
        <a href={pageUrl(base, specPath)}>{copy.spec}</a>
        <a href={pageUrl(base, alternatePath)}>{copy.alternate}</a>
      </nav>
    </section>

    <section class="sa-workbench">
      <div class="sa-toolbar">
        <label for="sa-input">{copy.inputLabel}</label>
        <input id="sa-input" value="banana" spellcheck="false" />
        <button type="button" data-sa-run>{copy.run}</button>
        <div class="sa-examples">
          {copy.examples.map(([value, label]) => (
            <button type="button" data-sa-example={value}>{label}</button>
          ))}
        </div>
      </div>

      <div class="sa-stage-tabs">
        {Object.entries(copy.stages).map(([stage, label]) => (
          <button
            type="button"
            data-sa-stage={stage}
            class={stage === "suffix" ? "is-active" : ""}
          >
            {label}
          </button>
        ))}
      </div>

      <section class="sa-stepper">
        <div class="sa-stepper-head">
          <div>
            <p class="sa-section-kicker" data-sa-stage-label></p>
            <h2 data-sa-step-title></h2>
          </div>
          <div class="sa-step-actions">
            <button type="button" data-sa-prev>{copy.prev}</button>
            <span data-sa-step-count></span>
            <button type="button" data-sa-next>{copy.next}</button>
          </div>
        </div>

        <div class="sa-playback">
          <button type="button" data-sa-play>{copy.play}</button>
          <div>
            {copy.speeds.map(([value, label]) => (
              <button
                type="button"
                data-sa-speed={value}
                class={value === "1500" ? "is-active" : ""}
              >
                {label}
              </button>
            ))}
          </div>
          <label>
            <span>{copy.interval}</span>
            <input
              type="number"
              min="300"
              max="10000"
              step="100"
              value="1500"
              data-sa-interval
            />
            <em>{copy.ms}</em>
          </label>
        </div>

        <div class="sa-step-body">
          <p data-sa-step-body></p>
          <div>
            <strong>{copy.panels.why}</strong>
            <p data-sa-step-why></p>
          </div>
        </div>

        <div class="sa-step-rail" data-sa-step-rail></div>
      </section>

      <section class="sa-grid">
        <article class="sa-panel">
          <h2>{copy.panels.tape}</h2>
          <div class="sa-tape" data-sa-tape></div>
        </article>

        <article class="sa-panel">
          <h2>{copy.panels.suffixes}</h2>
          <div class="sa-suffix-list" data-sa-suffixes></div>
        </article>

        <article class="sa-panel sa-wide">
          <h2>{copy.panels.round}</h2>
          <div class="sa-table-wrap">
            <table class="sa-table">
              <thead>
                <tr>
                  <th>{copy.table.order}</th>
                  <th>{copy.table.start}</th>
                  <th>{copy.table.suffix}</th>
                  <th>{copy.table.key}</th>
                  <th>{copy.table.rank}</th>
                </tr>
              </thead>
              <tbody data-sa-round></tbody>
            </table>
          </div>
        </article>

        <article class="sa-panel sa-links">
          <h2>{copy.panels.links}</h2>
          {copy.links.map(([linkTitle, body, path]) => (
            <a href={pageUrl(base, path)}>
              <strong>{linkTitle}</strong>
              <span>{body}</span>
            </a>
          ))}
        </article>
      </section>
    </section>

    <section class="sa-code-section">
      <div>
        <p class="sa-section-kicker">C++</p>
        <h2>{copy.panels.code}</h2>
        <p>{isZh
          ? "这段代码展示倍增构造的骨架。重点不是背模板，而是理解 rank 如何把一段前缀压成可比较的名字。"
          : "This code shows the doubling skeleton. The point is not memorizing a template, but seeing how ranks name comparable prefixes."}</p>
      </div>
      <pre class="sa-code"><code set:html={highlightedCode}></code></pre>
    </section>
  </main>

  <script
    type="application/json"
    id="sa-copy"
    set:html={JSON.stringify(copy)}
  ></script>
  <script>
    const copy = JSON.parse(document.getElementById("sa-copy").textContent);
    const input = document.getElementById("sa-input");
    const runButton = document.querySelector("[data-sa-run]");
    const tapeNode = document.querySelector("[data-sa-tape]");
    const suffixNode = document.querySelector("[data-sa-suffixes]");
    const roundNode = document.querySelector("[data-sa-round]");
    const stepTitleNode = document.querySelector("[data-sa-step-title]");
    const stepBodyNode = document.querySelector("[data-sa-step-body]");
    const stepWhyNode = document.querySelector("[data-sa-step-why]");
    const stepCountNode = document.querySelector("[data-sa-step-count]");
    const stageLabelNode = document.querySelector("[data-sa-stage-label]");
    const railNode = document.querySelector("[data-sa-step-rail]");
    const playButton = document.querySelector("[data-sa-play]");
    const intervalInput = document.querySelector("[data-sa-interval]");
    const stageButtons = Array.from(document.querySelectorAll("[data-sa-stage]"));
    const speedButtons = Array.from(document.querySelectorAll("[data-sa-speed]"));
    let state = {
      active: 0,
      data: null,
      interval: 1500,
      playing: false,
      round: 0,
      stage: "suffix",
      step: 0,
    };
    let timer = null;

    function cleanText(value) {
      const trimmed = String(value || "").replace(/\s+/g, "");
      return (trimmed || "banana").slice(0, 14);
    }

    function suffixOf(text, start) {
      return text.slice(start);
    }

    function keyCompare(left, right) {
      if (left[0] !== right[0]) return left[0] - right[0];
      return left[1] - right[1];
    }

    function classRows(text) {
      const chars = [...text];
      const alphabet = [...new Set(chars)].sort();
      const rankByChar = new Map(alphabet.map((char, index) => [char, index]));
      const rows = chars.map((char, start) => ({
        key: [rankByChar.get(char), -1],
        newRank: rankByChar.get(char),
        order: 0,
        start,
      }));
      rows.sort((left, right) => keyCompare(left.key, right.key));
      rows.forEach((row, order) => row.order = order);
      return rows;
    }

    function buildData(text) {
      const n = text.length;
      const initial = classRows(text);
      let sa = initial.map((row) => row.start);
      let rank = Array(n);
      initial.forEach((row) => rank[row.start] = row.newRank);
      const rounds = [{
        label: "1",
        len: 1,
        rows: initial,
        sa: sa.slice(),
      }];
      for (let len = 1; len < n; len <<= 1) {
        const before = rank.slice();
        const keyAt = (start) => [
          before[start],
          start + len < n ? before[start + len] : -1,
        ];
        sa.sort((left, right) => keyCompare(keyAt(left), keyAt(right)));
        const next = Array(n).fill(0);
        for (let i = 1; i < n; i += 1) {
          next[sa[i]] = next[sa[i - 1]];
          if (keyCompare(keyAt(sa[i - 1]), keyAt(sa[i])) < 0) {
            next[sa[i]] += 1;
          }
        }
        rounds.push({
          label: String(len * 2),
          len: len * 2,
          rows: sa.map((start, order) => ({
            key: keyAt(start),
            newRank: next[start],
            order,
            start,
          })),
          sa: sa.slice(),
        });
        rank = next;
      }
      return { rank, rounds, sa, text };
    }

    function clamp(value, min, max) {
      return Math.min(Math.max(value, min), max);
    }

    function activeStep() {
      return copy.steps[state.step] || copy.steps[0];
    }

    function activeRound() {
      const max = state.data.rounds.length - 1;
      const index = state.round >= 99 ? max : clamp(state.round, 0, max);
      return state.data.rounds[index];
    }

    function renderTape() {
      tapeNode.innerHTML = [...state.data.text].map((char, index) => `
        <button
          type="button"
          data-sa-start="${index}"
          class="${index === state.active ? "is-active" : ""}"
        >
          <span>${index}</span>
          <strong>${char}</strong>
        </button>
      `).join("");
    }

    function renderSuffixes() {
      const round = activeRound();
      suffixNode.innerHTML = round.sa.map((start, order) => `
        <button
          type="button"
          data-sa-start="${start}"
          class="${start === state.active ? "is-active" : ""}"
        >
          <span>${order}</span>
          <strong>${start}</strong>
          <code>${suffixOf(state.data.text, start)}</code>
        </button>
      `).join("");
    }

    function renderRound() {
      const round = activeRound();
      roundNode.innerHTML = round.rows.map((row) => `
        <tr
          data-sa-start="${row.start}"
          class="${row.start === state.active ? "is-active" : ""}"
        >
          <td>${row.order}</td>
          <td>${row.start}</td>
          <td><code>${suffixOf(state.data.text, row.start)}</code></td>
          <td>(${row.key[0]}, ${row.key[1]})</td>
          <td>${row.newRank}</td>
        </tr>
      `).join("");
    }

    function renderStepper() {
      const step = activeStep();
      const total = copy.steps.length;
      stepTitleNode.textContent = step.title;
      stepBodyNode.textContent = step.body;
      stepWhyNode.textContent = step.why;
      stepCountNode.textContent = `${copy.stepLabel} ${String(state.step + 1).padStart(2, "0")} / ${String(total).padStart(2, "0")}`;
      stageLabelNode.textContent = copy.stages[state.stage];
      railNode.innerHTML = copy.steps.map((item, index) => `
        <button
          type="button"
          data-sa-step="${index}"
          class="${index === state.step ? "is-active" : ""} ${
            index < state.step ? "is-complete" : ""
          }"
        >
          <span>${String(index + 1).padStart(2, "0")}</span>
          ${item.title}
        </button>
      `).join("");
      stageButtons.forEach((button) => {
        button.classList.toggle("is-active", button.dataset.saStage === state.stage);
      });
      playButton.textContent = state.playing ? copy.pause : copy.play;
      playButton.classList.toggle("is-playing", state.playing);
      intervalInput.value = String(state.interval);
      speedButtons.forEach((button) => {
        button.classList.toggle(
          "is-active",
          Number(button.dataset.saSpeed) === state.interval,
        );
      });
    }

    function renderAll() {
      if (!state.data) return;
      renderTape();
      renderSuffixes();
      renderRound();
      renderStepper();
    }

    function applyStep(index) {
      const stepIndex = clamp(index, 0, copy.steps.length - 1);
      const step = copy.steps[stepIndex];
      state.step = stepIndex;
      state.stage = step.stage;
      state.active = clamp(step.active, 0, state.data.text.length - 1);
      state.round = step.round;
      renderAll();
    }

    function stopPlayback() {
      if (timer !== null) window.clearTimeout(timer);
      timer = null;
      state.playing = false;
      renderStepper();
    }

    function schedulePlayback() {
      if (!state.playing) return;
      if (timer !== null) window.clearTimeout(timer);
      timer = window.setTimeout(() => {
        if (state.step >= copy.steps.length - 1) {
          stopPlayback();
          return;
        }
        applyStep(state.step + 1);
        schedulePlayback();
      }, state.interval);
    }

    function startPlayback() {
      if (state.step >= copy.steps.length - 1) applyStep(0);
      state.playing = true;
      renderStepper();
      schedulePlayback();
    }

    function setIntervalMs(value) {
      state.interval = clamp(Number(value) || 1500, 300, 10000);
      renderStepper();
      if (state.playing) schedulePlayback();
    }

    function rebuild() {
      stopPlayback();
      const text = cleanText(input.value);
      input.value = text;
      state.data = buildData(text);
      applyStep(0);
    }

    runButton.addEventListener("click", rebuild);
    input.addEventListener("keydown", (event) => {
      if (event.key === "Enter") rebuild();
    });
    document.addEventListener("click", (event) => {
      const stepButton = event.target.closest("[data-sa-step]");
      if (stepButton) {
        applyStep(Number(stepButton.dataset.saStep));
        return;
      }
      const startButton = event.target.closest("[data-sa-start]");
      if (startButton) {
        state.active = Number(startButton.dataset.saStart);
        renderAll();
        return;
      }
    });
    document.querySelector("[data-sa-prev]").addEventListener("click", () => {
      applyStep(state.step - 1);
    });
    document.querySelector("[data-sa-next]").addEventListener("click", () => {
      applyStep(state.step + 1);
    });
    playButton.addEventListener("click", () => {
      if (state.playing) stopPlayback();
      else startPlayback();
    });
    intervalInput.addEventListener("change", () => {
      setIntervalMs(intervalInput.value);
    });
    speedButtons.forEach((button) => {
      button.addEventListener("click", () => {
        setIntervalMs(button.dataset.saSpeed);
      });
    });
    stageButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const index = copy.steps.findIndex((step) =>
          step.stage === button.dataset.saStage
        );
        applyStep(index >= 0 ? index : state.step);
      });
    });
    document.querySelectorAll("[data-sa-example]").forEach((button) => {
      button.addEventListener("click", () => {
        input.value = button.dataset.saExample;
        rebuild();
      });
    });

    rebuild();
  </script>

