<script is:inline>
  (() => {
    const root = document.querySelector("[data-iq-root]");
    if (!root) return;

    const searchInput = root.querySelector("[data-iq-search]");
    const categoryButtons = Array.from(
      root.querySelectorAll("[data-iq-category]"),
    );
    const cards = Array.from(root.querySelectorAll("[data-iq-index-card]"));
    const puzzles = Array.from(root.querySelectorAll("[data-iq-puzzle]"));
    const status = root.querySelector("[data-iq-status]");
    const empty = root.querySelector("[data-iq-empty]");
    let activeCategory = "all";

    function normalize(value) {
      return String(value || "").trim().toLowerCase();
    }

    function matches(element, query) {
      const categoryOk =
        activeCategory === "all" || element.dataset.category === activeCategory;
      const searchOk =
        !query || normalize(element.dataset.search).includes(query);
      return categoryOk && searchOk;
    }

    function applyFilters() {
      const query = normalize(searchInput?.value);
      let visibleCount = 0;

      for (const card of cards) {
        const visible = matches(card, query);
        card.hidden = !visible;
      }

      for (const puzzle of puzzles) {
        const visible = matches(puzzle, query);
        puzzle.hidden = !visible;
        if (visible) visibleCount += 1;
      }

      if (status) {
        status.textContent = `当前显示 ${visibleCount} 道题。`;
      }
      if (empty) {
        empty.hidden = visibleCount !== 0;
      }
    }

    for (const button of categoryButtons) {
      button.addEventListener("click", () => {
        activeCategory = button.dataset.iqCategory || "all";
        for (const other of categoryButtons) {
          other.classList.toggle("is-active", other === button);
        }
        applyFilters();
      });
    }

    searchInput?.addEventListener("input", applyFilters);

    for (const demo of root.querySelectorAll("[data-iq-demo]")) {
      const frames = JSON.parse(demo.dataset.frames || "[]");
      const title = demo.querySelector("[data-iq-demo-title]");
      const step = demo.querySelector("[data-iq-demo-step]");
      const stage = demo.querySelector("[data-iq-demo-stage]");
      const body = demo.querySelector("[data-iq-demo-body]");
      const metric = demo.querySelector("[data-iq-demo-metric]");
      const prev = demo.querySelector("[data-iq-demo-prev]");
      const next = demo.querySelector("[data-iq-demo-next]");
      const play = demo.querySelector("[data-iq-demo-play]");
      const reset = demo.querySelector("[data-iq-demo-reset]");
      const playLabel = demo.querySelector("[data-iq-demo-play-label]");
      let index = 0;
      let timer = null;

      function stop() {
        if (timer) {
          window.clearInterval(timer);
          timer = null;
        }
        demo.classList.remove("is-playing");
        if (playLabel) playLabel.textContent = "播放";
      }

      function tokenNode(token) {
        const item = document.createElement("span");
        item.className = `iq-token is-${token.state || "neutral"}`;
        const label = document.createElement("strong");
        label.innerHTML = token.labelHtml || token.label;
        const detail = document.createElement("em");
        detail.innerHTML = token.detailHtml || token.detail || "";
        item.append(label, detail);
        if (typeof token.value === "number" && typeof token.max === "number") {
          const bar = document.createElement("i");
          const ratio = Math.max(0, Math.min(100, (token.value / token.max) * 100));
          bar.style.setProperty("--iq-token-fill", `${ratio}%`);
          item.append(bar);
        }
        return item;
      }

      function render() {
        const frame = frames[index];
        if (!frame) return;
        if (title) title.innerHTML = frame.titleHtml || frame.title;
        if (step) step.textContent = `${index + 1} / ${frames.length}`;
        if (body) body.innerHTML = frame.bodyHtml || frame.body;
        if (metric) metric.innerHTML = frame.metricHtml || frame.metric;
        if (stage) {
          stage.replaceChildren(...frame.tokens.map(tokenNode));
        }
      }

      function move(delta) {
        index = (index + delta + frames.length) % frames.length;
        render();
      }

      prev?.addEventListener("click", () => {
        stop();
        move(-1);
      });

      next?.addEventListener("click", () => {
        stop();
        move(1);
      });

      reset?.addEventListener("click", () => {
        stop();
        index = 0;
        render();
      });

      play?.addEventListener("click", () => {
        if (timer) {
          stop();
          return;
        }
        demo.classList.add("is-playing");
        if (playLabel) playLabel.textContent = "暂停";
        timer = window.setInterval(() => move(1), 1800);
      });

      render();
    }

    applyFilters();
  })();
</script>

