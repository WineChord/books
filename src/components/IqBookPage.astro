function searchBlob(puzzle: Puzzle) {
  return [
    puzzle.title,
    puzzle.category,
    puzzle.difficulty,
    puzzle.answer,
    ...puzzle.keywords,
    ...puzzle.problem,
    puzzle.principle,
  ].join(" ");
}

function escapeHtml(value: string) {
  return value
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;");
}

function normalizeLatex(value: string) {
  return value
    .replaceAll("₂", "_2")
    .replaceAll("≤", "\\le ")
    .replaceAll("≥", "\\ge ")
    .replaceAll("≈", "\\approx ")
    .replaceAll("→", "\\to ")
    .replaceAll("->", "\\to ")
    .replaceAll(">=", "\\ge ")
    .replaceAll("<=", "\\le ")
    .replaceAll("...", "\\ldots ")
    .replace(/\bxor\b/gi, "\\oplus ")
    .replace(/\bmod\b/gi, "\\bmod ")
    .replace(/\*/g, "\\times ")
    .replace(/%/g, "\\%")
    .replace(/\b([A-Za-z0-9]+)\s*\/\s*([A-Za-z0-9]+)\b/g, "\\frac{$1}{$2}");
}

function renderLatex(value: string) {
  return renderToString(normalizeLatex(value), katexOptions);
}

function shouldRenderMathRun(value: string) {
  return /[A-Za-z0-9]/.test(value)
    && /(\^|=|<=|>=|≤|≥|<|>|≈|\/|\+|-|\*|→|->|₂|%|\bxor\b|\bmod\b)/i
      .test(value);
}

function renderMathText(value: string) {
  const pattern = /[A-Za-z0-9][A-Za-z0-9\s+\-*/^=<>≤≥≈().,_₂%→]*[A-Za-z0-9%₂]?/g;
  let output = "";
  let cursor = 0;

  for (const match of value.matchAll(pattern)) {
    const raw = match[0];
    const index = match.index ?? 0;
    output += escapeHtml(value.slice(cursor, index));

    const leading = raw.match(/^\s*/)?.[0] ?? "";
    const trailing = raw.match(/\s*$/)?.[0] ?? "";
    const core = raw.trim();
    output += escapeHtml(leading);
    if (core && shouldRenderMathRun(core)) {
      output += renderLatex(core);
    } else {
      output += escapeHtml(core);
    }
    output += escapeHtml(trailing);
    cursor = index + raw.length;
  }

  output += escapeHtml(value.slice(cursor));
  return output;
}

function renderFrames(frames: DemoFrame[]) {
  return frames.map((frame) => ({
    ...frame,
    titleHtml: renderMathText(frame.title),
    bodyHtml: renderMathText(frame.body),
    metricHtml: renderMathText(frame.metric),
    tokens: frame.tokens.map((token) => ({
      ...token,
      labelHtml: renderMathText(token.label),
      detailHtml: token.detail ? renderMathText(token.detail) : "",
    })),
  }));
}
