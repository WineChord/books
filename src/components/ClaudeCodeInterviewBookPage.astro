          title: "恢复附件",
          body:
            "按最近活跃度恢复最多 5 个文件、每个最多 5K token、总计最多 50K token，并恢复技能和异步任务状态。",
        },
        {
          title: "接力",
          body:
            "旧消息链被替换为边界标记、摘要、附件和 hook 结果；模型被明确告知这是续跑，不是新会话。",
        },
      ];

      function readNumber(id) {
        const node = document.getElementById(id);
        return node instanceof HTMLInputElement ? Number(node.value) : 0;
      }

      function setText(id, value) {
        const node = document.getElementById(id);
        if (node) node.textContent = value;
      }

      function updateSimulator() {
        const base = readNumber("cc-base");
        const files = readNumber("cc-files");
        const rounds = readNumber("cc-rounds");
        const tool = readNumber("cc-tool");
        const total = base + files * 5000 + rounds * tool * 2;
        const ratio = Math.min(100, Math.round((total / windowTokens) * 100));
        let trigger = "第 1-3 层足够";
        if (total > autoThreshold) {
          trigger = "第 5 层 Auto-Compact";
        } else if (total > autoThreshold - 20000) {
          trigger = "接近警告线";
        } else if (total > effectiveWindow * 0.9) {
          trigger = "第 4 层 Context Collapse";
        } else if (total > effectiveWindow * 0.6) {
          trigger = "第 2-3 层开始减压";
        }

        setText("cc-total", `${format.format(total)} token`);
        setText("cc-ratio", `${ratio}%`);
        setText("cc-trigger", trigger);
        const fill = document.getElementById("cc-meter-fill");
        if (fill instanceof HTMLElement) {
          fill.style.width = `${ratio}%`;
          fill.dataset.level = trigger.includes("Auto")
            ? "hot"
            : trigger.includes("Context") || trigger.includes("警告")
              ? "warm"
              : "cool";
        }
      }

      function activateLayer(id) {
        const layer = layers.find((item) => item.id === id) || layers[0];
        document.querySelectorAll(".cc-layer-button").forEach((button) => {
          button.classList.toggle("is-active", button.dataset.layer === id);
        });
        setText("cc-layer-name", layer.name);
        setText("cc-layer-title", layer.title);
        setText("cc-layer-loss", layer.loss);
        setText("cc-layer-cost", layer.cost);
        setText("cc-layer-trigger", layer.trigger);
        setText("cc-layer-body", layer.detail);
      }

      function activateStep(index) {
        const step = pipeline[index] || pipeline[0];
        document.querySelectorAll(".cc-pipeline-tab").forEach((button) => {
          button.classList.toggle("is-active", Number(button.dataset.step) === index);
        });
        setText("cc-pipeline-title", step.title);
        setText("cc-pipeline-body", step.body);
      }

      ["cc-base", "cc-files", "cc-rounds", "cc-tool"].forEach((id) => {
        document.getElementById(id)?.addEventListener("input", updateSimulator);
      });

      document.querySelectorAll(".cc-layer-button").forEach((button) => {
        button.addEventListener("click", () => activateLayer(button.dataset.layer || "disk"));
      });

      document.querySelectorAll(".cc-pipeline-tab").forEach((button) => {
        button.addEventListener("click", () => activateStep(Number(button.dataset.step || 0)));
      });

      updateSimulator();
    })();
  </script>
</BaseLayout>

