---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "./Header.astro";
import { ccBook } from "../book.config";
import { pageUrl } from "../urls";

interface Props {
  lang?: "zh";
}

const { lang = "zh" } = Astro.props;
const base = import.meta.env.BASE_URL;
const book = ccBook;
const title = book.zhTitle;
const description = book.zhDescription;
const specPath = "cc/spec";

const sourceCards = [
  {
    title: "上下文窗口管理原文",
    status: "已读取微信正文",
    href: "https://mp.weixin.qq.com/s/NBR6dRr3iO7KCTEChk8QUg",
    body: "覆盖 token、三类朴素方案、五层压缩、Auto-Compact、摘要 prompt、配图图意和面试答法。",
  },
  {
    title: "Claude Code 源码解析",
    status: "微信受限，读取转载",
    href: "https://www.eefocus.com/article/1984643.html",
    body: "读取正文图 19 张，补齐 Agent loop、Tool-Use Loop、Plan Mode、System Prompt、记忆系统和压缩全景。",
  },
  {
    title: "多 Agent 实现机制",
    status: "微信受限，读取转载",
    href: "https://www.eefocus.com/article/2009921.html",
    body: "读取正文图 32 张，补齐 Subagent、Fork、Coordinator、工具隔离、上下文隔离和消息通信。",
  },
  {
    title: "Grep / Glob / Read 递归链接",
    status: "内链补全",
    href: "https://www.eefocus.com/article/2015097.html",
    body: "补齐为什么代码上下文优先用确定性检索、按需读取和子 agent 探索，而不是默认 RAG。",
  },
  {
    title: "Skills 与长期项目流程",
    status: "内链补全",
    href: "https://www.eefocus.com/article/2013527.html",
    body: "补齐 planning-with-files、Claude Mem、MCP Builder 等把流程和记忆落盘的工程意义。",
  },
  {
    title: "短期记忆章节",
    status: "递归复核",
    href: "https://www.yangyitao.com/books/harness-engineering/chapters/11-short-term-memory",
    body: "复核有效窗口、工具结果预算、prompt caching、熔断器和工作记忆设计。",
  },
  {
    title: "自动压缩章节",
    status: "递归复核",
    href: "https://zhanghandong.github.io/harness-engineering-from-cc-to-ai-coding/part3/ch09.html",
    body: "复核 20K 输出预留、13K 自动压缩缓冲、3K 手动压缩线、PTL 重试和附件恢复。",
  },
  {
    title: "Anthropic 官方文档",
    status: "公开能力校验",
    href: "https://docs.anthropic.com/en/docs/claude-code/sub-agents",
    body: "校验 subagents、独立上下文、工具权限、memory、MCP、slash commands 等公开能力。",
  },
];

const tocItems = [
  ["mental-model", "0. 先建立心智模型"],
  ["window", "1. 上下文窗口为什么会爆"],
  ["bad-solutions", "2. 三种朴素方案为什么不够"],
  ["pyramid", "3. 五层压缩金字塔"],
  ["auto-compact", "4. Auto-Compact 深拆"],
  ["summary-prompt", "5. 摘要 Prompt 怎么设计"],
  ["memory", "6. 记忆和上下文不是一回事"],
  ["multi-agent", "7. 多 Agent 为什么也是上下文管理"],
  ["interview", "8. 面试怎么答"],
  ["visual-atlas", "9. 原图图意重构"],
  ["recursive-audit", "10. 递归链接补全"],
  ["source-map", "11. 资料覆盖地图"],
];

const layerCards = [
  {
    id: "disk",
    name: "第 1 层",
    title: "大结果存磁盘",
    loss: "几乎无损",
    cost: "零 API",
    trigger: "单个工具结果过大",
    detail:
      "完整结果不塞进消息，只写到本地文件；上下文里留下短预览和可回读路径。适合日志、长文件、大 grep 结果。",
  },
  {
    id: "snip",
    name: "第 2 层",
    title: "Snip 边界裁剪",
    loss: "低",
    cost: "零 API",
    trigger: "很早的消息已明显过时",
    detail:
      "删除远古探索消息，插入边界标记。它不是摘要，而是承认某些早期噪声对当前任务已经没有价值。",
  },
  {
    id: "micro",
    name: "第 3 层",
    title: "Micro-Compact",
    loss: "中低",
    cost: "零 API",
    trigger: "Prompt cache 过期或工具结果太多",
    detail:
      "清掉可重复获取的旧工具结果，只保留最近少量结果；不可重复的子 agent 输出和任务状态不能裁剪。",
  },
  {
    id: "collapse",
    name: "第 4 层",
    title: "Context Collapse",
    loss: "中",
    cost: "低",
    trigger: "上下文约 90% 起",
    detail:
      "读时投影：原始历史不动，只在发 API 请求时动态生成压缩视图。够用时就避免昂贵的全量摘要。",
  },
  {
    id: "auto",
    name: "第 5 层",
    title: "Auto-Compact",
    loss: "高",
    cost: "一次模型调用",
    trigger: "有效窗口减 13K 缓冲",
    detail:
      "兜底全量重写：先为摘要输出预留约 20K，再用有效窗口减 13K 作为触发点，最后把最近文件、计划、技能、异步任务作为附件恢复。",
  },
];

const pipelineSteps = [
  {
    title: "触发",
    body: "先从名义窗口扣掉摘要输出预留，再用有效窗口减 13K 作为自动压缩触发点。手动 /compact 可在更小余量下运行。",
  },
  {
    title: "预处理",
    body: "先做 microcompact，把可重复获取的旧工具输出换成占位符，避免摘要器自己被撑爆。",
  },
  {
    title: "生成摘要",
    body: "用同一个主模型输出 XML 结构摘要，禁止调用任何工具，重点保留用户请求、文件、错误、待办和当前进度。",
  },
  {
    title: "恢复附件",
    body: "按最近活跃度恢复最多 5 个文件、每个最多 5K token、总计最多 50K token，并恢复技能和异步任务状态。",
  },
  {
    title: "接力",
    body: "旧消息链被替换为边界标记、摘要、附件和 hook 结果；模型被明确告知这是续跑，不是新会话。",
  },
];

const comparisonRows = [
  ["滑动窗口", "从最早消息开始砍", "会误删初始目标、约束和关键工具结果"],
  ["每 N 轮摘要", "固定轮数或固定 token 做摘要", "触发点机械，可能在关键转折处粗暴压缩"],
  ["向量召回历史", "把历史切片，按相似度召回 top-k", "忽略时序，可能拆散 tool_use 与 tool_result"],
  ["Claude Code 分层压缩", "先零成本瘦身，再读时投影，最后全量重写", "把语义、状态、永久规则分通道管理"],
];

const promptSections = [
  "Primary Request and Intent",
  "Key Technical Concepts",
  "Files and Code Sections",
  "Errors and fixes",
  "Problem Solving",
  "All user messages",
  "Pending Tasks",
  "Current Work",
  "Optional Next Step",
];

const memoryRows = [
  ["企业/组织规则", "IT 或 DevOps 管理", "所有人都必须遵守的安全、合规、代码规范"],
  ["项目记忆 CLAUDE.md", "仓库根目录", "团队共享的架构、命令、约束、常见坑"],
  ["用户记忆", "个人目录", "个人偏好、常用工具、跨项目工作习惯"],
  ["会话摘要", "当前对话内", "只服务这次长任务的压缩后接续状态"],
  ["计划文件 / Skills", "项目文件或技能包", "把复杂任务的计划、验收、流程和专用规则落盘"],
];

const multiAgentModes = [
  {
    title: "常规 Subagent",
    body: "主 agent 派一个专门角色去做子任务。子 agent 有独立上下文和工具池，完成后把结果交回主 agent。",
  },
  {
    title: "Fork Subagent",
    body: "让子 agent 复用父 agent 的缓存安全前缀，适合完整继承上下文、只分叉试一条轻量路线的场景。",
  },
  {
    title: "Coordinator 模式",
    body: "主 agent 只做拆分、派工、收结果和合成，worker 并行执行。关键是协调者必须理解结果，不能只转发。",
  },
];

const interviewCards = [
  {
    q: "Claude Code 的上下文窗口怎么管理？",
    a: "先说观点：不是简单滑动窗口，也不是固定轮数摘要，而是五层从轻到重的压缩体系。大结果存磁盘、Snip、Micro-Compact、Context Collapse 先尽量零成本减压，最后才由 Auto-Compact 做全量重写和附件恢复。",
  },
  {
    q: "Auto-Compact 什么时候触发？",
    a: "核心公式是有效上下文窗口减去固定缓冲。文章中提到的缓冲是 13K token，目的不是按比例省空间，而是给摘要任务和后续输出留出可预测余量。",
  },
  {
    q: "压缩时到底保什么？",
    a: "语义信息进摘要，状态信息走附件，永久规则下一轮重新加载，系统 prompt 重新构建。最近文件、异步任务、计划和技能都不应该只靠摘要保留。",
  },
  {
    q: "为什么向量召回不能直接替代上下文管理？",
    a: "Agent 历史强依赖顺序和成对工具消息。向量召回只按相似度选片段，可能漏掉低相似但高约束的信息，也可能拆散 tool_use 和 tool_result。",
  },
  {
    q: "多 Agent 的核心风险是什么？",
    a: "隔离和通信。工具权限要按 agent 类型过滤；上下文状态要按字段决定克隆、禁写或保留通路；父子之间要走消息队列和通知，而不是同步函数调用。",
  },
  {
    q: "为什么代码检索优先 Grep / Glob / Read？",
    a: "代码检索常常需要精确名字、最新文件和可审计路径。Grep/Glob/Read 让模型一轮一轮决定搜什么、读哪里；RAG 更适合稳定语义知识库，不适合替代实时仓库里的精确代码定位。",
  },
  {
    q: "Auto-Compact 的几个数字怎么讲？",
    a: "先扣摘要输出预留，再计算自动触发线。常见讲法是 20K 给摘要输出上限，13K 给自动压缩缓冲，3K 是手动 compact 更紧的安全余量，连续失败还要熔断。",
  },
];

const visualMotifs = [
  {
    title: "Agent 不是聊天框",
    source: "源码解析图 5-7",
    body: "原图把 ChatBot、Copilot、Agent 和 Claude Code 主循环分开。网页已重画成“用户目标 → 组装上下文 → tool_use/end_turn → 工具结果回写”的循环。",
  },
  {
    title: "ReAct、Tool-Use、Plan Mode",
    source: "源码解析图 8-13",
    body: "图意是从 Thought-Action-Observation 转向更薄的工具循环，再用 EnterPlanMode / ExitPlanMode 把规划做成工具能力。",
  },
  {
    title: "动态 System Prompt 边界",
    source: "源码解析图 14-16",
    body: "静态行为准则和动态环境信息用边界隔开，目标是让可缓存前缀尽量稳定，把项目规则、MCP、记忆放到可变区。",
  },
  {
    title: "记忆索引与按需加载",
    source: "源码解析图 17",
    body: "MEMORY.md 更像入口索引；独立记忆文件按需读入，避免把长期知识一次性全塞进当前窗口。",
  },
  {
    title: "压缩不是一次摘要",
    source: "源码解析图 18 + 上下文原文",
    body: "工具结果可重复获取就能裁剪；不可重放的子 agent 输出和任务状态必须保留。五层金字塔已把这个规则变成交互按钮。",
  },
  {
    title: "三种 Multi-Agent 拓扑",
    source: "多 Agent 图 1-3",
    body: "父子型、平级协作型、主从协调型的差异已整理进常规 Subagent、Fork Subagent、Coordinator 三张卡。",
  },
  {
    title: "工具隔离 + 上下文隔离",
    source: "多 Agent 图 4-8",
    body: "子 agent 不应该继承所有能力。网页补充了准入门、只读探索、字段级克隆、禁写和任务注册通路。",
  },
  {
    title: "异步消息通信",
    source: "多 Agent 图 9-16",
    body: "父到子用 pending message，子到父用通知消息；超过前台等待线后自动后台化，避免父 agent 被同步阻塞。",
  },
  {
    title: "Fork 缓存复用",
    source: "多 Agent 图 17-21",
    body: "缓存命中要求字节级前缀一致；Fork 复用父 agent 已渲染前缀，适合轻量分叉，不和 Coordinator 模式叠加。",
  },
  {
    title: "Coordinator 不是转发器",
    source: "多 Agent 图 22-32",
    body: "协调者要派工、续命、停止、合成并亲自理解结果；worker 不拿协调工具，防止递归派人失控。",
  },
];

const recursiveCards = [
  {
    title: "上下文窗口精确公式",
    href: "https://www.yangyitao.com/books/harness-engineering/chapters/11-short-term-memory",
    body: "递归复核后补入：名义窗口先扣摘要输出预留，自动压缩再扣 13K 缓冲；窗口管理是零和预算，不是越长越好。",
  },
  {
    title: "Auto-Compact 失败恢复",
    href: "https://zhanghandong.github.io/harness-engineering-from-cc-to-ai-coding/part3/ch09.html",
    body: "补入熔断、PTL 重试、先清空再恢复附件、SessionStart hooks 等面试可追问点。",
  },
  {
    title: "Grep / Glob / Read vs RAG",
    href: "https://www.eefocus.com/article/2015097.html",
    body: "补入代码检索的精确性、实时性、可解释性、token 经济，以及超过 3 次查询时派 Explore 子 agent。",
  },
  {
    title: "Skills 与项目记忆",
    href: "https://www.eefocus.com/article/2013527.html",
    body: "补入 planning-with-files、长期记忆、MCP Builder、UI/测试技能：它们都是把规则和流程从短窗口移到可复用载体。",
  },
  {
    title: "能力边界与选型",
    href: "https://www.eefocus.com/article/1988689.html",
    body: "补入 Claude Code 适合终端闭环、跨文件重构、测试修复；轻量补全或强本土化场景不一定是最优解。",
  },
  {
    title: "官方 Subagents",
    href: "https://docs.anthropic.com/en/docs/claude-code/sub-agents",
    body: "复核 subagent 可配置 tools、disallowedTools、permissionMode、skills、memory、mcpServers、background、worktree isolation。",
  },
];

const thresholdRows = [
  ["名义窗口", "模型宣称可接收的总 token 上限", "不能用满"],
  ["摘要输出预留", "通常按上限留约 20K", "保证 compact 自己有输出空间"],
  ["有效窗口", "名义窗口 - 摘要输出预留", "真正参与触发计算"],
  ["自动压缩缓冲", "有效窗口 - 13K", "自动 compact 的触发线"],
  ["手动 compact 余量", "约 3K", "用户主动压缩可更贴近上限"],
  ["连续失败熔断", "失败 3 次停止重试", "避免 prompt_too_long 类事故烧 API"],
];

const gapFixes = [
  "把正文图按图意分成 10 组，新增读图重构章节，明确没有直接热链复制第三方图片。",
  "把内链里的 Grep/RAG、Skills、能力边界、短期记忆、自动压缩、官方 Subagents 补进递归资料矩阵。",
  "把 Auto-Compact 从“窗口减 13K”修正为“名义窗口先扣摘要输出预留，再扣 13K 缓冲”。",
  "把多 Agent 的图意补到工具隔离、上下文隔离、pending message、XML-like notification、Fork 缓存和 Coordinator 递归防护。",
