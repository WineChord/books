          </label>
          <label>
            读取文件数
            <input id="cc-files" type="range" min="0" max="20" value="6" step="1" />
          </label>
          <label>
            工具轮数
            <input id="cc-rounds" type="range" min="0" max="80" value="18" step="1" />
          </label>
          <label>
            平均工具结果
            <input id="cc-tool" type="range" min="500" max="10000" value="2600" step="500" />
          </label>
          <div class="cc-meter" aria-hidden="true">
            <span id="cc-meter-fill"></span>
          </div>
          <div class="cc-sim-grid">
            <span>估算总量</span><strong id="cc-total">0</strong>
            <span>窗口占用</span><strong id="cc-ratio">0%</strong>
            <span>可能触发</span><strong id="cc-trigger">第 1 层</strong>
          </div>
        </div>
      </div>
    </section>

    <section class="cc-section cc-section-band" id="bad-solutions">
      <div class="cc-section-heading">
        <p class="cc-kicker">2. Naive Solutions</p>
