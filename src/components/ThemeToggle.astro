---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
const buttonPaddingClass = compact ? "p-1" : "p-2";
const iconSizeClass = compact ? "size-4" : "size-5";
---

<button
  id="theme-toggle"
  type="button"
  aria-label="Toggle dark mode"
  aria-pressed="false"
  class={`rounded-md ${buttonPaddingClass} text-charcoal transition-colors hover:bg-beige dark:text-cream dark:hover:bg-dark-surface`}
>
  <svg class={`hidden ${iconSizeClass} dark:block`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.36 6.36-.7-.7M6.34 6.34l-.7-.7m12.72 0-.7.7M6.34 17.66l-.7.7M16 12a4 4 0 1 1-8 0 4 4 0 0 1 8 0z" />
  </svg>
  <svg class={`block ${iconSizeClass} dark:hidden`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M20.35 15.35A9 9 0 0 1 8.65 3.65 9 9 0 1 0 20.35 15.35z" />
  </svg>
</button>

<script>
  import { getTheme, toggleTheme } from "../scripts/theme";

  const themeButton = document.getElementById("theme-toggle");

  function syncThemeButton() {
    themeButton?.setAttribute("aria-pressed", String(getTheme() === "dark"));
  }

  syncThemeButton();
  themeButton?.addEventListener("click", () => {
    toggleTheme();
    syncThemeButton();
  });
</script>
