---
import BaseLayout from "../layouts/BaseLayout.astro";
import { leetcodeBook } from "../book.config";
import {
  leetcodeCodeTemplateStats,
  leetcodeCodeTemplates,
} from "../data/leetcode-code-templates";
import {
  leetcodeImplementationReferences,
  leetcodeImplementationStats,
} from "../data/leetcode-implementation-references";
import {
  leetcodeGeneratedImplementationReferences,
  leetcodeGeneratedImplementationStats,
} from "../data/leetcode-implementation-generated";
import {
  leetcodeByteDanceProblems,
  leetcodeByteDanceStats,
} from "../data/leetcode-bytedance";
import {
  leetcodeDataSource,
  leetcodeDataUpdatedAt,
  leetcodeDuplicateAudit,
  leetcodeProblems,
  leetcodeStats,
} from "../data/leetcode-problems";
import {
  leetcodeProblemConstraintStats,
  leetcodeProblemConstraints,
} from "../data/leetcode-problem-constraints";
import {
  leetcodeProblemConstraintHtml,
  leetcodeProblemMathStats,
  leetcodeProblemStatementHtml,
} from "../data/leetcode-problem-math";
import {
  leetcodeRelatedQuestionStats,
  leetcodeRelatedQuestions,
} from "../data/leetcode-related";
import { pageUrl } from "../urls";

interface Props {
  lang?: "en" | "zh";
}

const { lang = "zh" } = Astro.props;
const base = import.meta.env.BASE_URL;
const book = leetcodeBook;
const isZh = lang === "zh";
const homePath = isZh ? `zh/${book.slug}/` : `${book.slug}/`;
const title = isZh ? book.zhTitle : book.title;
const description = isZh ? book.zhDescription : book.description;
const repositoryUrl = "https://github.com/WineChord/books";
const extensionDirectoryUrl = `${repositoryUrl}/tree/main/extensions/leetcode-submit`;
const extensionReleaseDownloadUrl = `${repositoryUrl}/releases/latest/download/leetcode-submit.zip`;
const extensionReleasesUrl = `${repositoryUrl}/releases`;
const issuesUrl = `${repositoryUrl}/issues`;
const leetcodeSpecUrl = `${repositoryUrl}/blob/main/docs/${
  isZh ? "zh/leetcode/spec.md" : "leetcode/spec.md"
}`;
const leetcodeChangelogUrl = `${repositoryUrl}/blob/main/docs/${
  isZh ? "zh/leetcode/changelog.md" : "leetcode/changelog.md"
}`;
const searchShortcutTitle = isZh ? "聚焦搜索（/）" : "Focus search (/)";
const previousPageShortcutTitle = isZh ? "上一页（←）" : "Previous page (←)";
const nextPageShortcutTitle = isZh ? "下一页（→）" : "Next page (→)";
const firstPageShortcutTitle = isZh ? "首页（Option+←）" : "First page (Option+←)";
const lastPageShortcutTitle = isZh ? "末页（Option+→）" : "Last page (Option+→)";
const pageJumpShortcutTitle = isZh ? "聚焦页码跳转（Option+P）" : "Focus page jump (Option+P)";
const shortcutHelpTitle = isZh ? "查看快捷键（?）" : "Show keyboard shortcuts (?)";
const resetSessionTitle = isZh
  ? "重开本次计时（Cmd+Option+Shift+S）"
  : "Restart this session timer (Cmd+Option+Shift+S)";
const restartProblemTimerTitle = isZh
  ? "重开本题计时（Cmd+Option+T）"
  : "Restart current problem timer (Cmd+Option+T)";
const clearProblemRecordTitle = isZh
  ? "清除当前题 PB 和上次 AC（Cmd+Option+Shift+T）"
  : "Clear current problem PB and last AC (Cmd+Option+Shift+T)";
const flowModeTitle = isZh
  ? "切换沉浸刷题流（Cmd+Option+F）"
  : "Toggle immersive practice flow (Cmd+Option+F)";
const skipSqlFlowTitle = isZh
  ? "顺序跳转、推荐流和 Option+↑/↓ 跳过数据库 SQL 题"
  : "Skip database SQL problems in list flow, suggested flow, and Option+Up/Down";
const skipFrontendFlowTitle = isZh
  ? "顺序跳转、推荐流和 Option+↑/↓ 跳过纯前端 JavaScript/TypeScript 题"
  : "Skip pure frontend JavaScript/TypeScript problems in list flow, suggested flow, and Option+Up/Down";
const suggestedFlowTitle = isZh
  ? "启动猜你想练推荐流（Cmd+Option+Shift+F）"
  : "Start suggested practice flow (Cmd+Option+Shift+F)";
const resetAllDraftsTitle = isZh
  ? "重置全部题目草稿（Cmd+Option+Shift+R）"
  : "Reset all problem drafts (Cmd+Option+Shift+R)";
const filterShortcutTitles = {
  all: isZh ? "范围：全部（Option+1）" : "Scope: all (Option+1)",
  hot100: isZh ? "范围：Hot100（Option+2）" : "Scope: Hot100 (Option+2)",
  companyFollowUps: isZh
    ? "范围：公司追问（Option+3）"
    : "Scope: follow-ups (Option+3)",
  bytedanceAll: isZh ? "字节：全部（Option+4）" : "ByteDance: all (Option+4)",
  bytedanceThirtyDays: isZh
    ? "字节：近 30 天（Option+5）"
    : "ByteDance: 30 days (Option+5)",
  bytedanceThreeMonths: isZh
    ? "字节：近 3 月（Option+6）"
    : "ByteDance: 3 months (Option+6)",
  bytedanceSixMonths: isZh
    ? "字节：近 6 月（Option+7）"
    : "ByteDance: 6 months (Option+7)",
  bytedanceMoreThanSixMonths: isZh
    ? "字节：6 月前（Option+8）"
    : "ByteDance: older than 6 months (Option+8)",
  unsolved: isZh ? "状态：未做（Option+9）" : "State: unsolved (Option+9)",
  review: isZh ? "状态：需思考（Option+0）" : "State: review (Option+0)",
  unmastered: isZh
    ? "状态：未熟练（Option+-）"
    : "State: unmastered (Option+-)",
};
const leetcodeTargetLimit = 888;
const syncedDedupedLimit = leetcodeStats.dedupedTop888;
const relatedTopicPeerLimit = 6;
const byteDanceBySlug = new Map(
  leetcodeByteDanceProblems.map((problem) => [problem.titleSlug, problem]),
);
const seriesRomanTokenValues = new Map([
  ["i", 1],
  ["ii", 2],
  ["iii", 3],
  ["iv", 4],
  ["v", 5],
  ["vi", 6],
  ["vii", 7],
  ["viii", 8],
  ["ix", 9],
  ["x", 10],
]);
const strongRelatedTagSlugs = new Set([
  "backtracking",
  "binary-search",
  "binary-tree",
  "bit-manipulation",
  "breadth-first-search",
  "depth-first-search",
  "dynamic-programming",
  "graph",
  "heap-priority-queue",
  "linked-list",
  "monotonic-queue",
  "monotonic-stack",
  "prefix-sum",
  "shortest-path",
  "sliding-window",
  "stack",
  "string-matching",
  "topological-sort",
  "tree",
  "trie",
  "two-pointers",
  "union-find",
]);

function mergedByteDanceBuckets(problem) {
  const entry = byteDanceBySlug.get(problem.titleSlug);
  if (entry) return entry.buckets;
  const periods = problem.bytedancePeriods || {};
  return {
    all: problem.bytedance ? problem.frequencyRank : null,
    thirtyDays: null,
    threeMonths: periods.past3Months,
    sixMonths: periods.past6Months,
    moreThanSixMonths: periods.before6Months,
  };
}

function frequencyLabel(value) {
  if (value === null || value === undefined) return "字节补充";
  return `${Number(value).toFixed(1)}%`;
}

function byteDanceSourceStatusLabel(status) {
  if (status === "companyFavorite") return "GraphQL 全量同步";
  if (status === "companyFavoriteWithChromeRenderedBuckets") {
    return "GraphQL 全量 + 官方页 Top100 校准";
  }
  if (status === "chromeRenderedTop100MergedWithLegacyTop888Fallback") {
    return "官方页 Top100 + 旧 Top888 fallback";
  }
  if (status === "legacyTop888Fallback") return "旧 Top888 fallback";
  return status;
}

function seriesCandidateKeys(slug) {
  const tokens = String(slug || "").toLowerCase().split("-").filter(Boolean);
  const keys = new Set();
  for (let index = 1; index < tokens.length; index += 1) {
    if (!seriesRomanTokenValues.has(tokens[index])) continue;
    const prefix = tokens.slice(0, index);
    if (prefix.length < 2) continue;
    keys.add(prefix.join("-"));
  }
  return [...keys];
}

function seriesOrderValue(slug, seriesKey) {
  if (slug === seriesKey) return 0;
  const suffix = slug.startsWith(`${seriesKey}-`)
    ? slug.slice(seriesKey.length + 1).split("-")[0]
    : "";
  return seriesRomanTokenValues.get(suffix) ?? Number.MAX_SAFE_INTEGER;
}

function buildSeriesGroups(catalogProblems) {
  const bySlug = new Map(catalogProblems.map((problem) => [
    problem.titleSlug,
    problem,
  ]));
  const membersByKey = new Map();
  for (const problem of catalogProblems) {
    for (const key of seriesCandidateKeys(problem.titleSlug)) {
      if (!membersByKey.has(key)) membersByKey.set(key, new Map());
      membersByKey.get(key).set(problem.titleSlug, problem);
    }
  }
  for (const [key, members] of membersByKey) {
    const baseProblem = bySlug.get(key);
    if (baseProblem) members.set(baseProblem.titleSlug, baseProblem);
  }
  const groupsBySlug = new Map();
  for (const [key, memberMap] of membersByKey) {
    const members = [...memberMap.values()];
    if (members.length < 2) continue;
    members.sort((left, right) => {
      const leftOrder = seriesOrderValue(left.titleSlug, key);
      const rightOrder = seriesOrderValue(right.titleSlug, key);
      return (
        leftOrder - rightOrder ||
        (left.topRank ?? left.frequencyRank ?? 999999) -
          (right.topRank ?? right.frequencyRank ?? 999999)
      );
    });
    for (const member of members) {
      const existing = groupsBySlug.get(member.titleSlug);
      if (!existing || members.length > existing.length) {
        groupsBySlug.set(member.titleSlug, members);
      }
    }
  }
  return groupsBySlug;
}

function relatedQuestionUrl(slug) {
  return `https://leetcode.cn/problems/${slug}/description/`;
}

function relatedSummary(question, catalogBySlug, currentSlug) {
  const bookProblem = catalogBySlug.get(question.titleSlug);
  const difficulty = bookProblem?.difficulty ?? question.difficulty ?? "";
  return {
    current: question.titleSlug === currentSlug,
    difficulty,
    frontendId: bookProblem?.frontendId ?? "",
    frequencyRank: bookProblem?.frequencyRank ?? null,
    hot100: Boolean(bookProblem?.hot100),
    hotRank: bookProblem?.hotRank ?? null,
    inBook: Boolean(bookProblem),
    paidOnly: Boolean(question.isPaidOnly || bookProblem?.paidOnly),
    sharedTags: question.sharedTags ?? [],
    title: question.title ?? "",
    titleCn:
      bookProblem?.titleCn ??
      question.translatedTitle ??
      question.title ??
      question.titleSlug,
    titleSlug: question.titleSlug,
    topRank: bookProblem?.topRank ?? null,
    url: bookProblem?.url ?? relatedQuestionUrl(question.titleSlug),
  };
}

function bookRelatedQuestion(problem) {
  return {
    difficulty: problem.difficulty,
    isPaidOnly: problem.paidOnly,
    title: problem.titleSlug,
    titleSlug: problem.titleSlug,
    translatedTitle: problem.titleCn,
  };
}

function sharedTags(problem, other) {
  const problemTags = new Map(problem.tags.map((tag) => [tag.slug, tag.name]));
  return other.tags
    .filter((tag) => problemTags.has(tag.slug))
    .map((tag) => ({
      name: problemTags.get(tag.slug) ?? tag.name,
      slug: tag.slug,
    }));
}

function topicPeerScore(problem, candidate, shared) {
  const strongShared = shared.filter((tag) => strongRelatedTagSlugs.has(tag.slug));
  if (shared.length < 2 && strongShared.length === 0) return 0;
  const rank = candidate.topRank ?? candidate.frequencyRank ?? 999999;
  const rankScore = Math.max(0, 2000 - rank);
  return (
    shared.length * 10000 +
    strongShared.length * 6000 +
    (candidate.hot100 ? 3000 : 0) +
    (candidate.bytedance ? 1800 : 0) +
    rankScore
  );
}

function buildTopicPeers(problem, catalogProblems, catalogBySlug, excludedSlugs) {
  return catalogProblems
    .filter((candidate) => (
      candidate.titleSlug !== problem.titleSlug &&
      !excludedSlugs.has(candidate.titleSlug)
    ))
    .map((candidate) => {
      const shared = sharedTags(problem, candidate);
      return {
        problem: candidate,
        score: topicPeerScore(problem, candidate, shared),
        shared,
      };
    })
    .filter((item) => item.score > 0)
    .sort((left, right) => {
      return (
        right.score - left.score ||
        (left.problem.topRank ?? left.problem.frequencyRank ?? 999999) -
          (right.problem.topRank ?? right.problem.frequencyRank ?? 999999)
      );
    })
    .slice(0, relatedTopicPeerLimit)
    .map((item) =>
      relatedSummary(
        {
          ...bookRelatedQuestion(item.problem),
          sharedTags: item.shared.slice(0, 3),
        },
        catalogBySlug,
        problem.titleSlug,
      ),
    );
}

const byteDanceStatusLabel = byteDanceSourceStatusLabel(
  leetcodeByteDanceStats.sourceStatus,
);

const leetcodeProblemsWithByteDance = leetcodeProblems.map((problem) => {
  const entry = byteDanceBySlug.get(problem.titleSlug);
  const bucketSourceValues = Object.values(entry?.bucketSources || {});
  const hasVerifiedByteDanceBucket = bucketSourceValues.some(
    (source) => source === "companyFavorite" || source === "companyRendered",
  );
  return {
    ...problem,
    bytedance: Boolean(entry || problem.bytedance),
    bytedanceBuckets: mergedByteDanceBuckets(problem),
    bytedanceBucketSources: entry?.bucketSources ?? {},
    bytedanceRank: entry?.bytedanceRank ?? null,
    bytedanceSource: entry?.source ?? (problem.bytedance ? "legacyTop888" : null),
    bytedanceVerified: hasVerifiedByteDanceBucket || problem.bytedanceVerified,
    constraints: leetcodeProblemConstraints[problem.titleSlug] ?? [],
    constraintHtml: leetcodeProblemConstraintHtml[problem.titleSlug] ?? [],
    statementHtml: leetcodeProblemStatementHtml[problem.titleSlug] ?? "",
  };
});
const existingSlugs = new Set(leetcodeProblems.map((problem) => problem.titleSlug));
const leetcodeByteDanceSupplements = leetcodeByteDanceProblems
  .filter((problem) => !existingSlugs.has(problem.titleSlug))
  .map((problem, index) => ({
    topRank: null,
    frequencyRank: leetcodeTargetLimit + index + 1,
    hotRank: null,
    frontendId: problem.frontendId,
    titleCn: problem.titleCn,
    titleSlug: problem.titleSlug,
    url: problem.url,
    difficulty: problem.difficulty,
    acRate: problem.acRate,
    frequency: frequencyLabel(problem.frequency),
    bytedance: true,
    bytedanceVerified: problem.source !== "legacyTop888",
    bytedancePeriods: {
      past3Months: null,
      past6Months: null,
      before6Months: null,
    },
    bytedanceBuckets: problem.buckets,
    bytedanceBucketSources: problem.bucketSources ?? {},
    bytedanceRank: problem.bytedanceRank,
    bytedanceSource: problem.source,
    hot100: false,
    paidOnly: problem.paidOnly,
    tags: problem.tags,
    statementPreview: problem.statementPreview ?? "",
    approachPreview: problem.approachPreview ?? "",
    constraints: leetcodeProblemConstraints[problem.titleSlug] ?? [],
    constraintHtml: leetcodeProblemConstraintHtml[problem.titleSlug] ?? [],
    statementHtml: leetcodeProblemStatementHtml[problem.titleSlug] ?? "",
    followUps: problem.followUps ?? [],
  }));
const mergedLeetcodeProblems = [
  ...leetcodeProblemsWithByteDance,
  ...leetcodeByteDanceSupplements,
];
const leetcodeProblemCatalogBySlug = new Map(
  mergedLeetcodeProblems.map((problem) => [problem.titleSlug, problem]),
);
const leetcodeSeriesGroupsBySlug = buildSeriesGroups(mergedLeetcodeProblems);
function buildRelatedQuestions(problem) {
  const series = (leetcodeSeriesGroupsBySlug.get(problem.titleSlug) ?? [])
    .map((item) =>
      relatedSummary(
        bookRelatedQuestion(item),
        leetcodeProblemCatalogBySlug,
        problem.titleSlug,
      ),
    );
  const seriesSlugs = new Set(series.map((item) => item.titleSlug));
  const official = (leetcodeRelatedQuestions[problem.titleSlug] ?? [])
    .filter((item) => !seriesSlugs.has(item.titleSlug))
    .map((item) =>
      relatedSummary(item, leetcodeProblemCatalogBySlug, problem.titleSlug),
    );
  const excludedSlugs = new Set([
    problem.titleSlug,
    ...seriesSlugs,
    ...official.map((item) => item.titleSlug),
  ]);
  const topicPeers = buildTopicPeers(
    problem,
    mergedLeetcodeProblems,
    leetcodeProblemCatalogBySlug,
    excludedSlugs,
  );
  return {
    official,
    series,
    topicPeers,
    total: official.length + series.length + topicPeers.length,
  };
}
const leetcodeProblemsWithReferences = mergedLeetcodeProblems.map((problem) => ({
  ...problem,
  codeTemplates: leetcodeCodeTemplates[problem.titleSlug] ?? [],
  implementationReferences:
    [
      ...(leetcodeImplementationReferences[problem.titleSlug] ?? []),
      ...(leetcodeGeneratedImplementationReferences[problem.titleSlug] ?? []),
    ],
  relatedQuestions: buildRelatedQuestions(problem),
}));
const leetcodeReferenceCount =
  leetcodeImplementationStats.references +
  leetcodeGeneratedImplementationStats.references;
const totalProblemCount = leetcodeProblemsWithReferences.length;
const shortcutRows = [
  {
    keys: "/",
    zh: "聚焦搜索",
    en: "Focus search",
  },
  {
    keys: "Option+1 / 2 / 3",
    zh: "范围筛选：全部 / Hot100 / 公司追问",
    en: "Scope filters: all / Hot100 / follow-ups",
  },
  {
    keys: "Option+4-8",
    zh: "字节筛选：全部 / 30天 / 3月 / 6月 / 6月前",
    en: "ByteDance filters: all / 30d / 3m / 6m / old",
  },
  {
    keys: "Option+9 / 0 / -",
    zh: "状态筛选：未做 / 需思考 / 未熟练",
    en: "State filters: unsolved / review / unmastered",
  },
  {
    keys: "Option+↓",
    zh: "下一题答题区",
    en: "Next problem editor",
  },
  {
    keys: "Option+↑",
    zh: "上一题答题区",
    en: "Previous problem editor",
  },
  {
    keys: "Cmd+'",
    zh: "运行官方示例",
    en: "Run official examples",
  },
  {
    keys: "Cmd+Enter",
    zh: "完整提交到力扣",
    en: "Submit to LeetCode",
  },
  {
    keys: "Cmd+Option+F",
    zh: "切换顺序沉浸流",
    en: "Toggle list flow",
  },
  {
    keys: "Cmd+Option+Shift+F",
    zh: "启动猜你想练流",
    en: "Start suggested flow",
  },
  {
    keys: "Cmd+/",
    zh: "注释或取消注释选中代码",
    en: "Toggle selected code comments",
  },
  {
    keys: "Cmd+Shift+L",
    zh: "打开当前题力扣页",
    en: "Open current LeetCode problem",
  },
  {
    keys: "Cmd+Option+R",
    zh: "重置当前题草稿",
    en: "Reset current problem draft",
  },
  {
    keys: "Cmd+Option+L",
    zh: "聚焦当前题语言选择",
    en: "Focus current language selector",
  },
  {
    keys: "Cmd+Option+C",
    zh: "复制当前题代码",
    en: "Copy current problem code",
  },
  {
    keys: "Cmd+Option+H",
    zh: "切换当前编辑器高度",
    en: "Toggle current editor height",
  },
  {
    keys: "Cmd+Option+Shift+R",
    zh: "重置全部题目草稿",
    en: "Reset all problem drafts",
  },
  {
    keys: "Cmd+Option+T",
    zh: "重开当前题计时",
