            </div>
            <div class="leetcode-practice-actions">
              <span class="leetcode-practice-control">
                <select data-editor-lang="${escapeHtml(problem.titleSlug)}" aria-label="${isChinesePage ? "选择当前题语言（Cmd+Option+L）" : "Choose current language (Cmd+Option+L)"}">
                  ${languages
                    .map(
                      ([value, label]) =>
                        `<option value="${escapeHtml(value)}" ${
                          lang === value ? "selected" : ""
                        }>${escapeHtml(label)}</option>`,
                    )
                    .join("")}
                </select>
              </span>
              <button type="button" data-editor-action="copy" data-slug="${escapeHtml(problem.titleSlug)}" aria-label="${isChinesePage ? "复制当前题代码（Cmd+Option+C）" : "Copy current problem code (Cmd+Option+C)"}">复制</button>
              <button type="button" data-editor-action="reset" data-slug="${escapeHtml(problem.titleSlug)}" aria-label="${isChinesePage ? "重置当前题草稿（Cmd+Option+R）" : "Reset current problem draft (Cmd+Option+R)"}">重置</button>
              <button type="button" data-editor-action="height-mode" data-slug="${escapeHtml(problem.titleSlug)}" aria-label="${isChinesePage ? "切换编辑器高度（Cmd+Option+H）" : "Toggle editor height (Cmd+Option+H)"}">高度：${editorAutoGrow ? "自适应" : "固定"}</button>
              <button type="button" data-editor-action="run-leetcode" data-slug="${escapeHtml(problem.titleSlug)}" aria-label="${isChinesePage ? "运行官方样例（Cmd+'）" : "Run official examples (Cmd+')"}">运行样例</button>
              <button type="button" data-editor-action="submit-leetcode" data-slug="${escapeHtml(problem.titleSlug)}" aria-label="${isChinesePage ? "提交到力扣（Cmd+Enter）" : "Submit to LeetCode (Cmd+Enter)"}">提交力扣</button>
              <a href="${escapeHtml(problem.url)}" target="_blank" rel="noopener noreferrer" aria-label="${isChinesePage ? "打开当前题力扣页（Cmd+Shift+L）" : "Open current LeetCode problem (Cmd+Shift+L)"}" data-link-slug="${escapeHtml(problem.titleSlug)}">打开力扣</a>
            </div>
