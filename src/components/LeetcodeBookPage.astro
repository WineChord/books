---
import Header from "./Header.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { leetcodeBook } from "../book.config";
import {
  leetcodeDataSource,
  leetcodeDataUpdatedAt,
  leetcodeDuplicateAudit,
  leetcodeProblems,
  leetcodeStats,
} from "../data/leetcode-problems";
import { pageUrl } from "../urls";

interface Props {
  lang?: "en" | "zh";
}

const { lang = "zh" } = Astro.props;
const base = import.meta.env.BASE_URL;
const book = leetcodeBook;
const isZh = lang === "zh";
const homePath = isZh ? `zh/${book.slug}/` : `${book.slug}/`;
const title = isZh ? book.zhTitle : book.title;
const description = isZh ? book.zhDescription : book.description;
const leetcodeTargetLimit = 1888;
const syncedTopLimit = leetcodeStats.top888;
const syncedDedupedLimit = leetcodeStats.dedupedTop888;
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={homePath}
  lang={lang}
  titleSuffix={title}
>
  <Header
    lang={lang}
    alternatePath={null}
    homePath={homePath}
    brandTitle={title}
    brandShortTitle={isZh ? book.zhShortTitle : book.shortTitle}
  />

  <main class="leetcode-shell mx-auto max-w-6xl px-4 py-2 md:px-8 md:py-3">
    <section class="leetcode-hero">
      <div>
        <p class="leetcode-kicker">{book.coverKicker}</p>
        <h1 class="leetcode-title">{isZh ? book.zhTitle : book.title}</h1>
        <p class="leetcode-copy">
          {isZh
            ? "目标覆盖 Top1888；当前展示已核实的 Top888 数据，合并 Hot100、重复题核对、字节跳动时间段、题意/思路/实现预览和本地状态。"
            : "Targets Top 1888; currently shows verified Top 888 data with Hot 100 flags, duplicate audit, ByteDance buckets, previews, implementation references, and local state."}
        </p>
        <div class="leetcode-actions">
          <a href={pageUrl(base, `${book.slug}/spec`)} class="leetcode-primary-link">
            {isZh ? "查看规格" : "Read spec"}
          </a>
          <a
            href="https://leetcode.cn/studyplan/top-100-liked/"
            target="_blank"
            rel="noopener noreferrer"
            class="leetcode-secondary-link"
          >
            Hot 100
          </a>
        </div>
      </div>
      <div class="book-cover" aria-label={`${title} cover`}>
        <div class="book-cover__kicker">{book.coverKicker}</div>
        <div class="book-cover__title" set:html={book.coverTitle} />
        <div class="book-cover__footer">{book.coverFooter}</div>
      </div>
    </section>

    <section class="leetcode-stats" aria-label={isZh ? "统计" : "Stats"}>
      <div>
        <span>{leetcodeTargetLimit}</span>
        <p>{isZh ? "Top1888 目标" : "Top 1888 target"}</p>
      </div>
      <div>
        <span>{syncedTopLimit}</span>
        <p>{isZh ? "已同步" : "Synced"}</p>
      </div>
      <div>
        <span>{syncedDedupedLimit}</span>
        <p>{isZh ? "去重后" : "Deduped"}</p>
      </div>
      <div>
        <span>{leetcodeStats.hot100}</span>
        <p>Hot 100</p>
      </div>
      <div>
        <span>{leetcodeStats.duplicatesRemoved}</span>
        <p>{isZh ? "去重核对" : "Duplicate audit"}</p>
      </div>
      <div>
        <span>{leetcodeStats.bytedance}</span>
        <p>{isZh ? "字节出现" : "ByteDance"}</p>
      </div>
    </section>

    <section class="leetcode-workspace" aria-label={isZh ? "题目列表" : "Problem list"}>
      <div class="leetcode-toolbar">
        <div class="leetcode-search">
          <label for="leetcode-search">{isZh ? "搜索" : "Search"}</label>
          <input id="leetcode-search" type="search" placeholder={isZh ? "题号、题名、标签" : "Id, title, tag"} />
        </div>

        <div class="leetcode-filter-panel" aria-label={isZh ? "筛选" : "Filters"}>
          <div class="leetcode-filter-cluster">
            <span>{isZh ? "范围" : "Scope"}</span>
            <div class="leetcode-filter-group" role="group" aria-label={isZh ? "范围筛选" : "Scope filters"}>
              <button type="button" class="is-active" data-filter="all">{isZh ? "全部" : "All"}</button>
              <button type="button" data-filter="hot100">Hot100</button>
              <button type="button" data-filter="companyFollowUps">{isZh ? "公司追问" : "Follow-ups"}</button>
            </div>
          </div>
          <div class="leetcode-filter-cluster">
            <span>{isZh ? "字节" : "ByteDance"}</span>
            <div class="leetcode-filter-group" role="group" aria-label={isZh ? "字节筛选" : "ByteDance filters"}>
              <button type="button" data-filter="bytedance">{isZh ? "全部" : "Any"}</button>
              <button type="button" data-filter="bytedancePast3Months">{isZh ? "近3月" : "3m"}</button>
              <button type="button" data-filter="bytedancePast6Months">{isZh ? "3-6月" : "3-6m"}</button>
              <button type="button" data-filter="bytedanceBefore6Months">{isZh ? "6月前" : "Old"}</button>
            </div>
          </div>
          <div class="leetcode-filter-cluster">
            <span>{isZh ? "状态" : "State"}</span>
            <div class="leetcode-filter-group" role="group" aria-label={isZh ? "状态筛选" : "State filters"}>
              <button type="button" data-filter="unsolved">{isZh ? "未做" : "Unsolved"}</button>
              <button type="button" data-filter="review">{isZh ? "需思考" : "Review"}</button>
              <button type="button" data-filter="unmastered">{isZh ? "未熟练" : "Unmastered"}</button>
            </div>
          </div>
        </div>

        <div class="leetcode-page-size">
          <label for="leetcode-page-size">{isZh ? "每页" : "Page size"}</label>
          <select id="leetcode-page-size">
            <option value="10">10</option>
            <option value="20" selected>20</option>
            <option value="50">50</option>
            <option value="100">100</option>
            <option value="custom">{isZh ? "自定义" : "Custom"}</option>
          </select>
          <input
            id="leetcode-custom-size"
            type="number"
            min="1"
            max={leetcodeStats.total}
            inputmode="numeric"
            placeholder="32"
            hidden
          />
        </div>
      </div>

      <div class="leetcode-summary">
        <span id="leetcode-result-count"></span>
        <span>{isZh ? "数据日期" : "Data date"}: {leetcodeDataUpdatedAt}</span>
        <span>
          {isZh
            ? "力扣中国区按出题频率排序；字节数据来自可核实企业题库/companyTagStatsV2；公司追问来自公开 Discuss。"
            : leetcodeDataSource}
        </span>
      </div>

      {
        leetcodeDuplicateAudit.length > 0 && (
          <details class="leetcode-duplicate-audit">
            <summary>
              {isZh
                ? `去重核对：默认隐藏 ${leetcodeDuplicateAudit.length} 道明显重复题`
                : `Duplicate audit: ${leetcodeDuplicateAudit.length} hidden by default`}
            </summary>
            <div class="leetcode-duplicate-list">
              {leetcodeDuplicateAudit.map((item) => (
                <div class="leetcode-duplicate-row">
                  <span>#{item.duplicateRank}</span>
                  <a
                    href={`https://leetcode.cn/problems/${item.duplicateTitleSlug}/description/`}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {item.duplicateFrontendId}. {item.duplicateTitleCn}
                  </a>
                  <span>{isZh ? "保留" : "kept"}</span>
                  <a
                    href={`https://leetcode.cn/problems/${item.keptTitleSlug}/description/`}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    #{item.keptRank} {item.keptFrontendId}. {item.keptTitleCn}
                  </a>
                </div>
              ))}
            </div>
          </details>
        )
      }

      <div class="leetcode-table-wrap">
        <div class="leetcode-table-head" aria-hidden="true">
          <span>Top</span>
          <span>Hot</span>
          <span>{isZh ? "题目" : "Problem"}</span>
          <span>{isZh ? "难度" : "Level"}</span>
          <span>{isZh ? "频率" : "Freq"}</span>
          <span>{isZh ? "字节" : "BD"}</span>
          <span>{isZh ? "状态" : "State"}</span>
        </div>
        <div id="leetcode-problem-list" class="leetcode-problem-list"></div>
      </div>

      <div class="leetcode-pagination">
        <button type="button" id="leetcode-prev">{isZh ? "上一页" : "Prev"}</button>
        <span id="leetcode-page-indicator"></span>
        <button type="button" id="leetcode-next">{isZh ? "下一页" : "Next"}</button>
      </div>
    </section>
  </main>

  <script type="application/json" id="leetcode-data" set:html={JSON.stringify(leetcodeProblems)}></script>

  <script>
    const progressKey = "leetcode-book-progress-v1";
    const clickedKey = "leetcode-book-clicked-v1";
    const editorKey = "leetcode-book-editor-v1";
    const dataNode = document.getElementById("leetcode-data");
    const problems = JSON.parse(dataNode?.textContent || "[]");
    const maxPageSize = problems.length || 20;
    const list = document.getElementById("leetcode-problem-list");
    const searchInput = document.getElementById("leetcode-search");
    const pageSizeSelect = document.getElementById("leetcode-page-size");
    const customSizeInput = document.getElementById("leetcode-custom-size");
    const resultCount = document.getElementById("leetcode-result-count");
    const pageIndicator = document.getElementById("leetcode-page-indicator");
    const prevButton = document.getElementById("leetcode-prev");
    const nextButton = document.getElementById("leetcode-next");
    const filterButtons = Array.from(document.querySelectorAll("[data-filter]"));
    const state = {
      filter: "all",
      page: 1,
      pageSize: 20,
      query: "",
      expandedSlug: "",
    };

    function readJson(key, fallback) {
      try {
        return JSON.parse(localStorage.getItem(key) || JSON.stringify(fallback));
      } catch {
        return fallback;
      }
    }

    let progress = readJson(progressKey, {});
    let clicked = readJson(clickedKey, {});
    let editorDrafts = readJson(editorKey, {});

    function writeState() {
      localStorage.setItem(progressKey, JSON.stringify(progress));
      localStorage.setItem(clickedKey, JSON.stringify(clicked));
      localStorage.setItem(editorKey, JSON.stringify(editorDrafts));
    }

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;");
    }

    function rowState(slug) {
      return progress[slug] || { done: false, review: false, mastered: false };
    }

    function pageSize() {
      if (pageSizeSelect?.value === "custom") {
        const custom = Number(customSizeInput?.value || 20);
        return Math.max(1, Math.min(maxPageSize, Number.isFinite(custom) ? custom : 20));
      }
      return Number(pageSizeSelect?.value || 20);
    }

    function matchesFilter(problem) {
      const status = rowState(problem.titleSlug);
      const byteDance = problem.bytedancePeriods || {};
      if (state.filter === "hot100" && !problem.hot100) return false;
      if (state.filter === "companyFollowUps" && !problem.companyFollowUps?.length) return false;
      if (state.filter === "bytedance" && !problem.bytedance) return false;
      if (state.filter === "bytedancePast3Months" && !byteDance.past3Months) return false;
      if (state.filter === "bytedancePast6Months" && !byteDance.past6Months) return false;
      if (state.filter === "bytedanceBefore6Months" && !byteDance.before6Months) return false;
      if (state.filter === "unsolved" && status.done) return false;
      if (state.filter === "review" && !status.review) return false;
      if (state.filter === "unmastered" && status.mastered) return false;
      if (!state.query) return true;
      const haystack = [
        problem.frontendId,
        problem.titleCn,
        problem.titleSlug,
        problem.difficulty,
        problem.bytedance ? "字节跳动 bytedance" : "",
        ...problem.tags.map((tag) => tag.name),
        ...(problem.followUps || []).flatMap((item) => [item.question, item.answer]),
        ...(problem.companyFollowUps || []).flatMap((item) => [
          item.question,
          item.answer,
          item.company,
          item.sourceTitle,
        ]),
      ].join(" ").toLowerCase();
      return haystack.includes(state.query.toLowerCase());
    }

    function orderedProblems() {
      const filtered = problems.filter(matchesFilter);
      if (state.filter === "hot100") {
        return filtered.sort((a, b) => (a.hotRank || 999) - (b.hotRank || 999));
      }
      return filtered;
    }

    function badgeClass(difficulty) {
      if (difficulty === "简单") return "is-easy";
      if (difficulty === "困难") return "is-hard";
      return "is-medium";
    }

    function renderTags(problem) {
      return problem.tags
        .slice(0, 3)
        .map((tag) => `<span>${escapeHtml(tag.name)}</span>`)
        .join("");
    }

    function renderByteDance(problem) {
      if (!problem.bytedance) return "";
      const periods = problem.bytedancePeriods || {};
      const labels = [
        ["近3月", periods.past3Months],
        ["3-6月", periods.past6Months],
        ["6月前", periods.before6Months],
      ]
        .filter(([, count]) => count)
        .map(([label, count]) => `${label} ${count}`)
        .join(" / ");
      return `<span title="${escapeHtml(labels || "字节跳动")}">是</span>`;
    }

    function renderByteDanceMeta(problem) {
      const periods = problem.bytedancePeriods || {};
      const chips = [
        ["字节近3月", periods.past3Months],
        ["3-6月", periods.past6Months],
        ["6月前", periods.before6Months],
      ].filter(([, count]) => count);
      if (!chips.length) return "";
      return chips
        .map(([label, count]) => `<span>${escapeHtml(label)} ${escapeHtml(count)}</span>`)
        .join("");
    }

    function renderStudyChecks(problem) {
      const checks = problem.followUps || [];
      if (!checks.length) return "";
      return `
        <span class="leetcode-popover-section">
          <strong>通用检查点</strong>
          ${checks
            .map(
              (item) => `
                <span class="leetcode-check">
                  <em>${escapeHtml(item.question)}</em>
                  <span>${escapeHtml(item.answer)}</span>
                </span>
              `,
            )
            .join("")}
        </span>
      `;
    }

    function renderCompanyFollowUps(problem) {
      const followUps = problem.companyFollowUps || [];
      if (!followUps.length) {
        return '<span class="leetcode-popover-muted">暂无公开核实到的公司追问来源。</span>';
      }
      return `
        <span class="leetcode-popover-section">
          <strong>公司追问</strong>
          ${followUps
            .map(
              (item) => `
                <span class="leetcode-company-follow-up">
                  <span class="leetcode-followup-source">
                    <b>${escapeHtml(item.company)}</b>
                    <a
                      class="leetcode-source-link"
                      href="${escapeHtml(item.sourceUrl)}"
                      title="${escapeHtml(item.sourceTitle)}"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      来源
                    </a>
                  </span>
                  <em>${escapeHtml(item.question)}</em>
                  <span>${escapeHtml(item.answer)}</span>
                </span>
              `,
            )
            .join("")}
        </span>
      `;
    }

    function renderTagReference(problem, topLabel) {
      return `
        <span class="leetcode-tag-popover">
          ${topLabel ? `<span>freq ${escapeHtml(topLabel)}</span>` : ""}
          ${problem.hot100 ? "<span>Hot100</span>" : ""}
          ${problem.bytedanceVerified === false ? "<span>企业待核</span>" : ""}
          ${problem.companyFollowUps?.length ? `<span>公司追问 ${escapeHtml(problem.companyFollowUps.length)}</span>` : ""}
          ${renderByteDanceMeta(problem)}
          ${renderTags(problem)}
        </span>
      `;
    }

    function implementationTracks(problem) {
      const tags = new Set(problem.tags.map((tag) => tag.slug));
      const tracks = [];
      if (tags.has("hash-table")) tracks.push(["哈希表", "先写清 key/value 语义，再确认写入时机和重复值处理。"]);
      if (tags.has("two-pointers")) tracks.push(["双指针", "用区间不变量解释每次移动能排除哪一批候选答案。"]);
      if (tags.has("sliding-window")) tracks.push(["滑动窗口", "维护窗口内计数或约束，右端扩张、左端按条件单调收缩。"]);
      if (tags.has("dynamic-programming")) tracks.push(["动态规划", "先定义状态和转移，再检查是否能滚动压缩空间。"]);
      if (tags.has("stack") || tags.has("monotonic-stack")) tracks.push(["栈/单调栈", "栈里保存尚未确定答案的元素，出栈时一次性结算贡献。"]);
      if (tags.has("binary-search")) tracks.push(["二分", "明确单调谓词，使用左闭右闭或左闭右开一种模板到底。"]);
      if (tags.has("tree") || tags.has("binary-tree")) tracks.push(["树遍历", "先确定递归返回值，再决定前序、后序或层序。"]);
      if (tags.has("graph")) tracks.push(["图搜索", "建图、访问状态和队列/栈边界分开写，避免重复入队。"]);
      if (!tracks.length) tracks.push(["主解法", "先按题面约束写出可讲清楚的不变量，再做复杂度优化。"]);
      return tracks.slice(0, 4);
    }

    function renderImplementationReference(problem) {
      const tracks = implementationTracks(problem);
      return `
        <span class="leetcode-popover-lead">
          Reference implementation 待同步最近提交。当前先展示面试实现顺序；
          最终代码会标记为「我的提交」「已优化」或「生成参考」。
        </span>
        <span class="leetcode-popover-section">
          <strong>建议展开顺序</strong>
          ${tracks
            .map(
              ([name, detail], index) => `
                <span class="leetcode-check">
                  <em>${index + 1}. ${escapeHtml(name)}</em>
                  <span>${escapeHtml(detail)}</span>
                </span>
              `,
            )
            .join("")}
        </span>
        ${renderStudyChecks(problem)}
        ${renderCompanyFollowUps(problem)}
      `;
    }

    function draftFor(problem) {
      return editorDrafts[problem.titleSlug] || {};
    }

    function defaultTemplate(problem, lang) {
      const heading = `${problem.frontendId}. ${problem.titleCn}`;
      if (lang === "python3") {
        return `# ${heading}\n# TODO: sync the official LeetCode signature.\nclass Solution:\n    pass\n`;
      }
      if (lang === "go") {
        return `// ${heading}\n// TODO: sync the official LeetCode signature.\npackage main\n`;
      }
      if (lang === "java") {
        return `// ${heading}\n// TODO: sync the official LeetCode signature.\nclass Solution {\n}\n`;
      }
      if (lang === "typescript") {
        return `// ${heading}\n// TODO: sync the official LeetCode signature.\n`;
      }
      return `// ${heading}\n// TODO: sync the official LeetCode signature.\nclass Solution {\npublic:\n};\n`;
    }

    function renderPracticePanel(problem) {
      const draft = draftFor(problem);
      const lang = draft.lang || "cpp";
      const code = draft.code || defaultTemplate(problem, lang);
      return `
        <section class="leetcode-practice-panel" data-editor-panel="${escapeHtml(problem.titleSlug)}">
          <div class="leetcode-practice-head">
            <div>
              <strong>${escapeHtml(problem.frontendId)}. ${escapeHtml(problem.titleCn)}</strong>
              <span>本地练习草稿，保存在当前浏览器。</span>
            </div>
            <div class="leetcode-practice-actions">
              <select data-editor-lang="${escapeHtml(problem.titleSlug)}" aria-label="Language">
                <option value="cpp" ${lang === "cpp" ? "selected" : ""}>C++</option>
                <option value="python3" ${lang === "python3" ? "selected" : ""}>Python3</option>
                <option value="go" ${lang === "go" ? "selected" : ""}>Go</option>
                <option value="java" ${lang === "java" ? "selected" : ""}>Java</option>
                <option value="typescript" ${lang === "typescript" ? "selected" : ""}>TypeScript</option>
              </select>
              <button type="button" data-editor-action="copy" data-slug="${escapeHtml(problem.titleSlug)}">复制</button>
              <button type="button" data-editor-action="reset" data-slug="${escapeHtml(problem.titleSlug)}">重置</button>
              <a href="${escapeHtml(problem.url)}" target="_blank" rel="noopener noreferrer">打开力扣</a>
            </div>
          </div>
          <textarea
            spellcheck="false"
            data-editor-code="${escapeHtml(problem.titleSlug)}"
            aria-label="Local code editor for ${escapeHtml(problem.titleCn)}"
          >${escapeHtml(code)}</textarea>
          <p>
            直接提交到力扣需要浏览器扩展、用户脚本或本地 companion。纯 GitHub Pages
            版本只做本地练习、复制和跳转，不读取你的登录 cookie。
          </p>
        </section>
      `;
    }

    function renderProblem(problem) {
      const status = rowState(problem.titleSlug);
      const visitedClass = clicked[problem.titleSlug] ? " is-visited" : "";
      const topRank = problem.topRank ?? "";
      const hotRank = problem.hotRank ?? "";
      const byteDance = renderByteDance(problem);
      const topLabel = problem.topRank === null ? `#${problem.frequencyRank}` : "";
      return `
        <article class="leetcode-row${visitedClass}" data-slug="${escapeHtml(problem.titleSlug)}">
          <div class="leetcode-rank">${topRank}</div>
          <div class="leetcode-rank is-hot">${hotRank}</div>
          <div class="leetcode-problem-main">
            <a class="leetcode-problem-link" href="${escapeHtml(problem.url)}" target="_blank" rel="noopener noreferrer" data-link-slug="${escapeHtml(problem.titleSlug)}">
              <span class="leetcode-title-text">${escapeHtml(problem.frontendId)}. ${escapeHtml(problem.titleCn)}</span>
              <span class="leetcode-popover">${escapeHtml(problem.statementPreview)}</span>
            </a>
            <span class="leetcode-title-tools">
              <span class="leetcode-preview-control" data-preview aria-expanded="false" role="button" tabindex="0">
                思路
                <span class="leetcode-popover">
                  <span class="leetcode-popover-lead">${escapeHtml(problem.approachPreview)}</span>
                  ${renderStudyChecks(problem)}
                  ${renderCompanyFollowUps(problem)}
                </span>
              </span>
              <span class="leetcode-preview-control" data-preview aria-expanded="false" role="button" tabindex="0">
                实现
                <span class="leetcode-popover">
                  ${renderImplementationReference(problem)}
                </span>
              </span>
              <span class="leetcode-preview-control" data-preview aria-expanded="false" role="button" tabindex="0">
                标签
                <span class="leetcode-popover">
                  ${renderTagReference(problem, topLabel)}
                </span>
              </span>
            </span>
          </div>
          <div><span class="leetcode-difficulty ${badgeClass(problem.difficulty)}">${escapeHtml(problem.difficulty)}</span></div>
          <div class="leetcode-frequency">${escapeHtml(problem.frequency)}</div>
          <div class="leetcode-byte">${byteDance}</div>
          <div class="leetcode-status">
            <button type="button" data-action="done" data-slug="${escapeHtml(problem.titleSlug)}" class="${status.done ? "is-on" : ""}">做过</button>
            <button type="button" data-action="review" data-slug="${escapeHtml(problem.titleSlug)}" class="${status.review ? "is-on" : ""}">思考</button>
            <button type="button" data-action="mastered" data-slug="${escapeHtml(problem.titleSlug)}" class="${status.mastered ? "is-on" : ""}">熟练</button>
          </div>
        </article>
      `;
    }

    function renderProblemBundle(problem) {
      return renderProblem(problem) + (state.expandedSlug === problem.titleSlug ? renderPracticePanel(problem) : "");
    }

    function render() {
      const items = orderedProblems();
      state.pageSize = pageSize();
      const totalPages = Math.max(1, Math.ceil(items.length / state.pageSize));
      state.page = Math.min(state.page, totalPages);
      const start = (state.page - 1) * state.pageSize;
      const pageItems = items.slice(start, start + state.pageSize);
      if (list) list.innerHTML = pageItems.map(renderProblemBundle).join("");
      if (resultCount) {
        resultCount.textContent = `${items.length} 道题`;
      }
      if (pageIndicator) {
        pageIndicator.textContent = `${state.page} / ${totalPages}`;
      }
      if (prevButton) prevButton.disabled = state.page <= 1;
      if (nextButton) nextButton.disabled = state.page >= totalPages;
    }

    searchInput?.addEventListener("input", (event) => {
      state.query = event.target.value.trim();
      state.page = 1;
      render();
    });

    pageSizeSelect?.addEventListener("change", () => {
      customSizeInput.hidden = pageSizeSelect.value !== "custom";
      state.page = 1;
      render();
    });

    customSizeInput?.addEventListener("input", () => {
      state.page = 1;
      render();
    });

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        filterButtons.forEach((item) => item.classList.remove("is-active"));
        button.classList.add("is-active");
        state.filter = button.dataset.filter || "all";
        state.page = 1;
        render();
      });
    });

    prevButton?.addEventListener("click", () => {
      state.page = Math.max(1, state.page - 1);
      render();
    });

    nextButton?.addEventListener("click", () => {
      state.page += 1;
      render();
    });

    list?.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const link = target.closest("[data-link-slug]");
      if (link instanceof HTMLElement) {
        clicked[link.dataset.linkSlug || ""] = true;
        writeState();
        return;
      }
      if (target.closest(".leetcode-source-link")) return;
      if (target.closest(".leetcode-practice-panel")) {
        const actionButton = target.closest("[data-editor-action]");
        if (actionButton instanceof HTMLElement) {
          const slug = actionButton.dataset.slug || "";
          const panel = actionButton.closest(".leetcode-practice-panel");
          const textarea = panel?.querySelector("[data-editor-code]");
          if (!(textarea instanceof HTMLTextAreaElement)) return;
          if (actionButton.dataset.editorAction === "copy") {
            navigator.clipboard?.writeText(textarea.value);
            actionButton.textContent = "已复制";
            setTimeout(() => {
              actionButton.textContent = "复制";
            }, 1200);
          }
          if (actionButton.dataset.editorAction === "reset") {
            const lang = editorDrafts[slug]?.lang || "cpp";
            const problem = problems.find((item) => item.titleSlug === slug);
            if (!problem) return;
            editorDrafts[slug] = { lang, code: defaultTemplate(problem, lang) };
            writeState();
            render();
          }
        }
        return;
      }
      const previewButton = target.closest("[data-preview]");
      if (previewButton instanceof HTMLElement) {
        const isOpen = previewButton.classList.contains("is-open");
        list.querySelectorAll("[data-preview].is-open").forEach((item) => {
          item.classList.remove("is-open");
          item.setAttribute("aria-expanded", "false");
        });
        previewButton.classList.toggle("is-open", !isOpen);
        previewButton.setAttribute("aria-expanded", String(!isOpen));
        return;
      }
      const button = target.closest("[data-action]");
      if (button instanceof HTMLElement) {
        const slug = button.dataset.slug || "";
        const action = button.dataset.action || "";
        const current = rowState(slug);
        const next = { ...current };
        if (action === "done") next.done = !next.done;
        if (action === "review") {
          next.review = !next.review;
          if (next.review) next.mastered = false;
        }
        if (action === "mastered") {
          next.mastered = !next.mastered;
          if (next.mastered) {
            next.done = true;
            next.review = false;
          }
        }
        progress[slug] = next;
        writeState();
        render();
        return;
      }

      const row = target.closest(".leetcode-row");
      if (!(row instanceof HTMLElement)) return;
      const slug = row.dataset.slug || "";
      state.expandedSlug = state.expandedSlug === slug ? "" : slug;
      render();
    });

    list?.addEventListener("change", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLSelectElement)) return;
      const slug = target.dataset.editorLang || "";
      if (!slug) return;
      const problem = problems.find((item) => item.titleSlug === slug);
      if (!problem) return;
      editorDrafts[slug] = {
        lang: target.value,
        code: defaultTemplate(problem, target.value),
      };
      writeState();
      render();
    });

    list?.addEventListener("input", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLTextAreaElement)) return;
      const slug = target.dataset.editorCode || "";
      if (!slug) return;
      const panel = target.closest(".leetcode-practice-panel");
      const select = panel?.querySelector("[data-editor-lang]");
      const lang = select instanceof HTMLSelectElement ? select.value : editorDrafts[slug]?.lang || "cpp";
      editorDrafts[slug] = { lang, code: target.value };
      writeState();
    });

    list?.addEventListener("keydown", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const previewButton = target.closest("[data-preview]");
      if (!(previewButton instanceof HTMLElement)) return;
      if (event.key !== "Enter" && event.key !== " ") return;
      event.preventDefault();
      previewButton.click();
    });

    render();
  </script>

