    function languageKey(lang) {
      const normalized = String(lang || "").toLowerCase();
      if (["c++", "c++17", "cpp"].includes(normalized)) return "cpp";
      if (["c#", "csharp"].includes(normalized)) return "csharp";
      if (["go", "golang"].includes(normalized)) return "go";
      if (["js", "javascript"].includes(normalized)) return "javascript";
      if (["mysql", "mssql", "oracle", "oraclesql", "sql"].includes(normalized)) return "sql";
      if (["pandas", "python", "python3"].includes(normalized)) return "python";
      if (["ts", "typescript"].includes(normalized)) return "typescript";
      return normalized;
    }

    function lineEnd(code, index) {
      let end = index;
      while (end < code.length && code[end] !== "\n") end += 1;
      return end;
    }

    function highlightedSpan(className, value) {
      return `<span class="${className}">${escapeToken(value)}</span>`;
    }

    function matchComment(code, index, grammar) {
      const char = code[index];
      const next = code[index + 1] || "";
      const comments = grammar.comments || [];
      if (comments.includes("racketBlock") && char === "#" && next === "|") {
        const end = code.indexOf("|#", index + 2);
        return end === -1 ? code.length : end + 2;
      }
      if (comments.includes("slash") && char === "/" && next === "/") {
        return lineEnd(code, index + 2);
      }
      if (comments.includes("slash") && char === "/" && next === "*") {
        const end = code.indexOf("*/", index + 2);
        return end === -1 ? code.length : end + 2;
      }
      if (comments.includes("sql") && char === "-" && next === "-") {
        return lineEnd(code, index + 2);
      }
      if (comments.includes("semicolon") && char === ";") {
        return lineEnd(code, index + 1);
      }
      if (comments.includes("percent") && char === "%") {
        return lineEnd(code, index + 1);
      }
      if (comments.includes("hash") && char === "#") {
        return lineEnd(code, index + 1);
      }
      return -1;
    }

    function matchString(code, index, grammar) {
      const char = code[index];
      if (grammar === highlightGrammarByLanguage.python) {
        const triple = code.slice(index, index + 3);
        if (triple === "'''" || triple === '"""') {
          const end = code.indexOf(triple, index + 3);
          return end === -1 ? code.length : end + 3;
        }
      }
      if (char !== '"' && char !== "'" && char !== "`") return -1;
      let end = index + 1;
      while (end < code.length) {
        if (code[end] === "\\") {
          end += 2;
          continue;
        }
        end += 1;
        if (code[end - 1] === char) break;
      }
      return end;
    }

    const lightPlusControlKeywords = new Set([
      "after",
      "await",
      "break",
      "case",
      "catch",
      "continue",
      "default",
      "defer",
      "do",
      "elif",
      "else",
      "except",
      "finally",
      "for",
      "foreach",
      "guard",
      "if",
      "loop",
      "match",
      "receive",
      "rescue",
      "return",
      "select",
      "switch",
      "throw",
      "throws",
      "try",
      "unless",
      "when",
      "while",
      "with",
      "yield",
    ]);

    function highlightCode(code, lang) {
      const grammar =
        highlightGrammarByLanguage[languageKey(lang)] || {
          comments: ["slash", "hash"],
          keywords: new Set(),
          types: new Set(),
        };
      let html = "";
      for (let index = 0; index < code.length;) {
        const char = code[index];
        const commentEnd = matchComment(code, index, grammar);
        if (commentEnd !== -1) {
          const tokenClass =
            char === "#" && grammar.comments?.includes("directive")
              ? "leetcode-token-directive"
              : "leetcode-token-comment";
          html += highlightedSpan(tokenClass, code.slice(index, commentEnd));
          index = commentEnd;
          continue;
        }
        if (char === "#" && grammar.comments?.includes("directive")) {
          const end = lineEnd(code, index + 1);
          html += highlightedSpan("leetcode-token-directive", code.slice(index, end));
          index = end;
          continue;
        }
        const stringEnd = matchString(code, index, grammar);
        if (stringEnd !== -1) {
          html += highlightedSpan("leetcode-token-string", code.slice(index, stringEnd));
          index = stringEnd;
          continue;
        }
        if (/[0-9]/.test(char)) {
          let end = index + 1;
          while (end < code.length && /[A-Za-z0-9_.]/.test(code[end])) end += 1;
          html += highlightedSpan("leetcode-token-number", code.slice(index, end));
          index = end;
          continue;
        }
        if (isIdentifierStart(char)) {
          let end = index + 1;
          while (end < code.length && isIdentifierPart(code[end])) end += 1;
          const word = code.slice(index, end);
          const lowerWord = word.toLowerCase();
          if (grammar.keywords.has(word) || grammar.keywords.has(lowerWord)) {
            html += highlightedSpan(
              lightPlusControlKeywords.has(lowerWord)
                ? "leetcode-token-control"
                : "leetcode-token-keyword",
              word,
            );
          } else if (grammar.types.has(word) || grammar.types.has(lowerWord)) {
            html += highlightedSpan("leetcode-token-type", word);
          } else {
            html += escapeToken(word);
          }
          index = end;
          continue;
        }
        html += escapeToken(char);
        index += 1;
      }
      return html;
    }

    function rowState(slug) {
      return progress[slug] || { done: false, review: false, mastered: false };
    }

    function byteDanceBuckets(problem) {
      const buckets = problem.bytedanceBuckets || {};
      const periods = problem.bytedancePeriods || {};
      return {
        all: buckets.all ?? (problem.bytedance ? problem.bytedanceRank : null),
        thirtyDays: buckets.thirtyDays ?? null,
        threeMonths: buckets.threeMonths ?? periods.past3Months ?? null,
        sixMonths: buckets.sixMonths ?? periods.past6Months ?? null,
        moreThanSixMonths:
          buckets.moreThanSixMonths ?? periods.before6Months ?? null,
      };
    }

    function byteDanceBucketSources(problem) {
      return problem.bytedanceBucketSources || {};
    }

    function byteDanceSourceLabel(source) {
      if (source === "companyFavorite") return "GraphQL 全量";
      if (source === "companyRendered") return "官方页 Top100";
      if (source === "legacyTop888") return "旧数据";
      return "";
    }

    function byteDanceRankFor(problem, filter = "bytedanceAll") {
      const buckets = byteDanceBuckets(problem);
      if (filter === "bytedanceThirtyDays") return buckets.thirtyDays;
      if (filter === "bytedanceThreeMonths") return buckets.threeMonths;
      if (filter === "bytedanceSixMonths") return buckets.sixMonths;
      if (filter === "bytedanceMoreThanSixMonths") return buckets.moreThanSixMonths;
      return problem.bytedanceRank ?? buckets.all;
    }

    function pageSize() {
      if (pageSizeSelect?.value === "custom") {
        const custom = Number(customSizeInput?.value || 20);
        return Math.max(1, Math.min(maxPageSize, Number.isFinite(custom) ? custom : 20));
      }
      return Number(pageSizeSelect?.value || 20);
    }

    function clampPage(page, totalPages = state.totalPages) {
      const nextPage = Number(page);
      if (!Number.isFinite(nextPage)) return state.page;
      return Math.max(1, Math.min(totalPages, Math.trunc(nextPage)));
    }

    function syncPagination() {
      pageIndicators.forEach((indicator) => {
        indicator.textContent = `/ ${state.totalPages}`;
      });
      pageJumpInputs.forEach((input) => {
        if (!(input instanceof HTMLInputElement)) return;
        input.max = String(state.totalPages);
        input.value = String(state.page);
      });
      pageActionButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        const action = button.dataset.pageAction;
        button.disabled =
          ((action === "first" || action === "prev") && state.page <= 1) ||
          ((action === "next" || action === "last") && state.page >= state.totalPages);
      });
    }

    function setPage(page) {
      const nextPage = clampPage(page);
      if (nextPage === state.page) {
        syncPagination();
        scheduleViewStateWrite();
        return;
      }
      state.page = nextPage;
      render();
      scheduleViewStateWrite();
    }

    function jumpToInputPage(input) {
      if (!(input instanceof HTMLInputElement)) return;
      setPage(input.value);
    }

    function focusSearchInput() {
      if (!(searchInput instanceof HTMLInputElement)) return false;
      searchInput.focus({ preventScroll: true });
      searchInput.select();
      return true;
    }

    function focusPageJumpInput() {
      const input = pageJumpInputs.find((item) => item instanceof HTMLInputElement);
      if (!(input instanceof HTMLInputElement)) return false;
      input.focus({ preventScroll: true });
      input.select();
      return true;
    }

    function isEditableTarget(element) {
      if (!(element instanceof HTMLElement)) return false;
      if (element.isContentEditable) return true;
      return Boolean(
        element.closest(
          "input, textarea, select, button, a, [contenteditable='true'], .leetcode-practice-panel",
        ),
      );
    }

    function isTextEntryTarget(element) {
      if (!(element instanceof HTMLElement)) return false;
      if (element.isContentEditable) return true;
      return element.matches("input, textarea, select, [contenteditable='true']");
    }

    function applyFilter(filter) {
      const button = filterButtons.find(
        (item) => item instanceof HTMLElement && item.dataset.filter === filter,
      );
      if (!(button instanceof HTMLElement)) return false;
      state.filter = filter || "all";
      syncFilterButtons();
      state.page = 1;
      render();
      scheduleViewStateWrite();
      return true;
    }

    function matchesFilter(problem) {
      const status = rowState(problem.titleSlug);
      const byteDance = byteDanceBuckets(problem);
      if (state.filter === "hot100" && !problem.hot100) return false;
      if (state.filter === "companyFollowUps" && !problem.companyFollowUps?.length) return false;
      if (state.filter === "bytedanceAll" && !byteDance.all) return false;
      if (state.filter === "bytedanceThirtyDays" && !byteDance.thirtyDays) return false;
      if (state.filter === "bytedanceThreeMonths" && !byteDance.threeMonths) return false;
      if (state.filter === "bytedanceSixMonths" && !byteDance.sixMonths) return false;
      if (state.filter === "bytedanceMoreThanSixMonths" && !byteDance.moreThanSixMonths) return false;
      if (state.filter === "unsolved" && status.done) return false;
      if (state.filter === "review" && !status.review) return false;
      if (state.filter === "unmastered" && status.mastered) return false;
      if (!state.query) return true;
      const haystack = [
        problem.frontendId,
        problem.titleCn,
        problem.titleSlug,
        problem.difficulty,
        problem.bytedance ? "字节跳动 bytedance" : "",
        problem.bytedanceRank ? `bd ${problem.bytedanceRank}` : "",
        byteDance.thirtyDays ? `字节近30天 ${byteDance.thirtyDays}` : "",
        byteDance.threeMonths ? `字节近3月 ${byteDance.threeMonths}` : "",
        byteDance.sixMonths ? `字节近6月 ${byteDance.sixMonths}` : "",
        byteDance.moreThanSixMonths ? `字节6月前 ${byteDance.moreThanSixMonths}` : "",
        ...Object.entries(byteDanceBucketSources(problem)).map(
          ([key, source]) => `字节${key} ${byteDanceSourceLabel(source)}`,
        ),
        ...problem.tags.map((tag) => tag.name),
        ...(problem.constraints || []),
        ...(problem.followUps || []).flatMap((item) => [item.question, item.answer]),
        ...(problem.companyFollowUps || []).flatMap((item) => [
          item.question,
          item.answer,
          item.company,
          item.sourceTitle,
        ]),
        ...(problem.implementationReferences || []).flatMap((item) => [
          item.language,
          item.provenance,
          item.approachTitle,
          item.complexity,
          item.license,
          item.sourceTitle,
        ]),
        ...(problem.relatedQuestions?.series || []).flatMap((item) => [
          item.frontendId,
          item.titleCn,
          item.title,
          item.titleSlug,
        ]),
        ...(problem.relatedQuestions?.official || []).flatMap((item) => [
          item.frontendId,
          item.titleCn,
          item.title,
          item.titleSlug,
        ]),
        ...(problem.relatedQuestions?.topicPeers || []).flatMap((item) => [
          item.frontendId,
          item.titleCn,
          item.title,
          item.titleSlug,
          ...(item.sharedTags || []).map((tag) => tag.name),
        ]),
      ].join(" ").toLowerCase();
      return haystack.includes(state.query.toLowerCase());
    }

    function orderedProblems() {
      const filtered = problems.filter(matchesFilter);
      if (state.filter === "hot100") {
        return filtered.sort((a, b) => (a.hotRank || 999) - (b.hotRank || 999));
      }
      if (state.filter.startsWith("bytedance")) {
        return filtered.sort((a, b) => {
          const left = byteDanceRankFor(a, state.filter) || Number.MAX_SAFE_INTEGER;
          const right = byteDanceRankFor(b, state.filter) || Number.MAX_SAFE_INTEGER;
          return left - right || (a.frequencyRank || 999999) - (b.frequencyRank || 999999);
        });
      }
      return filtered;
    }

    function editorPanelForSlug(slug) {
      return Array.from(list?.querySelectorAll("[data-editor-panel]") || []).find(
        (item) => item instanceof HTMLElement && item.dataset.editorPanel === slug,
      );
    }

    function stickyHeaderOffset() {
      const header = document.querySelector("header");
      const height =
        header instanceof HTMLElement ? header.getBoundingClientRect().height : 0;
      return Math.max(0, height + editorContextTopGap);
    }

    function editorContextMaxReveal() {
      const viewportHeight =
        window.innerHeight || document.documentElement.clientHeight || 0;
      return Math.min(
        editorContextMaxRevealMax,
        Math.max(
          editorContextMaxRevealMin,
          viewportHeight * editorContextMaxRevealRatio,
        ),
      );
    }

    function scrollEditorContextIntoView(panel, textarea, options = {}) {
      if (!(panel instanceof HTMLElement)) return;
      const behavior = options.behavior || "smooth";
      const contextElement =
        options.contextElement instanceof HTMLElement
          ? options.contextElement
          : panel;
      const viewportHeight =
        window.innerHeight || document.documentElement.clientHeight || 0;
      const headerOffset = stickyHeaderOffset();
      const panelTop = panel.getBoundingClientRect().top + window.scrollY;
      const contextTop = Math.min(
        contextElement.getBoundingClientRect().top + window.scrollY,
        panelTop,
      );
      const editorTop =
        textarea instanceof HTMLTextAreaElement
          ? textarea.getBoundingClientRect().top + window.scrollY
          : panelTop;
      const editorOffset = Math.max(0, editorTop - contextTop);
      const editorLimit = viewportHeight - editorBottomGuard();
      let nextTop = contextTop - headerOffset;

      if (editorOffset > editorLimit) {
        const contextReveal = Math.min(editorOffset, editorContextMaxReveal());
        nextTop = editorTop - headerOffset - contextReveal;
      }

      window.scrollTo({
        behavior,
        left: 0,
        top: Math.max(0, nextTop),
      });
    }

    function focusEditorForSlug(slug, options = {}) {
      window.requestAnimationFrame(() => {
        const panel = editorPanelForSlug(slug);
        const row = Array.from(list?.querySelectorAll(".leetcode-row") || [])
          .find((item) => item instanceof HTMLElement && item.dataset.slug === slug);
        const textarea = panel?.querySelector("[data-editor-code]");
        const target = panel || row;
        const shouldFrameContext = options.frameContext === true;
        if (target instanceof HTMLElement) {
          if (shouldFrameContext && panel instanceof HTMLElement) {
            scrollEditorContextIntoView(panel, textarea, { contextElement: row });
          } else {
            target.scrollIntoView({ block: "center", behavior: "smooth" });
          }
        }
        if (textarea instanceof HTMLTextAreaElement) {
          const context = editorContextFor(textarea);
          if (shouldFrameContext) {
            suppressNextEditorFocusRevealSlug = slug;
            window.setTimeout(() => {
              if (suppressNextEditorFocusRevealSlug === slug) {
                suppressNextEditorFocusRevealSlug = "";
              }
            }, focusRevealSuppressClearDelayMs);
          }
          textarea.focus({ preventScroll: true });
          placeEditorCaretAtImplementation(textarea, context);
          if (!shouldFrameContext) {
            scheduleEditorCaretReveal(textarea, "smooth");
          }
        }
      });
    }

    function currentPracticeSlug(fallbackSlug = "") {
      const active = document.activeElement;
      if (active instanceof HTMLTextAreaElement && active.dataset.editorCode) {
        return active.dataset.editorCode;
      }
      return fallbackSlug || state.expandedSlug || "";
    }

    function openPracticeAtIndex(items, index) {
      const target = items[index];
      if (!target) return;
      state.pageSize = pageSize();
      state.totalPages = Math.max(1, Math.ceil(items.length / state.pageSize));
      state.page = Math.floor(index / state.pageSize) + 1;
      state.expandedSlug = target.titleSlug;
      render();
      scheduleViewStateWrite();
      focusEditorForSlug(target.titleSlug, { frameContext: true });
    }

    function practiceRouteTarget(items, startIndex, direction) {
      const step = direction > 0 ? 1 : -1;
      for (
        let index = startIndex + step;
        index >= 0 && index < items.length;
        index += step
      ) {
        if (!shouldSkipRouteProblem(items[index])) {
          return { index, problem: items[index] };
        }
      }
      return null;
    }

    function navigatePractice(direction, fallbackSlug = "") {
      const items = orderedProblems();
      if (!items.length) return;
      const slug = currentPracticeSlug(fallbackSlug);
      const currentIndex = items.findIndex((item) => item.titleSlug === slug);
      const startIndex = currentIndex === -1
        ? (direction > 0 ? -1 : items.length)
        : currentIndex;
      const target = practiceRouteTarget(items, startIndex, direction);
      if (!target) {
        timingMilestone = flowSkipBoundaryLabel(direction);
        syncTimingUi();
        return;
      }
      openPracticeAtIndex(items, target.index);
    }

    function startSuggestedFlow() {
      const problem = suggestedFlowProblem();
      if (!problem?.titleSlug) {
        timingMilestone = isChinesePage
          ? "暂无可推荐题目"
          : "No suggested practice problem available";
        syncTimingUi();
        syncFlowModeUi();
        return false;
      }
      setFlowMode(flowModeInsight);
      timingMilestone = isChinesePage
        ? `推荐流已进入 ${problem.frontendId}. ${problem.titleCn}`
        : `Suggested flow opened ${problem.frontendId}. ${problem.titleCn}`;
      openRelatedProblem(problem.titleSlug);
      return true;
    }

    function nextListFlowProblemAfterAccepted(problem) {
      if (flowMode !== flowModeList || !problem?.titleSlug) return null;
      const items = orderedProblems();
      const currentIndex = items.findIndex(
        (item) => item.titleSlug === problem.titleSlug,
      );
      if (currentIndex < 0) return null;
      return practiceRouteTarget(items, currentIndex, 1)?.problem || null;
    }

    function advanceFlowAfterAcceptedSubmit(nextProblem, timingResult = {}) {
      if (!flowModeEnabled()) return false;
      if (!nextProblem?.titleSlug) {
        timingMilestone = timingResult.milestone || (
          isChinesePage
            ? "已 AC；当前沉浸流没有下一题"
            : "Accepted; current flow has no next problem"
        );
        syncTimingUi();
        return false;
      }

      if (flowMode === flowModeList) {
        const items = orderedProblems();
        const nextIndex = items.findIndex(
          (item) => item.titleSlug === nextProblem.titleSlug,
        );
        if (nextIndex === -1) {
          timingMilestone = timingResult.milestone || (
            isChinesePage
              ? "已 AC；下一题不在当前列表"
              : "Accepted; next problem is outside the current list"
          );
          syncTimingUi();
          return false;
        }

        timingMilestone = [
          timingResult.milestone,
          isChinesePage
            ? `顺序流已进入 ${nextProblem.frontendId}. ${nextProblem.titleCn}`
            : `List flow opened ${nextProblem.frontendId}. ${nextProblem.titleCn}`,
        ].filter(Boolean).join(" · ");
        openPracticeAtIndex(items, nextIndex);
        return true;
      }

      timingMilestone = [
        timingResult.milestone,
        isChinesePage
          ? `推荐流已进入 ${nextProblem.frontendId}. ${nextProblem.titleCn}`
          : `Suggested flow opened ${nextProblem.frontendId}. ${nextProblem.titleCn}`,
      ].filter(Boolean).join(" · ");
      return openRelatedProblem(nextProblem.titleSlug);
    }

    function openRelatedProblem(slug) {
      let items = orderedProblems();
      let index = items.findIndex((item) => item.titleSlug === slug);
      if (index === -1) {
        if (!problems.some((item) => item.titleSlug === slug)) return false;
        if (searchInput instanceof HTMLInputElement) searchInput.value = "";
        state.query = "";
        applyFilter("all");
        items = orderedProblems();
        index = items.findIndex((item) => item.titleSlug === slug);
      }
      if (index === -1) return false;
      openPracticeAtIndex(items, index);
      return true;
    }

    function badgeClass(difficulty) {
      if (difficulty === "简单") return "is-easy";
      if (difficulty === "困难") return "is-hard";
      return "is-medium";
    }

    function renderTags(problem) {
      return problem.tags
        .slice(0, 3)
        .map((tag) => `<span>${escapeHtml(tag.name)}</span>`)
        .join("");
    }

    function renderByteDance(problem) {
      if (!problem.bytedance) return "";
      const buckets = byteDanceBuckets(problem);
      const sources = byteDanceBucketSources(problem);
      const labels = [
        ["全量", "all", buckets.all],
        ["近30天", "thirtyDays", buckets.thirtyDays],
        ["近3月", "threeMonths", buckets.threeMonths],
        ["近6月", "sixMonths", buckets.sixMonths],
        ["6月前", "moreThanSixMonths", buckets.moreThanSixMonths],
      ]
        .filter(([, , count]) => count)
        .map(([label, key, count]) => {
          const source = byteDanceSourceLabel(sources[key]);
          return `${label} #${count}${source ? ` · ${source}` : ""}`;
        })
        .join(" / ");
      const shortLabels = [
        ["30", buckets.thirtyDays],
        ["3", buckets.threeMonths],
        ["6", buckets.sixMonths],
        ["旧", buckets.moreThanSixMonths],
      ]
        .filter(([, count]) => count)
        .map(([label]) => label)
        .join("/");
      return `<span aria-label="${escapeHtml(labels || "字节跳动")}">${escapeHtml(shortLabels || "全")}</span>`;
    }

    function renderByteDanceMeta(problem) {
      const buckets = byteDanceBuckets(problem);
      const sources = byteDanceBucketSources(problem);
      const chips = [
        ["字节全量", "all", buckets.all],
        ["近30天", "thirtyDays", buckets.thirtyDays],
        ["近3月", "threeMonths", buckets.threeMonths],
        ["近6月", "sixMonths", buckets.sixMonths],
        ["6月前", "moreThanSixMonths", buckets.moreThanSixMonths],
      ].filter(([, , count]) => count);
      if (!chips.length) return "";
      return chips
        .map(([label, key, count]) => {
          const source = byteDanceSourceLabel(sources[key]);
          const suffix = source ? ` · ${source}` : "";
          return `<span>${escapeHtml(label)} #${escapeHtml(count)}${escapeHtml(suffix)}</span>`;
        })
        .join("");
    }

    function renderStudyChecks(problem) {
      const checks = problem.followUps || [];
      if (!checks.length) return "";
      return `
        <span class="leetcode-popover-section">
          <strong>通用检查点</strong>
          ${checks
            .map(
              (item) => `
                <span class="leetcode-check">
                  <em>${escapeHtml(item.question)}</em>
                  <span>${escapeHtml(item.answer)}</span>
                </span>
              `,
            )
            .join("")}
        </span>
      `;
    }

    function renderCompanyFollowUps(problem) {
      const followUps = problem.companyFollowUps || [];
      if (!followUps.length) {
        return '<span class="leetcode-popover-muted">暂无公开核实到的公司追问来源。</span>';
      }
      return `
        <span class="leetcode-popover-section">
          <strong>公司追问</strong>
          ${followUps
            .map(
              (item) => `
                <span class="leetcode-company-follow-up">
                  <span class="leetcode-followup-source">
                    <b>${escapeHtml(item.company)}</b>
                    <a
                      class="leetcode-source-link"
                      href="${escapeHtml(item.sourceUrl)}"
                      aria-label="${escapeHtml(item.sourceTitle)}"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      来源
                    </a>
                  </span>
                  <em>${escapeHtml(item.question)}</em>
                  <span>${escapeHtml(item.answer)}</span>
                </span>
              `,
            )
            .join("")}
        </span>
      `;
    }

    function renderTagReference(problem, topLabel) {
      return `
        <span class="leetcode-tag-popover">
          ${topLabel ? `<span>freq ${escapeHtml(topLabel)}</span>` : ""}
          ${problem.hot100 ? "<span>Hot100</span>" : ""}
          ${problem.bytedanceVerified === false ? "<span>企业待核</span>" : ""}
          ${problem.companyFollowUps?.length ? `<span>公司追问 ${escapeHtml(problem.companyFollowUps.length)}</span>` : ""}
          ${problem.implementationReferences?.length ? `<span>实现参考 ${escapeHtml(problem.implementationReferences.length)}</span>` : ""}
          ${renderByteDanceMeta(problem)}
          ${renderTags(problem)}
        </span>
      `;
    }

    function relatedRankLabel(item) {
      if (item.current) return isChinesePage ? "当前" : "Current";
      if (item.topRank !== null && item.topRank !== undefined) {
        return `Top ${item.topRank}`;
      }
      if (item.hotRank) return `Hot ${item.hotRank}`;
      if (item.frequencyRank) return `#${item.frequencyRank}`;
      return item.inBook
        ? (isChinesePage ? "书内" : "In book")
        : (isChinesePage ? "力扣" : "LeetCode");
    }

    function renderRelatedMeta(item) {
      const chips = [
        relatedRankLabel(item),
        item.difficulty,
        item.hot100 ? "Hot100" : "",
        item.paidOnly ? (isChinesePage ? "付费" : "Paid") : "",
        ...(item.sharedTags || []).map((tag) => tag.name),
      ].filter(Boolean);
      return chips
        .map((chip) => `<span>${escapeHtml(chip)}</span>`)
        .join("");
    }

    function renderRelatedItem(item) {
      const title = `${item.frontendId ? `${item.frontendId}. ` : ""}${item.titleCn}`;
      const classes = [
        "leetcode-related-item",
        item.current ? "is-current" : "",
        item.inBook ? "is-in-book" : "",
      ].filter(Boolean).join(" ");
      const content = `
        <span class="leetcode-related-title">${escapeHtml(title)}</span>
        <span class="leetcode-related-meta">${renderRelatedMeta(item)}</span>
      `;
      if (item.current) {
        return `<span class="${classes}">${content}</span>`;
      }
      if (item.inBook) {
        return `
          <button
            type="button"
            class="${classes}"
            data-open-related="${escapeHtml(item.titleSlug)}"
          >
            ${content}
          </button>
        `;
      }
      return `
        <a
          class="${classes}"
          href="${escapeHtml(item.url)}"
          target="_blank"
          rel="noopener noreferrer"
        >
          ${content}
        </a>
      `;
    }

    function renderRelatedSection(title, items) {
      if (!items?.length) return "";
      return `
        <span class="leetcode-popover-section">
          <strong>${escapeHtml(title)}</strong>
          <span class="leetcode-related-list">
            ${items.map(renderRelatedItem).join("")}
          </span>
        </span>
      `;
    }

    function renderRelatedQuestions(problem) {
      const related = problem.relatedQuestions || {};
      if (!related.total) {
        return '<span class="leetcode-popover-muted">暂无已同步的相关题。</span>';
      }
      return `
        <span class="leetcode-popover-lead">
          ${isChinesePage
            ? "优先看同系列题，再看力扣官方相关题，最后用同路线高频题补齐模式。"
            : "Start with the same series, then official related problems, then high-frequency peers on the same track."}
        </span>
        ${renderRelatedSection(isChinesePage ? "系列题目" : "Series", related.series)}
        ${renderRelatedSection(isChinesePage ? "力扣相关" : "LeetCode related", related.official)}
        ${renderRelatedSection(isChinesePage ? "同路线高频" : "Same-track high frequency", related.topicPeers)}
      `;
    }

    function implementationTracks(problem) {
      const tags = new Set(problem.tags.map((tag) => tag.slug));
      const tracks = [];
      if (tags.has("hash-table")) tracks.push(["哈希表", "先写清 key/value 语义，再确认写入时机和重复值处理。"]);
      if (tags.has("two-pointers")) tracks.push(["双指针", "用区间不变量解释每次移动能排除哪一批候选答案。"]);
      if (tags.has("sliding-window")) tracks.push(["滑动窗口", "维护窗口内计数或约束，右端扩张、左端按条件单调收缩。"]);
      if (tags.has("dynamic-programming")) tracks.push(["动态规划", "先定义状态和转移，再检查是否能滚动压缩空间。"]);
      if (tags.has("stack") || tags.has("monotonic-stack")) tracks.push(["栈/单调栈", "栈里保存尚未确定答案的元素，出栈时一次性结算贡献。"]);
      if (tags.has("binary-search")) tracks.push(["二分", "明确单调谓词，使用左闭右闭或左闭右开一种模板到底。"]);
      if (tags.has("tree") || tags.has("binary-tree")) tracks.push(["树遍历", "先确定递归返回值，再决定前序、后序或层序。"]);
      if (tags.has("graph")) tracks.push(["图搜索", "建图、访问状态和队列/栈边界分开写，避免重复入队。"]);
      if (!tracks.length) tracks.push(["主解法", "先按题面约束写出可讲清楚的不变量，再做复杂度优化。"]);
      return tracks.slice(0, 4);
    }

    function implementationProvenanceLabel(provenance) {
      if (provenance === "my-recent-accepted-submission") return "我的提交";
      if (provenance === "optimized") return "已优化";
      if (provenance === "external-reference") return "授权参考";
      return "生成参考";
    }

    function isCppReference(reference) {
      return reference.language === "C++" || reference.language === "C++17";
    }

    function implementationReferencesForDisplay(problem) {
      const references = problem.implementationReferences || [];
      const cppReferences = references.filter(isCppReference);
      return cppReferences.length ? cppReferences : references;
    }

    function renderImplementationCode(reference) {
      const code = highlightCode(reference.code, reference.language);
      return `
        <span class="leetcode-implementation-card">
          <span class="leetcode-implementation-meta">
            ${reference.approachTitle ? `<span>${escapeHtml(reference.approachTitle)}</span>` : ""}
            <span>${escapeHtml(implementationProvenanceLabel(reference.provenance))}</span>
            <span>${escapeHtml(reference.language)}</span>
            ${reference.status ? `<span>${escapeHtml(reference.status)}</span>` : ""}
            ${reference.submittedAt ? `<span>${escapeHtml(reference.submittedAt)}</span>` : ""}
            ${reference.runtime ? `<span>${escapeHtml(reference.runtime)}</span>` : ""}
            ${reference.memory ? `<span>${escapeHtml(reference.memory)}</span>` : ""}
            ${reference.complexity ? `<span>${escapeHtml(reference.complexity)}</span>` : ""}
            ${reference.license ? `<span>${escapeHtml(reference.license)}</span>` : ""}
            ${reference.modified ? "<span>已按本页风格整理</span>" : ""}
            <a
              href="${escapeHtml(reference.sourceUrl)}"
              target="_blank"
              rel="noopener noreferrer"
              class="leetcode-source-link"
            >
              来源
            </a>
          </span>
          <pre class="leetcode-code-block"><code class="language-${escapeHtml(languageKey(reference.language))}">${code}</code></pre>
        </span>
      `;
    }

    function renderImplementationReference(problem) {
      const tracks = implementationTracks(problem);
      const references = implementationReferencesForDisplay(problem);
      const allReferences = problem.implementationReferences || [];
      const cppReferences = allReferences.filter(isCppReference);
      const lead = references.length
        ? cppReferences.length
          ? `C++ reference implementation 已同步 ${cppReferences.length} 份；我的通过提交优先，其余按公开授权题解和本页生成参考补齐。`
          : `这题没有可用 C++ reference，展示与官方题型匹配的 ${references.map((item) => item.language).join(" / ")} 实现。`
        : allReferences.length
          ? `这题暂时只有 ${allReferences.length} 份非 C++ 历史提交；C++ reference implementation 待同步。`
        : "Reference implementation 待同步最近提交。当前先展示面试实现顺序；最终代码会标记为「我的提交」「已优化」或「生成参考」。";
      return `
        <span class="leetcode-popover-lead">
          ${escapeHtml(lead)}
        </span>
        ${
          references.length
            ? `<span class="leetcode-popover-section">
                <strong>参考实现</strong>
                ${references.map(renderImplementationCode).join("")}
              </span>`
            : ""
        }
        <span class="leetcode-popover-section">
          <strong>建议展开顺序</strong>
          ${tracks
            .map(
              ([name, detail], index) => `
                <span class="leetcode-check">
                  <em>${index + 1}. ${escapeHtml(name)}</em>
                  <span>${escapeHtml(detail)}</span>
                </span>
              `,
            )
            .join("")}
        </span>
        ${renderStudyChecks(problem)}
        ${renderCompanyFollowUps(problem)}
      `;
    }

    function draftFor(problem) {
      return editorDrafts[problem.titleSlug] || {};
    }

    function normalizeLangSlug(lang) {
      return lang === "go" ? "golang" : lang;
    }

    function editorLanguages(problem) {
      const templates = problem.codeTemplates || [];
      if (!templates.length) return fallbackLanguages;
      const seen = new Set();
      return templates
        .filter((template) => {
          if (seen.has(template.langSlug)) return false;
          seen.add(template.langSlug);
          return true;
        })
        .map((template) => [template.langSlug, template.lang]);
    }

    function preferredLang(problem, draftLang) {
      const languages = editorLanguages(problem);
      const normalized = normalizeLangSlug(draftLang || "");
      if (languages.some(([langSlug]) => langSlug === normalized)) {
        return normalized;
      }
      return (
        preferredLanguageOrder.find((langSlug) =>
          languages.some(([item]) => item === langSlug),
        ) ||
        languages[0]?.[0] ||
        "cpp"
      );
    }

    function officialTemplate(problem, lang) {
      const normalized = normalizeLangSlug(lang);
      return (
        problem.codeTemplates?.find((template) => template.langSlug === normalized)
          ?.code || ""
      );
    }

    function fallbackTemplate(problem, lang) {
      const heading = `${problem.frontendId}. ${problem.titleCn}`;
      if (lang === "python3") {
        return `# ${heading}\n# Official signature is unavailable locally; start from this minimal shell.\nclass Solution:\n    pass\n`;
      }
      if (lang === "go" || lang === "golang") {
        return `// ${heading}\n// Official signature is unavailable locally; start from this minimal shell.\npackage main\n`;
      }
      if (lang === "java") {
        return `// ${heading}\n// Official signature is unavailable locally; start from this minimal shell.\nclass Solution {\n}\n`;
      }
      if (lang === "typescript") {
        return `// ${heading}\n// Official signature is unavailable locally; start from this minimal shell.\n`;
      }
      return `// ${heading}\n// Official signature is unavailable locally; start from this minimal shell.\nclass Solution {\npublic:\n};\n`;
    }

    function defaultTemplate(problem, lang) {
      return officialTemplate(problem, lang) || fallbackTemplate(problem, lang);
    }

    function lineIndexAtPosition(code, position) {
      return String(code).slice(0, Math.max(0, position)).split("\n").length - 1;
    }

    function leadingWhitespace(value) {
      return String(value).match(/^[\t ]*/)?.[0] || "";
    }

    function implementationBlankLinePosition(code) {
      const lines = String(code).split("\n");
      let offset = 0;
      let best = null;
      lines.forEach((line) => {
        if (/^[\t ]+$/.test(line)) {
          const indent = leadingWhitespace(line).length;
          if (!best || indent > best.indent) {
            best = { indent, position: offset + indent };
          }
        }
        offset += line.length + 1;
      });
      return best?.position ?? -1;
    }

    function closingBodyLinePosition(code) {
      const lines = String(code).split("\n");
      let offset = 0;
      const starts = [];
      lines.forEach((line) => {
        starts.push(offset);
        offset += line.length + 1;
      });
      for (let index = 1; index < lines.length; index += 1) {
        const previous = lines[index - 1];
        const current = lines[index].trimStart();
        const isClosing =
          current.startsWith("}") ||
          current.startsWith("]") ||
          current.startsWith(")") ||
          current.startsWith(".") ||
          current === "end";
        if (previous.trim() === "" && isClosing) {
          const indent = leadingWhitespace(lines[index]).length;
          return starts[index - 1] + Math.min(indent, previous.length);
        }
      }
      return -1;
    }

    function implementationCaretPosition(code, lang) {
      const blankLine = implementationBlankLinePosition(code);
      if (blankLine !== -1) return blankLine;
      const closingLine = closingBodyLinePosition(code);
      if (closingLine !== -1) return closingLine;
      const key = languageKey(lang);
      if (key === "python") {
        const colon = String(code).indexOf(":\n");
        return colon === -1 ? String(code).length : colon + 2 + editorIndentUnit.length;
      }
      const brace = String(code).indexOf("{\n");
      return brace === -1 ? String(code).length : brace + 2 + editorIndentUnit.length;
    }

    function placeEditorCaretAtImplementation(textarea, context) {
      if (!(textarea instanceof HTMLTextAreaElement) || !context) return;
      const defaultCode = defaultTemplate(context.problem, context.lang);
      if (textarea.value !== defaultCode) return;
      const position = Math.min(
        textarea.value.length,
        implementationCaretPosition(textarea.value, context.lang),
      );
      textarea.setSelectionRange(position, position);
      const lineIndex = lineIndexAtPosition(textarea.value, position);
      const lineHeight = editorLineHeight(textarea);
      textarea.scrollTop = Math.max(0, (lineIndex - 2) * lineHeight);
      syncEditorHighlight(context.panel, textarea, context.lang);
    }

    function editorHighlightHtml(code, lang) {
      return highlightCode(code, lang);
    }

    function editorLineNumbersText(code) {
      const lineCount = Math.max(1, String(code).split("\n").length);
      return Array.from({ length: lineCount }, (_, index) => String(index + 1)).join("\n");
    }

    function editorLineCount(textarea) {
      return Math.max(1, String(textarea.value || "").split("\n").length);
    }

    function editorLineHeight(textarea) {
      const style = window.getComputedStyle(textarea);
      const lineHeight = Number.parseFloat(style.lineHeight);
      if (Number.isFinite(lineHeight)) return lineHeight;
      const fontSize = Number.parseFloat(style.fontSize);
      return Number.isFinite(fontSize) ? fontSize * 1.55 : 20;
    }

    function editorVerticalPadding(textarea) {
      const style = window.getComputedStyle(textarea);
      const top = Number.parseFloat(style.paddingTop);
      const bottom = Number.parseFloat(style.paddingBottom);
      return (Number.isFinite(top) ? top : 0) + (Number.isFinite(bottom) ? bottom : 0);
    }

    function editorPaddingTop(textarea) {
      const value = Number.parseFloat(window.getComputedStyle(textarea).paddingTop);
      return Number.isFinite(value) ? value : 0;
    }

    function editorCaretLineIndex(textarea) {
      const position = Math.max(0, textarea.selectionStart || 0);
      return textarea.value.slice(0, position).split("\n").length - 1;
    }

    function editorBottomGuard() {
      const viewportHeight = window.innerHeight || document.documentElement.clientHeight || 0;
      return Math.min(
        editorCaretBottomGuardMax,
        Math.max(editorCaretBottomGuardMin, viewportHeight * editorCaretBottomGuardRatio),
      );
    }

    function revealEditorCaret(textarea, behavior = "auto") {
      if (!(textarea instanceof HTMLTextAreaElement)) return;
      const rect = textarea.getBoundingClientRect();
      const lineHeight = editorLineHeight(textarea);
      const caretTop =
        rect.top +
        editorPaddingTop(textarea) +
        editorCaretLineIndex(textarea) * lineHeight -
        textarea.scrollTop;
      const caretBottom = caretTop + lineHeight;
      const viewportHeight = window.innerHeight || document.documentElement.clientHeight || 0;
      const bottomLimit = viewportHeight - editorBottomGuard();
      let delta = 0;
      if (caretBottom > bottomLimit) {
        delta = caretBottom - bottomLimit;
      } else if (caretTop < editorCaretTopGuard) {
        delta = caretTop - editorCaretTopGuard;
      }
      if (Math.abs(delta) < 1) return;
      window.scrollBy({ top: delta, behavior });
    }

    function scheduleEditorCaretReveal(textarea, behavior = "auto") {
      window.requestAnimationFrame(() => revealEditorCaret(textarea, behavior));
    }

    function syncEditorHeight(panel, textarea) {
      const shell = panel?.querySelector(".leetcode-editor-shell");
      if (!(shell instanceof HTMLElement)) return;
      const visibleLines = editorAutoGrow
        ? Math.min(
            editorMaxAutoVisibleLines,
            editorLineCount(textarea) + editorExtraVisibleLines,
          )
        : editorFixedVisibleLines;
      const height = Math.ceil(
        visibleLines * editorLineHeight(textarea) + editorVerticalPadding(textarea),
      );
      shell.style.setProperty("--leetcode-editor-height", `${height}px`);
      if (editorAutoGrow) shell.style.height = "";
      shell.classList.toggle("is-fixed-height", !editorAutoGrow);
      textarea.style.overflowY =
        editorAutoGrow && editorLineCount(textarea) < editorMaxAutoVisibleLines
          ? "hidden"
          : "auto";
    }

    function syncEditorHighlight(panel, textarea, lang) {
      const highlight = panel?.querySelector(".leetcode-editor-highlight");
      const code = highlight?.querySelector("code");
      const lineNumbers = panel?.querySelector(".leetcode-editor-lines");
      syncEditorHeight(panel, textarea);
      if (code) {
        code.innerHTML = editorHighlightHtml(textarea.value, lang);
      }
      if (lineNumbers instanceof HTMLElement) {
        lineNumbers.textContent = editorLineNumbersText(textarea.value);
        lineNumbers.scrollTop = textarea.scrollTop;
      }
      if (highlight instanceof HTMLElement) {
        highlight.scrollTop = textarea.scrollTop;
        highlight.scrollLeft = textarea.scrollLeft;
      }
    }

    function syncRenderedEditors() {
      list?.querySelectorAll("[data-editor-code]").forEach((textarea) => {
        if (!(textarea instanceof HTMLTextAreaElement)) return;
        const context = editorContextFor(textarea);
        if (!context) return;
        syncEditorHighlight(context.panel, textarea, context.lang);
      });
    }

    function editorContextFor(textarea) {
      const slug = textarea.dataset.editorCode || "";
      const panel = textarea.closest(".leetcode-practice-panel");
      const select = panel?.querySelector("[data-editor-lang]");
      const problem = problems.find((item) => item.titleSlug === slug);
      if (!problem) return null;
      const lang =
        select instanceof HTMLSelectElement
          ? preferredLang(problem, select.value)
          : preferredLang(problem, editorDrafts[slug]?.lang);
      return { lang, panel, problem, slug };
    }

    function persistEditorTextarea(textarea) {
      if (rollEditorDraftsForToday()) {
        state.expandedSlug = "";
        render();
        return;
      }
      const context = editorContextFor(textarea);
      if (!context) return;
      editorDrafts[context.slug] = { lang: context.lang, code: textarea.value };
      syncEditorHighlight(context.panel, textarea, context.lang);
      writeState();
      scheduleViewStateWrite();
      scheduleEditorCaretReveal(textarea);
    }

    function replaceTextareaRange(textarea, start, end, value, nextStart, nextEnd = nextStart) {
      textarea.setRangeText(value, start, end, "preserve");
      textarea.selectionStart = nextStart;
      textarea.selectionEnd = nextEnd;
      persistEditorTextarea(textarea);
    }

    function lineBounds(value, position) {
      const start = value.lastIndexOf("\n", Math.max(0, position - 1)) + 1;
      const nextBreak = value.indexOf("\n", position);
      const end = nextBreak === -1 ? value.length : nextBreak;
      return {
        afterCursor: value.slice(position, end),
        beforeCursor: value.slice(start, position),
        end,
        start,
        text: value.slice(start, end),
      };
    }

    function lineIndent(line) {
      return line.match(/^[\t ]*/)?.[0] || "";
    }

    function shouldIncreaseIndent(beforeCursor, lang) {
      const trimmed = beforeCursor.trimEnd();
      if (!trimmed) return false;
      if (/[\{\[\(]$/.test(trimmed)) return true;
      if (languageKey(lang) === "python" && /:\s*(#.*)?$/.test(trimmed)) {
        return true;
      }
      return false;
    }

    function startsWithClosingToken(text) {
      return /^[\t ]*[\}\]\)]/.test(text);
    }

    function removeOneIndent(value) {
      if (value.startsWith("\t")) return value.slice(1);
      const spaces = value.match(/^ {1,4}/)?.[0] || "";
      return value.slice(spaces.length);
    }

    function handleEditorEnter(event, textarea, context) {
      const value = textarea.value;
      const start = textarea.selectionStart;
      const end = textarea.selectionEnd;
      const bounds = lineBounds(value, start);
      const baseIndent = lineIndent(bounds.beforeCursor);
      const extraIndent = shouldIncreaseIndent(bounds.beforeCursor, context.lang)
        ? editorIndentUnit
        : "";
      const shouldSplitPair = extraIndent && startsWithClosingToken(bounds.afterCursor);
      const insertion = shouldSplitPair
        ? `\n${baseIndent}${extraIndent}\n${baseIndent}`
        : `\n${baseIndent}${extraIndent}`;
      const nextPosition = start + 1 + baseIndent.length + extraIndent.length;
      event.preventDefault();
      replaceTextareaRange(textarea, start, end, insertion, nextPosition);
    }

    function editorSelectionFocus(textarea) {
      if (textarea.selectionStart === textarea.selectionEnd) return textarea.selectionStart;
      return textarea.selectionDirection === "backward"
        ? textarea.selectionStart
        : textarea.selectionEnd;
    }

    function editorSelectionAnchor(textarea) {
      if (textarea.selectionStart === textarea.selectionEnd) return textarea.selectionEnd;
      return textarea.selectionDirection === "backward"
        ? textarea.selectionEnd
        : textarea.selectionStart;
    }

    function firstCodePositionInLine(value, start, end) {
      const offset = value.slice(start, end).search(/\S/);
      return offset === -1 ? start : start + offset;
    }

    function isEditorSmartLineSelectShortcut(event) {
      return (
        event.metaKey &&
        event.shiftKey &&
        !event.altKey &&
        !event.ctrlKey &&
        event.key === "ArrowLeft"
      );
    }

    function isEditorSmartLineStartShortcut(event) {
      return (
        event.metaKey &&
        !event.shiftKey &&
        !event.altKey &&
        !event.ctrlKey &&
        event.key === "ArrowLeft"
      );
    }

    function smartLineStartPosition(value, position) {
      const bounds = lineBounds(value, position);
      const codeStart = firstCodePositionInLine(value, bounds.start, bounds.end);
      return position > codeStart ? codeStart : bounds.start;
    }

    function handleEditorSmartLineStart(event, textarea) {
      if (!isEditorSmartLineStartShortcut(event)) return false;
      const nextPosition = smartLineStartPosition(
        textarea.value,
        editorSelectionFocus(textarea),
      );
      event.preventDefault();
      textarea.setSelectionRange(nextPosition, nextPosition);
      scheduleViewStateWrite();
      scheduleEditorCaretReveal(textarea);
      return true;
    }

    function handleEditorSmartLineSelect(event, textarea) {
      if (!isEditorSmartLineSelectShortcut(event)) return false;
      const value = textarea.value;
      const focus = editorSelectionFocus(textarea);
      const anchor = editorSelectionAnchor(textarea);
      const nextFocus = smartLineStartPosition(value, focus);
      const selectionStart = Math.min(anchor, nextFocus);
      const selectionEnd = Math.max(anchor, nextFocus);
      const direction = nextFocus < anchor ? "backward" : "forward";
      event.preventDefault();
      textarea.setSelectionRange(selectionStart, selectionEnd, direction);
      scheduleViewStateWrite();
      scheduleEditorCaretReveal(textarea);
      return true;
    }

    function isPlainEditorTypingEvent(event) {
      return !event.metaKey && !event.altKey && !event.ctrlKey;
    }

    function isEditorQuoteToken(token) {
      return token === '"' || token === "'" || token === "`";
    }

    function isEditorWordToken(token) {
      return /[\p{L}\p{N}_$]/u.test(token || "");
    }

    function handleEditorAutoPair(event, textarea) {
      if (!isPlainEditorTypingEvent(event)) return false;
      const closer = editorAutoPairs.get(event.key);
      if (!closer) return false;
      const value = textarea.value;
      const start = textarea.selectionStart;
      const end = textarea.selectionEnd;
      if (
        start === end &&
        isEditorQuoteToken(event.key) &&
        (isEditorWordToken(value[start - 1]) || isEditorWordToken(value[start]))
      ) {
        return false;
      }
      event.preventDefault();
      replaceTextareaRange(
        textarea,
        start,
        end,
        `${event.key}${value.slice(start, end)}${closer}`,
        start + 1,
        end > start ? end + 1 : start + 1,
      );
      return true;
    }

    function handleEditorClosingPairSkip(event, textarea) {
      if (!isPlainEditorTypingEvent(event)) return false;
      if (!editorAutoPairClosers.has(event.key)) return false;
      if (textarea.selectionStart !== textarea.selectionEnd) return false;
      if (textarea.value[textarea.selectionStart] !== event.key) return false;
      event.preventDefault();
      textarea.selectionStart += 1;
      textarea.selectionEnd = textarea.selectionStart;
      scheduleViewStateWrite();
      return true;
    }

    function handleEditorEmptyPairBackspace(event, textarea) {
      if (!isPlainEditorTypingEvent(event)) return false;
      if (event.key !== "Backspace") return false;
      if (textarea.selectionStart !== textarea.selectionEnd) return false;
      const start = textarea.selectionStart;
      if (start < 1) return false;
      const opener = textarea.value[start - 1];
      const closer = textarea.value[start];
      if (!editorAutoPairOpeners.has(opener) || editorAutoPairs.get(opener) !== closer) {
        return false;
      }
      event.preventDefault();
      replaceTextareaRange(textarea, start - 1, start + 1, "", start - 1);
      return true;
    }

    function editorIndentColumn(text) {
      let column = 0;
      for (const token of String(text)) {
        if (token === "\t") {
          const remainder = column % editorIndentUnit.length;
          column += remainder === 0 ? editorIndentUnit.length : editorIndentUnit.length - remainder;
        } else {
          column += 1;
        }
      }
      return column;
    }

    function editorBackspaceIndentStart(prefix) {
      const currentColumn = editorIndentColumn(prefix);
      if (currentColumn <= 0) return prefix.length;
      const remainder = currentColumn % editorIndentUnit.length;
      const previousStop =
        remainder === 0
          ? currentColumn - editorIndentUnit.length
          : currentColumn - remainder;
      let column = 0;
      for (let index = 0; index < prefix.length; index += 1) {
        const token = prefix[index];
        const nextColumn =
          token === "\t"
            ? column +
              (column % editorIndentUnit.length === 0
                ? editorIndentUnit.length
                : editorIndentUnit.length - (column % editorIndentUnit.length))
            : column + 1;
        if (nextColumn > previousStop) return index;
        column = nextColumn;
      }
      return prefix.length;
    }

    function handleEditorIndentBackspace(event, textarea) {
      if (!isPlainEditorTypingEvent(event)) return false;
      if (event.key !== "Backspace") return false;
      if (textarea.selectionStart !== textarea.selectionEnd) return false;
      const start = textarea.selectionStart;
      const bounds = lineBounds(textarea.value, start);
      if (!/^[\t ]+$/.test(bounds.beforeCursor)) return false;
      const deleteStart =
        bounds.start + editorBackspaceIndentStart(bounds.beforeCursor);
      if (deleteStart >= start) return false;
      event.preventDefault();
      replaceTextareaRange(textarea, deleteStart, start, "", deleteStart);
      return true;
    }

    function indentTextareaSelection(textarea) {
      const value = textarea.value;
      const start = textarea.selectionStart;
      const end = textarea.selectionEnd;
      if (start === end) {
        replaceTextareaRange(
          textarea,
          start,
          end,
          editorIndentUnit,
          start + editorIndentUnit.length,
        );
        return;
      }

      const blockStart = value.lastIndexOf("\n", Math.max(0, start - 1)) + 1;
      const nextBreak = value.indexOf("\n", end);
      const blockEnd = nextBreak === -1 ? value.length : nextBreak;
      const block = value.slice(blockStart, blockEnd);
      const lineCount = block.split("\n").length;
      const replacement = block.replace(/^/gm, editorIndentUnit);
      replaceTextareaRange(
        textarea,
        blockStart,
        blockEnd,
        replacement,
        start + editorIndentUnit.length,
        end + editorIndentUnit.length * lineCount,
      );
    }

    function outdentTextareaSelection(textarea) {
      const value = textarea.value;
      const start = textarea.selectionStart;
      const end = textarea.selectionEnd;
      const blockStart = value.lastIndexOf("\n", Math.max(0, start - 1)) + 1;
      const nextBreak = value.indexOf("\n", end);
      const blockEnd = nextBreak === -1 ? value.length : nextBreak;
      const block = value.slice(blockStart, blockEnd);
      let nextStart = start;
      let nextEnd = end;
      let cursor = blockStart;
      const replacement = block
        .split("\n")
        .map((line) => {
          const removed = line.length - removeOneIndent(line).length;
          if (cursor < start) {
            nextStart -= Math.min(removed, start - cursor);
          }
          if (cursor < end) {
            nextEnd -= Math.min(removed, Math.max(0, end - cursor));
          }
          cursor += line.length + 1;
          return removeOneIndent(line);
        })
        .join("\n");
      replaceTextareaRange(textarea, blockStart, blockEnd, replacement, nextStart, nextEnd);
    }

    function editorLineCommentPrefix(lang) {
      const grammar = highlightGrammarByLanguage[languageKey(lang)] || {};
      const comments = grammar.comments || [];
      if (comments.includes("sql")) return "-- ";
      if (comments.includes("semicolon")) return "; ";
      if (comments.includes("percent")) return "% ";
      if (comments.includes("hash") && !comments.includes("slash")) return "# ";
      return "// ";
    }

    function lineCommentRemovalLength(line, prefix) {
      const indent = lineIndent(line);
      const rest = line.slice(indent.length);
      const marker = prefix.trimEnd();
      if (!rest.startsWith(marker)) return 0;
      return marker.length + (rest[marker.length] === " " ? 1 : 0);
    }

    function lineHasCommentPrefix(line, prefix) {
      return lineCommentRemovalLength(line, prefix) > 0;
    }

    function selectedEditorLineRange(value, start, end) {
      const effectiveEnd =
        end > start && end > 0 && value[end - 1] === "\n" ? end - 1 : end;
      const blockStart = value.lastIndexOf("\n", Math.max(0, start - 1)) + 1;
      const nextBreak = value.indexOf("\n", effectiveEnd);
      return {
        end: nextBreak === -1 ? value.length : nextBreak,
        start: blockStart,
      };
    }

    function positionAfterLineCommentChanges(position, changes) {
      let next = position;
      let totalDelta = 0;
      for (const change of changes) {
        const start = change.start;
        const end = start + change.removedLength;
        const delta = change.insertedLength - change.removedLength;
        const adjustedStart = start + totalDelta;
        if (position < start) break;
        if (change.removedLength > 0 && position <= end) {
          return adjustedStart + change.insertedLength;
        }
        if (position >= start) {
          next += delta;
        }
        totalDelta += delta;
      }
      return next;
    }

    function toggleTextareaLineComment(textarea, lang) {
      const value = textarea.value;
      const start = textarea.selectionStart;
      const end = textarea.selectionEnd;
      const prefix = editorLineCommentPrefix(lang);
      const range = selectedEditorLineRange(value, start, end);
      const block = value.slice(range.start, range.end);
      const lines = block.split("\n");
      const nonBlankLines = lines.filter((line) => line.trim());
      const shouldUncomment =
        nonBlankLines.length > 0 &&
        nonBlankLines.every((line) => lineHasCommentPrefix(line, prefix));
      const changes = [];
      let cursor = range.start;
      const replacement = lines
        .map((line) => {
          const lineStart = cursor;
          cursor += line.length + 1;
          if (shouldUncomment) {
            const indent = lineIndent(line);
            const removalLength = lineCommentRemovalLength(line, prefix);
            if (!removalLength) return line;
            changes.push({
              insertedLength: 0,
              removedLength: removalLength,
              start: lineStart + indent.length,
            });
            return indent + line.slice(indent.length + removalLength);
          }
          if (!line.trim() && lines.length > 1) return line;
          const indent = lineIndent(line);
          changes.push({
            insertedLength: prefix.length,
            removedLength: 0,
            start: lineStart + indent.length,
          });
          return indent + prefix + line.slice(indent.length);
        })
        .join("\n");
      if (!changes.length) return false;
      replaceTextareaRange(
        textarea,
        range.start,
        range.end,
        replacement,
        positionAfterLineCommentChanges(start, changes),
        positionAfterLineCommentChanges(end, changes),
      );
      return true;
    }

    function handleEditorClosingToken(event, textarea) {
      if (!editorClosingTokens.has(event.key)) return false;
      if (textarea.selectionStart !== textarea.selectionEnd) return false;
      const value = textarea.value;
      const start = textarea.selectionStart;
      const bounds = lineBounds(value, start);
      if (!/^[\t ]+$/.test(bounds.beforeCursor)) return false;
      const nextIndent = removeOneIndent(bounds.beforeCursor);
      event.preventDefault();
      replaceTextareaRange(
        textarea,
        bounds.start,
        start,
        `${nextIndent}${event.key}`,
        bounds.start + nextIndent.length + 1,
      );
      return true;
    }

    function isEditorRunShortcut(event) {
      return (
        event.metaKey &&
        !event.altKey &&
        !event.ctrlKey &&
        !event.shiftKey &&
        (event.key === "'" || event.code === "Quote")
      );
    }

    function isEditorSubmitShortcut(event) {
      return (
        event.metaKey &&
        !event.altKey &&
        !event.ctrlKey &&
        !event.shiftKey &&
        event.key === "Enter"
      );
    }

    function isEditorOpenLeetcodeShortcut(event) {
      return (
        event.metaKey &&
        event.shiftKey &&
        !event.altKey &&
        !event.ctrlKey &&
        event.code === "KeyL"
      );
    }

    function isEditorToggleCommentShortcut(event) {
      return (
        event.metaKey &&
        !event.altKey &&
        !event.ctrlKey &&
        !event.shiftKey &&
        (event.key === "/" || event.code === "Slash")
      );
    }

    function isEditorResetCurrentShortcut(event) {
      return (
        event.metaKey &&
        event.altKey &&
        !event.ctrlKey &&
        !event.shiftKey &&
        event.code === "KeyR"
      );
    }

    function isEditorResetAllShortcut(event) {
      return (
        event.metaKey &&
        event.altKey &&
        event.shiftKey &&
        !event.ctrlKey &&
        event.code === "KeyR"
      );
    }

    function isRestartProblemTimerShortcut(event) {
      return (
        event.metaKey &&
        event.altKey &&
        !event.ctrlKey &&
        !event.shiftKey &&
        event.code === "KeyT"
      );
    }

    function isResetSessionShortcut(event) {
      return (
        event.metaKey &&
        event.altKey &&
        event.shiftKey &&
        !event.ctrlKey &&
        event.code === "KeyS"
      );
    }

    function isFlowModeShortcut(event) {
      return (
        event.metaKey &&
        event.altKey &&
        !event.ctrlKey &&
        !event.shiftKey &&
        event.code === "KeyF"
      );
    }

    function isSuggestedFlowShortcut(event) {
      return (
        event.metaKey &&
        event.altKey &&
        event.shiftKey &&
        !event.ctrlKey &&
        event.code === "KeyF"
      );
    }

    function isClearProblemRecordShortcut(event) {
      return (
        event.metaKey &&
        event.altKey &&
        event.shiftKey &&
        !event.ctrlKey &&
        event.code === "KeyT"
      );
    }

    function isCopyCurrentEditorShortcut(event) {
      return (
        event.metaKey &&
        event.altKey &&
        !event.ctrlKey &&
        !event.shiftKey &&
        event.code === "KeyC"
      );
    }

    function isToggleEditorHeightShortcut(event) {
      return (
        event.metaKey &&
        event.altKey &&
        !event.ctrlKey &&
        !event.shiftKey &&
        event.code === "KeyH"
      );
    }

    function isFocusEditorLanguageShortcut(event) {
      return (
        event.metaKey &&
        event.altKey &&
        !event.ctrlKey &&
        !event.shiftKey &&
        event.code === "KeyL"
      );
    }

    function progressShortcutAction(event) {
      if (!event.metaKey || !event.altKey || event.ctrlKey || event.shiftKey) return "";
      if (event.code === "KeyD") return "done";
      if (event.code === "KeyS") return "review";
      if (event.code === "KeyM") return "mastered";
      return "";
    }

    function filterShortcut(event) {
      if (!event.altKey || event.metaKey || event.ctrlKey || event.shiftKey) return "";
      return filterShortcutByCode[event.code] || "";
    }

    function pageEdgeShortcut(event) {
      if (!event.altKey || event.metaKey || event.ctrlKey || event.shiftKey) return "";
      if (event.key === "ArrowLeft") return "first";
      if (event.key === "ArrowRight") return "last";
      return "";
    }

    function isSearchFocusShortcut(event) {
      return (
        !event.metaKey &&
        !event.altKey &&
        !event.ctrlKey &&
        !event.shiftKey &&
        event.key === "/"
      );
    }

    function isPageJumpFocusShortcut(event) {
      return (
        event.altKey &&
        !event.metaKey &&
        !event.ctrlKey &&
        !event.shiftKey &&
        event.code === "KeyP"
      );
    }

    function openLeetcodeProblem(problem) {
      if (!problem?.url) return;
      clicked[problem.titleSlug] = true;
      writeState();
      window.open(problem.url, "_blank", "noopener,noreferrer");
    }

    function resetEditorDraft(problem, lang, options = {}) {
      if (!problem) return false;
      const slug = problem.titleSlug;
      const nextLang = preferredLang(problem, lang || editorDrafts[slug]?.lang);
      editorDrafts[slug] = { lang: nextLang, code: defaultTemplate(problem, nextLang) };
      writeState();
      render();
      scheduleViewStateWrite();
      if (options.focus) focusEditorForSlug(slug);
      return true;
    }

    function resetAllEditorDrafts(options = {}) {
      const needsConfirm = options.confirm !== false;
      const message = isChinesePage
        ? "确认重置所有题目的本地代码草稿？做过/思考/熟练和计时不会被清空。"
        : "Reset local code drafts for all problems? Progress and timing stay unchanged.";
      if (needsConfirm && !window.confirm(message)) return false;
      const focusSlug = options.focusSlug || currentPracticeSlug();
      editorDrafts = {};
      writeState();
      render();
      scheduleViewStateWrite();
      if (focusSlug) focusEditorForSlug(focusSlug);
      return true;
    }

    function practiceNavigationDirection(event) {
      if (!event.altKey || event.metaKey || event.ctrlKey || event.shiftKey) return 0;
      if (event.code === "KeyJ" || event.key === "ArrowDown") return 1;
      if (event.code === "KeyK" || event.key === "ArrowUp") return -1;
      return 0;
    }

    function editorActionButton(panel, action) {
      return panel?.querySelector(`[data-editor-action="${action}"]`);
    }

    function currentEditorContext(fallbackSlug = "") {
      const active = document.activeElement;
      if (active instanceof HTMLTextAreaElement && active.dataset.editorCode) {
        return editorContextFor(active);
      }
      const slug = currentPracticeSlug(fallbackSlug);
      const panel = editorPanelForSlug(slug);
      const textarea = panel?.querySelector("[data-editor-code]");
      if (!(textarea instanceof HTMLTextAreaElement)) return null;
      return editorContextFor(textarea);
    }

    function editorFocusSnapshot(slug) {
      const active = document.activeElement;
      if (!(active instanceof HTMLTextAreaElement) || active.dataset.editorCode !== slug) {
        return null;
      }
      return {
        end: active.selectionEnd,
        scrollLeft: active.scrollLeft,
        scrollTop: active.scrollTop,
        slug,
        start: active.selectionStart,
      };
    }

    function restoreEditorFocus(snapshot) {
      if (!snapshot) return;
      window.requestAnimationFrame(() => {
        const panel = editorPanelForSlug(snapshot.slug);
        const textarea = panel?.querySelector("[data-editor-code]");
        if (!(textarea instanceof HTMLTextAreaElement)) return;
        textarea.focus({ preventScroll: true });
        textarea.setSelectionRange(snapshot.start, snapshot.end);
        textarea.scrollTop = snapshot.scrollTop;
        textarea.scrollLeft = snapshot.scrollLeft;
      });
    }

    function toggleProblemProgress(slug, action, options = {}) {
      if (!slug || !action) return false;
      const current = rowState(slug);
      const next = { ...current };
      if (action === "done") {
        next.done = !next.done;
      } else if (action === "review") {
        next.review = !next.review;
        if (next.review) next.mastered = false;
      } else if (action === "mastered") {
        next.mastered = !next.mastered;
        if (next.mastered) {
          next.done = true;
          next.review = false;
        }
      } else {
        return false;
      }
      const focusSnapshot = options.preserveEditorFocus
        ? editorFocusSnapshot(slug)
        : null;
      progress[slug] = next;
      writeState();
      appendPracticeEvent(practiceEventProgressSet, { slug, state: next });
      render();
      restoreEditorFocus(focusSnapshot);
      scheduleViewStateWrite();
      return true;
    }

    function flashCopyButton(actionButton) {
      if (!(actionButton instanceof HTMLElement)) return;
      const originalLabel =
        actionButton.dataset.copyLabel ||
        actionButton.textContent ||
        (isChinesePage ? "复制" : "Copy");
      actionButton.dataset.copyLabel = originalLabel;
      actionButton.textContent = isChinesePage ? "已复制" : "Copied";
      window.setTimeout(() => {
        actionButton.textContent = actionButton.dataset.copyLabel || originalLabel;
      }, 1200);
    }

    function copyEditorCode(textarea, actionButton = null) {
      if (!(textarea instanceof HTMLTextAreaElement)) return false;
      navigator.clipboard?.writeText(textarea.value);
      flashCopyButton(actionButton);
      return true;
    }

    function copyCurrentEditorCode() {
      const context = currentEditorContext(state.expandedSlug || activePracticeTimer.slug);
      if (!context) return false;
      const textarea = context.panel?.querySelector("[data-editor-code]");
      const actionButton = editorActionButton(context.panel, "copy");
      return copyEditorCode(textarea, actionButton);
    }

    function focusCurrentEditorLanguage() {
      const context = currentEditorContext(state.expandedSlug || activePracticeTimer.slug);
      const select = context?.panel?.querySelector("[data-editor-lang]");
      if (!(select instanceof HTMLSelectElement)) return false;
      select.focus({ preventScroll: true });
      return true;
    }

    function syncEditorHeightButtons() {
      list
        ?.querySelectorAll('[data-editor-action="height-mode"]')
        .forEach((button) => {
          button.textContent = `${isChinesePage ? "高度" : "Height"}：${
            editorAutoGrow
              ? (isChinesePage ? "自适应" : "Auto")
              : (isChinesePage ? "固定" : "Fixed")
          }`;
        });
    }

    function toggleEditorHeightMode() {
      editorAutoGrow = !editorAutoGrow;
      localStorage.setItem(editorHeightModeKey, editorAutoGrow ? "auto" : "fixed");
      syncEditorHeightButtons();
      syncRenderedEditors();
      scheduleViewStateWrite();
      return true;
    }

    function handleEditorKeydown(event, textarea) {
      const context = editorContextFor(textarea);
      if (!context) return false;
      const practiceDirection = practiceNavigationDirection(event);
      if (practiceDirection) {
        event.preventDefault();
        navigatePractice(practiceDirection, context.slug);
        return true;
      }
      if (handleEditorSmartLineSelect(event, textarea)) {
        return true;
      }
      if (handleEditorSmartLineStart(event, textarea)) {
        return true;
      }
      if (isEditorRunShortcut(event)) {
        event.preventDefault();
        runLeetcode(
          context.panel,
          editorActionButton(context.panel, "run-leetcode"),
          context.problem,
          textarea,
        );
        return true;
      }
      if (isEditorSubmitShortcut(event)) {
        event.preventDefault();
        submitLeetcode(
          context.panel,
          editorActionButton(context.panel, "submit-leetcode"),
          context.problem,
          textarea,
        );
        return true;
      }
      if (isEditorToggleCommentShortcut(event)) {
        event.preventDefault();
        return toggleTextareaLineComment(textarea, context.lang);
      }
      if (isEditorOpenLeetcodeShortcut(event)) {
        event.preventDefault();
        openLeetcodeProblem(context.problem);
        return true;
      }
      if (isEditorResetAllShortcut(event)) {
        event.preventDefault();
        resetAllEditorDrafts({ focusSlug: context.slug });
        return true;
      }
      if (isEditorResetCurrentShortcut(event)) {
        event.preventDefault();
        resetEditorDraft(context.problem, context.lang, { focus: true });
        return true;
      }
      if (isRestartProblemTimerShortcut(event)) {
        event.preventDefault();
        restartActiveProblemTimer();
        return true;
      }
      if (isResetSessionShortcut(event)) {
        event.preventDefault();
        resetSessionTiming();
        return true;
      }
      if (isClearProblemRecordShortcut(event)) {
        event.preventDefault();
        clearActiveProblemTimingRecord(context.slug);
        return true;
      }
      if (isCopyCurrentEditorShortcut(event)) {
        event.preventDefault();
        copyEditorCode(textarea, editorActionButton(context.panel, "copy"));
        return true;
      }
      if (isFocusEditorLanguageShortcut(event)) {
        event.preventDefault();
        focusCurrentEditorLanguage();
        return true;
      }
      if (isToggleEditorHeightShortcut(event)) {
        event.preventDefault();
        toggleEditorHeightMode();
        return true;
      }
      const progressAction = progressShortcutAction(event);
      if (progressAction) {
        event.preventDefault();
        toggleProblemProgress(context.slug, progressAction, {
          preserveEditorFocus: true,
        });
        return true;
      }
      if (handleEditorClosingPairSkip(event, textarea)) {
        return true;
      }
      if (handleEditorAutoPair(event, textarea)) {
        return true;
      }
      if (handleEditorEmptyPairBackspace(event, textarea)) {
        return true;
      }
      if (handleEditorIndentBackspace(event, textarea)) {
        return true;
      }
      if (event.key === "Enter") {
        handleEditorEnter(event, textarea, context);
        return true;
      }
      if (event.key === "Tab") {
        event.preventDefault();
        if (event.shiftKey) {
          outdentTextareaSelection(textarea);
        } else {
          indentTextareaSelection(textarea);
        }
        return true;
      }
      return handleEditorClosingToken(event, textarea);
    }

    function openShortcutHelp() {
      if (!(shortcutHelp instanceof HTMLElement)) return;
      shortcutHelp.scrollIntoView({ block: "center", behavior: "smooth" });
      shortcutHelp.focus({ preventScroll: true });
    }

    function closeShortcutHelp() {
      const active = document.activeElement;
      if (!(active instanceof HTMLElement)) return;
      document.querySelectorAll(".leetcode-shortcut-tip").forEach((tip) => {
        if (tip instanceof HTMLElement && tip.contains(active)) active.blur();
      });
    }

    function clearPreviewHoverCloseTimer() {
      if (!previewHoverCloseTimer) return;
      window.clearTimeout(previewHoverCloseTimer);
      previewHoverCloseTimer = 0;
    }

    function closePreviewPopovers(except = null) {
      clearPreviewHoverCloseTimer();
      list?.querySelectorAll("[data-preview].is-open").forEach((item) => {
        if (item === except) return;
        item.classList.remove("is-open");
        item.classList.remove("is-popover-above");
        item.setAttribute("aria-expanded", "false");
      });
      list?.querySelectorAll("[data-preview].is-hover-open").forEach((item) => {
        if (item === except) return;
        item.classList.remove("is-hover-open");
        item.classList.remove("is-popover-above");
      });
      const active = document.activeElement;
      if (active instanceof HTMLElement) {
        const activePreview = active.closest("[data-preview]");
        if (activePreview instanceof HTMLElement && activePreview !== except) {
          active.blur();
        }
      }
    }

    function placePreviewPopover(previewButton) {
      const popover = previewButton.querySelector(".leetcode-popover");
      if (!(popover instanceof HTMLElement)) return;
      previewButton.classList.remove("is-popover-above");
      const buttonRect = previewButton.getBoundingClientRect();
      const bottomGuard = 16;
      const topGuard = 16;
      const minPopoverHeight = 180;
      const maxPopoverHeight = 480;
      const belowSpace = window.innerHeight - buttonRect.bottom - bottomGuard;
      const aboveSpace = buttonRect.top - topGuard;
      const shouldOpenAbove = belowSpace < minPopoverHeight && aboveSpace > belowSpace;
      const availableSpace = shouldOpenAbove ? aboveSpace : belowSpace;
      const nextMaxHeight = Math.max(
        minPopoverHeight,
        Math.min(maxPopoverHeight, availableSpace),
      );
      popover.style.maxHeight = `${nextMaxHeight}px`;
      if (shouldOpenAbove) {
        previewButton.classList.add("is-popover-above");
      }
    }

    function keepPreviewHoverOpen(previewButton) {
      clearPreviewHoverCloseTimer();
      list?.querySelectorAll("[data-preview].is-hover-open").forEach((item) => {
        if (item === previewButton) return;
        item.classList.remove("is-hover-open");
        item.classList.remove("is-popover-above");
      });
      previewButton.classList.add("is-hover-open");
      placePreviewPopover(previewButton);
    }

    function schedulePreviewHoverClose(previewButton) {
      clearPreviewHoverCloseTimer();
      previewHoverCloseTimer = window.setTimeout(() => {
        previewButton.classList.remove("is-hover-open");
        previewButton.classList.remove("is-popover-above");
        previewHoverCloseTimer = 0;
      }, previewHoverCloseDelayMs);
    }

    function extensionDetectingMessage() {
      return isChinesePage
        ? "正在检测 Chrome 扩展状态..."
        : "Checking Chrome extension status...";
    }

    function extensionProbeFailedMessage() {
      return isChinesePage
        ? "扩展检测失败。"
        : "Extension check failed.";
    }

    function outdatedExtensionMessage() {
      return isChinesePage
        ? "Chrome 扩展已连接，但版本偏旧；请在 chrome://extensions 里重新加载 extensions/leetcode-submit，然后刷新本页。"
        : "The Chrome extension is connected but outdated; reload extensions/leetcode-submit in chrome://extensions, then refresh this page.";
    }

    function extensionLoginRequiredMessage() {
      return isChinesePage
        ? "Chrome 扩展已连接且版本最新，但当前 Chrome 未登录 leetcode.cn。"
        : "The Chrome extension is connected and current, but this Chrome profile is not signed in to leetcode.cn.";
    }

    function extensionCsrfMissingMessage() {
      return isChinesePage
        ? "Chrome 扩展已连接且版本最新，但缺少 leetcode.cn CSRF cookie。"
        : "The Chrome extension is connected and current, but the leetcode.cn CSRF cookie is missing.";
    }

    function currentExtensionMessage(data) {
      const version = String(data?.extensionVersion || "").trim();
      const versionText = version ? ` ${version}` : "";
      return isChinesePage
        ? `Chrome 扩展已连接，已是最新版本${versionText}；可运行样例/提交力扣。`
        : `Chrome extension connected and current${versionText}; ready to run examples or submit.`;
    }

    function extensionLoginData(response) {
      const data = response?.data;
      return data && typeof data === "object" ? data : {};
    }

    function extensionCapabilitySet(data) {
      if (!Array.isArray(data?.capabilities)) return new Set();
      return new Set(data.capabilities.map((capability) => String(capability)));
    }

    function currentExtensionSupportsPage(data) {
      const version = Number(data?.featureVersion || 0);
      const capabilities = extensionCapabilitySet(data);
      return (
        version >= extensionRequiredFeatureVersion &&
        capabilities.has(extensionCheckRequestType) &&
        capabilities.has(extensionRunRequestType) &&
        capabilities.has(extensionSubmitRequestType) &&
        capabilities.has(extensionExtraRunTestcasesCapability) &&
        capabilities.has(extensionGroupedRunTestcasesCapability) &&
        capabilities.has(extensionRunOutputDetailsCapability)
      );
    }

    function extensionReadiness(response) {
      if (!response?.ok) {
        return {
          message: extensionErrorMessage(response, extensionProbeFailedMessage()),
          ready: false,
          tone: "error",
        };
      }
      const data = extensionLoginData(response);
      if (!currentExtensionSupportsPage(data)) {
        return {
          message: outdatedExtensionMessage(),
          ready: false,
          tone: "error",
        };
      }
      if (!data.isLoggedIn) {
        return {
          message: extensionLoginRequiredMessage(),
          ready: false,
          tone: "error",
        };
      }
      if (!data.hasCsrfToken) {
        return {
          message: extensionCsrfMissingMessage(),
          ready: false,
          tone: "error",
        };
      }
      return {
        message: currentExtensionMessage(data),
        ready: true,
        tone: "success",
      };
    }

    function extensionProbeErrorResponse(error) {
      return {
        error: {
          code: error?.timedOut
            ? extensionProbeTimeoutCode
            : extensionProbeFailedCode,
          message: error?.message || extensionProbeFailedMessage(),
        },
        ok: false,
        type: "error",
      };
    }

    function cacheExtensionProbeResponse(response) {
      extensionProbeCheckedAt = Date.now();
      extensionProbeResponse = response;
      return response;
    }

    async function leetcodeLoginStatus(options = {}) {
      const force = Boolean(options.force);
      const isFresh =
        extensionProbeResponse &&
        Date.now() - extensionProbeCheckedAt < extensionProbeCacheMs;
      if (!force && isFresh) return extensionProbeResponse;
      if (!force && extensionProbePromise) return extensionProbePromise;

      extensionProbePromise = extensionRequest(
        extensionLoginStatusRequestType,
        {},
        extensionPingTimeoutMs,
      )
        .then(cacheExtensionProbeResponse)
        .catch((error) => cacheExtensionProbeResponse(
          extensionProbeErrorResponse(error),
        ));

      try {
        return await extensionProbePromise;
      } finally {
        extensionProbePromise = null;
      }
    }

    function panelHasActiveLeetcodeAction(panel) {
      return panel instanceof HTMLElement &&
        panel.dataset.leetcodeActionBusy === "true";
    }

    function setPanelLeetcodeActionBusy(panel, busy) {
      if (!(panel instanceof HTMLElement)) return;
      if (busy) {
        panel.dataset.leetcodeActionBusy = "true";
        return;
      }
      delete panel.dataset.leetcodeActionBusy;
    }

    function applyLeetcodeExtensionProbe(panel, response) {
      if (!(panel instanceof HTMLElement) || !panel.isConnected) return;
      if (panelHasActiveLeetcodeAction(panel)) return;
      const readiness = extensionReadiness(response);
      setSubmitStatus(panel, readiness.message, readiness.tone);
    }

    function syncRenderedExtensionStatus() {
      list?.querySelectorAll(".leetcode-practice-panel").forEach((panel) => {
        if (!(panel instanceof HTMLElement)) return;
        if (panel.dataset.extensionProbeStarted === "true") return;
        panel.dataset.extensionProbeStarted = "true";
        if (
          extensionProbeResponse &&
          Date.now() - extensionProbeCheckedAt < extensionProbeCacheMs
        ) {
          applyLeetcodeExtensionProbe(panel, extensionProbeResponse);
          return;
        }
        setSubmitStatus(panel, extensionDetectingMessage(), "pending");
        leetcodeLoginStatus()
          .then((response) => applyLeetcodeExtensionProbe(panel, response))
          .catch((error) => {
            applyLeetcodeExtensionProbe(
              panel,
              extensionProbeErrorResponse(error),
            );
          });
      });
    }

    async function ensureLeetcodeReady(panel) {
      setSubmitStatus(panel, extensionDetectingMessage(), "pending");
      const loginStatus = await leetcodeLoginStatus({ force: true });
      const readiness = extensionReadiness(loginStatus);
      if (!readiness.ready) throw new Error(readiness.message);
    }

    function editorPayload(problem, textarea, options = {}) {
      const panel = textarea.closest(".leetcode-practice-panel");
      const select = panel?.querySelector("[data-editor-lang]");
      const lang =
        select instanceof HTMLSelectElement
          ? preferredLang(problem, select.value)
          : preferredLang(problem, editorDrafts[problem.titleSlug]?.lang);
      const payload = {
        code: textarea.value,
        langSlug: normalizeLangSlug(lang),
        titleSlug: problem.titleSlug,
      };
      if (options.extraTestcases) {
        payload.extraTestcases = options.extraTestcases;
      }
      return payload;
    }

    function setActionBusy(actionButton, busy) {
      if (actionButton instanceof HTMLButtonElement) {
        actionButton.disabled = busy;
      }
    }

    function setSubmitStatus(
      panel,
      message,
      tone = "",
      result = null,
      detailRows = [],
    ) {
      const status = panel?.querySelector("[data-submit-status]");
      if (status instanceof HTMLElement) {
        status.textContent = message;
        status.dataset.tone = tone;
      }
      renderSubmitDetails(panel, [
        ...detailRows,
        ...(tone === "error" ? submissionFailureDetails(result) : []),
      ]);
    }

    function delay(ms) {
      return new Promise((resolve) => {
        window.setTimeout(resolve, ms);
      });
    }

    function extensionRequest(type, payload, timeoutMs = extensionRequestTimeoutMs) {
      return new Promise((resolve, reject) => {
        const requestId = `leetcode-${Date.now()}-${extensionRequestSequence += 1}`;
        const timeout = window.setTimeout(() => {
          const pending = pendingExtensionRequests.get(requestId);
          pendingExtensionRequests.delete(requestId);
          const error = new Error(extensionTimeoutMessage(type, pending?.ack));
          error.requestType = type;
          error.timedOut = true;
          reject(error);
        }, timeoutMs);
        pendingExtensionRequests.set(requestId, {
          ack: false,
          reject,
          resolve,
          timeout,
        });
        window.postMessage(
          {
            payload,
            requestId,
            source: extensionRequestSource,
            type,
            version: extensionProtocolVersion,
          },
          window.location.origin,
        );
      });
    }

    function extensionTimeoutMessage(type, acknowledged) {
      if (!acknowledged) {
        return "未检测到 Chrome 扩展响应，请确认已加载 extensions/leetcode-submit。";
      }
      if (type === extensionCheckRequestType) {
        return "扩展已连接，但本次力扣结果查询超时。";
      }
      if (type === extensionLoginStatusRequestType) {
        return "扩展已连接，但登录状态检测超时；请刷新本页后重试。";
      }
      return "扩展已连接，但力扣请求超时；请稍后查看力扣提交记录。";
    }

    function unsupportedCheckMessage() {
      return isChinesePage
        ? "当前加载的 Chrome 扩展版本不支持查询结果；请在 chrome://extensions 里重新加载 extensions/leetcode-submit，然后刷新本页。"
        : "The loaded Chrome extension does not support result checks; reload extensions/leetcode-submit in chrome://extensions, then refresh this page.";
    }

    function extensionErrorMessage(response, fallback) {
      const error = response?.error;
      if (!error) return fallback;
      const message = String(error.message || "");
      if (
        error.code === unsupportedRequestTypeCode &&
        message.includes(extensionCheckRequestType)
      ) {
        return unsupportedCheckMessage();
      }
      return message || fallback;
    }

    function retryableCheckError(error) {
      return Boolean(error?.timedOut && error?.requestType === extensionCheckRequestType);
    }

    function retryableCheckResponse(response) {
      return response?.error?.code === leetcodeRequestTimeoutCode;
    }

    function submissionStatusAccepted(result) {
      return (
        result?.statusMessage === "Accepted" ||
        result?.status_msg === "Accepted"
      );
    }

    function numericSubmissionCount(value) {
      const text = meaningfulSubmissionValue(value);
      if (!/^\d+$/.test(text)) return null;
      const number = Number(text);
      return Number.isFinite(number) ? number : null;
    }

    function allSubmittedTestcasesPassed(result) {
      if (result?.runSuccess === false) return false;
      const totalCorrect = numericSubmissionCount(result?.totalCorrect);
      const totalTestcases = numericSubmissionCount(result?.totalTestcases);
      return (
        totalCorrect !== null &&
        totalTestcases !== null &&
        totalTestcases > 0 &&
        totalCorrect === totalTestcases
      );
    }

    function runAccepted(result) {
      if (
        result?.totalCorrect !== null &&
        result?.totalCorrect !== undefined &&
        result?.totalTestcases !== null &&
        result?.totalTestcases !== undefined
      ) {
        return allSubmittedTestcasesPassed(result);
      }
      return Boolean(result?.runSuccess && submissionStatusAccepted(result));
    }

    function meaningfulSubmissionValue(value) {
      if (value === null || value === undefined) return "";
      const text = String(value).trim();
      if (!text || text === "N/A") return "";
      return text;
    }

    function firstSubmissionLine(value) {
      const text = meaningfulSubmissionValue(value);
      if (!text) return "";
      return text.split("\n").map((line) => line.trim()).find(Boolean) || "";
    }

    function normalizedSubmissionRuntime(value) {
      const text = meaningfulSubmissionValue(value);
      if (!text) return "";
      return /^\d+$/.test(text) ? `${text} ms` : text;
    }

    function normalizedSubmissionMemory(value) {
      const text = meaningfulSubmissionValue(value);
      if (!text) return "";
      if (!/^\d+(?:\.\d+)?$/.test(text)) return text;
      const bytes = Number(text);
      if (!Number.isFinite(bytes) || bytes <= 0) return text;
      const megabytes = bytes / 1000 / 1000;
      return `${megabytes.toFixed(1)} MB`;
    }

    function submissionTestSummary(result) {
      const totalCorrect = meaningfulSubmissionValue(result?.totalCorrect);
      const totalTestcases = meaningfulSubmissionValue(result?.totalTestcases);
      return totalCorrect && totalTestcases
        ? `${totalCorrect}/${totalTestcases}`
        : "";
    }

    function submissionDetailValue(value) {
      if (value === null || value === undefined) return "";
      if (Array.isArray(value)) {
        return value.map(submissionDetailValue).filter(Boolean).join("\n");
      }
      if (typeof value === "object") {
        try {
          return JSON.stringify(value, null, 2);
        } catch {
          return "";
        }
      }
      return meaningfulSubmissionValue(value);
    }

    function submissionFailureDetails(result) {
      const labels = isChinesePage
        ? {
            compileError: "编译错误",
            expectedOutput: "期望输出",
            input: "失败用例",
            output: "实际输出",
            runtimeError: "运行错误",
            standardOutput: "stdout",
          }
        : {
            compileError: "Compile error",
            expectedOutput: "Expected output",
            input: "Failing testcase",
            output: "Actual output",
            runtimeError: "Runtime error",
            standardOutput: "Stdout",
          };
      return [
        [labels.compileError, submissionDetailValue(result?.compileError)],
        [labels.runtimeError, submissionDetailValue(result?.runtimeError)],
        [labels.input, submissionDetailValue(result?.input)],
        [labels.output, submissionDetailValue(result?.output)],
        [labels.expectedOutput, submissionDetailValue(result?.expectedOutput)],
        [labels.standardOutput, submissionDetailValue(result?.standardOutput)],
      ].filter(([, value]) => value);
    }

    function testcaseSourceLabel(source) {
      if (source === "extra") return isChinesePage ? "补充" : "Extra";
      if (source === "official") return isChinesePage ? "官方" : "Official";
      return "";
    }

    function normalizedRunTestcaseGroups(groups) {
      if (!Array.isArray(groups)) return [];
      return groups
        .map((group, index) => {
          const fields = Array.isArray(group?.fields) ? group.fields : [];
          const normalizedFields = fields
            .map((field, fieldIndex) => {
              const value = submissionDetailValue(field?.value);
              if (!value) return null;
              return {
                name: String(field?.name || `arg${fieldIndex + 1}`).trim(),
                value,
              };
            })
            .filter(Boolean);
          if (!normalizedFields.length) return null;
          return {
            fields: normalizedFields,
            label: isChinesePage ? `用例 ${index + 1}` : `Case ${index + 1}`,
            source: testcaseSourceLabel(group?.source),
          };
        })
        .filter(Boolean);
    }

    function runTestcaseDetails(testcases, groups = []) {
      const cases = normalizedRunTestcaseGroups(groups);
      if (cases.length) {
        return [
          {
            cases,
            kind: "testcases",
            label: isChinesePage ? "运行用例" : "Run testcases",
          },
        ];
      }
      const value = submissionDetailValue(testcases);
      if (!value) return [];
      return [[isChinesePage ? "运行用例" : "Run testcases", value]];
    }

    function parsedDetailArray(value) {
      if (Array.isArray(value)) {
        return value.map(submissionDetailValue).filter(Boolean);
      }
      const text = meaningfulSubmissionValue(value);
      if (!text || !text.startsWith("[")) return [];
      try {
        const parsed = JSON.parse(text);
        return Array.isArray(parsed)
          ? parsed.map(submissionDetailValue).filter(Boolean)
          : [];
      } catch {
        return [];
      }
    }

    function detailValuesForCases(value, caseCount) {
      const parsed = parsedDetailArray(value);
      if (parsed.length === caseCount) return parsed;
      const text = submissionDetailValue(value);
      if (!text) return [];
      const lines = text
        .split(/\r?\n/)
        .map((line) => line.trim())
        .filter(Boolean);
      return lines.length === caseCount ? lines : [];
    }

    function runResultLabels() {
      return isChinesePage
        ? {
            compileError: "编译错误",
            expectedOutput: "期望输出",
            output: "实际输出",
            runtimeError: "运行错误",
            standardOutput: "stdout",
            passed: "通过",
            failed: "未通过",
          }
        : {
            compileError: "Compile error",
            expectedOutput: "Expected output",
            output: "Actual output",
            runtimeError: "Runtime error",
            standardOutput: "Stdout",
            passed: "Passed",
            failed: "Failed",
          };
    }

    function appendResultField(fields, name, value, kind = "") {
      if (!value) return false;
      fields.push({ kind, name, value });
      return true;
    }

    function comparableOutput(value) {
      const text = String(value || "")
        .replace(/\r\n/g, "\n")
        .trim();
      try {
        return JSON.stringify(JSON.parse(text));
      } catch {
        return text;
      }
    }

    function testcaseResultState(output, expectedOutput) {
      if (!output || !expectedOutput) return "";
      return comparableOutput(output) === comparableOutput(expectedOutput)
        ? "success"
        : "error";
    }

    function enrichRunTestcases(cases, result) {
      const labels = runResultLabels();
      const caseCount = cases.length;
      const outputs = detailValuesForCases(result?.output, caseCount);
      const expectedOutputs = detailValuesForCases(result?.expectedOutput, caseCount);
      const standardOutputs = detailValuesForCases(result?.standardOutput, caseCount);
      const consumed = {
        expectedOutput: expectedOutputs.length === caseCount,
        output: outputs.length === caseCount,
        standardOutput: standardOutputs.length === caseCount,
      };
      const allCasesPassed = allSubmittedTestcasesPassed(result);
      return {
        cases: cases.map((testcase, index) => {
          const fields = [...testcase.fields];
          const output = consumed.output ? outputs[index] : "";
          const expectedOutput = consumed.expectedOutput
            ? expectedOutputs[index]
            : "";
          const standardOutput = consumed.standardOutput
            ? standardOutputs[index]
            : "";
          if (output) {
            appendResultField(fields, labels.output, output, "output");
          }
          if (consumed.expectedOutput) {
            appendResultField(
              fields,
              labels.expectedOutput,
              expectedOutput,
              "expected",
            );
          }
          if (standardOutput) {
            appendResultField(
              fields,
              labels.standardOutput,
              standardOutput,
              "stdout",
            );
          }
          const resultState = allCasesPassed
            ? "success"
            : testcaseResultState(output, expectedOutput);
          const resultLabel =
            resultState === "success"
              ? labels.passed
              : resultState === "error"
                ? labels.failed
                : "";
          return { ...testcase, fields, resultLabel, resultState };
        }),
        consumed,
      };
    }

    function standaloneRunResultDetails(
      result,
      consumed = {},
      options = {},
    ) {
      const labels = runResultLabels();
      const includeCaseOutputs = options.includeCaseOutputs !== false;
      const details = [
        [labels.compileError, submissionDetailValue(result?.compileError)],
        [labels.runtimeError, submissionDetailValue(result?.runtimeError)],
      ];
      if (includeCaseOutputs && !consumed.output) {
        details.push([labels.output, submissionDetailValue(result?.output)]);
      }
      if (includeCaseOutputs && !consumed.expectedOutput) {
        details.push([
          labels.expectedOutput,
          submissionDetailValue(result?.expectedOutput),
        ]);
      }
      if (includeCaseOutputs && !consumed.standardOutput) {
        details.push([
          labels.standardOutput,
          submissionDetailValue(result?.standardOutput),
        ]);
      }
      return details.filter(([, value]) => value);
    }

    function runResultDetails(testcases, groups, result) {
      const rows = runTestcaseDetails(testcases, groups);
      const testcaseRow = rows.find(
        (row) => row && typeof row === "object" && row.kind === "testcases",
      );
      if (!testcaseRow) {
        return [
          ...rows,
          ...standaloneRunResultDetails(result),
        ];
      }
      const enriched = enrichRunTestcases(testcaseRow.cases, result);
      return [
        { ...testcaseRow, cases: enriched.cases },
        ...standaloneRunResultDetails(
          result,
          enriched.consumed,
          { includeCaseOutputs: false },
        ),
      ];
    }

    function saveFailedSubmissionCase(problem, result) {
      const testcase = submissionDetailValue(result?.input);
      if (!testcase) return false;
      return addExtraRunCase(problem.titleSlug, testcase);
    }

    function appendSubmissionDetailRow(container, label, value) {
      const row = document.createElement("div");
      const labelElement = document.createElement("span");
      const valueElement = document.createElement("pre");
      row.className = "leetcode-submit-detail-row";
      labelElement.className = "leetcode-submit-detail-label";
      labelElement.textContent = label;
      valueElement.textContent = value;
      row.append(labelElement, valueElement);
      container.append(row);
    }

    function appendTestcaseField(panel, field) {
      const fieldElement = document.createElement("div");
      const labelElement = document.createElement("span");
      const valueElement = document.createElement("pre");
      fieldElement.className = "leetcode-testcase-field";
      if (field.kind) fieldElement.dataset.resultField = field.kind;
      labelElement.className = "leetcode-testcase-field-label";
      labelElement.textContent = field.name ? `${field.name} =` : "input =";
      valueElement.textContent = field.value;
      fieldElement.append(labelElement, valueElement);
      panel.append(fieldElement);
    }

    function appendTestcaseDetailRow(container, row) {
      const wrapper = document.createElement("div");
      const labelElement = document.createElement("span");
      const card = document.createElement("div");
      const tabs = document.createElement("div");
      const body = document.createElement("div");
      const tabId = `leetcode-case-${Date.now()}-${Math.random()
        .toString(36)
        .slice(2)}`;
      wrapper.className = "leetcode-submit-detail-row leetcode-testcase-row";
      labelElement.className = "leetcode-submit-detail-label";
      labelElement.textContent = row.label;
      card.className = "leetcode-testcase-card";
      card.dataset.testcaseCard = "true";
      tabs.className = "leetcode-testcase-tabs";
      tabs.setAttribute("role", "tablist");
      body.className = "leetcode-testcase-body";

      row.cases.forEach((testcase, index) => {
        const tab = document.createElement("button");
        const panel = document.createElement("div");
        const isActive = index === 0;
        tab.type = "button";
        tab.dataset.testcaseTab = String(index);
        tab.className = isActive ? "is-active" : "";
        tab.id = `${tabId}-tab-${index}`;
        tab.setAttribute("aria-controls", `${tabId}-panel-${index}`);
        tab.setAttribute("aria-selected", String(isActive));
        tab.setAttribute("role", "tab");
        tab.append(document.createTextNode(testcase.label));
        if (testcase.resultState) {
          tab.dataset.resultState = testcase.resultState;
          const result = document.createElement("span");
          result.className = "leetcode-testcase-result";
          result.textContent = testcase.resultLabel;
          tab.append(result);
        }
        if (testcase.source) {
          const source = document.createElement("span");
          source.className = "leetcode-testcase-source";
          source.textContent = testcase.source;
          tab.append(source);
        }

        panel.className = "leetcode-testcase-panel";
        panel.dataset.testcasePanel = String(index);
        panel.hidden = !isActive;
        panel.id = `${tabId}-panel-${index}`;
        panel.setAttribute("aria-labelledby", tab.id);
        panel.setAttribute("role", "tabpanel");
        testcase.fields.forEach((field) => appendTestcaseField(panel, field));

        tabs.append(tab);
        body.append(panel);
      });

      card.append(tabs, body);
      wrapper.append(labelElement, card);
      container.append(wrapper);
    }

    function renderSubmitDetails(panel, rows) {
      const container = panel?.querySelector("[data-submit-detail]");
      if (!(container instanceof HTMLElement)) return;
      container.replaceChildren();
      if (!rows.length) {
        container.hidden = true;
        return;
      }
      rows.forEach((detailRow) => {
        if (
          detailRow &&
          typeof detailRow === "object" &&
          detailRow.kind === "testcases"
        ) {
          appendTestcaseDetailRow(container, detailRow);
          return;
        }
        const [label, value] = detailRow;
        appendSubmissionDetailRow(container, label, value);
      });
      container.hidden = false;
    }

    function submissionSummary(result, options = {}) {
      const status = result?.statusMessage || result?.status_msg || result?.state || "已返回";
      const statusPart =
        options.suppressAcceptedStatus && submissionStatusAccepted(result)
          ? ""
          : status;
      const compileError = firstSubmissionLine(result?.compileError);
      if (compileError) {
        return `${status}: ${compileError}`.slice(0, 220);
      }
      return [
        statusPart,
        submissionTestSummary(result),
        normalizedSubmissionRuntime(result?.runtime),
        normalizedSubmissionMemory(result?.memory),
      ].filter(Boolean).join(" · ");
    }

    function resultFinished(result) {
      const state = result?.state;
      if (state) return state !== "PENDING" && state !== "STARTED";
      return Boolean(result?.finished || result?.statusMessage || result?.statusCode);
    }

    function submissionIdFrom(response, kind) {
      return (
        response?.data?.submissionId ||
        response?.data?.[kind]?.interpret_id ||
        response?.data?.[kind]?.submission_id ||
        ""
      );
    }

    function finishedInitialResult(response) {
      const result = response?.data?.result;
      if (!result || typeof result !== "object") return null;
      return resultFinished(result) ? result : null;
    }

    async function pollLeetcodeResult(
      panel,
      submissionId,
      label,
      maxAttempts,
      detailRows = [],
    ) {
      await delay(submissionPollInitialDelayMs);
      let lastErrorMessage = "";
      for (let attempt = 1; attempt <= maxAttempts; attempt += 1) {
        setSubmitStatus(
          panel,
          `${label}，等待结果 ${attempt}/${maxAttempts}...`,
          "pending",
          null,
          detailRows,
        );
        let response;
        try {
          response = await extensionRequest(
            extensionCheckRequestType,
            { submissionId },
            extensionCheckTimeoutMs,
          );
        } catch (error) {
          lastErrorMessage = error.message || "查询结果失败。";
          if (retryableCheckError(error) && attempt < maxAttempts) {
            setSubmitStatus(
              panel,
              `${label}，本次查询超时，继续等待 ${attempt}/${maxAttempts}...`,
              "pending",
              null,
              detailRows,
            );
            await delay(submissionPollIntervalMs);
            continue;
          }
          throw error;
        }
        if (!response?.ok) {
          const message = extensionErrorMessage(response, "查询结果失败。");
          lastErrorMessage = message;
          if (retryableCheckResponse(response) && attempt < maxAttempts) {
            setSubmitStatus(
              panel,
              `${label}，本次查询超时，继续等待 ${attempt}/${maxAttempts}...`,
              "pending",
              null,
              detailRows,
            );
            await delay(submissionPollIntervalMs);
            continue;
          }
          throw new Error(message);
        }
        const result = response.data?.result || {};
        if (resultFinished(result)) return result;
        await delay(submissionPollIntervalMs);
      }
      const suffix = lastErrorMessage ? `最近错误：${lastErrorMessage}` : "";
      throw new Error(`${label}超时；请稍后查看力扣提交记录。${suffix}`);
    }

    async function leetcodeResultFromResponse(
      panel,
      response,
      kind,
      label,
      maxAttempts,
      detailRows = [],
    ) {
      const initialResult = finishedInitialResult(response);
      if (initialResult) return initialResult;
      const submissionId = submissionIdFrom(response, kind);
      if (!submissionId) {
        throw new Error("力扣没有返回运行或提交 ID。");
      }
      return pollLeetcodeResult(
        panel,
        submissionId,
        label,
        maxAttempts,
        detailRows,
      );
    }

    async function runLeetcode(panel, actionButton, problem, textarea) {
      setActionBusy(actionButton, true);
      setPanelLeetcodeActionBusy(panel, true);
      try {
        await ensureLeetcodeReady(panel);
        setSubmitStatus(panel, "正在运行官方示例...", "pending");
        const extraTestcases = extraRunTestcasesFor(problem);
        const response = await extensionRequest(
          extensionRunRequestType,
          editorPayload(problem, textarea, { extraTestcases }),
          extensionInitialResultTimeoutMs,
        );
        if (!response?.ok) {
          throw new Error(extensionErrorMessage(response, "运行失败。"));
        }
        const testcaseRows = runTestcaseDetails(
          response.data?.testcases || extraTestcases,
          response.data?.testcaseGroups,
        );
        if (testcaseRows.length) {
          setSubmitStatus(
            panel,
            "正在运行官方示例...",
            "pending",
            null,
            testcaseRows,
          );
        }
        const result = await leetcodeResultFromResponse(
          panel,
          response,
          extensionRunRequestType,
          "正在运行官方示例",
          runPollAttempts,
          testcaseRows,
        );
        const completedRows = runResultDetails(
          response.data?.testcases || extraTestcases,
          response.data?.testcaseGroups,
          result,
        );
        const accepted = runAccepted(result);
        const summary = submissionSummary(result, {
          suppressAcceptedStatus: !accepted,
        });
        recordRunAttempt(problem, textarea, accepted);
        if (accepted) {
          setSubmitStatus(panel, `样例通过 ${summary}`, "success", null, completedRows);
          return;
        }
        setSubmitStatus(panel, `样例未通过 ${summary}`, "error", null, completedRows);
      } catch (error) {
        setSubmitStatus(panel, error.message || "运行失败。", "error");
      } finally {
        setPanelLeetcodeActionBusy(panel, false);
        setActionBusy(actionButton, false);
      }
    }

    async function submitLeetcode(panel, actionButton, problem, textarea) {
      setActionBusy(actionButton, true);
      setPanelLeetcodeActionBusy(panel, true);
      try {
        await ensureLeetcodeReady(panel);
        setSubmitStatus(panel, "正在提交到力扣...", "pending");
        const response = await extensionRequest(
          extensionSubmitRequestType,
          editorPayload(problem, textarea),
          extensionInitialResultTimeoutMs,
        );
        if (!response?.ok) {
          throw new Error(extensionErrorMessage(response, "提交失败。"));
        }
        const submissionId = submissionIdFrom(
          response,
          extensionSubmitRequestType,
        );
        const result = await leetcodeResultFromResponse(
          panel,
          response,
          extensionSubmitRequestType,
          "正在提交到力扣",
          submitPollAttempts,
        );
        const summary = submissionSummary(result);
        if (submissionStatusAccepted(result)) {
          const timingResult = recordAcceptedTiming(problem.titleSlug);
          let nextFlowProblem = nextListFlowProblemAfterAccepted(problem);
          recordSubmissionAttempt(problem, textarea, result, {
            accepted: true,
            elapsedMs: timingResult.elapsed,
            submissionId,
          });
          const timingSummary =
            `${isChinesePage ? "本题" : "Problem"} ${formatDuration(timingResult.elapsed)}` +
            (timingResult.isPersonalBest
              ? (isChinesePage ? "，新 PB" : ", new PB")
              : "");
          const milestoneSummary = timingResult.milestone
            ? ` · ${timingResult.milestone}`
            : "";
          progress[problem.titleSlug] = {
            ...rowState(problem.titleSlug),
            done: true,
          };
          writeState();
          appendPracticeEvent(practiceEventProgressSet, {
            slug: problem.titleSlug,
            state: progress[problem.titleSlug],
          });
          if (flowMode === flowModeInsight) {
            nextFlowProblem = suggestedFlowProblem(problem.titleSlug);
          }
          setSubmitStatus(
            panel,
            `${summary || "Accepted"} · ${timingSummary}${milestoneSummary}`,
            "success",
          );
          advanceFlowAfterAcceptedSubmit(nextFlowProblem, timingResult);
          return;
        }
        recordSubmissionAttempt(problem, textarea, result, {
          accepted: false,
          elapsedMs: activePracticeElapsed(),
          submissionId,
        });
        const savedCase = saveFailedSubmissionCase(problem, result);
        const savedMessage = savedCase
          ? (isChinesePage ? " · 已加入下次运行样例" : " · Added to next run")
          : "";
        setSubmitStatus(panel, `${summary}${savedMessage}`, "error", result);
      } catch (error) {
        setSubmitStatus(panel, error.message || "提交失败。", "error");
      } finally {
        setPanelLeetcodeActionBusy(panel, false);
        setActionBusy(actionButton, false);
      }
    }

    const statementExampleSectionPattern =
      /(?:示例\s*\d*\s*[：:]|Example\s*\d*\s*:)[\s\S]*$/iu;
    const statementExampleIntroSectionPattern =
      /(^|[。！？；;]\s*)[^。！？；;]*(?:下图|在文本格式中)[^。！？；;]*(?:示例|如下所示)[^。！？；;]*[：:][\s\S]*$/iu;
    const statementExampleReferencePatterns = [
      /[（(][^（）()\n。！？；;：:]*?(?:示例|Example)[^（）()\n。！？；;：:]*?[）)]/giu,
      /[，,]\s*(?:如|参考|参见|请参考)[^。！？；;：:]*?(?:示例|Example)(?:图)?(?:所示)?/giu,
    ];
    const statementInlineExampleTailPattern =
      /([。！？；;：:，,]\s*)(?:例如|比如|举例)[^。！？；;]*(?:[。！？；;]|$)/giu;
    const statementExampleSentencePattern =
      /(^|[。！？；;]\s*)[^。！？；;：:]*(?:示例|Example|例如|比如|举例)[^。！？；;：:]*(?:[。！？；;：:]|$)/giu;
    const statementResultFormatSentencePattern =
      /(^|[。！？；;]\s*)[^。！？；;：:]*(?:(?:查询|返回)?结果(?:表)?(?:的)?格式如下|(?:查询|返回)结果(?:表)?如下例)[^。！？；;：:]*(?:[。！？；;：:]|$)/giu;
    const inlineEnumerationLabelPattern =
      /\s+((?:开关|按钮|操作|值|条件|规则|方法|步骤)\s*(?:\d+|[一二三四五六七八九十]+)\s*[：:])/gu;

    function normalizeInlineEnumerationLabels(text) {
      return text.replace(
        inlineEnumerationLabelPattern,
        (match, label, offset, input) => {
          const normalizedLabel = label.replace(/\s*([：:])\s*/u, "$1");
          const previous = input.slice(0, offset).trimEnd().at(-1) || "";
          if (!previous || /[。！？；：:;]/u.test(previous)) {
            return ` ${normalizedLabel}`;
          }
          return `；${normalizedLabel}`;
        },
      );
    }

    function normalizeStatementText(text) {
      return normalizeInlineEnumerationLabels(
        String(text)
          .replace(/\r\n/g, "\n")
          .replace(/&nbsp;|&#160;/gi, " ")
          .replace(/&ldquo;/gi, "“")
          .replace(/&rdquo;/gi, "”")
          .replace(/&lsquo;/gi, "‘")
          .replace(/&rsquo;/gi, "’")
          .replace(/&quot;/gi, '"')
          .replace(/&#39;|&apos;/gi, "'")
          .replace(/&lt;/gi, "<")
          .replace(/&gt;/gi, ">")
          .replace(/&amp;/gi, "&")
          .replace(/\s+([。！？；：，、])/gu, "$1")
          .replace(/([。！？；：，、])\s+/gu, "$1")
          .replace(/([（(])\s+/gu, "$1")
          .replace(/\s+([）)])/gu, "$1")
          .replace(/\.\s+\.\s+\./g, "...")
          .replace(/\s{2,}/g, " ")
          .trim(),
      );
    }

    function stripStatementExamples(text) {
      let cleaned = normalizeStatementText(text)
        .replace(statementExampleSectionPattern, "")
        .replace(statementExampleIntroSectionPattern, "$1")
        .trim();
      statementExampleReferencePatterns.forEach((pattern) => {
        cleaned = cleaned.replace(pattern, "");
      });
      return normalizeStatementText(
        cleaned
          .replace(statementInlineExampleTailPattern, (_match, prefix) => {
            if (/[。！？；;]/u.test(prefix)) return `${prefix.trim()} `;
            return "。 ";
          })
          .replace(statementResultFormatSentencePattern, (_match, prefix) => {
            return prefix || "";
          })
          .replace(statementExampleSentencePattern, (_match, prefix) => {
            return prefix || "";
          })
          .trim(),
      );
    }

    function problemStatementText(problem) {
      const rawStatement = String(
        problem.statement ||
          problem.statementText ||
          problem.contentText ||
          problem.statementPreview ||
          "",
      );
      return stripStatementExamples(rawStatement);
    }

    function problemStatementParagraphs(problem) {
      const text = problemStatementText(problem);
      if (!text) return [];
      const explicitParagraphs = text
        .replace(/\r\n/g, "\n")
        .split(/\n{2,}/)
        .map((paragraph) => paragraph.trim())
        .filter(Boolean);
      if (explicitParagraphs.length > 1) return explicitParagraphs;

      const sentences = text
        .match(/[^。！？；!?]+[。！？；!?]?/g)
        ?.map((sentence) => sentence.trim())
        .filter(Boolean);
      if (!sentences?.length) return [text];

      const paragraphs = [];
      let current = "";
      sentences.forEach((sentence) => {
        if (current && `${current} ${sentence}`.length > 190) {
          paragraphs.push(current);
          current = sentence;
          return;
        }
        current = joinStatementSentences(current, sentence);
      });
      if (current) paragraphs.push(current);
      return paragraphs;
    }

    function joinStatementSentences(left, right) {
      if (!left) return right;
      if (/[。！？；：，、]$/u.test(left)) return `${left}${right}`;
      return `${left} ${right}`;
    }

    function problemConstraintItems(problem) {
      const constraintHtml = Array.isArray(problem.constraintHtml)
        ? problem.constraintHtml.filter(Boolean)
        : [];
      const constraints = Array.isArray(problem.constraints)
        ? problem.constraints.filter(Boolean)
        : [];
      if (!constraintHtml.length && !constraints.length) return [];
      const items = constraintHtml.length
        ? constraintHtml
        : constraints.map((item) => escapeHtml(item));
      return items.map(normalizeConstraintDisplayItem).filter(Boolean);
    }

    function normalizeConstraintDisplayItem(item) {
      const text = String(item)
        .replace(/\s+([。！？；：，、])/gu, "$1")
        .replace(/(?:\s|&nbsp;)*[。；.](?:\s|&nbsp;)*$/u, "")
        .trim();
      if (/&(?:#[0-9]+|#x[0-9a-f]+|[a-z]+);$/iu.test(text)) return text;
      return text.replace(/(?:\s|&nbsp;)*;(?:\s|&nbsp;)*$/u, "").trim();
    }

    function renderProblemConstraints(problem) {
      const items = problemConstraintItems(problem);
      if (!items.length) return "";
      const separator = ";";
      return `
        <p class="leetcode-statement-constraints">
          <strong>${isChinesePage ? "数据范围：" : "Constraints:"}</strong>
          ${items
            .map((item, index) => {
              const prefix = index
                ? `<span class="leetcode-statement-constraint-separator">${separator}</span>`
                : "";
              return `${prefix}<span class="leetcode-statement-constraint-item">${item}</span>`;
            })
            .join("")}
        </p>
      `;
    }

    function renderProblemConstraintsPreview(problem) {
      const items = problemConstraintItems(problem);
      if (!items.length) return "";
      const separator = ";";
      return `
        <span class="leetcode-statement-preview-constraints">
          <strong>${isChinesePage ? "数据范围：" : "Constraints:"}</strong>
          ${items
            .map((item, index) => {
              const prefix = index
                ? `<span class="leetcode-statement-constraint-separator">${separator}</span>`
                : "";
              return `${prefix}<span class="leetcode-statement-constraint-item">${item}</span>`;
            })
            .join("")}
        </span>
      `;
    }

    function renderPopoverHint(text) {
      return `<span class="leetcode-popover-hint">${escapeHtml(text)}</span>`;
    }

    function previewPinHint(name) {
      return isChinesePage
        ? `悬浮查看${name}；点击或 Enter/Space 固定展开`
        : `Hover for ${name}; click or Enter/Space to pin`;
    }

    function renderProblemStatementPreview(problem) {
      const paragraphs = problemStatementParagraphs(problem);
      const body = paragraphs.length
        ? paragraphs
            .slice(0, 3)
            .map(
              (paragraph) => `
                <span class="leetcode-statement-preview-paragraph">
                  ${escapeHtml(paragraph)}
                </span>
              `,
            )
            .join("")
        : `<span class="leetcode-statement-preview-paragraph">${
            isChinesePage
              ? "本地题面待同步，可先打开力扣原题查看。"
              : "Local statement pending; open LeetCode for the full problem."
          }</span>`;
      return `
        ${renderPopoverHint(
          isChinesePage
            ? "悬浮查看题面；点击标题打开力扣原题"
            : "Hover for statement; click the title to open LeetCode",
