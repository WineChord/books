          ${isChinesePage ? "题面" : "Statement"}
        </span>
        <span class="leetcode-statement-preview-body">
          ${body}
          ${renderProblemConstraintsPreview(problem)}
        </span>
      `;
    }

    function renderProblemStatementBody(problem) {
      if (
        typeof problem.statementHtml === "string" &&
        problem.statementHtml.trim()
      ) {
        return problem.statementHtml;
      }
      const paragraphs = problemStatementParagraphs(problem);
      if (paragraphs.length) {
        return paragraphs
          .map((paragraph) => `<p>${escapeHtml(paragraph)}</p>`)
          .join("");
      }
      return `<p>${
        isChinesePage
          ? "本地题面待同步，可先打开力扣原题查看。"
          : "Local statement pending; open LeetCode for the full problem."
      }</p>`;
    }

    function renderProblemStatementPanel(problem) {
      const slug = escapeHtml(problem.titleSlug);
      const hiddenClass = editorStatementPanelVisible ? "" : " is-hidden";
      const body = renderProblemStatementBody(problem);
      const constraints = renderProblemConstraints(problem);
      return `
        <div class="leetcode-statement-panel${hiddenClass}" data-statement-panel="${slug}">
          <div class="leetcode-statement-collapsed">
            <span>${isChinesePage ? "已收起" : "Hidden"}</span>
            <button type="button" data-editor-action="statement-panel" data-statement-visible="true" aria-expanded="false">
