                <span class="leetcode-popover" role="tooltip">
                  ${renderPopoverHint(previewPinHint(isChinesePage ? "思路" : "approach"))}
                  <span class="leetcode-popover-lead">${escapeHtml(problem.approachPreview)}</span>
                  ${renderStudyChecks(problem)}
                  ${renderCompanyFollowUps(problem)}
                </span>
              </span>
              <span class="leetcode-preview-control" data-preview aria-expanded="false" role="button" tabindex="0" aria-label="${escapeHtml(previewPinHint(isChinesePage ? "实现" : "implementation"))}">
                实现
