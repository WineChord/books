            </button>
          </div>
          <div class="leetcode-statement-content">
            <div class="leetcode-statement-head">
              <div class="leetcode-statement-actions">
                <a href="${escapeHtml(problem.url)}" target="_blank" rel="noopener noreferrer" data-link-slug="${slug}">
                  ${isChinesePage ? "力扣原题" : "LeetCode"}
                </a>
                <button type="button" data-editor-action="statement-panel" data-statement-visible="false" aria-expanded="true">
