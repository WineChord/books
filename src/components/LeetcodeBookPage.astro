    }

    function syncStatementPanels() {
      list?.querySelectorAll("[data-statement-panel]").forEach((panel) => {
        if (!(panel instanceof HTMLElement)) return;
        panel.classList.toggle("is-hidden", !editorStatementPanelVisible);
        panel.querySelectorAll("[data-statement-visible]").forEach((control) => {
          if (!(control instanceof HTMLElement)) return;
          control.setAttribute("aria-expanded", String(editorStatementPanelVisible));
        });
      });
    }

    function setStatementPanelVisible(visible) {
      editorStatementPanelVisible = visible;
      localStorage.setItem(
        editorStatementPanelKey,
        editorStatementPanelVisible ? "on" : "off",
      );
      syncStatementPanels();
    }

    function renderPracticePanel(problem) {
      const draft = draftFor(problem);
      const lang = preferredLang(problem, draft.lang);
