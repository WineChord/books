      if (event.payload?.dateKey) return event.payload.dateKey;
      const time = Date.parse(event.payload?.acceptedAt || event.createdAt || "");
      return Number.isFinite(time) ? localDateKey(new Date(time)) : localDateKey();
    }

    function applyAcceptedTimingEvent(timingStore, event) {
      const slug = event.payload?.slug || "";
      if (!slug) return;
      const elapsed = Math.max(0, Number(event.payload?.elapsedMs || 0));
      const acceptedAt = event.payload?.acceptedAt || event.createdAt || null;
      const dateKey = eventDateKey(event);
      const record = ensureTimingProblemIn(timingStore, slug);
      record.acceptedCount += 1;
      record.totalAcceptedMs += elapsed;
      record.lastAcceptedAt = acceptedAt;
      record.lastMs = elapsed;
      record.bestMs = !record.bestMs || elapsed < record.bestMs
        ? elapsed
        : record.bestMs;

      const day = ensureDayTimingIn(timingStore, dateKey);
      day.acceptedCount += 1;
      day.totalAcceptedMs += elapsed;
      day.bestMs = !day.bestMs || elapsed < day.bestMs ? elapsed : day.bestMs;
      day.firstAcceptedAt = day.firstAcceptedAt || acceptedAt;
      day.lastAcceptedAt = acceptedAt;
      if (!day.acceptedSlugs.includes(slug)) day.acceptedSlugs.push(slug);
    }

    function applySubmissionAttemptEvent(submissionStore, event) {
      const slug = event.payload?.slug || "";
      if (!slug) return;
      const attempt = normalizedSubmissionEventRecord(event.payload?.event || {});
      attempt.at = attempt.at || event.createdAt || null;
      const record = ensureSubmissionRecordIn(submissionStore, slug);
      record.attemptCount += 1;
      record.firstSubmittedAt = record.firstSubmittedAt || attempt.at;
      record.lastSubmittedAt = attempt.at;
      record.lastCodeChars = attempt.codeChars;
      record.lastCodeLines = attempt.codeLines;
      record.lastCodeNonBlankLines = attempt.codeNonBlankLines;
      record.events.push(attempt);
      record.events = record.events.slice(-submissionHistoryLimit);
      if (attempt.accepted) {
        record.acceptedCount += 1;
        record.totalAcceptedMs += attempt.elapsedMs;
        record.lastAcceptedAt = attempt.at;
        record.lastElapsedMs = attempt.elapsedMs;
        record.bestMs =
          !record.bestMs || attempt.elapsedMs < record.bestMs
            ? attempt.elapsedMs
            : record.bestMs;
        return;
      }
      record.errorCount += 1;
    }

    function applyRunAttemptEvent(submissionStore, event) {
      const slug = event.payload?.slug || "";
      if (!slug) return;
      const record = ensureSubmissionRecordIn(submissionStore, slug);
      record.runAttemptCount += 1;
      record.lastRunAt = event.payload?.at || event.createdAt || null;
      record.lastCodeChars = Number(event.payload?.codeChars || 0);
      record.lastCodeLines = Number(event.payload?.codeLines || 0);
      record.lastCodeNonBlankLines =
        Number(event.payload?.codeNonBlankLines || 0);
      if (event.payload?.accepted) {
        record.runAcceptedCount += 1;
        return;
      }
      record.runErrorCount += 1;
    }

    function practiceEventSort(left, right) {
      return (
        Number(left.createdAtMs || 0) - Number(right.createdAtMs || 0) ||
        String(left.id || "").localeCompare(String(right.id || ""))
      );
    }

    function reducePracticeEvents(events) {
      const projection = emptyPracticeProjection();
      events
        .filter((event) => event && typeof event === "object")
        .sort(practiceEventSort)
        .forEach((event) => {
          if (event.type === practiceEventLegacyProgress) {
            projection.progress = normalizedProgressSnapshot(
              event.payload?.progress,
            );
            return;
          }
          if (event.type === practiceEventLegacyTiming) {
            projection.timing = normalizedTimingSnapshot(event.payload?.timing);
            return;
          }
          if (event.type === practiceEventLegacySubmissionStats) {
            projection.submissionStats = normalizedSubmissionStatsSnapshot(
              event.payload?.submissionStats,
            );
            return;
          }
          if (event.type === practiceEventProgressSet) {
            const slug = event.payload?.slug || "";
            if (slug) {
              projection.progress[slug] = normalizedRowStatus(
                event.payload?.state,
              );
            }
            return;
          }
          if (event.type === practiceEventAcceptedTiming) {
            applyAcceptedTimingEvent(projection.timing, event);
            return;
          }
          if (event.type === practiceEventTimingCleared) {
            const slug = event.payload?.slug || "";
            if (slug) delete projection.timing.problems[slug];
            return;
          }
          if (event.type === practiceEventSubmissionAttempt) {
            applySubmissionAttemptEvent(projection.submissionStats, event);
            return;
          }
          if (event.type === practiceEventRunAttempt) {
            applyRunAttemptEvent(projection.submissionStats, event);
          }
        });
      return {
        progress: normalizedProgressSnapshot(projection.progress),
        submissionStats: normalizedSubmissionStatsSnapshot(
          projection.submissionStats,
        ),
        timing: normalizedTimingSnapshot(projection.timing),
      };
    }

    function idbRequestPromise(request) {
      return new Promise((resolve, reject) => {
        request.onsuccess = () => resolve(request.result);
        request.onerror = () => reject(request.error);
      });
    }

    function idbTransactionPromise(transaction) {
      return new Promise((resolve, reject) => {
        transaction.oncomplete = () => resolve();
        transaction.onerror = () => reject(transaction.error);
        transaction.onabort = () => reject(transaction.error);
      });
    }

    function openPracticeDb() {
      if (!window.indexedDB) return Promise.resolve(null);
      if (practiceDbPromise) return practiceDbPromise;
      practiceDbPromise = new Promise((resolve, reject) => {
        const request = window.indexedDB.open(
          practiceDbName,
          practiceDbVersion,
        );
        request.onupgradeneeded = () => {
          const db = request.result;
          const store = db.objectStoreNames.contains(practiceEventStoreName)
            ? request.transaction.objectStore(practiceEventStoreName)
            : db.createObjectStore(practiceEventStoreName, { keyPath: "id" });
          if (!store.indexNames.contains(practiceEventCreatedAtIndex)) {
            store.createIndex(
              practiceEventCreatedAtIndex,
              practiceEventCreatedAtIndex,
              { unique: false },
            );
          }
        };
        request.onsuccess = () => resolve(request.result);
        request.onerror = () => reject(request.error);
        request.onblocked = () => reject(request.error);
      }).catch((error) => {
        console.warn("IndexedDB practice storage is unavailable", error);
        return null;
      });
      return practiceDbPromise;
    }

    function legacyPracticeEvent(id, type, payload) {
      return {
        createdAt: "1970-01-01T00:00:00.000Z",
        createdAtMs: 0,
        id,
        payload: cloneJson(payload, {}),
        schemaVersion: practiceEventSchemaVersion,
        sourceId: "legacy-local-storage",
        type,
      };
    }

    async function addPracticeEventIfMissing(db, event) {
      try {
        const transaction = db.transaction(practiceEventStoreName, "readwrite");
        const done = idbTransactionPromise(transaction);
        const store = transaction.objectStore(practiceEventStoreName);
        await new Promise((resolve, reject) => {
          const request = store.get(event.id);
          request.onsuccess = () => {
            if (!request.result) store.add(event);
            resolve();
          };
          request.onerror = () => reject(request.error);
        });
        await done;
      } catch (error) {
        if (error?.name !== "ConstraintError") throw error;
      }
    }

    async function migrateLegacyPracticeStorage(db) {
      await addPracticeEventIfMissing(
        db,
        legacyPracticeEvent(
          practiceLegacyProgressEventId,
          practiceEventLegacyProgress,
          { progress },
        ),
      );
      await addPracticeEventIfMissing(
        db,
        legacyPracticeEvent(
          practiceLegacyTimingEventId,
          practiceEventLegacyTiming,
          { timing },
        ),
      );
      await addPracticeEventIfMissing(
        db,
        legacyPracticeEvent(
          practiceLegacySubmissionStatsEventId,
          practiceEventLegacySubmissionStats,
          { submissionStats },
        ),
      );
    }

    async function readPracticeEvents() {
      const db = await openPracticeDb();
      if (!db) return [];
      const transaction = db.transaction(practiceEventStoreName, "readonly");
      const done = idbTransactionPromise(transaction);
      const store = transaction.objectStore(practiceEventStoreName);
      const events = await idbRequestPromise(store.getAll());
      await done;
      return Array.isArray(events) ? events.sort(practiceEventSort) : [];
    }

    function practiceEventId(type, createdAtMs) {
      return [
        String(createdAtMs || Date.now()).padStart(13, "0"),
        type,
        randomStorageId(),
      ].join(":");
    }

    async function writePracticeEvent(event) {
      const db = await openPracticeDb();
      if (!db) return false;
      const transaction = db.transaction(practiceEventStoreName, "readwrite");
      const done = idbTransactionPromise(transaction);
      transaction.objectStore(practiceEventStoreName).add(event);
      await done;
      return true;
    }

    function notifyPracticeEvent(event) {
      practiceBroadcastChannel?.postMessage({
        eventId: event.id,
        sourceId: practiceTabId,
        type: "practice-event",
      });
      try {
        localStorage.setItem(
          practiceEventPulseKey,
          JSON.stringify({
            eventId: event.id,
            sourceId: practiceTabId,
            updatedAt: event.createdAt,
          }),
        );
      } catch {
        // Storage events are only a fallback for BroadcastChannel.
      }
    }

    function appendPracticeEvent(
      type,
      payload,
      createdAt = new Date().toISOString(),
    ) {
      const parsedTime = Date.parse(createdAt);
      const createdAtMs = Number.isFinite(parsedTime) ? parsedTime : Date.now();
      const event = {
        createdAt,
        createdAtMs,
        id: practiceEventId(type, createdAtMs),
        payload: cloneJson(payload, {}),
        schemaVersion: practiceEventSchemaVersion,
        sourceId: practiceTabId,
        type,
      };
      writePracticeEvent(event)
        .then((written) => {
          if (written) {
            notifyPracticeEvent(event);
            schedulePracticeEventReload();
          }
        })
        .catch((error) => {
          console.warn("Could not append practice event", error);
        });
    }

    function writePracticeProjectionCache() {
      localStorage.setItem(progressKey, JSON.stringify(progress));
      localStorage.setItem(timingKey, JSON.stringify(timing));
      localStorage.setItem(submissionStatsKey, JSON.stringify(submissionStats));
    }

    function syncVisibleProgressButtons(slug) {
      const status = rowState(slug);
      list?.querySelectorAll(".leetcode-row").forEach((row) => {
        if (!(row instanceof HTMLElement)) return;
        if (row.dataset.slug !== slug) return;
        row.querySelectorAll("[data-action]").forEach((button) => {
          if (!(button instanceof HTMLElement)) return;
          const action = button.dataset.action || "";
          button.classList.toggle("is-on", Boolean(status[action]));
        });
      });
    }

    function syncVisiblePracticeProjectionUi() {
      const progressFilters = new Set(["unsolved", "review", "unmastered"]);
      if (progressFilters.has(state.filter)) {
        render();
        return;
      }
      list?.querySelectorAll(".leetcode-row").forEach((row) => {
        if (!(row instanceof HTMLElement)) return;
        const slug = row.dataset.slug || "";
        if (!slug) return;
        syncVisibleProgressButtons(slug);
        syncSubmissionStatsUi(slug);
        syncProblemSignal(slug);
      });
      syncTimingUi();
      syncSubmissionInsightUi();
    }

    function applyPracticeProjection(projection, options = {}) {
      progress = normalizedProgressSnapshot(projection.progress);
      timing = normalizedTimingSnapshot(projection.timing);
      submissionStats = normalizedSubmissionStatsSnapshot(
        projection.submissionStats,
      );
      writePracticeProjectionCache();
      if (options.updateUi) syncVisiblePracticeProjectionUi();
    }

    async function reloadPracticeEvents(options = {}) {
      const events = await readPracticeEvents();
      applyPracticeProjection(reducePracticeEvents(events), options);
    }

    function schedulePracticeEventReload() {
      if (practiceEventReloadPromise) {
        practiceEventReloadQueued = true;
        return practiceEventReloadPromise;
      }
      practiceEventReloadQueued = false;
      practiceEventReloadPromise = reloadPracticeEvents({ updateUi: true })
        .catch((error) => {
          console.warn("Could not reload practice events", error);
        })
        .finally(() => {
          practiceEventReloadPromise = null;
          if (practiceEventReloadQueued) schedulePracticeEventReload();
        });
      return practiceEventReloadPromise;
    }

    function setupPracticeEventTransport() {
      if (practiceEventTransportReady) return;
      practiceEventTransportReady = true;
      if (window.BroadcastChannel) {
        practiceBroadcastChannel = new BroadcastChannel(practiceBroadcastName);
        practiceBroadcastChannel.addEventListener("message", (event) => {
          if (event.data?.sourceId === practiceTabId) return;
          schedulePracticeEventReload();
        });
      }
      window.addEventListener("storage", (event) => {
        if (event.key !== practiceEventPulseKey || !event.newValue) return;
        try {
          const pulse = JSON.parse(event.newValue);
          if (pulse?.sourceId === practiceTabId) return;
        } catch {
          // A malformed pulse is still enough to know something changed.
        }
        schedulePracticeEventReload();
      });
    }

    async function hydratePracticeEventStore() {
      setupPracticeEventTransport();
      const db = await openPracticeDb();
      if (!db) return;
      await migrateLegacyPracticeStorage(db);
      await reloadPracticeEvents({ updateUi: true });
    }

    let progress = normalizedProgressSnapshot(readJson(progressKey, {}));
    let clicked = readJson(clickedKey, {});
    let editorDrafts = readJson(editorKey, {});
    let editorAppearance = readJson(editorAppearanceKey, {});
    let extraRunCases = readJson(extraRunCasesKey, {});
    let viewState = readJson(viewStateKey, {});
    if (!editorAppearance || typeof editorAppearance !== "object") {
      editorAppearance = {};
    }
    if (!extraRunCases || typeof extraRunCases !== "object") {
      extraRunCases = {};
    }
    if (!viewState || typeof viewState !== "object") {
      viewState = {};
    }
    let editorAutoGrow = localStorage.getItem(editorHeightModeKey) !== "fixed";
    let editorStatementPanelVisible =
      localStorage.getItem(editorStatementPanelKey) !== "off";
    let suppressNextEditorFocusRevealSlug = "";
    let flowMode = normalizedFlowMode(localStorage.getItem(flowModeKey));
    let flowSkipSql = savedFlowSkipEnabled(flowSkipSqlKey);
    let flowSkipFrontend = savedFlowSkipEnabled(flowSkipFrontendKey);
    let timing = normalizedTimingSnapshot(readJson(timingKey, {}));
    let submissionStats = normalizedSubmissionStatsSnapshot(
      readJson(submissionStatsKey, {}),
    );
    const sessionTiming = {
      acceptedDurations: [],
      acceptedSlugs: new Set(),
      elapsedMs: 0,
      startedAt: isPracticeTimingActive() ? Date.now() : 0,
    };
    let activePracticeTimer = { elapsedMs: 0, slug: "", startedAt: 0 };
    let timingMilestone = "";

    function dailyEditorResetEnabled() {
      return localStorage.getItem(editorDailyResetKey) !== "off";
    }

    function normalizedFlowMode(value) {
      if (value === "on" || value === flowModeList) return flowModeList;
      if (value === flowModeInsight) return flowModeInsight;
      return flowModeOff;
    }

    function savedFlowSkipEnabled(key) {
      const value = localStorage.getItem(key);
      if (value === flowModeOff) return false;
      if (value === flowSkipOn) return true;
      return flowSkipDefaultEnabled;
    }

    function problemCodeTemplates(problem) {
      return Array.isArray(problem?.codeTemplates) ? problem.codeTemplates : [];
    }

    function isSqlProblem(problem) {
      const tags = Array.isArray(problem?.tags) ? problem.tags : [];
      if (tags.some((tag) => tag?.slug === sqlProblemTagSlug)) return true;
      return problemCodeTemplates(problem).some((template) => (
        sqlLanguageSlugs.has(languageKey(template?.langSlug || template?.lang))
      ));
    }

    function isPureFrontendProblem(problem) {
      const templates = problemCodeTemplates(problem);
      return templates.length > 0 && templates.every((template) => (
        frontendLanguageSlugs.has(
          languageKey(template?.langSlug || template?.lang),
        )
      ));
    }

    function shouldSkipRouteProblem(problem) {
      return (
        (flowSkipSql && isSqlProblem(problem)) ||
        (flowSkipFrontend && isPureFrontendProblem(problem))
      );
    }

    function writeEditorAppearance() {
      localStorage.setItem(editorAppearanceKey, JSON.stringify(editorAppearance));
    }

    function selectedAppearanceValue(select, value, fallback) {
      if (!(select instanceof HTMLSelectElement)) return value || fallback;
      return Array.from(select.options).some((option) => option.value === value)
        ? value
        : fallback;
    }

    function defaultPageFont() {
      const platform = navigator.platform || "";
      const userAgent = navigator.userAgent || "";
      const deviceSignature = `${platform} ${userAgent}`;
      return appleDevicePattern.test(deviceSignature)
        ? pageFontDefaultApple
        : pageFontDefaultFallback;
    }

    function syncDailyResetUi() {
      const enabled = dailyEditorResetEnabled();
      if (dailyResetToggle instanceof HTMLInputElement) {
        dailyResetToggle.checked = enabled;
      }
      if (dailyResetStatus instanceof HTMLElement) {
        dailyResetStatus.textContent = enabled
          ? (isChinesePage ? "已开启" : "On")
          : (isChinesePage ? "已关闭" : "Off");
      }
    }

    function flowModeLabel() {
      if (flowMode === flowModeInsight) {
        return isChinesePage ? "推荐流：开" : "Suggested flow: on";
      }
      if (flowMode === flowModeList) {
        return isChinesePage ? "顺序流：开" : "List flow: on";
      }
      return isChinesePage ? "沉浸流：关" : "Flow: off";
    }

    function flowModeEnabled() {
      return flowMode !== flowModeOff;
    }

    function insightFlowLabel() {
      if (flowMode === flowModeInsight) {
        return isChinesePage ? "推荐流运行中" : "Suggested flow on";
      }
      return isChinesePage ? "开始推荐流" : "Start suggested flow";
    }

    function insightFlowNote(hasPick = true) {
      if (!hasPick) {
        return isChinesePage ? "暂无可推荐题目" : "No recommendation available";
      }
      if (flowMode === flowModeInsight) {
        return isChinesePage
          ? "完整 AC 后会重新推荐下一题"
          : "Full Accepted submits choose the next recommendation";
      }
      return isChinesePage
        ? "先打开第一推荐；完整 AC 后继续推荐"
        : "Opens the top pick first; full Accepted submits continue it";
    }

    function flowSkipSqlLabel() {
      return flowSkipSql
        ? (isChinesePage ? "跳过 SQL：开" : "Skip SQL: on")
        : (isChinesePage ? "跳过 SQL：关" : "Skip SQL: off");
    }

    function flowSkipFrontendLabel() {
      return flowSkipFrontend
        ? (isChinesePage ? "跳过前端：开" : "Skip FE: on")
        : (isChinesePage ? "跳过前端：关" : "Skip FE: off");
    }

    function flowSkipStatus() {
      const skipped = [];
      if (flowSkipSql) skipped.push(isChinesePage ? "SQL" : "SQL");
      if (flowSkipFrontend) {
        skipped.push(isChinesePage ? "纯前端" : "pure frontend");
      }
      if (skipped.length) {
        return isChinesePage
          ? `刷题跳转将跳过 ${skipped.join("、")} 题`
          : `Practice routing will skip ${skipped.join(" and ")} problems`;
      }
      return isChinesePage
        ? "刷题跳转包含 SQL 和纯前端题"
        : "Practice routing includes SQL and pure frontend problems";
    }

    function syncFlowSkipSqlUi() {
      flowSkipSqlButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        button.classList.toggle("is-on", flowSkipSql);
        button.setAttribute("aria-pressed", String(flowSkipSql));
        button.textContent = flowSkipSqlLabel();
      });
    }

    function syncFlowSkipFrontendUi() {
      flowSkipFrontendButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        button.classList.toggle("is-on", flowSkipFrontend);
        button.setAttribute("aria-pressed", String(flowSkipFrontend));
        button.textContent = flowSkipFrontendLabel();
      });
    }

    function syncFlowSkipUi() {
      syncFlowSkipSqlUi();
      syncFlowSkipFrontendUi();
    }

    function flowSkipBoundaryLabel(direction) {
      return flowSkipSql || flowSkipFrontend
        ? skippedRouteBoundaryLabel(direction)
        : normalRouteBoundaryLabel(direction);
    }

    function syncFlowModeUi() {
      flowModeToggleButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        button.classList.toggle("is-on", flowModeEnabled());
        button.setAttribute("aria-pressed", String(flowModeEnabled()));
        button.textContent = flowModeLabel();
      });
      syncInsightFlowUi();
    }

    function syncInsightFlowUi(hasPick = Boolean(suggestedFlowProblem())) {
      insightFlowButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        button.classList.toggle("is-on", flowMode === flowModeInsight);
        button.disabled = !hasPick;
        button.setAttribute(
          "aria-pressed",
          String(flowMode === flowModeInsight),
        );
        button.textContent = insightFlowLabel();
      });
      insightFlowNotes.forEach((note) => {
        if (note instanceof HTMLElement) {
          note.textContent = insightFlowNote(hasPick);
        }
      });
    }

    function normalRouteBoundaryLabel(direction) {
      if (direction > 0) {
        return isChinesePage
          ? "当前列表没有下一题"
          : "No next problem in the current list";
      }
      return isChinesePage
        ? "当前列表没有上一题"
        : "No previous problem in the current list";
    }

    function skippedRouteBoundaryLabel(direction) {
      if (direction > 0) {
        return isChinesePage
          ? "跳过已关闭题型后当前列表没有下一题"
          : "No next problem after skipped problem types";
      }
      return isChinesePage
        ? "跳过已关闭题型后当前列表没有上一题"
        : "No previous problem after skipped problem types";
    }

    function setFlowSkipValue(key, nextValue) {
      localStorage.setItem(
        key,
        nextValue ? flowSkipOn : flowModeOff,
      );
    }

    function setFlowSkipSql(nextValue) {
      flowSkipSql = Boolean(nextValue);
      setFlowSkipValue(flowSkipSqlKey, flowSkipSql);
      syncFlowSkipUi();
      syncSubmissionInsightUi();
    }

    function toggleFlowSkipSql() {
      setFlowSkipSql(!flowSkipSql);
      timingMilestone = flowSkipStatus();
      syncTimingUi();
      return true;
    }

    function setFlowSkipFrontend(nextValue) {
      flowSkipFrontend = Boolean(nextValue);
      setFlowSkipValue(flowSkipFrontendKey, flowSkipFrontend);
      syncFlowSkipUi();
      syncSubmissionInsightUi();
    }

    function toggleFlowSkipFrontend() {
      setFlowSkipFrontend(!flowSkipFrontend);
      timingMilestone = flowSkipStatus();
      syncTimingUi();
      return true;
    }

    function setFlowMode(nextMode) {
      flowMode = normalizedFlowMode(nextMode);
      localStorage.setItem(flowModeKey, flowMode);
      syncFlowModeUi();
    }

    function toggleFlowMode() {
      const nextMode = flowModeEnabled() ? flowModeOff : flowModeList;
      setFlowMode(nextMode);
      timingMilestone = flowModeEnabled()
        ? (isChinesePage ? "顺序沉浸流已开启" : "List flow enabled")
        : (isChinesePage ? "沉浸刷题流已关闭" : "Immersive flow disabled");
      syncTimingUi();
      return true;
    }

    function applyEditorAppearance() {
      const pageFont = selectedAppearanceValue(
        pageFontSelect,
        editorAppearance.pageFont,
        defaultPageFont(),
      );
      const theme = selectedAppearanceValue(
        editorThemeSelect,
        editorAppearance.theme,
        editorDefaultTheme,
      );
      const font = selectedAppearanceValue(
        editorFontSelect,
        editorAppearance.font,
        editorDefaultFont,
      );
      const size = selectedAppearanceValue(
        editorSizeSelect,
        editorAppearance.size,
        editorDefaultSize,
      );
      const leading = selectedAppearanceValue(
        editorLeadingSelect,
        editorAppearance.leading,
        editorDefaultLeading,
      );
      if (leetcodeShell instanceof HTMLElement) {
        leetcodeShell.dataset.pageFont = pageFont;
        leetcodeShell.dataset.editorTheme = theme;
        leetcodeShell.dataset.editorFont = font;
        leetcodeShell.dataset.editorSize = size;
        leetcodeShell.dataset.editorLeading = leading;
      }
      if (pageFontSelect instanceof HTMLSelectElement) {
        pageFontSelect.value = pageFont;
      }
      if (editorThemeSelect instanceof HTMLSelectElement) {
        editorThemeSelect.value = theme;
      }
      if (editorFontSelect instanceof HTMLSelectElement) {
        editorFontSelect.value = font;
      }
      if (editorSizeSelect instanceof HTMLSelectElement) {
        editorSizeSelect.value = size;
      }
      if (editorLeadingSelect instanceof HTMLSelectElement) {
        editorLeadingSelect.value = leading;
      }
    }

    function boundedInteger(value, fallback, min, max) {
      const number = Number.parseInt(value, 10);
      if (!Number.isFinite(number)) return fallback;
      return Math.max(min, Math.min(max, number));
    }

    function knownProblemSlug(slug) {
      return Boolean(slug && problems.some((item) => item.titleSlug === slug));
    }

    function knownFilter(filter) {
      return filterButtons.some(
        (button) => button instanceof HTMLElement && button.dataset.filter === filter,
      );
    }

    function syncFilterButtons() {
      filterButtons.forEach((button) => {
        if (!(button instanceof HTMLElement)) return;
        button.classList.toggle("is-active", button.dataset.filter === state.filter);
      });
    }

    function savedEditorStateFor(slug) {
      const saved = viewState.editor;
      if (!saved || typeof saved !== "object") return {};
      return saved.slug === slug ? saved : {};
    }

    function visibleEditorViewState() {
      const active = document.activeElement;
      if (active instanceof HTMLTextAreaElement && active.dataset.editorCode) {
        return {
          end: active.selectionEnd,
          focused: true,
          scrollLeft: active.scrollLeft,
          scrollTop: active.scrollTop,
          slug: active.dataset.editorCode,
          start: active.selectionStart,
        };
      }

      const slug = state.expandedSlug || viewState.editor?.slug || "";
      if (!knownProblemSlug(slug)) return {};
      const panel = editorPanelForSlug(slug);
      const textarea = panel?.querySelector("[data-editor-code]");
      const saved = savedEditorStateFor(slug);
      if (!(textarea instanceof HTMLTextAreaElement)) return saved;
      return {
        end: boundedInteger(saved.end, textarea.selectionEnd, 0, textarea.value.length),
        focused: false,
        scrollLeft: textarea.scrollLeft,
        scrollTop: textarea.scrollTop,
        slug,
        start: boundedInteger(saved.start, textarea.selectionStart, 0, textarea.value.length),
      };
    }

    function currentViewState() {
      return {
        customPageSize: customSizeInput instanceof HTMLInputElement
          ? customSizeInput.value
          : "",
        editor: visibleEditorViewState(),
        expandedSlug: state.expandedSlug,
        filter: state.filter,
        page: state.page,
        pageSizeValue: pageSizeSelect instanceof HTMLSelectElement
          ? pageSizeSelect.value
          : "",
        query: state.query,
        scrollY: Math.max(0, Math.round(window.scrollY || 0)),
      };
    }

    function writeViewState() {
      viewState = currentViewState();
      localStorage.setItem(viewStateKey, JSON.stringify(viewState));
    }

    function scheduleViewStateWrite() {
      if (viewStateWriteTimer) window.clearTimeout(viewStateWriteTimer);
      viewStateWriteTimer = window.setTimeout(() => {
        viewStateWriteTimer = 0;
        writeViewState();
      }, viewStateWriteDelayMs);
    }

    function flushViewStateWrite() {
      if (viewStateWriteTimer) {
        window.clearTimeout(viewStateWriteTimer);
        viewStateWriteTimer = 0;
      }
      writeViewState();
    }

    function restoreViewStateControls() {
      if (typeof viewState.query === "string") {
        state.query = viewState.query;
        if (searchInput instanceof HTMLInputElement) {
          searchInput.value = viewState.query;
        }
      }
      if (typeof viewState.filter === "string" && knownFilter(viewState.filter)) {
        state.filter = viewState.filter;
      }
      syncFilterButtons();

      if (pageSizeSelect instanceof HTMLSelectElement) {
        const value = String(viewState.pageSizeValue || "");
        const hasOption = Array.from(pageSizeSelect.options).some(
          (option) => option.value === value,
        );
        if (hasOption) pageSizeSelect.value = value;
      }
      if (customSizeInput instanceof HTMLInputElement) {
        const customSize = boundedInteger(viewState.customPageSize, 20, 1, maxPageSize);
        customSizeInput.value = String(customSize);
        customSizeInput.hidden = pageSizeSelect?.value !== "custom";
      }

      state.page = boundedInteger(viewState.page, state.page, 1, Number.MAX_SAFE_INTEGER);
      state.expandedSlug = knownProblemSlug(viewState.expandedSlug)
        ? viewState.expandedSlug
        : "";
      if (!state.expandedSlug) return;

      const items = orderedProblems();
      const index = items.findIndex((item) => item.titleSlug === state.expandedSlug);
      if (index === -1) {
        state.expandedSlug = "";
        return;
      }
      state.page = Math.floor(index / pageSize()) + 1;
    }

    function restoreEditorViewState() {
      const editorState = viewState.editor;
      if (!editorState || typeof editorState !== "object") return;
      const slug = knownProblemSlug(editorState.slug)
        ? editorState.slug
        : state.expandedSlug;
      if (!slug || slug !== state.expandedSlug) return;
      const panel = editorPanelForSlug(slug);
      const textarea = panel?.querySelector("[data-editor-code]");
      if (!(textarea instanceof HTMLTextAreaElement)) return;

      const start = boundedInteger(editorState.start, 0, 0, textarea.value.length);
      const end = boundedInteger(editorState.end, start, 0, textarea.value.length);
      textarea.setSelectionRange(start, Math.max(start, end));
      textarea.scrollTop = boundedInteger(
        editorState.scrollTop,
        0,
        0,
        Number.MAX_SAFE_INTEGER,
      );
      textarea.scrollLeft = boundedInteger(
        editorState.scrollLeft,
        0,
        0,
        Number.MAX_SAFE_INTEGER,
      );
      syncEditorHighlight(panel, textarea, editorContextFor(textarea)?.lang || "");
      if (editorState.focused) {
        textarea.focus({ preventScroll: true });
      }
    }

    function restoreViewStateAfterRender() {
      window.requestAnimationFrame(() => {
        restoreEditorViewState();
        const scrollY = boundedInteger(
          viewState.scrollY,
          0,
          0,
          Number.MAX_SAFE_INTEGER,
        );
        window.scrollTo({ top: scrollY, left: 0, behavior: "auto" });
      });
    }

    function writeState() {
      rollEditorDraftsForToday();
      localStorage.setItem(progressKey, JSON.stringify(progress));
      localStorage.setItem(clickedKey, JSON.stringify(clicked));
      localStorage.setItem(editorKey, JSON.stringify(editorDrafts));
    }

    function writeExtraRunCases() {
      localStorage.setItem(extraRunCasesKey, JSON.stringify(extraRunCases));
    }

    function writeTiming() {
      localStorage.setItem(timingKey, JSON.stringify(timing));
    }

    function writeSubmissionStats() {
      localStorage.setItem(submissionStatsKey, JSON.stringify(submissionStats));
    }

    function pad2(value) {
      return String(value).padStart(2, "0");
    }

    function localDateKey(date = new Date()) {
      const parts = Object.fromEntries(
        timingDateFormatter
          .formatToParts(date)
          .map((part) => [part.type, part.value]),
      );
      return [parts.year, parts.month, parts.day].join("-");
    }

    let insightFatigueDateKey = localDateKey();

    function syncInsightDateBoundary() {
      const todayKey = localDateKey();
      if (todayKey === insightFatigueDateKey) return;
      insightFatigueDateKey = todayKey;
      syncSubmissionInsightUi();
    }

    function rollExtraRunCasesForToday() {
      const todayKey = localDateKey();
      const storedKey = localStorage.getItem(extraRunCasesDayKey);
      if (storedKey === todayKey) return false;
      localStorage.setItem(extraRunCasesDayKey, todayKey);
      if (!storedKey) return false;
      extraRunCases = {};
      writeExtraRunCases();
      return true;
    }

    function extraRunCaseList(slug) {
      const cases = extraRunCases[slug];
      return Array.isArray(cases)
        ? cases.map((item) => String(item || "").trim()).filter(Boolean)
        : [];
    }

    function extraRunTestcasesFor(problem) {
      return extraRunCaseList(problem.titleSlug).join("\n");
    }

    function normalizedExtraRunCase(testcase) {
      return String(testcase || "")
        .split(/\r?\n/)
        .map((line) => line.trim())
        .filter(Boolean)
        .join("\n");
    }

    function addExtraRunCase(slug, testcase) {
      const normalized = normalizedExtraRunCase(testcase);
      if (!slug || !normalized) return false;
      const cases = extraRunCaseList(slug);
      const exists = cases.some(
        (item) => normalizedExtraRunCase(item) === normalized,
      );
      if (exists) return false;
      cases.push(normalized);
      extraRunCases[slug] = cases.slice(-maxExtraRunCasesPerProblem);
      writeExtraRunCases();
      return true;
    }

    function rollEditorDraftsForToday() {
      const todayKey = localDateKey();
      const storedKey = localStorage.getItem(editorDraftDayKey);
      if (storedKey === todayKey) return false;
      localStorage.setItem(editorDraftDayKey, todayKey);
      if (!storedKey) return false;
      if (!dailyEditorResetEnabled()) return false;
      editorDrafts = {};
      localStorage.setItem(editorKey, JSON.stringify(editorDrafts));
      return true;
    }

    function syncEditorDraftDay() {
      const extraCasesReset = rollExtraRunCasesForToday();
      if (!rollEditorDraftsForToday()) {
        if (extraCasesReset) scheduleViewStateWrite();
        return;
      }
      state.expandedSlug = "";
      render();
      scheduleViewStateWrite();
    }

    syncDailyResetUi();
    syncFlowModeUi();
    syncFlowSkipUi();
    applyEditorAppearance();
    rollExtraRunCasesForToday();
    rollEditorDraftsForToday();

    function dateKeyParts(dateKey) {
      const [year, month, day] = String(dateKey || "")
        .split("-")
        .map((part) => Number.parseInt(part, 10));
      if (!year || !month || !day) return null;
      return { day, month, year };
    }

    function shiftDateKey(dateKey, offsetDays) {
      const parts = dateKeyParts(dateKey);
      if (!parts) return localDateKey();
      const date = new Date(
        Date.UTC(parts.year, parts.month - 1, parts.day) +
          offsetDays * timingDayMs,
      );
      return [
        date.getUTCFullYear(),
        pad2(date.getUTCMonth() + 1),
        pad2(date.getUTCDate()),
      ].join("-");
    }

    function shortDateLabel(dateKey) {
      const parts = dateKeyParts(dateKey);
      if (!parts) return dateKey;
      return `${pad2(parts.month)}/${pad2(parts.day)}`;
    }

    function formatDuration(ms) {
      const totalSeconds = Math.max(0, Math.floor(Number(ms || 0) / 1000));
      const hours = Math.floor(totalSeconds / 3600);
      const minutes = Math.floor((totalSeconds % 3600) / 60);
      const seconds = totalSeconds % 60;
      if (hours > 0) return `${hours}:${pad2(minutes)}:${pad2(seconds)}`;
      return `${minutes}:${pad2(seconds)}`;
    }

    function formatProblemCount(count) {
      const value = Number(count || 0);
      return isChinesePage ? `${value} 题` : `${value} solved`;
    }

    function formatTodayBestCount(todayCount, bestCount) {
      return `${Number(todayCount || 0)}/${bestCount || "--"}`;
    }

    function todayBestCountLabel(todayCount, bestCount) {
      const bestLabel = bestCount || (isChinesePage ? "暂无" : "none yet");
      return isChinesePage
        ? `今日 ${todayCount} 题，历史纪录 ${bestLabel}`
        : `Today ${todayCount}, best day ${bestLabel}`;
    }

    function dayTiming(dateKey = localDateKey()) {
      if (!timing.days[dateKey] || typeof timing.days[dateKey] !== "object") {
        timing.days[dateKey] = {
          acceptedCount: 0,
          acceptedSlugs: [],
          bestMs: null,
          firstAcceptedAt: null,
          lastAcceptedAt: null,
          totalAcceptedMs: 0,
        };
      }
      const day = timing.days[dateKey];
      if (!Array.isArray(day.acceptedSlugs)) day.acceptedSlugs = [];
      day.acceptedCount = Number(day.acceptedCount || 0);
      day.totalAcceptedMs = Number(day.totalAcceptedMs || 0);
      day.bestMs = day.bestMs === null ? null : Number(day.bestMs || 0) || null;
      day.firstAcceptedAt = day.firstAcceptedAt || null;
      day.lastAcceptedAt = day.lastAcceptedAt || null;
      return day;
    }

    function dayUniqueCount(day) {
      return Array.isArray(day?.acceptedSlugs) ? day.acceptedSlugs.length : 0;
    }

    function dayAcceptedCount(day) {
      return Number(day?.acceptedCount || 0);
    }

    function dayAverageMs(day) {
      const acceptedCount = dayAcceptedCount(day);
      return acceptedCount ? Number(day?.totalAcceptedMs || 0) / acceptedCount : 0;
    }

    function validDayKeys() {
      return Object.keys(timing.days || {})
        .filter((dateKey) => /^\d{4}-\d{2}-\d{2}$/.test(dateKey))
        .sort();
    }

    function bestDayStats(excludeKey = "") {
      return validDayKeys().reduce(
        (best, dateKey) => {
          if (dateKey === excludeKey) return best;
          const day = timing.days[dateKey];
          const unique = dayUniqueCount(day);
          if (!unique) return best;
          const accepted = dayAcceptedCount(day);
          const averageMs = dayAverageMs(day);
          const isBetter =
            unique > best.unique ||
            (unique === best.unique && accepted > best.accepted) ||
            (unique === best.unique &&
              accepted === best.accepted &&
              averageMs > 0 &&
              (!best.averageMs || averageMs < best.averageMs));
          return isBetter
            ? { accepted, averageMs, dateKey, unique }
            : best;
        },
        { accepted: 0, averageMs: 0, dateKey: "", unique: 0 },
      );
    }

    function fastestDayStats(excludeKey = "") {
      return validDayKeys().reduce(
        (fastest, dateKey) => {
          if (dateKey === excludeKey) return fastest;
          const day = timing.days[dateKey];
          const averageMs = dayAverageMs(day);
          if (!averageMs) return fastest;
          return !fastest.averageMs || averageMs < fastest.averageMs
            ? { averageMs, dateKey }
            : fastest;
        },
        { averageMs: 0, dateKey: "" },
      );
    }

    function recentTimingStats(todayKey = localDateKey()) {
      const slugs = new Set();
      let accepted = 0;
      let activeDays = 0;
      let totalMs = 0;
      for (let index = 0; index < 7; index += 1) {
        const dateKey = shiftDateKey(todayKey, -index);
        const day = timing.days[dateKey];
        if (!day) continue;
        day.acceptedSlugs?.forEach((slug) => slugs.add(slug));
        accepted += dayAcceptedCount(day);
        totalMs += Number(day.totalAcceptedMs || 0);
        if (dayUniqueCount(day)) activeDays += 1;
      }
      return {
        accepted,
        activeDays,
        averageMs: accepted ? totalMs / accepted : 0,
        unique: slugs.size,
      };
    }

    function streakStats(todayKey = localDateKey()) {
      const todaySolved = dayUniqueCount(timing.days[todayKey]) > 0;
      let cursor = todaySolved ? todayKey : shiftDateKey(todayKey, -1);
      let count = 0;
      while (dayUniqueCount(timing.days[cursor]) > 0) {
        count += 1;
        cursor = shiftDateKey(cursor, -1);
      }
      return {
        count,
        pendingToday: !todaySolved && count > 0,
      };
    }

    function timingOverview() {
      const todayKey = localDateKey();
      const today = dayTiming(todayKey);
      return {
        bestDay: bestDayStats(),
        bestDayBeforeToday: bestDayStats(todayKey),
        fastestDayBeforeToday: fastestDayStats(todayKey),
        recent: recentTimingStats(todayKey),
        streak: streakStats(todayKey),
        today,
        todayKey,
        todayUnique: dayUniqueCount(today),
      };
    }

    function formatStreak(streak) {
      if (!streak.count) return isChinesePage ? "0 天" : "0 days";
      const suffix = streak.pendingToday
        ? (isChinesePage ? "待续" : "pending")
        : "";
      return isChinesePage
        ? `${streak.count} 天${suffix}`
        : `${streak.count} days${suffix ? ` ${suffix}` : ""}`;
    }

    function defaultTimingMilestone(overview) {
      const bestBefore = overview.bestDayBeforeToday;
      if (!overview.todayUnique) {
        if (overview.streak.pendingToday) {
          return isChinesePage
            ? `连续 ${overview.streak.count} 天待续，今天 AC 后续上`
            : `${overview.streak.count}-day streak pending today`;
        }
        return isChinesePage
          ? "今天 AC 后自动进入日统计"
          : "Daily stats start after today's first Accepted";
      }
      if (!bestBefore.unique || overview.todayUnique > bestBefore.unique) {
        return isChinesePage
          ? `今日新纪录 ${overview.todayUnique} 题`
          : `New daily record: ${overview.todayUnique}`;
      }
      if (overview.todayUnique === bestBefore.unique) {
        return isChinesePage
          ? `今日追平历史日记录 ${overview.todayUnique} 题`
          : `Tied daily record: ${overview.todayUnique}`;
      }
      return isChinesePage
        ? `距历史日记录还差 ${bestBefore.unique - overview.todayUnique} 题`
        : `${bestBefore.unique - overview.todayUnique} away from daily record`;
    }

    function acceptedTimingMilestone(result) {
      const messages = [];
      if (result.isNewDailyRecord) {
        messages.push(isChinesePage ? "今日新纪录" : "new daily record");
      } else if (result.tiedDailyRecord) {
        messages.push(isChinesePage ? "追平日记录" : "tied daily record");
      }
      if (result.isPersonalBest) {
        messages.push(isChinesePage ? "本题 PB" : "problem PB");
      }
      if (result.isFastestDayAverage) {
        messages.push(isChinesePage ? "均速新高" : "best daily pace");
      }
      if (result.streakCount > 1 && !result.streakPendingToday) {
        messages.push(
          isChinesePage
            ? `连续 ${result.streakCount} 天`
            : `${result.streakCount}-day streak`,
        );
      }
      if (!messages.length) {
        messages.push(
          isChinesePage
            ? `今日 ${result.todayUnique} 题`
            : `${result.todayUnique} today`,
        );
      }
      return messages.join(" · ");
    }

    function renderTimingHistory(overview) {
      return Array.from({ length: timingHistoryDays }, (_, index) => {
        const dateKey = shiftDateKey(overview.todayKey, -index);
        const day = timing.days[dateKey] || {};
        const unique = dayUniqueCount(day);
        const averageMs = dayAverageMs(day);
        const classes = [
          "leetcode-history-day",
          dateKey === overview.todayKey ? "is-today" : "",
          unique && unique === overview.bestDay.unique ? "is-best" : "",
          unique ? "" : "is-empty",
        ].filter(Boolean).join(" ");
        const label = dateKey === overview.todayKey
          ? (isChinesePage ? "今天" : "Today")
          : shortDateLabel(dateKey);
        const avgLabel = averageMs ? formatDuration(averageMs) : "--";
        const countLabel = isChinesePage ? `${unique}题` : `${unique}`;
        return `
          <span class="${classes}" aria-label="${escapeHtml(dateKey)}">
            <b>${escapeHtml(label)}</b>
            <em>${escapeHtml(countLabel)}</em>
            <small>${escapeHtml(avgLabel)}</small>
          </span>
        `;
      }).join("");
    }

    function problemTiming(slug) {
      if (!slug) return {};
      if (!timing.problems[slug] || typeof timing.problems[slug] !== "object") {
        timing.problems[slug] = {
          acceptedCount: 0,
          bestMs: null,
          lastAcceptedAt: null,
          lastMs: null,
          totalAcceptedMs: 0,
        };
      }
      const record = timing.problems[slug];
      record.acceptedCount = Number(record.acceptedCount || 0);
      record.totalAcceptedMs = Number(record.totalAcceptedMs || 0);
      record.bestMs = record.bestMs === null ? null : Number(record.bestMs || 0);
      record.lastMs = record.lastMs === null ? null : Number(record.lastMs || 0);
      return record;
    }

    function storedProblemTiming(slug) {
      const record = slug ? timing.problems[slug] : null;
      return record && typeof record === "object" ? record : {};
    }

    function hasProblemTimingRecord(slug) {
      const record = storedProblemTiming(slug);
      return Boolean(record.bestMs || record.lastMs || record.acceptedCount);
    }

    function isPracticeTimingActive() {
      const focused = typeof document.hasFocus === "function"
        ? document.hasFocus()
        : true;
      return !document.hidden && focused;
    }

    function startElapsedClock(clock, now = Date.now()) {
      if (clock.startedAt || !isPracticeTimingActive()) return;
      clock.startedAt = now;
    }

    function pauseElapsedClock(clock, now = Date.now()) {
      if (!clock.startedAt) return;
      clock.elapsedMs += Math.max(0, now - clock.startedAt);
      clock.startedAt = 0;
    }

    function resetElapsedClock(clock, now = Date.now()) {
      clock.elapsedMs = 0;
      clock.startedAt = isPracticeTimingActive() ? now : 0;
    }

    function elapsedClockMs(clock, now = Date.now()) {
      const currentSegment = clock.startedAt
        ? Math.max(0, now - clock.startedAt)
        : 0;
      return Math.max(0, Number(clock.elapsedMs || 0) + currentSegment);
    }

    function syncPracticeClockState() {
      const now = Date.now();
      const active = isPracticeTimingActive();
      if (!active) {
        pauseElapsedClock(sessionTiming, now);
        pauseElapsedClock(activePracticeTimer, now);
        return false;
      }
      startElapsedClock(sessionTiming, now);
      if (activePracticeTimer.slug) startElapsedClock(activePracticeTimer, now);
      return true;
    }

    function activePracticeElapsed(now = Date.now()) {
      if (!activePracticeTimer.slug) return 0;
      return elapsedClockMs(activePracticeTimer, now);
    }

    function setTextAll(selector, value) {
      document.querySelectorAll(selector).forEach((node) => {
        node.textContent = value;
      });
    }

    function setTextAndLabelAll(selector, value, label) {
      document.querySelectorAll(selector).forEach((node) => {
        node.textContent = value;
        if (node instanceof HTMLElement) {
          node.setAttribute("aria-label", label);
        }
      });
    }

    function syncTimingUi() {
      const practiceTimingActive = syncPracticeClockState();
      const now = Date.now();
      const elapsed = activePracticeElapsed(now);
      const activeSlug = activePracticeTimer.slug;
      const activeRecord = activeSlug ? storedProblemTiming(activeSlug) : {};
      const sessionElapsed = elapsedClockMs(sessionTiming, now);
      const sessionAcceptedCount = sessionTiming.acceptedDurations.length;
      const sessionAverage = sessionAcceptedCount
        ? sessionTiming.acceptedDurations.reduce((sum, item) => sum + item, 0) /
          sessionAcceptedCount
        : 0;
      const overview = timingOverview();
      const todayBest = overview.bestDay.unique || "--";
      const todayBestText = formatTodayBestCount(
        overview.todayUnique,
        todayBest,
      );
      const milestone = practiceTimingActive
        ? timingMilestone || defaultTimingMilestone(overview)
        : (isChinesePage
          ? "计时已暂停，回到本页后继续"
          : "Timing paused; return to this page to resume");

      setTextAll("[data-timing-active]", formatDuration(elapsed));
      setTextAll("[data-timing-session]", formatDuration(sessionElapsed));
      setTextAll(
        "[data-timing-session-solved]",
        formatProblemCount(sessionTiming.acceptedSlugs.size),
      );
      setTextAll(
        "[data-timing-session-avg]",
        sessionAverage ? formatDuration(sessionAverage) : "--",
      );
      setTextAndLabelAll(
        "[data-timing-today]",
        todayBestText,
        todayBestCountLabel(overview.todayUnique, todayBest),
      );
      setTextAll("[data-timing-streak]", formatStreak(overview.streak));
      setTextAll("[data-timing-week]", formatProblemCount(overview.recent.unique));
      setTextAll(
        "[data-timing-current-best]",
        activeRecord.bestMs ? formatDuration(activeRecord.bestMs) : "--",
      );
      setTextAll("[data-timing-timezone]", isChinesePage ? "北京时间" : "Beijing time");
      setTextAll("[data-timing-milestone]", milestone);
      document.querySelectorAll("[data-timing-history-list]").forEach((node) => {
        if (node instanceof HTMLElement) {
          node.innerHTML = renderTimingHistory(overview);
        }
      });

      document.querySelectorAll("[data-problem-active]").forEach((node) => {
        const slug = node instanceof HTMLElement ? node.dataset.problemActive : "";
        node.textContent =
          slug && slug === activeSlug ? formatDuration(elapsed) : "0:00";
      });
      document.querySelectorAll("[data-problem-best]").forEach((node) => {
        const slug = node instanceof HTMLElement ? node.dataset.problemBest : "";
        const record = slug ? storedProblemTiming(slug) : {};
        node.textContent = record.bestMs ? formatDuration(record.bestMs) : "--";
      });
      document.querySelectorAll("[data-problem-last]").forEach((node) => {
        const slug = node instanceof HTMLElement ? node.dataset.problemLast : "";
        const record = slug ? storedProblemTiming(slug) : {};
        node.textContent = record.lastMs ? formatDuration(record.lastMs) : "--";
      });
      document.querySelectorAll("[data-timing-action='restart-problem']").forEach((button) => {
        if (button instanceof HTMLButtonElement) {
          button.disabled = !activePracticeTimer.slug;
        }
      });
      document.querySelectorAll("[data-timing-action='clear-problem-record']").forEach((button) => {
        if (button instanceof HTMLButtonElement) {
          button.disabled = !hasProblemTimingRecord(activePracticeTimer.slug);
        }
      });
      syncInsightDateBoundary();
    }

    function syncActivePracticeTimerAfterRender() {
      const hasPanel = Boolean(
        state.expandedSlug &&
          Array.from(list?.querySelectorAll("[data-editor-panel]") || []).some(
            (item) =>
              item instanceof HTMLElement &&
              item.dataset.editorPanel === state.expandedSlug,
          ),
      );
      const nextSlug = hasPanel ? state.expandedSlug : "";
      if (activePracticeTimer.slug !== nextSlug) {
        const now = Date.now();
        activePracticeTimer = {
          elapsedMs: 0,
          slug: nextSlug,
          startedAt: nextSlug && isPracticeTimingActive() ? now : 0,
        };
      }
      syncTimingUi();
    }

    function resetSessionTiming() {
      sessionTiming.acceptedDurations = [];
      sessionTiming.acceptedSlugs = new Set();
      resetElapsedClock(sessionTiming);
      timingMilestone = "";
      if (activePracticeTimer.slug) {
        resetElapsedClock(activePracticeTimer);
      }
      syncTimingUi();
      syncSubmissionInsightUi();
    }

    function restartActiveProblemTimer() {
      if (!activePracticeTimer.slug) return;
      resetElapsedClock(activePracticeTimer);
      timingMilestone = isChinesePage
        ? "已重开本题计时"
        : "Current problem timer restarted";
      syncTimingUi();
    }

    function clearActiveProblemTimingRecord(slugOverride = "") {
      const slug = slugOverride || activePracticeTimer.slug;
      if (!slug || !hasProblemTimingRecord(slug)) return;
      const message = isChinesePage
        ? "确认清空当前题的 PB 和上次 AC 记录？今日统计不会被回滚。"
        : "Clear this problem's PB and last Accepted record? Daily stats stay unchanged.";
      if (!window.confirm(message)) return;
      delete timing.problems[slug];
      timingMilestone = isChinesePage
        ? "已清本题 PB / 上次 AC 记录"
        : "Problem PB / last Accepted cleared";
      writeTiming();
      appendPracticeEvent(practiceEventTimingCleared, { slug });
      syncTimingUi();
      syncSubmissionInsightUi();
    }

    function recordAcceptedTiming(slug) {
      syncPracticeClockState();
      const elapsed = Math.max(0, activePracticeTimer.slug === slug
        ? activePracticeElapsed()
        : 0);
      const todayKey = localDateKey();
      const beforeOverview = timingOverview();
      const beforeTodayUnique = beforeOverview.todayUnique;
      const record = problemTiming(slug);
      const previousBest = record.bestMs || null;
      const isPersonalBest = !previousBest || elapsed < previousBest;
      const nowIso = new Date().toISOString();
      record.acceptedCount += 1;
      record.totalAcceptedMs += elapsed;
      record.lastAcceptedAt = nowIso;
      record.lastMs = elapsed;
      record.bestMs = isPersonalBest ? elapsed : previousBest;

      const today = dayTiming(todayKey);
      today.acceptedCount += 1;
      today.totalAcceptedMs += elapsed;
      today.bestMs = !today.bestMs || elapsed < today.bestMs ? elapsed : today.bestMs;
      today.firstAcceptedAt = today.firstAcceptedAt || nowIso;
      today.lastAcceptedAt = nowIso;
      if (!today.acceptedSlugs.includes(slug)) today.acceptedSlugs.push(slug);

      sessionTiming.acceptedDurations.push(elapsed);
      sessionTiming.acceptedSlugs.add(slug);
      if (activePracticeTimer.slug === slug) {
        resetElapsedClock(activePracticeTimer);
      }
      const afterOverview = timingOverview();
      const todayUnique = afterOverview.todayUnique;
      const bestBefore = beforeOverview.bestDayBeforeToday;
      const wasNewUnique = todayUnique > beforeTodayUnique;
      const isNewDailyRecord = wasNewUnique &&
        (!bestBefore.unique || todayUnique > bestBefore.unique);
      const tiedDailyRecord = wasNewUnique &&
        bestBefore.unique > 0 &&
        todayUnique === bestBefore.unique;
      const todayAverage = dayAverageMs(today);
      const fastestBefore = beforeOverview.fastestDayBeforeToday;
      const isFastestDayAverage = Boolean(
        todayAverage &&
          (!fastestBefore.averageMs || todayAverage < fastestBefore.averageMs),
      );
      timingMilestone = acceptedTimingMilestone({
        isFastestDayAverage,
        isNewDailyRecord,
        isPersonalBest,
        streakCount: afterOverview.streak.count,
        streakPendingToday: afterOverview.streak.pendingToday,
        tiedDailyRecord,
        todayUnique,
      });
      writeTiming();
      appendPracticeEvent(
        practiceEventAcceptedTiming,
        {
          acceptedAt: nowIso,
          dateKey: todayKey,
          elapsedMs: elapsed,
          slug,
        },
        nowIso,
      );
      syncTimingUi();
      return {
        bestMs: record.bestMs,
        elapsed,
        isNewDailyRecord,
        isPersonalBest,
        milestone: timingMilestone,
        tiedDailyRecord,
      };
    }

    function codeMetrics(code) {
      const text = String(code || "").replace(/\r\n/g, "\n");
      const lines = text ? text.split("\n") : [];
      return {
        chars: text.length,
        lines: Math.max(1, lines.length),
        nonBlankLines: Math.max(
          1,
          lines.filter((line) => line.trim()).length,
        ),
      };
    }

    function submissionEvents(record) {
      return Array.isArray(record?.events) ? record.events : [];
    }

    function acceptedSubmissionEvents(record) {
      return submissionEvents(record).filter((event) => event?.accepted);
    }

    function lastAcceptedSubmissionEvent(record) {
      const events = acceptedSubmissionEvents(record);
      return events[events.length - 1] || null;
    }

    function problemSubmissionStats(slug) {
      if (!slug) return {};
      if (
        !submissionStats.problems[slug] ||
        typeof submissionStats.problems[slug] !== "object"
      ) {
        submissionStats.problems[slug] = {
          acceptedCount: 0,
          attemptCount: 0,
          bestMs: null,
          errorCount: 0,
          events: [],
          firstSubmittedAt: null,
          lastAcceptedAt: null,
          lastCodeChars: 0,
          lastCodeLines: 0,
          lastCodeNonBlankLines: 0,
          lastElapsedMs: null,
          lastRunAt: null,
          lastSubmittedAt: null,
          runAcceptedCount: 0,
          runAttemptCount: 0,
          runErrorCount: 0,
          totalAcceptedMs: 0,
        };
      }
      const record = submissionStats.problems[slug];
      record.acceptedCount = Number(record.acceptedCount || 0);
      record.attemptCount = Number(record.attemptCount || 0);
      record.errorCount = Number(record.errorCount || 0);
      record.runAcceptedCount = Number(record.runAcceptedCount || 0);
      record.runAttemptCount = Number(record.runAttemptCount || 0);
      record.runErrorCount = Number(record.runErrorCount || 0);
      record.totalAcceptedMs = Number(record.totalAcceptedMs || 0);
      record.events = submissionEvents(record).slice(-submissionHistoryLimit);
      record.bestMs = record.bestMs === null ? null : Number(record.bestMs || 0);
      record.lastElapsedMs =
        record.lastElapsedMs === null ? null : Number(record.lastElapsedMs || 0);
      record.lastCodeChars = Number(record.lastCodeChars || 0);
      record.lastCodeLines = Number(record.lastCodeLines || 0);
      record.lastCodeNonBlankLines = Number(record.lastCodeNonBlankLines || 0);
      record.firstSubmittedAt = record.firstSubmittedAt || null;
      record.lastAcceptedAt = record.lastAcceptedAt || null;
      record.lastRunAt = record.lastRunAt || null;
      record.lastSubmittedAt = record.lastSubmittedAt || null;
      return record;
    }

    function storedProblemSubmissionStats(slug) {
      const record = slug ? submissionStats.problems[slug] : null;
      return record && typeof record === "object" ? record : {};
    }

    function averageAcceptedMs(record) {
      const accepted = Number(record?.acceptedCount || 0);
      return accepted ? Number(record?.totalAcceptedMs || 0) / accepted : 0;
    }

    function totalErrorCount(record) {
      return Number(record?.errorCount || 0) + Number(record?.runErrorCount || 0);
    }

    function elapsedPerTenLinesMs(elapsedMs, nonBlankLines) {
      const elapsed = Number(elapsedMs || 0);
      const lines = Number(nonBlankLines || 0);
      if (!elapsed || !lines) return 0;
      return elapsed / Math.max(1, lines / submissionTenLineUnit);
    }

    function lastAcceptedSpeedMs(record) {
      const event = lastAcceptedSubmissionEvent(record);
      if (!event) return 0;
      return elapsedPerTenLinesMs(event.elapsedMs, event.codeNonBlankLines);
    }

    function bestAcceptedSpeedMs(record) {
      return acceptedSubmissionEvents(record).reduce((best, event) => {
        const current = elapsedPerTenLinesMs(
          event.elapsedMs,
          event.codeNonBlankLines,
        );
        if (!current) return best;
        return !best || current < best ? current : best;
      }, 0);
    }

    function averageAcceptedSpeedMs(record) {
      const speeds = acceptedSubmissionEvents(record)
        .map((event) => elapsedPerTenLinesMs(
          event.elapsedMs,
          event.codeNonBlankLines,
        ))
        .filter(Boolean);
      if (!speeds.length) return 0;
      return speeds.reduce((sum, speed) => sum + speed, 0) / speeds.length;
    }

    function scoreAcceptedSpeedMs(record) {
      const lastSpeed = lastAcceptedSpeedMs(record);
      const averageSpeed = averageAcceptedSpeedMs(record);
      if (!lastSpeed) return averageSpeed;
      if (!averageSpeed) return lastSpeed;
      return lastSpeed * lastAcceptedSpeedScoreWeight +
        averageSpeed * averageAcceptedSpeedScoreWeight;
    }

    function daysSinceIso(value) {
      const time = Date.parse(String(value || ""));
      if (!Number.isFinite(time)) return 0;
      return Math.max(0, (Date.now() - time) / timingDayMs);
    }

    function recentAcceptedStreak(record) {
      let count = 0;
      const events = submissionEvents(record);
      for (let index = events.length - 1; index >= 0; index -= 1) {
        if (!events[index]?.accepted) break;
        count += 1;
      }
      return count;
    }

    function smoothedFailureRate(
      errors,
      attempts,
      priorAttempts,
      priorRate,
    ) {
      if (!attempts) return 0;
      const priorErrors = priorAttempts * priorRate;
      return (errors + priorErrors) / (attempts + priorAttempts);
    }

    function failurePenalty(
      errors,
      attempts,
      priorAttempts,
      priorRate,
      rateWeight,
      countWeight,
      cap,
    ) {
      if (!attempts || !errors) return 0;
      const rateSignal = smoothedFailureRate(
        errors,
        attempts,
        priorAttempts,
        priorRate,
      ) * rateWeight;
      const countSignal = Math.log1p(errors) * countWeight;
      return Math.min(cap, rateSignal + countSignal);
    }

    function clampScore(value) {
      return Math.max(0, Math.min(submissionScoreMax, Math.round(value)));
    }

    function clampValue(value, min, max) {
      return Math.max(min, Math.min(max, value));
    }

    function slowSpeedPenalty(speedMs) {
      if (!speedMs) return 0;
      const seconds = speedMs / 1000;
      if (seconds <= submissionSlowSecondsPerTenLines) return 0;
      const range =
        submissionVerySlowSecondsPerTenLines -
        submissionSlowSecondsPerTenLines;
      const ratio = Math.min(
        1,
        (seconds - submissionSlowSecondsPerTenLines) / range,
      );
      return ratio * submissionSpeedPenaltyCap;
    }

    function rankValueScore(rank, maxRank, cap) {
      const currentRank = Number(rank || 0);
      if (!currentRank || currentRank >= recommendationRankFallback) return 0;
      const normalizedMaxRank = Math.max(maxRank, currentRank);
      const denominator = Math.log1p(normalizedMaxRank);
      if (!denominator) return 0;
      const ratio = 1 - Math.log(currentRank) / denominator;
      return clampValue(ratio * cap, 0, cap);
    }

    function difficultyIndex(problem) {
      const difficulty = String(problem?.difficulty || "").toLowerCase();
      if (difficulty.includes("easy") || difficulty.includes("简单")) return 0;
      if (difficulty.includes("hard") || difficulty.includes("困难")) return 2;
      return 1;
    }

    function tagSlugSet(problem) {
      return new Set((problem?.tags || []).map((tag) => tag.slug));
    }

    function sharedTagSlugs(left, right) {
      const rightTags = tagSlugSet(right);
      return (left?.tags || [])
        .map((tag) => tag.slug)
        .filter((slug) => rightTags.has(slug));
    }

    function relatedQuestionSlugs(problem) {
      const related = problem?.relatedQuestions || {};
      return [
        ...(related.official || []),
        ...(related.series || []),
        ...(related.topicPeers || []),
      ].map((item) => item.titleSlug);
    }

    function hasRelatedLink(left, right) {
      if (!left || !right || left.titleSlug === right.titleSlug) return false;
      return relatedQuestionSlugs(left).includes(right.titleSlug) ||
        relatedQuestionSlugs(right).includes(left.titleSlug);
    }

    function byteDanceValueScore(problem) {
      if (!problem?.bytedance) return 0;
      const buckets = byteDanceBuckets(problem);
      const bucketScore = Object.entries(recommendationByteDanceBucketWeights)
        .reduce((score, [bucket, weight]) => {
          return score + rankValueScore(
            buckets[bucket],
            recommendationByteDanceBucketRankMax,
            weight,
          );
        }, 0);
      return recommendationByteDanceValueBase +
        Math.min(recommendationByteDanceBucketValueCap, bucketScore);
    }

    function coreTagValueScore(problem) {
      const coreTagCount = (problem?.tags || [])
        .filter((tag) => recommendationCoreTagSlugs.has(tag.slug))
        .length;
      return Math.min(
        recommendationCoreTagValueCap,
        coreTagCount * recommendationCoreTagValueWeight,
      );
    }

    function relatedValueScore(problem) {
      return Math.min(
        recommendationRelatedValueCap,
        Number(problem?.relatedQuestions?.total || 0) *
          recommendationRelatedValueWeight,
      );
    }

    function problemValueScore(problem) {
      const rank = problem.topRank ?? problem.frequencyRank;
      const frequencyScore = rankValueScore(
        rank,
        maxPageSize,
        recommendationFrequencyValueCap,
      );
      const hotScore = problem.hot100
        ? recommendationHotValueBase +
          rankValueScore(
            problem.hotRank,
            recommendationHotRankMax,
            recommendationHotRankValueCap,
          )
        : 0;
      const followUpScore = problem.companyFollowUps?.length
        ? recommendationCompanyFollowUpValue
        : 0;
      return clampScore(
        frequencyScore +
          hotScore +
          byteDanceValueScore(problem) +
          coreTagValueScore(problem) +
          relatedValueScore(problem) +
          followUpScore,
      );
    }

    function activeInsightProblem() {
      const slug = activePracticeTimer.slug || state.expandedSlug;
      return problems.find((problem) => problem.titleSlug === slug) || null;
    }

    function currentFitScore(problem) {
      const activeProblem = activeInsightProblem();
      if (!activeProblem) return 0;
      if (activeProblem.titleSlug === problem.titleSlug) {
        return recommendationCurrentProblemFitScore;
      }
      const shared = sharedTagSlugs(activeProblem, problem);
      const coreSharedCount = shared
        .filter((slug) => recommendationCoreTagSlugs.has(slug))
        .length;
      const tagScore = shared.length * recommendationSharedTagFitScore +
        coreSharedCount * recommendationCoreSharedTagFitScore;
      const relatedScore = hasRelatedLink(activeProblem, problem)
        ? recommendationRelatedFitScore
        : 0;
      const difficultyGap = Math.abs(
        difficultyIndex(activeProblem) - difficultyIndex(problem),
      );
      const difficultyScore = difficultyGap === 0
        ? recommendationSameDifficultyFitScore
        : (difficultyGap === 1 ? recommendationNearbyDifficultyFitScore : 0);
      return clampScore(tagScore + relatedScore + difficultyScore);
    }

    function todayAcceptedSlugs() {
      const today = timing.days?.[localDateKey()];
      return Array.isArray(today?.acceptedSlugs) ? today.acceptedSlugs : [];
    }

    function practicedTagSlugs() {
      const slugs = new Set([
        ...todayAcceptedSlugs(),
        ...Array.from(sessionTiming.acceptedSlugs || []),
      ]);
      const tags = new Set();
      problems.forEach((problem) => {
        if (!slugs.has(problem.titleSlug)) return;
        problem.tags?.forEach((tag) => tags.add(tag.slug));
      });
      return tags;
    }

    function tagFatiguePenalty(problem) {
      const practicedTags = practicedTagSlugs();
      if (!practicedTags.size) return 0;
      const overlap = (problem.tags || [])
        .filter((tag) => practicedTags.has(tag.slug))
        .length;
      return Math.min(
        recommendationTagFatiguePenaltyCap,
        overlap * recommendationTagFatiguePenaltyWeight,
      );
    }

    function fatiguePenalty(problem) {
      const todayAccepted = todayAcceptedSlugs().includes(problem.titleSlug)
        ? recommendationTodayAcceptedPenalty
        : 0;
      const sessionAccepted = sessionTiming.acceptedSlugs.has(problem.titleSlug)
        ? recommendationSessionAcceptedPenalty
        : 0;
      return todayAccepted + sessionAccepted + tagFatiguePenalty(problem);
    }

    function recommendationStabilityDays(item) {
      let stability = recommendationBaseStabilityDays +
        Math.log1p(item.accepted) * recommendationAcceptedStabilityDays +
        recentAcceptedStreak(item.record) * recommendationStreakStabilityDays +
        Math.sqrt(item.runAccepted) * recommendationRunAcceptedStabilityDays;
      stability -= Math.log1p(item.totalErrors) *
        recommendationErrorStabilityPenaltyDays;
      stability -= slowSpeedPenalty(item.scoreSpeed) *
        recommendationSpeedStabilityPenaltyFactor;
      if (item.status.mastered) {
        stability *= recommendationMasteredStabilityMultiplier;
      }
      if (item.status.review) {
        stability *= recommendationReviewStabilityMultiplier;
      }
      return clampValue(
        stability,
        recommendationMinStabilityDays,
        recommendationMaxStabilityDays,
      );
    }

    function retrievabilityScore(staleDays, stabilityDays) {
      if (!staleDays) return 1;
      return clampValue(Math.exp(-staleDays / stabilityDays), 0, 1);
    }

    function uncertaintyScore(accepted, attempts, runAttempts) {
      if (!accepted && !attempts && !runAttempts) {
        return recommendationColdStartUncertaintyScore;
      }
      if (!accepted) return recommendationPartialEvidenceUncertaintyScore;
      if (accepted === 1) return recommendationSingleAcceptedUncertaintyScore;
      return 0;
    }

    function submissionInsightFor(problem) {
      const record = storedProblemSubmissionStats(problem.titleSlug);
      const attempts = Number(record.attemptCount || 0);
      const runAttempts = Number(record.runAttemptCount || 0);
      const timingRecord = storedProblemTiming(problem.titleSlug);
      const accepted = Math.max(
        Number(record.acceptedCount || 0),
        Number(timingRecord.acceptedCount || 0),
      );
      const errors = Number(record.errorCount || 0);
      const runAccepted = Number(record.runAcceptedCount || 0);
      const runErrors = Number(record.runErrorCount || 0);
      const totalErrors = totalErrorCount(record);
      const bestSpeed = bestAcceptedSpeedMs(record);
      const scoreSpeed = scoreAcceptedSpeedMs(record);
      const lastAccepted = lastAcceptedSubmissionEvent(record);
      const lastAcceptedAt = lastAccepted?.at || timingRecord.lastAcceptedAt;
      const staleDays = accepted ? daysSinceIso(lastAcceptedAt) : 0;
      const noAcceptedPenalty = accepted
        ? 0
        : (runAccepted ? samplePassedNoAcceptedPenalty : noAcceptedBasePenalty);
      const errorPenalty = failurePenalty(
        errors,
        attempts,
        submitFailurePriorAttempts,
        submitFailurePriorRate,
        submitFailureRateWeight,
        submitFailureCountWeight,
        submitFailurePenaltyCap,
      );
      const runErrorPenalty = failurePenalty(
        runErrors,
        runAttempts,
        runFailurePriorAttempts,
        runFailurePriorRate,
        runFailureRateWeight,
        runFailureCountWeight,
        runFailurePenaltyCap,
      );
      const repeatDiscount = Math.min(
        acceptedRepeatDiscountCap,
        Math.log1p(accepted) * acceptedCountDiscountWeight +
          recentAcceptedStreak(record) * acceptedStreakDiscountWeight +
          runAccepted * runAcceptedDiscountWeight,
      );
      const status = rowState(problem.titleSlug);
      const manualPenalty = status.review ? manualReviewPenalty : 0;
      const manualDiscount = status.mastered ? manualMasteredDiscount : 0;
      const weaknessScore = clampScore(
        noAcceptedPenalty +
          errorPenalty +
          runErrorPenalty +
          slowSpeedPenalty(scoreSpeed) +
          uncertaintyScore(accepted, attempts, runAttempts) +
          manualPenalty -
          repeatDiscount -
          manualDiscount,
      );
      const localEvidenceCount = attempts + runAttempts + accepted;
      const item = {
        accepted,
        attempts,
        bestSpeed,
        errors,
        lastAccepted,
        lastAcceptedAt,
        localEvidenceCount,
        problem,
        record,
        runAccepted,
        runAttempts,
        runErrors,
        scoreSpeed,
        staleDays,
        status,
        totalErrors,
        weaknessScore,
      };
      const stabilityDays = recommendationStabilityDays(item);
      const retrievability = accepted
        ? retrievabilityScore(staleDays, stabilityDays)
        : 0;
      const dueScore = accepted
        ? clampScore((1 - retrievability) * submissionScoreMax)
        : (runAccepted
          ? recommendationSamplePassedDueScore
          : (localEvidenceCount
            ? recommendationNoAcceptedDueScore
            : recommendationColdStartDueScore));
      const valueScore = problemValueScore(problem);
      const fitScore = currentFitScore(problem);
      const penalty = fatiguePenalty(problem);
      const score = clampScore(
        dueScore * recommendationDueWeight +
          weaknessScore * recommendationWeaknessWeight +
          valueScore * recommendationValueWeight +
          fitScore * recommendationFitWeight -
          penalty,
      );

      return {
        accepted,
        attempts,
        bestSpeed,
        dueScore,
        errors,
        fitScore,
        lastAccepted,
        lastAcceptedAt,
        localEvidenceCount,
        penalty,
        problem,
        record,
        retrievability,
        runAccepted,
        runAttempts,
        runErrors,
        scoreSpeed,
        score,
        staleDays,
        stabilityDays,
        status,
        totalErrors,
        valueScore,
        weaknessScore,
      };
    }

    function isUnacceptedHot100Insight(item) {
      return Boolean(item.problem?.hot100 && !item.accepted);
    }

    function submissionInsightItems() {
      return problems
        .map(submissionInsightFor)
        .sort((left, right) => (
          Number(isUnacceptedHot100Insight(right)) -
            Number(isUnacceptedHot100Insight(left)) ||
          right.score - left.score ||
          right.dueScore - left.dueScore ||
          right.weaknessScore - left.weaknessScore ||
          right.valueScore - left.valueScore ||
          right.fitScore - left.fitScore ||
          left.penalty - right.penalty ||
          right.errors - left.errors ||
          right.runErrors - left.runErrors ||
          right.scoreSpeed - left.scoreSpeed ||
          left.accepted - right.accepted ||
          (left.problem.frequencyRank || 999999) -
            (right.problem.frequencyRank || 999999)
        ));
    }

    function suggestedPracticeItems() {
      return submissionInsightItems()
        .filter((item) => !shouldSkipRouteProblem(item.problem));
    }

    function suggestedFlowProblem(excludedSlug = "") {
      return suggestedPracticeItems()
        .find((item) => item.problem.titleSlug !== excludedSlug)
        ?.problem || null;
    }

    function submissionReason(item) {
      const reasons = [];
      if (isUnacceptedHot100Insight(item)) {
        reasons.push(isChinesePage ? "Hot100 未完整 AC" : "Hot100 not accepted");
      } else if (!item.accepted) {
        reasons.push(isChinesePage ? "未完整 AC" : "not accepted yet");
      } else if (item.dueScore >= 50) {
        reasons.push(
          isChinesePage
            ? `可回忆率 ${Math.round(item.retrievability * 100)}%`
            : `${Math.round(item.retrievability * 100)}% retrievable`,
        );
      }
      if (item.errors) {
        reasons.push(
          isChinesePage
            ? `提交错 ${item.errors} 次`
            : `${item.errors} submit failed`,
        );
      }
      if (item.runErrors) {
        reasons.push(
          isChinesePage
            ? `样例错 ${item.runErrors} 次`
            : `${item.runErrors} sample run failed`,
        );
      }
      if (item.scoreSpeed) {
        const seconds = item.scoreSpeed / 1000;
        if (seconds > submissionSlowSecondsPerTenLines) {
          reasons.push(
            isChinesePage
              ? `每 10 行 ${formatDuration(item.scoreSpeed)}`
              : `${formatDuration(item.scoreSpeed)} per 10 lines`,
          );
        }
      }
      if (item.valueScore >= 70) {
        reasons.push(isChinesePage ? "高价值题" : "high-value problem");
      }
      if (item.fitScore >= 24) {
        reasons.push(isChinesePage ? "同路线迁移" : "same-route practice");
      }
      if (item.staleDays >= 1 && reasons.length < 4) {
        reasons.push(
          isChinesePage
            ? `${Math.floor(item.staleDays)} 天未 AC`
            : `${Math.floor(item.staleDays)} days stale`,
        );
      }
      if (!reasons.length) {
        reasons.push(isChinesePage ? "高频冷启动" : "high-value cold start");
      }
      return reasons.slice(0, 3).join(" · ");
    }

    function submissionErrorLabel(record) {
      const submitErrors = Number(record?.errorCount || 0);
      const runErrors = Number(record?.runErrorCount || 0);
      const totalErrors = submitErrors + runErrors;
      if (!totalErrors) return isChinesePage ? "错 0" : "0 failed";
      const split = isChinesePage
        ? `提${submitErrors}/样${runErrors}`
        : `submit ${submitErrors}/sample ${runErrors}`;
      return isChinesePage
        ? `错 ${totalErrors}（${split}）`
        : `${totalErrors} failed (${split})`;
    }

    function submissionShortErrorLabel(item) {
      if (!item.totalErrors) return isChinesePage ? "错0" : "0 failed";
      if (!item.runErrors) {
        return isChinesePage
          ? `错${item.totalErrors}`
          : `${item.totalErrors} failed`;
      }
      return isChinesePage
        ? `错${item.totalErrors}(提${item.errors}/样${item.runErrors})`
        : `${item.totalErrors} failed(sub${item.errors}/run${item.runErrors})`;
    }

    function submissionStatsLabel(slug) {
      const record = storedProblemSubmissionStats(slug);
      const attempts = Number(record.attemptCount || 0);
      const runAttempts = Number(record.runAttemptCount || 0);
      if (!attempts && !runAttempts) {
        return isChinesePage ? "暂无提交" : "No submits";
      }
      const lastSpeed = lastAcceptedSpeedMs(record);
      return [
        attempts
          ? (isChinesePage ? `写 ${attempts}` : `${attempts} submits`)
          : "",
        runAttempts
          ? (isChinesePage ? `跑 ${runAttempts}` : `${runAttempts} runs`)
          : "",
        submissionErrorLabel(record),
        lastSpeed
          ? `${isChinesePage ? "耗/10行" : "time/10 lines"} ${
              formatDuration(lastSpeed)
            }`
          : "",
      ].filter(Boolean).join(" · ");
    }

    function submissionCompactSignal(problem) {
      const item = submissionInsightFor(problem);
      if (
        !item.localEvidenceCount &&
        !item.status.review &&
        !item.status.mastered
      ) {
        return "";
      }
      const record = item.record;
      const speed = lastAcceptedSpeedMs(record);
      const title = [
        submissionStatsLabel(problem.titleSlug),
        isChinesePage
          ? `练习分 ${item.score}`
          : `practice score ${item.score}`,
        submissionReason(item),
      ].join(" · ");
      const speedText = speed
        ? (isChinesePage
          ? ` · ${formatDuration(speed)}/10行`
          : ` · ${formatDuration(speed)}/10 lines`)
        : "";
      const label = isChinesePage
        ? `练${item.score} · 写${item.attempts}/跑${item.runAttempts}${speedText}`
        : `practice ${item.score} · ${item.attempts}/${item.runAttempts}${speedText}`;
      return `
        <span class="leetcode-practice-signal" aria-label="${escapeHtml(title)}">
          ${escapeHtml(label)}
        </span>
      `;
    }

    function syncProblemSignal(slug) {
      const problem = problems.find((item) => item.titleSlug === slug);
      const row = Array.from(list?.querySelectorAll(".leetcode-row") || [])
        .find((item) => item instanceof HTMLElement && item.dataset.slug === slug);
      const tools = row?.querySelector(".leetcode-title-tools");
      if (!(tools instanceof HTMLElement) || !problem) return;
      tools.querySelector(".leetcode-practice-signal")?.remove();
      const signal = submissionCompactSignal(problem);
      if (signal) tools.insertAdjacentHTML("beforeend", signal);
    }

    function renderSubmissionInsightItem(item, index) {
      const problem = item.problem;
      const meta = [
        isChinesePage
          ? `练 ${item.score}`
          : `score ${item.score}`,
        isChinesePage
          ? `复 ${item.dueScore}`
          : `due ${item.dueScore}`,
        isChinesePage
          ? `弱 ${item.weaknessScore}`
          : `weak ${item.weaknessScore}`,
        isChinesePage
          ? `值 ${item.valueScore}`
          : `value ${item.valueScore}`,
        item.fitScore
          ? (isChinesePage ? `适 ${item.fitScore}` : `fit ${item.fitScore}`)
          : "",
        item.attempts
          ? (isChinesePage ? `写 ${item.attempts}` : `${item.attempts} submits`)
          : "",
        item.runAttempts
          ? (isChinesePage ? `跑 ${item.runAttempts}` : `${item.runAttempts} runs`)
          : "",
        item.scoreSpeed
          ? `${isChinesePage ? "计分/10行" : "score/10 lines"} ${
              formatDuration(item.scoreSpeed)
            }`
          : "",
      ].filter(Boolean).join(" · ");
      return `
        <button
          type="button"
          class="leetcode-insight-item"
          data-open-insight="${escapeHtml(problem.titleSlug)}"
        >
          <b>${index + 1}. ${escapeHtml(problem.frontendId)}. ${escapeHtml(problem.titleCn)}</b>
          <span>${escapeHtml(meta)}</span>
          <em>${escapeHtml(submissionReason(item))}</em>
        </button>
      `;
    }

    function syncSubmissionInsightUi() {
      const items = suggestedPracticeItems();
      const pick = items[0];
      if (insightPick instanceof HTMLElement) {
        insightPick.textContent = pick
          ? `${pick.problem.frontendId}. ${pick.problem.titleCn} · ${pick.score}`
          : (isChinesePage
            ? "按本地状态和题目价值排序"
            : "Ranked by local state and problem value");
      }
      if (insightOpen instanceof HTMLButtonElement) {
        insightOpen.setAttribute("aria-disabled", String(!pick));
        if (pick) {
          insightOpen.dataset.openInsight = pick.problem.titleSlug;
        } else {
          delete insightOpen.dataset.openInsight;
        }
      }
      if (insightList instanceof HTMLElement) {
        insightList.innerHTML = items.length
          ? items
              .slice(0, insightDisplayLimit)
              .map(renderSubmissionInsightItem)
              .join("")
          : `<span>${
              isChinesePage
                ? "暂无可推荐题目。"
                : "No recommendable problems yet."
            }</span>`;
      }
      syncInsightFlowUi(Boolean(pick));
    }

    function syncSubmissionStatsUi(slug) {
      const record = storedProblemSubmissionStats(slug);
      const attempts = Number(record.attemptCount || 0);
      const errors = totalErrorCount(record);
      const lastCodeLines = Number(record.lastCodeNonBlankLines || 0);
      const avgMs = averageAcceptedMs(record);
      const lastSpeed = lastAcceptedSpeedMs(record);
      setTextAll(`[data-problem-submits="${slug}"]`, String(attempts));
      setTextAll(`[data-problem-errors="${slug}"]`, String(errors));
      setTextAll(
        `[data-problem-code-lines="${slug}"]`,
        lastCodeLines
          ? (isChinesePage ? `${lastCodeLines} 行` : `${lastCodeLines} lines`)
          : "--",
      );
      setTextAll(
        `[data-problem-avg="${slug}"]`,
        avgMs ? formatDuration(avgMs) : "--",
      );
      setTextAll(
        `[data-problem-speed="${slug}"]`,
        lastSpeed ? formatDuration(lastSpeed) : "--",
      );
    }

    function updateSubmissionCodeSnapshot(record, metrics) {
      record.lastCodeChars = metrics.chars;
      record.lastCodeLines = metrics.lines;
      record.lastCodeNonBlankLines = metrics.nonBlankLines;
    }

    function recordSubmissionAttempt(
      problem,
      textarea,
      result,
      options = {},
    ) {
      const slug = problem?.titleSlug || "";
      if (!slug || !(textarea instanceof HTMLTextAreaElement)) return null;
      const record = problemSubmissionStats(slug);
      const payload = editorPayload(problem, textarea);
      const metrics = codeMetrics(payload.code);
      const accepted = Boolean(options.accepted);
      const elapsedMs = Math.max(0, Number(options.elapsedMs || 0));
      const nowIso = new Date().toISOString();
      const event = {
        accepted,
        at: nowIso,
        codeChars: metrics.chars,
        codeLines: metrics.lines,
        codeNonBlankLines: metrics.nonBlankLines,
        elapsedMs,
        langSlug: payload.langSlug,
        memory: normalizedSubmissionMemory(result?.memory),
        runtime: normalizedSubmissionRuntime(result?.runtime),
        statusMessage: meaningfulSubmissionValue(
          result?.statusMessage || result?.status_msg || result?.state,
        ),
        submissionId: String(options.submissionId || result?.submissionId || ""),
      };
      record.attemptCount += 1;
      record.firstSubmittedAt = record.firstSubmittedAt || nowIso;
      record.lastSubmittedAt = nowIso;
      updateSubmissionCodeSnapshot(record, metrics);
      record.events.push(event);
      record.events = record.events.slice(-submissionHistoryLimit);
      if (accepted) {
        record.acceptedCount += 1;
        record.totalAcceptedMs += elapsedMs;
        record.lastAcceptedAt = nowIso;
        record.lastElapsedMs = elapsedMs;
        record.bestMs =
          !record.bestMs || elapsedMs < record.bestMs ? elapsedMs : record.bestMs;
      } else {
        record.errorCount += 1;
      }
      writeSubmissionStats();
      appendPracticeEvent(
        practiceEventSubmissionAttempt,
        { event, slug },
        nowIso,
      );
      syncSubmissionStatsUi(slug);
      syncProblemSignal(slug);
      syncSubmissionInsightUi();
      return record;
    }

    function recordRunAttempt(
      problem,
      textarea,
      accepted,
    ) {
      const slug = problem?.titleSlug || "";
      if (!slug || !(textarea instanceof HTMLTextAreaElement)) return null;
      const record = problemSubmissionStats(slug);
      const payload = editorPayload(problem, textarea);
      const metrics = codeMetrics(payload.code);
      const runAccepted = Boolean(accepted);
      const nowIso = new Date().toISOString();
      record.runAttemptCount += 1;
      record.lastRunAt = nowIso;
      updateSubmissionCodeSnapshot(record, metrics);
      if (runAccepted) {
        record.runAcceptedCount += 1;
      } else {
        record.runErrorCount += 1;
      }
      writeSubmissionStats();
      appendPracticeEvent(
        practiceEventRunAttempt,
        {
          accepted: runAccepted,
          at: nowIso,
          codeChars: metrics.chars,
          codeLines: metrics.lines,
          codeNonBlankLines: metrics.nonBlankLines,
          langSlug: payload.langSlug,
          slug,
        },
        nowIso,
      );
      syncSubmissionStatsUi(slug);
      syncProblemSignal(slug);
      syncSubmissionInsightUi();
      return record;
    }

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;");
    }

    function escapeToken(value) {
      return escapeHtml(value);
    }

    function isIdentifierStart(char) {
      return /[A-Za-z_$@]/.test(char);
    }

    function isIdentifierPart(char) {
      return /[A-Za-z0-9_$@]/.test(char);
    }

    function wordSet(words) {
      return new Set(words.split(/\s+/).filter(Boolean));
    }

