            <button type="button" data-action="review" data-slug="${escapeHtml(problem.titleSlug)}" class="${status.review ? "is-on" : ""}" aria-label="${isChinesePage ? "切换需思考状态（Cmd+Option+S）" : "Toggle review (Cmd+Option+S)"}">思考</button>
            <button type="button" data-action="mastered" data-slug="${escapeHtml(problem.titleSlug)}" class="${status.mastered ? "is-on" : ""}" aria-label="${isChinesePage ? "切换熟练状态（Cmd+Option+M）" : "Toggle mastered (Cmd+Option+M)"}">熟练</button>
          </div>
        </article>
      `;
