    function renderProblemBundle(problem) {
      return renderProblem(problem) + (state.expandedSlug === problem.titleSlug ? renderPracticePanel(problem) : "");
    }

    function switchTestcaseTab(tab) {
      const card = tab.closest("[data-testcase-card]");
      if (!(card instanceof HTMLElement)) return;
      const activeIndex = tab.dataset.testcaseTab || "";
      card.querySelectorAll("[data-testcase-tab]").forEach((item) => {
        if (!(item instanceof HTMLElement)) return;
        const isActive = item.dataset.testcaseTab === activeIndex;
        item.classList.toggle("is-active", isActive);
        item.setAttribute("aria-selected", String(isActive));
      });
      card.querySelectorAll("[data-testcase-panel]").forEach((item) => {
        if (!(item instanceof HTMLElement)) return;
        item.hidden = item.dataset.testcasePanel !== activeIndex;
      });
    }

    function render() {
      rollEditorDraftsForToday();
      const items = orderedProblems();
      state.pageSize = pageSize();
      state.totalPages = Math.max(1, Math.ceil(items.length / state.pageSize));
      state.page = clampPage(state.page, state.totalPages);
      const start = (state.page - 1) * state.pageSize;
      const pageItems = items.slice(start, start + state.pageSize);
      if (list) list.innerHTML = pageItems.map(renderProblemBundle).join("");
      if (resultCount) {
        resultCount.textContent = `${items.length} 道题`;
      }
      syncPagination();
      syncStatementPanels();
      syncRenderedEditors();
      syncRenderedExtensionStatus();
      syncActivePracticeTimerAfterRender();
      pageItems.forEach((problem) => syncSubmissionStatsUi(problem.titleSlug));
      syncSubmissionInsightUi();
    }

    searchInput?.addEventListener("input", (event) => {
      state.query = event.target.value.trim();
      state.page = 1;
      render();
      scheduleViewStateWrite();
    });

    pageSizeSelect?.addEventListener("change", () => {
      customSizeInput.hidden = pageSizeSelect.value !== "custom";
      state.page = 1;
      render();
      scheduleViewStateWrite();
    });

    customSizeInput?.addEventListener("input", () => {
      state.page = 1;
      render();
      scheduleViewStateWrite();
    });

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        applyFilter(button.dataset.filter || "all");
      });
    });

    pageActionButtons.forEach((button) => {
      button.addEventListener("click", () => {
        if (!(button instanceof HTMLElement)) return;
        const action = button.dataset.pageAction;
        if (action === "first") setPage(1);
        if (action === "prev") setPage(state.page - 1);
        if (action === "next") setPage(state.page + 1);
        if (action === "last") setPage(state.totalPages);
      });
    });

    pageJumpInputs.forEach((input) => {
      input.addEventListener("change", () => jumpToInputPage(input));
      input.addEventListener("keydown", (event) => {
        if (event.key !== "Enter") return;
        event.preventDefault();
        jumpToInputPage(input);
      });
    });

    dailyResetToggle?.addEventListener("change", () => {
      if (!(dailyResetToggle instanceof HTMLInputElement)) return;
      localStorage.setItem(
        editorDailyResetKey,
        dailyResetToggle.checked ? "on" : "off",
      );
      localStorage.setItem(editorDraftDayKey, localDateKey());
      syncDailyResetUi();
    });

    pageFontSelect?.addEventListener("change", () => {
      if (!(pageFontSelect instanceof HTMLSelectElement)) return;
      editorAppearance = {
        ...editorAppearance,
        pageFont: pageFontSelect.value,
      };
      writeEditorAppearance();
      applyEditorAppearance();
    });

