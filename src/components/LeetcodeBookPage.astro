    function languageKey(lang) {
      const normalized = String(lang || "").toLowerCase();
      if (["c++", "c++17", "cpp"].includes(normalized)) return "cpp";
      if (["c#", "csharp"].includes(normalized)) return "csharp";
      if (["go", "golang"].includes(normalized)) return "go";
      if (["js", "javascript"].includes(normalized)) return "javascript";
      if (["mysql", "mssql", "oracle", "oraclesql", "sql"].includes(normalized)) return "sql";
      if (["pandas", "python", "python3"].includes(normalized)) return "python";
      if (["ts", "typescript"].includes(normalized)) return "typescript";
      return normalized;
    }

    function lineEnd(code, index) {
      let end = index;
      while (end < code.length && code[end] !== "\n") end += 1;
      return end;
    }

    function highlightedSpan(className, value) {
      return `<span class="${className}">${escapeToken(value)}</span>`;
    }

    function matchComment(code, index, grammar) {
      const char = code[index];
      const next = code[index + 1] || "";
      const comments = grammar.comments || [];
      if (comments.includes("racketBlock") && char === "#" && next === "|") {
        const end = code.indexOf("|#", index + 2);
        return end === -1 ? code.length : end + 2;
      }
      if (comments.includes("slash") && char === "/" && next === "/") {
        return lineEnd(code, index + 2);
      }
      if (comments.includes("slash") && char === "/" && next === "*") {
        const end = code.indexOf("*/", index + 2);
        return end === -1 ? code.length : end + 2;
      }
      if (comments.includes("sql") && char === "-" && next === "-") {
        return lineEnd(code, index + 2);
      }
      if (comments.includes("semicolon") && char === ";") {
        return lineEnd(code, index + 1);
      }
      if (comments.includes("percent") && char === "%") {
        return lineEnd(code, index + 1);
      }
      if (comments.includes("hash") && char === "#") {
        return lineEnd(code, index + 1);
      }
      return -1;
    }

    function matchString(code, index, grammar) {
      const char = code[index];
      if (grammar === highlightGrammarByLanguage.python) {
        const triple = code.slice(index, index + 3);
        if (triple === "'''" || triple === '"""') {
          const end = code.indexOf(triple, index + 3);
          return end === -1 ? code.length : end + 3;
        }
      }
      if (char !== '"' && char !== "'" && char !== "`") return -1;
      let end = index + 1;
      while (end < code.length) {
        if (code[end] === "\\") {
          end += 2;
          continue;
        }
        end += 1;
        if (code[end - 1] === char) break;
      }
      return end;
    }

    function highlightCode(code, lang) {
      const grammar =
        highlightGrammarByLanguage[languageKey(lang)] || {
          comments: ["slash", "hash"],
          keywords: new Set(),
          types: new Set(),
        };
      let html = "";
      for (let index = 0; index < code.length;) {
        const char = code[index];
        const commentEnd = matchComment(code, index, grammar);
        if (commentEnd !== -1) {
          const tokenClass =
            char === "#" && grammar.comments?.includes("directive")
              ? "leetcode-token-directive"
              : "leetcode-token-comment";
          html += highlightedSpan(tokenClass, code.slice(index, commentEnd));
          index = commentEnd;
          continue;
        }
        if (char === "#" && grammar.comments?.includes("directive")) {
          const end = lineEnd(code, index + 1);
          html += highlightedSpan("leetcode-token-directive", code.slice(index, end));
          index = end;
          continue;
        }
        const stringEnd = matchString(code, index, grammar);
        if (stringEnd !== -1) {
          html += highlightedSpan("leetcode-token-string", code.slice(index, stringEnd));
          index = stringEnd;
          continue;
        }
        if (/[0-9]/.test(char)) {
          let end = index + 1;
          while (end < code.length && /[A-Za-z0-9_.]/.test(code[end])) end += 1;
          html += highlightedSpan("leetcode-token-number", code.slice(index, end));
          index = end;
          continue;
        }
        if (isIdentifierStart(char)) {
          let end = index + 1;
          while (end < code.length && isIdentifierPart(code[end])) end += 1;
          const word = code.slice(index, end);
          if (grammar.keywords.has(word) || grammar.keywords.has(word.toLowerCase())) {
            html += highlightedSpan("leetcode-token-keyword", word);
          } else if (grammar.types.has(word) || grammar.types.has(word.toLowerCase())) {
            html += highlightedSpan("leetcode-token-type", word);
          } else {
            html += escapeToken(word);
          }
          index = end;
          continue;
        }
        html += escapeToken(char);
        index += 1;
      }
      return html;
    }

    function rowState(slug) {
      return progress[slug] || { done: false, review: false, mastered: false };
    }

    function byteDanceBuckets(problem) {
      const buckets = problem.bytedanceBuckets || {};
      const periods = problem.bytedancePeriods || {};
      return {
        all: buckets.all ?? (problem.bytedance ? problem.bytedanceRank : null),
        thirtyDays: buckets.thirtyDays ?? null,
        threeMonths: buckets.threeMonths ?? periods.past3Months ?? null,
        sixMonths: buckets.sixMonths ?? periods.past6Months ?? null,
        moreThanSixMonths:
          buckets.moreThanSixMonths ?? periods.before6Months ?? null,
      };
    }

    function byteDanceRankFor(problem, filter = "bytedanceAll") {
      const buckets = byteDanceBuckets(problem);
      if (filter === "bytedanceThirtyDays") return buckets.thirtyDays;
      if (filter === "bytedanceThreeMonths") return buckets.threeMonths;
      if (filter === "bytedanceSixMonths") return buckets.sixMonths;
      if (filter === "bytedanceMoreThanSixMonths") return buckets.moreThanSixMonths;
      return problem.bytedanceRank ?? buckets.all;
    }

    function pageSize() {
      if (pageSizeSelect?.value === "custom") {
        const custom = Number(customSizeInput?.value || 20);
        return Math.max(1, Math.min(maxPageSize, Number.isFinite(custom) ? custom : 20));
      }
      return Number(pageSizeSelect?.value || 20);
    }

    function clampPage(page, totalPages = state.totalPages) {
      const nextPage = Number(page);
      if (!Number.isFinite(nextPage)) return state.page;
      return Math.max(1, Math.min(totalPages, Math.trunc(nextPage)));
    }

    function syncPagination() {
      pageIndicators.forEach((indicator) => {
        indicator.textContent = `/ ${state.totalPages}`;
      });
      pageJumpInputs.forEach((input) => {
        if (!(input instanceof HTMLInputElement)) return;
        input.max = String(state.totalPages);
        input.value = String(state.page);
      });
      pageActionButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        const action = button.dataset.pageAction;
        button.disabled =
          ((action === "first" || action === "prev") && state.page <= 1) ||
          ((action === "next" || action === "last") && state.page >= state.totalPages);
      });
    }

    function setPage(page) {
      const nextPage = clampPage(page);
      if (nextPage === state.page) {
        syncPagination();
        return;
      }
      state.page = nextPage;
      render();
    }

    function jumpToInputPage(input) {
      if (!(input instanceof HTMLInputElement)) return;
      setPage(input.value);
    }

    function isEditableTarget(element) {
      if (!(element instanceof HTMLElement)) return false;
      if (element.isContentEditable) return true;
      return Boolean(
        element.closest(
          "input, textarea, select, button, a, [contenteditable='true'], .leetcode-practice-panel",
        ),
      );
    }

    function isTextEntryTarget(element) {
      if (!(element instanceof HTMLElement)) return false;
      if (element.isContentEditable) return true;
      return element.matches("input, textarea, select, [contenteditable='true']");
    }

    function matchesFilter(problem) {
      const status = rowState(problem.titleSlug);
      const byteDance = byteDanceBuckets(problem);
      if (state.filter === "hot100" && !problem.hot100) return false;
      if (state.filter === "companyFollowUps" && !problem.companyFollowUps?.length) return false;
      if (state.filter === "bytedanceAll" && !byteDance.all) return false;
      if (state.filter === "bytedanceThirtyDays" && !byteDance.thirtyDays) return false;
      if (state.filter === "bytedanceThreeMonths" && !byteDance.threeMonths) return false;
      if (state.filter === "bytedanceSixMonths" && !byteDance.sixMonths) return false;
      if (state.filter === "bytedanceMoreThanSixMonths" && !byteDance.moreThanSixMonths) return false;
      if (state.filter === "unsolved" && status.done) return false;
      if (state.filter === "review" && !status.review) return false;
      if (state.filter === "unmastered" && status.mastered) return false;
      if (!state.query) return true;
      const haystack = [
        problem.frontendId,
        problem.titleCn,
        problem.titleSlug,
        problem.difficulty,
        problem.bytedance ? "字节跳动 bytedance" : "",
        problem.bytedanceRank ? `bd ${problem.bytedanceRank}` : "",
        byteDance.thirtyDays ? `字节近30天 ${byteDance.thirtyDays}` : "",
        byteDance.threeMonths ? `字节近3月 ${byteDance.threeMonths}` : "",
        byteDance.sixMonths ? `字节近6月 ${byteDance.sixMonths}` : "",
        byteDance.moreThanSixMonths ? `字节6月前 ${byteDance.moreThanSixMonths}` : "",
        ...problem.tags.map((tag) => tag.name),
        ...(problem.followUps || []).flatMap((item) => [item.question, item.answer]),
        ...(problem.companyFollowUps || []).flatMap((item) => [
          item.question,
          item.answer,
          item.company,
          item.sourceTitle,
        ]),
        ...(problem.implementationReferences || []).flatMap((item) => [
          item.language,
          item.provenance,
          item.sourceTitle,
        ]),
      ].join(" ").toLowerCase();
      return haystack.includes(state.query.toLowerCase());
    }

    function orderedProblems() {
      const filtered = problems.filter(matchesFilter);
      if (state.filter === "hot100") {
        return filtered.sort((a, b) => (a.hotRank || 999) - (b.hotRank || 999));
      }
      if (state.filter.startsWith("bytedance")) {
        return filtered.sort((a, b) => {
          const left = byteDanceRankFor(a, state.filter) || Number.MAX_SAFE_INTEGER;
          const right = byteDanceRankFor(b, state.filter) || Number.MAX_SAFE_INTEGER;
          return left - right || (a.frequencyRank || 999999) - (b.frequencyRank || 999999);
        });
      }
      return filtered;
    }

    function focusEditorForSlug(slug) {
      window.requestAnimationFrame(() => {
        const panel = Array.from(list?.querySelectorAll("[data-editor-panel]") || [])
          .find((item) => item instanceof HTMLElement && item.dataset.editorPanel === slug);
        const row = Array.from(list?.querySelectorAll(".leetcode-row") || [])
          .find((item) => item instanceof HTMLElement && item.dataset.slug === slug);
        const textarea = panel?.querySelector("[data-editor-code]");
        const target = panel || row;
        if (target instanceof HTMLElement) {
          target.scrollIntoView({ block: "center", behavior: "smooth" });
        }
        if (textarea instanceof HTMLTextAreaElement) {
          textarea.focus({ preventScroll: true });
        }
      });
    }

    function currentPracticeSlug(fallbackSlug = "") {
      const active = document.activeElement;
      if (active instanceof HTMLTextAreaElement && active.dataset.editorCode) {
        return active.dataset.editorCode;
      }
      return fallbackSlug || state.expandedSlug || "";
    }

    function openPracticeAtIndex(items, index) {
      const target = items[index];
      if (!target) return;
      state.pageSize = pageSize();
      state.totalPages = Math.max(1, Math.ceil(items.length / state.pageSize));
      state.page = Math.floor(index / state.pageSize) + 1;
      state.expandedSlug = target.titleSlug;
      render();
      focusEditorForSlug(target.titleSlug);
    }

    function navigatePractice(direction, fallbackSlug = "") {
      const items = orderedProblems();
      if (!items.length) return;
      const slug = currentPracticeSlug(fallbackSlug);
      const currentIndex = items.findIndex((item) => item.titleSlug === slug);
      const startIndex = currentIndex === -1 ? (direction > 0 ? -1 : items.length) : currentIndex;
      const nextIndex = Math.max(0, Math.min(items.length - 1, startIndex + direction));
      openPracticeAtIndex(items, nextIndex);
    }

    function badgeClass(difficulty) {
      if (difficulty === "简单") return "is-easy";
      if (difficulty === "困难") return "is-hard";
      return "is-medium";
    }

    function renderTags(problem) {
      return problem.tags
        .slice(0, 3)
        .map((tag) => `<span>${escapeHtml(tag.name)}</span>`)
        .join("");
    }

    function renderByteDance(problem) {
      if (!problem.bytedance) return "";
      const buckets = byteDanceBuckets(problem);
      const labels = [
        ["全量", buckets.all],
        ["近30天", buckets.thirtyDays],
        ["近3月", buckets.threeMonths],
        ["近6月", buckets.sixMonths],
        ["6月前", buckets.moreThanSixMonths],
      ]
        .filter(([, count]) => count)
        .map(([label, count]) => `${label} #${count}`)
        .join(" / ");
      const shortLabels = [
        ["30", buckets.thirtyDays],
        ["3", buckets.threeMonths],
        ["6", buckets.sixMonths],
        ["旧", buckets.moreThanSixMonths],
      ]
        .filter(([, count]) => count)
        .map(([label]) => label)
        .join("/");
      return `<span title="${escapeHtml(labels || "字节跳动")}">${escapeHtml(shortLabels || "全")}</span>`;
    }

    function renderByteDanceMeta(problem) {
      const buckets = byteDanceBuckets(problem);
      const chips = [
        ["字节全量", buckets.all],
        ["近30天", buckets.thirtyDays],
        ["近3月", buckets.threeMonths],
        ["近6月", buckets.sixMonths],
        ["6月前", buckets.moreThanSixMonths],
      ].filter(([, count]) => count);
      if (!chips.length) return "";
      return chips
        .map(([label, count]) => `<span>${escapeHtml(label)} #${escapeHtml(count)}</span>`)
        .join("");
    }

    function renderStudyChecks(problem) {
      const checks = problem.followUps || [];
      if (!checks.length) return "";
      return `
        <span class="leetcode-popover-section">
          <strong>通用检查点</strong>
          ${checks
            .map(
              (item) => `
                <span class="leetcode-check">
                  <em>${escapeHtml(item.question)}</em>
                  <span>${escapeHtml(item.answer)}</span>
                </span>
              `,
            )
            .join("")}
        </span>
      `;
    }

    function renderCompanyFollowUps(problem) {
      const followUps = problem.companyFollowUps || [];
      if (!followUps.length) {
        return '<span class="leetcode-popover-muted">暂无公开核实到的公司追问来源。</span>';
      }
      return `
        <span class="leetcode-popover-section">
          <strong>公司追问</strong>
          ${followUps
            .map(
              (item) => `
                <span class="leetcode-company-follow-up">
                  <span class="leetcode-followup-source">
                    <b>${escapeHtml(item.company)}</b>
                    <a
                      class="leetcode-source-link"
                      href="${escapeHtml(item.sourceUrl)}"
                      title="${escapeHtml(item.sourceTitle)}"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      来源
                    </a>
                  </span>
                  <em>${escapeHtml(item.question)}</em>
                  <span>${escapeHtml(item.answer)}</span>
                </span>
              `,
            )
            .join("")}
        </span>
      `;
    }

    function renderTagReference(problem, topLabel) {
      return `
        <span class="leetcode-tag-popover">
          ${topLabel ? `<span>freq ${escapeHtml(topLabel)}</span>` : ""}
          ${problem.hot100 ? "<span>Hot100</span>" : ""}
          ${problem.bytedanceVerified === false ? "<span>企业待核</span>" : ""}
          ${problem.companyFollowUps?.length ? `<span>公司追问 ${escapeHtml(problem.companyFollowUps.length)}</span>` : ""}
          ${problem.implementationReferences?.length ? `<span>实现参考 ${escapeHtml(problem.implementationReferences.length)}</span>` : ""}
          ${renderByteDanceMeta(problem)}
          ${renderTags(problem)}
        </span>
      `;
    }

    function implementationTracks(problem) {
      const tags = new Set(problem.tags.map((tag) => tag.slug));
      const tracks = [];
      if (tags.has("hash-table")) tracks.push(["哈希表", "先写清 key/value 语义，再确认写入时机和重复值处理。"]);
      if (tags.has("two-pointers")) tracks.push(["双指针", "用区间不变量解释每次移动能排除哪一批候选答案。"]);
      if (tags.has("sliding-window")) tracks.push(["滑动窗口", "维护窗口内计数或约束，右端扩张、左端按条件单调收缩。"]);
      if (tags.has("dynamic-programming")) tracks.push(["动态规划", "先定义状态和转移，再检查是否能滚动压缩空间。"]);
      if (tags.has("stack") || tags.has("monotonic-stack")) tracks.push(["栈/单调栈", "栈里保存尚未确定答案的元素，出栈时一次性结算贡献。"]);
      if (tags.has("binary-search")) tracks.push(["二分", "明确单调谓词，使用左闭右闭或左闭右开一种模板到底。"]);
      if (tags.has("tree") || tags.has("binary-tree")) tracks.push(["树遍历", "先确定递归返回值，再决定前序、后序或层序。"]);
      if (tags.has("graph")) tracks.push(["图搜索", "建图、访问状态和队列/栈边界分开写，避免重复入队。"]);
      if (!tracks.length) tracks.push(["主解法", "先按题面约束写出可讲清楚的不变量，再做复杂度优化。"]);
      return tracks.slice(0, 4);
    }

    function implementationProvenanceLabel(provenance) {
      if (provenance === "my-recent-accepted-submission") return "我的提交";
      if (provenance === "optimized") return "已优化";
      return "生成参考";
    }

    function isCppReference(reference) {
      return reference.language === "C++" || reference.language === "C++17";
    }

    function implementationReferencesForDisplay(problem) {
      const references = problem.implementationReferences || [];
      return references.filter(isCppReference);
    }

    function renderImplementationCode(reference) {
      const code = highlightCode(reference.code, reference.language);
      return `
        <span class="leetcode-implementation-card">
          <span class="leetcode-implementation-meta">
            <span>${escapeHtml(implementationProvenanceLabel(reference.provenance))}</span>
            <span>${escapeHtml(reference.language)}</span>
            ${reference.submittedAt ? `<span>${escapeHtml(reference.submittedAt)}</span>` : ""}
            ${reference.runtime ? `<span>${escapeHtml(reference.runtime)}</span>` : ""}
            ${reference.memory ? `<span>${escapeHtml(reference.memory)}</span>` : ""}
            <a
              href="${escapeHtml(reference.sourceUrl)}"
              target="_blank"
              rel="noopener noreferrer"
              class="leetcode-source-link"
            >
              提交来源
            </a>
          </span>
          <pre class="leetcode-code-block"><code class="language-${escapeHtml(languageKey(reference.language))}">${code}</code></pre>
        </span>
      `;
    }

    function renderImplementationReference(problem) {
      const tracks = implementationTracks(problem);
      const references = implementationReferencesForDisplay(problem);
      const allReferences = problem.implementationReferences || [];
      const lead = references.length
        ? `C++ reference implementation 已公开同步 ${references.length} 份最近通过提交；优先展示 C++ 我的提交，后续可继续补充优化版和生成参考。`
        : allReferences.length
          ? `这题暂时只有 ${allReferences.length} 份非 C++ 历史提交；C++ reference implementation 待同步。`
        : "Reference implementation 待同步最近提交。当前先展示面试实现顺序；最终代码会标记为「我的提交」「已优化」或「生成参考」。";
      return `
        <span class="leetcode-popover-lead">
          ${escapeHtml(lead)}
        </span>
        ${
          references.length
            ? `<span class="leetcode-popover-section">
                <strong>参考实现</strong>
                ${references.map(renderImplementationCode).join("")}
              </span>`
            : ""
        }
        <span class="leetcode-popover-section">
          <strong>建议展开顺序</strong>
          ${tracks
            .map(
              ([name, detail], index) => `
                <span class="leetcode-check">
                  <em>${index + 1}. ${escapeHtml(name)}</em>
                  <span>${escapeHtml(detail)}</span>
                </span>
              `,
            )
            .join("")}
        </span>
        ${renderStudyChecks(problem)}
        ${renderCompanyFollowUps(problem)}
      `;
    }

    function draftFor(problem) {
      return editorDrafts[problem.titleSlug] || {};
    }

    function normalizeLangSlug(lang) {
      return lang === "go" ? "golang" : lang;
    }

    function editorLanguages(problem) {
      const templates = problem.codeTemplates || [];
      if (!templates.length) return fallbackLanguages;
      const seen = new Set();
      return templates
        .filter((template) => {
          if (seen.has(template.langSlug)) return false;
          seen.add(template.langSlug);
          return true;
        })
        .map((template) => [template.langSlug, template.lang]);
    }

    function preferredLang(problem, draftLang) {
      const languages = editorLanguages(problem);
      const normalized = normalizeLangSlug(draftLang || "");
      if (languages.some(([langSlug]) => langSlug === normalized)) {
        return normalized;
      }
      return (
        preferredLanguageOrder.find((langSlug) =>
          languages.some(([item]) => item === langSlug),
        ) ||
        languages[0]?.[0] ||
        "cpp"
      );
    }

    function officialTemplate(problem, lang) {
      const normalized = normalizeLangSlug(lang);
      return (
        problem.codeTemplates?.find((template) => template.langSlug === normalized)
          ?.code || ""
      );
    }

    function fallbackTemplate(problem, lang) {
      const heading = `${problem.frontendId}. ${problem.titleCn}`;
      if (lang === "python3") {
        return `# ${heading}\n# TODO: sync the official LeetCode signature.\nclass Solution:\n    pass\n`;
      }
      if (lang === "go" || lang === "golang") {
        return `// ${heading}\n// TODO: sync the official LeetCode signature.\npackage main\n`;
      }
      if (lang === "java") {
        return `// ${heading}\n// TODO: sync the official LeetCode signature.\nclass Solution {\n}\n`;
      }
      if (lang === "typescript") {
        return `// ${heading}\n// TODO: sync the official LeetCode signature.\n`;
      }
      return `// ${heading}\n// TODO: sync the official LeetCode signature.\nclass Solution {\npublic:\n};\n`;
    }

    function defaultTemplate(problem, lang) {
      return officialTemplate(problem, lang) || fallbackTemplate(problem, lang);
    }

    function editorHighlightHtml(code, lang) {
      return highlightCode(code, lang);
    }

    function editorLineNumbersText(code) {
      const lineCount = Math.max(1, String(code).split("\n").length);
      return Array.from({ length: lineCount }, (_, index) => String(index + 1)).join("\n");
    }

    function editorLineCount(textarea) {
      return Math.max(1, String(textarea.value || "").split("\n").length);
    }

    function editorLineHeight(textarea) {
      const style = window.getComputedStyle(textarea);
      const lineHeight = Number.parseFloat(style.lineHeight);
      if (Number.isFinite(lineHeight)) return lineHeight;
      const fontSize = Number.parseFloat(style.fontSize);
      return Number.isFinite(fontSize) ? fontSize * 1.55 : 20;
    }

    function editorVerticalPadding(textarea) {
      const style = window.getComputedStyle(textarea);
      const top = Number.parseFloat(style.paddingTop);
      const bottom = Number.parseFloat(style.paddingBottom);
      return (Number.isFinite(top) ? top : 0) + (Number.isFinite(bottom) ? bottom : 0);
    }

    function syncEditorHeight(panel, textarea) {
      const shell = panel?.querySelector(".leetcode-editor-shell");
      if (!(shell instanceof HTMLElement)) return;
      const visibleLines = editorAutoGrow
        ? Math.min(
            editorMaxAutoVisibleLines,
            Math.max(editorMinVisibleLines, editorLineCount(textarea) + 1),
          )
        : editorFixedVisibleLines;
      const height = Math.ceil(
        visibleLines * editorLineHeight(textarea) + editorVerticalPadding(textarea),
      );
      shell.style.setProperty("--leetcode-editor-height", `${height}px`);
      if (editorAutoGrow) shell.style.height = "";
      shell.classList.toggle("is-fixed-height", !editorAutoGrow);
      textarea.style.overflowY =
        editorAutoGrow && editorLineCount(textarea) < editorMaxAutoVisibleLines
          ? "hidden"
          : "auto";
    }

    function syncEditorHighlight(panel, textarea, lang) {
      const highlight = panel?.querySelector(".leetcode-editor-highlight");
      const code = highlight?.querySelector("code");
      const lineNumbers = panel?.querySelector(".leetcode-editor-lines");
      syncEditorHeight(panel, textarea);
      if (code) {
        code.innerHTML = editorHighlightHtml(textarea.value, lang);
      }
      if (lineNumbers instanceof HTMLElement) {
        lineNumbers.textContent = editorLineNumbersText(textarea.value);
        lineNumbers.scrollTop = textarea.scrollTop;
      }
      if (highlight instanceof HTMLElement) {
        highlight.scrollTop = textarea.scrollTop;
        highlight.scrollLeft = textarea.scrollLeft;
      }
    }

    function syncRenderedEditors() {
      list?.querySelectorAll("[data-editor-code]").forEach((textarea) => {
        if (!(textarea instanceof HTMLTextAreaElement)) return;
        const context = editorContextFor(textarea);
        if (!context) return;
        syncEditorHighlight(context.panel, textarea, context.lang);
      });
    }

    function editorContextFor(textarea) {
      const slug = textarea.dataset.editorCode || "";
      const panel = textarea.closest(".leetcode-practice-panel");
      const select = panel?.querySelector("[data-editor-lang]");
      const problem = problems.find((item) => item.titleSlug === slug);
      if (!problem) return null;
      const lang =
        select instanceof HTMLSelectElement
          ? preferredLang(problem, select.value)
          : preferredLang(problem, editorDrafts[slug]?.lang);
      return { lang, panel, problem, slug };
    }

    function persistEditorTextarea(textarea) {
      const context = editorContextFor(textarea);
      if (!context) return;
      editorDrafts[context.slug] = { lang: context.lang, code: textarea.value };
      syncEditorHighlight(context.panel, textarea, context.lang);
      writeState();
    }

    function replaceTextareaRange(textarea, start, end, value, nextStart, nextEnd = nextStart) {
      textarea.setRangeText(value, start, end, "preserve");
      textarea.selectionStart = nextStart;
      textarea.selectionEnd = nextEnd;
      persistEditorTextarea(textarea);
    }

    function lineBounds(value, position) {
      const start = value.lastIndexOf("\n", Math.max(0, position - 1)) + 1;
      const nextBreak = value.indexOf("\n", position);
      const end = nextBreak === -1 ? value.length : nextBreak;
      return {
        afterCursor: value.slice(position, end),
        beforeCursor: value.slice(start, position),
        end,
        start,
        text: value.slice(start, end),
      };
    }

    function lineIndent(line) {
      return line.match(/^[\t ]*/)?.[0] || "";
    }

    function shouldIncreaseIndent(beforeCursor, lang) {
      const trimmed = beforeCursor.trimEnd();
      if (!trimmed) return false;
      if (/[\{\[\(]$/.test(trimmed)) return true;
      if (languageKey(lang) === "python" && /:\s*(#.*)?$/.test(trimmed)) {
        return true;
      }
      return false;
    }

    function startsWithClosingToken(text) {
      return /^[\t ]*[\}\]\)]/.test(text);
    }

    function removeOneIndent(value) {
      if (value.startsWith("\t")) return value.slice(1);
      const spaces = value.match(/^ {1,4}/)?.[0] || "";
      return value.slice(spaces.length);
    }

    function handleEditorEnter(event, textarea, context) {
      const value = textarea.value;
      const start = textarea.selectionStart;
      const end = textarea.selectionEnd;
      const bounds = lineBounds(value, start);
      const baseIndent = lineIndent(bounds.beforeCursor);
      const extraIndent = shouldIncreaseIndent(bounds.beforeCursor, context.lang)
        ? editorIndentUnit
        : "";
      const shouldSplitPair = extraIndent && startsWithClosingToken(bounds.afterCursor);
      const insertion = shouldSplitPair
        ? `\n${baseIndent}${extraIndent}\n${baseIndent}`
        : `\n${baseIndent}${extraIndent}`;
      const nextPosition = start + 1 + baseIndent.length + extraIndent.length;
      event.preventDefault();
      replaceTextareaRange(textarea, start, end, insertion, nextPosition);
    }

    function indentTextareaSelection(textarea) {
      const value = textarea.value;
      const start = textarea.selectionStart;
      const end = textarea.selectionEnd;
      if (start === end) {
        replaceTextareaRange(
          textarea,
          start,
          end,
          editorIndentUnit,
          start + editorIndentUnit.length,
        );
        return;
      }

      const blockStart = value.lastIndexOf("\n", Math.max(0, start - 1)) + 1;
      const nextBreak = value.indexOf("\n", end);
      const blockEnd = nextBreak === -1 ? value.length : nextBreak;
      const block = value.slice(blockStart, blockEnd);
      const lineCount = block.split("\n").length;
      const replacement = block.replace(/^/gm, editorIndentUnit);
      replaceTextareaRange(
        textarea,
        blockStart,
        blockEnd,
        replacement,
        start + editorIndentUnit.length,
        end + editorIndentUnit.length * lineCount,
      );
    }

    function outdentTextareaSelection(textarea) {
      const value = textarea.value;
      const start = textarea.selectionStart;
      const end = textarea.selectionEnd;
      const blockStart = value.lastIndexOf("\n", Math.max(0, start - 1)) + 1;
      const nextBreak = value.indexOf("\n", end);
      const blockEnd = nextBreak === -1 ? value.length : nextBreak;
      const block = value.slice(blockStart, blockEnd);
      let nextStart = start;
      let nextEnd = end;
      let cursor = blockStart;
      const replacement = block
        .split("\n")
        .map((line) => {
          const removed = line.length - removeOneIndent(line).length;
          if (cursor < start) {
            nextStart -= Math.min(removed, start - cursor);
          }
          if (cursor < end) {
            nextEnd -= Math.min(removed, Math.max(0, end - cursor));
          }
          cursor += line.length + 1;
          return removeOneIndent(line);
        })
        .join("\n");
      replaceTextareaRange(textarea, blockStart, blockEnd, replacement, nextStart, nextEnd);
    }

    function handleEditorClosingToken(event, textarea) {
      if (!editorClosingTokens.has(event.key)) return false;
      if (textarea.selectionStart !== textarea.selectionEnd) return false;
      const value = textarea.value;
      const start = textarea.selectionStart;
      const bounds = lineBounds(value, start);
      if (!/^[\t ]+$/.test(bounds.beforeCursor)) return false;
      const nextIndent = removeOneIndent(bounds.beforeCursor);
      event.preventDefault();
      replaceTextareaRange(
        textarea,
        bounds.start,
        start,
        `${nextIndent}${event.key}`,
        bounds.start + nextIndent.length + 1,
      );
      return true;
    }

    function isEditorRunShortcut(event) {
      return (
        event.metaKey &&
        !event.altKey &&
        !event.ctrlKey &&
        !event.shiftKey &&
        (event.key === "'" || event.code === "Quote")
      );
    }

    function isEditorSubmitShortcut(event) {
      return (
        event.metaKey &&
        !event.altKey &&
        !event.ctrlKey &&
        !event.shiftKey &&
        event.key === "Enter"
      );
    }

    function practiceNavigationDirection(event) {
      if (!event.altKey || event.metaKey || event.ctrlKey || event.shiftKey) return 0;
      if (event.code === "KeyJ" || event.key === "ArrowDown") return 1;
      if (event.code === "KeyK" || event.key === "ArrowUp") return -1;
      return 0;
    }

    function editorActionButton(panel, action) {
      return panel?.querySelector(`[data-editor-action="${action}"]`);
    }

    function handleEditorKeydown(event, textarea) {
      const context = editorContextFor(textarea);
      if (!context) return false;
      const practiceDirection = practiceNavigationDirection(event);
      if (practiceDirection) {
        event.preventDefault();
        navigatePractice(practiceDirection, context.slug);
        return true;
      }
      if (isEditorRunShortcut(event)) {
        event.preventDefault();
        runLeetcode(
          context.panel,
          editorActionButton(context.panel, "run-leetcode"),
          context.problem,
          textarea,
        );
        return true;
      }
      if (isEditorSubmitShortcut(event)) {
        event.preventDefault();
        submitLeetcode(
          context.panel,
          editorActionButton(context.panel, "submit-leetcode"),
          context.problem,
          textarea,
        );
        return true;
      }
      if (event.key === "Enter") {
        handleEditorEnter(event, textarea, context);
        return true;
      }
      if (event.key === "Tab") {
        event.preventDefault();
        if (event.shiftKey) {
          outdentTextareaSelection(textarea);
        } else {
          indentTextareaSelection(textarea);
        }
        return true;
      }
      return handleEditorClosingToken(event, textarea);
    }

    function openShortcutHelp() {
      if (!(shortcutHelp instanceof HTMLDetailsElement)) return;
      shortcutHelp.open = true;
      shortcutHelp.scrollIntoView({ block: "center", behavior: "smooth" });
      const summary = shortcutHelp.querySelector("summary");
      if (summary instanceof HTMLElement) {
        summary.focus({ preventScroll: true });
      }
    }

    async function ensureLeetcodeReady(panel) {
      setSubmitStatus(panel, "正在检测 Chrome 扩展...", "pending");
      const loginStatus = await extensionRequest(
        "login-status",
        {},
        extensionPingTimeoutMs,
      );
      if (!loginStatus?.ok) {
        throw new Error(loginStatus?.error?.message || "扩展检测失败。");
      }
      if (!loginStatus.data?.isLoggedIn) {
        throw new Error("Chrome 扩展已连接，但当前 Chrome 未登录 leetcode.cn。");
      }
      if (!loginStatus.data?.hasCsrfToken) {
        throw new Error("Chrome 扩展已连接，但缺少 leetcode.cn CSRF cookie。");
      }
    }

    function editorPayload(problem, textarea) {
      const panel = textarea.closest(".leetcode-practice-panel");
      const select = panel?.querySelector("[data-editor-lang]");
      const lang =
        select instanceof HTMLSelectElement
          ? preferredLang(problem, select.value)
          : preferredLang(problem, editorDrafts[problem.titleSlug]?.lang);
      return {
        code: textarea.value,
        langSlug: normalizeLangSlug(lang),
        titleSlug: problem.titleSlug,
      };
    }

    function setActionBusy(actionButton, busy) {
      if (actionButton instanceof HTMLButtonElement) {
        actionButton.disabled = busy;
      }
    }

    function setSubmitStatus(panel, message, tone = "") {
      const status = panel?.querySelector("[data-submit-status]");
      if (!(status instanceof HTMLElement)) return;
      status.textContent = message;
      status.dataset.tone = tone;
    }

    function delay(ms) {
      return new Promise((resolve) => {
        window.setTimeout(resolve, ms);
      });
    }

    function extensionRequest(type, payload, timeoutMs = extensionRequestTimeoutMs) {
      return new Promise((resolve, reject) => {
        const requestId = `leetcode-${Date.now()}-${extensionRequestSequence += 1}`;
        const timeout = window.setTimeout(() => {
          const pending = pendingExtensionRequests.get(requestId);
          pendingExtensionRequests.delete(requestId);
          const message = pending?.ack
            ? "扩展已连接，但力扣请求超时；请稍后查看力扣提交记录。"
            : "未检测到 Chrome 扩展响应，请确认已加载 extensions/leetcode-submit。";
          reject(new Error(message));
        }, timeoutMs);
        pendingExtensionRequests.set(requestId, {
          ack: false,
          reject,
          resolve,
          timeout,
        });
        window.postMessage(
          {
            payload,
            requestId,
            source: extensionRequestSource,
            type,
            version: extensionProtocolVersion,
          },
          window.location.origin,
        );
      });
    }

    function submissionAccepted(result) {
      return (
        result?.statusMessage === "Accepted" ||
        result?.status_msg === "Accepted" ||
        (result?.runSuccess &&
          result?.totalCorrect !== null &&
          result?.totalCorrect === result?.totalTestcases)
      );
    }

    function meaningfulSubmissionValue(value) {
      if (value === null || value === undefined) return "";
      const text = String(value).trim();
      if (!text || text === "N/A") return "";
      return text;
    }

    function firstSubmissionLine(value) {
      const text = meaningfulSubmissionValue(value);
      if (!text) return "";
      return text.split("\n").map((line) => line.trim()).find(Boolean) || "";
    }

    function submissionSummary(result) {
      const status = result?.statusMessage || result?.status_msg || result?.state || "已返回";
      const compileError = firstSubmissionLine(result?.compileError);
      if (compileError) {
        return `${status}: ${compileError}`.slice(0, 220);
      }
      const totalCorrect = meaningfulSubmissionValue(result?.totalCorrect);
      const totalTestcases = meaningfulSubmissionValue(result?.totalTestcases);
      const tests = totalCorrect && totalTestcases ? ` ${totalCorrect}/${totalTestcases}` : "";
      const runtime = meaningfulSubmissionValue(result?.runtime);
      const memory = meaningfulSubmissionValue(result?.memory);
      return `${status}${tests}${runtime}${memory}`.trim();
    }

    function resultFinished(result) {
      const state = result?.state;
      if (state) return state !== "PENDING" && state !== "STARTED";
      return Boolean(result?.finished || result?.statusMessage || result?.statusCode);
    }

    function submissionIdFrom(response, kind) {
      return (
        response?.data?.submissionId ||
        response?.data?.[kind]?.interpret_id ||
        response?.data?.[kind]?.submission_id ||
        ""
      );
    }

    async function pollLeetcodeResult(panel, submissionId, label, maxAttempts) {
      await delay(submissionPollInitialDelayMs);
      for (let attempt = 1; attempt <= maxAttempts; attempt += 1) {
        setSubmitStatus(panel, `${label}，等待结果 ${attempt}/${maxAttempts}...`, "pending");
        const response = await extensionRequest(
          "check",
          { submissionId },
          extensionCheckTimeoutMs,
        );
        if (!response?.ok) {
          throw new Error(response?.error?.message || "查询结果失败。");
        }
        const result = response.data?.result || {};
        if (resultFinished(result)) return result;
        await delay(submissionPollIntervalMs);
      }
      throw new Error(`${label}超时；请稍后查看力扣提交记录。`);
    }

    async function runLeetcode(panel, actionButton, problem, textarea) {
      setActionBusy(actionButton, true);
      try {
        await ensureLeetcodeReady(panel);
        setSubmitStatus(panel, "正在运行官方示例...", "pending");
        const response = await extensionRequest("run", editorPayload(problem, textarea));
        if (!response?.ok) {
          throw new Error(response?.error?.message || "运行失败。");
        }
        const submissionId = submissionIdFrom(response, "run");
        if (!submissionId) {
          throw new Error("力扣没有返回样例运行 ID。");
        }
        const result = await pollLeetcodeResult(
          panel,
          submissionId,
          "正在运行官方示例",
          runPollAttempts,
        );
        const summary = submissionSummary(result);
        if (submissionAccepted(result)) {
          setSubmitStatus(panel, `样例通过 ${summary}`, "success");
          return;
        }
        setSubmitStatus(panel, `样例未通过 ${summary}`, "error");
      } catch (error) {
        setSubmitStatus(panel, error.message || "运行失败。", "error");
      } finally {
        setActionBusy(actionButton, false);
      }
    }

    async function submitLeetcode(panel, actionButton, problem, textarea) {
      setActionBusy(actionButton, true);
      try {
        await ensureLeetcodeReady(panel);
        setSubmitStatus(panel, "正在提交到力扣...", "pending");
        const response = await extensionRequest("submit", editorPayload(problem, textarea));
        if (!response?.ok) {
          throw new Error(response?.error?.message || "提交失败。");
        }
        const submissionId = submissionIdFrom(response, "submit");
        if (!submissionId) {
          throw new Error("力扣没有返回提交 ID。");
        }
        const result = await pollLeetcodeResult(
          panel,
          submissionId,
          "正在提交到力扣",
          submitPollAttempts,
        );
        const summary = submissionSummary(result);
        if (submissionAccepted(result)) {
          const timingResult = recordAcceptedTiming(problem.titleSlug);
          const timingSummary =
            `${isChinesePage ? "本题" : "Problem"} ${formatDuration(timingResult.elapsed)}` +
            (timingResult.isPersonalBest
              ? (isChinesePage ? "，新 PB" : ", new PB")
              : "");
          const milestoneSummary = timingResult.milestone
            ? ` · ${timingResult.milestone}`
            : "";
          progress[problem.titleSlug] = {
            ...rowState(problem.titleSlug),
            done: true,
          };
          writeState();
          setSubmitStatus(
            panel,
            `Accepted ${summary} · ${timingSummary}${milestoneSummary}`,
            "success",
          );
          return;
        }
        setSubmitStatus(panel, summary, "error");
      } catch (error) {
        setSubmitStatus(panel, error.message || "提交失败。", "error");
      } finally {
        setActionBusy(actionButton, false);
      }
    }

    function renderPracticePanel(problem) {
      const draft = draftFor(problem);
      const lang = preferredLang(problem, draft.lang);
      const code = draft.code || defaultTemplate(problem, lang);
      const languages = editorLanguages(problem);
      return `
        <section class="leetcode-practice-panel" data-editor-panel="${escapeHtml(problem.titleSlug)}">
          <div class="leetcode-practice-head">
            <div>
              <strong>${escapeHtml(problem.frontendId)}. ${escapeHtml(problem.titleCn)}</strong>
              <span>${
                problem.codeTemplates?.length
                  ? "官方模板已同步；草稿保存在当前浏览器。"
                  : "官方模板缺失，先使用本地 fallback；草稿保存在当前浏览器。"
              }</span>
              <span class="leetcode-practice-meter">
                <b>${isChinesePage ? "当前" : "Now"} <em data-problem-active="${escapeHtml(problem.titleSlug)}">0:00</em></b>
                <b>PB <em data-problem-best="${escapeHtml(problem.titleSlug)}">--</em></b>
                <b>${isChinesePage ? "上次 AC" : "Last AC"} <em data-problem-last="${escapeHtml(problem.titleSlug)}">--</em></b>
              </span>
            </div>
            <div class="leetcode-practice-actions">
              <select data-editor-lang="${escapeHtml(problem.titleSlug)}" aria-label="Language">
                ${languages
                  .map(
                    ([value, label]) =>
                      `<option value="${escapeHtml(value)}" ${
                        lang === value ? "selected" : ""
                      }>${escapeHtml(label)}</option>`,
                  )
                  .join("")}
              </select>
              <button type="button" data-editor-action="copy" data-slug="${escapeHtml(problem.titleSlug)}">复制</button>
              <button type="button" data-editor-action="reset" data-slug="${escapeHtml(problem.titleSlug)}">重置</button>
              <button type="button" data-editor-action="height-mode" data-slug="${escapeHtml(problem.titleSlug)}">高度：${editorAutoGrow ? "自适应" : "固定"}</button>
              <button type="button" data-editor-action="run-leetcode" data-slug="${escapeHtml(problem.titleSlug)}" title="Cmd+'">运行样例</button>
              <button type="button" data-editor-action="submit-leetcode" data-slug="${escapeHtml(problem.titleSlug)}" title="Cmd+Enter">提交力扣</button>
              <a href="${escapeHtml(problem.url)}" target="_blank" rel="noopener noreferrer">打开力扣</a>
            </div>
          </div>
          <div class="leetcode-editor-shell">
            <pre class="leetcode-editor-lines" aria-hidden="true">${editorLineNumbersText(code)}</pre>
            <pre class="leetcode-editor-highlight" aria-hidden="true"><code>${editorHighlightHtml(code, lang)}</code></pre>
            <textarea
              spellcheck="false"
              wrap="off"
              data-editor-code="${escapeHtml(problem.titleSlug)}"
              aria-label="Local code editor for ${escapeHtml(problem.titleCn)}"
            >${escapeHtml(code)}</textarea>
          </div>
          <p class="leetcode-submit-note">
            <span data-submit-status="${escapeHtml(problem.titleSlug)}">安装本仓库 Chrome 扩展后可直接提交到力扣；页面不会读取你的登录 cookie。</span>
          </p>
        </section>
      `;
    }

    function renderProblem(problem) {
      const status = rowState(problem.titleSlug);
      const visitedClass = clicked[problem.titleSlug] ? " is-visited" : "";
      const topRank = problem.topRank ?? "";
      const hotRank = problem.hotRank ?? "";
      const bytedanceRank = byteDanceRankFor(problem) ?? "";
      const byteDance = renderByteDance(problem);
      const topLabel = problem.topRank === null ? `#${problem.frequencyRank}` : "";
      return `
        <article class="leetcode-row${visitedClass}" data-slug="${escapeHtml(problem.titleSlug)}">
          <div class="leetcode-rank">${topRank}</div>
          <div class="leetcode-rank is-hot">${hotRank}</div>
          <div class="leetcode-rank is-bytedance">${bytedanceRank}</div>
          <div class="leetcode-problem-main">
            <a class="leetcode-problem-link" href="${escapeHtml(problem.url)}" target="_blank" rel="noopener noreferrer" data-link-slug="${escapeHtml(problem.titleSlug)}">
              <span class="leetcode-title-text">${escapeHtml(problem.frontendId)}. ${escapeHtml(problem.titleCn)}</span>
              <span class="leetcode-popover">${escapeHtml(problem.statementPreview)}</span>
            </a>
            <span class="leetcode-title-tools">
              <span class="leetcode-preview-control" data-preview aria-expanded="false" role="button" tabindex="0">
                思路
                <span class="leetcode-popover">
                  <span class="leetcode-popover-lead">${escapeHtml(problem.approachPreview)}</span>
                  ${renderStudyChecks(problem)}
                  ${renderCompanyFollowUps(problem)}
                </span>
              </span>
              <span class="leetcode-preview-control" data-preview aria-expanded="false" role="button" tabindex="0">
                实现
                <span class="leetcode-popover">
                  ${renderImplementationReference(problem)}
                </span>
              </span>
              <span class="leetcode-preview-control" data-preview aria-expanded="false" role="button" tabindex="0">
                标签
                <span class="leetcode-popover">
                  ${renderTagReference(problem, topLabel)}
                </span>
              </span>
            </span>
          </div>
          <div><span class="leetcode-difficulty ${badgeClass(problem.difficulty)}">${escapeHtml(problem.difficulty)}</span></div>
          <div class="leetcode-frequency">${escapeHtml(problem.frequency)}</div>
          <div class="leetcode-byte">${byteDance}</div>
          <div class="leetcode-status">
            <button type="button" data-action="done" data-slug="${escapeHtml(problem.titleSlug)}" class="${status.done ? "is-on" : ""}">做过</button>
            <button type="button" data-action="review" data-slug="${escapeHtml(problem.titleSlug)}" class="${status.review ? "is-on" : ""}">思考</button>
            <button type="button" data-action="mastered" data-slug="${escapeHtml(problem.titleSlug)}" class="${status.mastered ? "is-on" : ""}">熟练</button>
          </div>
        </article>
      `;
    }

    function renderProblemBundle(problem) {
      return renderProblem(problem) + (state.expandedSlug === problem.titleSlug ? renderPracticePanel(problem) : "");
    }

    function render() {
      const items = orderedProblems();
      state.pageSize = pageSize();
      state.totalPages = Math.max(1, Math.ceil(items.length / state.pageSize));
      state.page = clampPage(state.page, state.totalPages);
      const start = (state.page - 1) * state.pageSize;
      const pageItems = items.slice(start, start + state.pageSize);
      if (list) list.innerHTML = pageItems.map(renderProblemBundle).join("");
      if (resultCount) {
        resultCount.textContent = `${items.length} 道题`;
      }
      syncPagination();
      syncRenderedEditors();
      syncActivePracticeTimerAfterRender();
    }

    searchInput?.addEventListener("input", (event) => {
      state.query = event.target.value.trim();
      state.page = 1;
      render();
    });

    pageSizeSelect?.addEventListener("change", () => {
      customSizeInput.hidden = pageSizeSelect.value !== "custom";
      state.page = 1;
      render();
    });

    customSizeInput?.addEventListener("input", () => {
      state.page = 1;
      render();
    });

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        filterButtons.forEach((item) => item.classList.remove("is-active"));
        button.classList.add("is-active");
        state.filter = button.dataset.filter || "all";
        state.page = 1;
        render();
      });
    });

    pageActionButtons.forEach((button) => {
      button.addEventListener("click", () => {
        if (!(button instanceof HTMLElement)) return;
        const action = button.dataset.pageAction;
        if (action === "first") setPage(1);
        if (action === "prev") setPage(state.page - 1);
        if (action === "next") setPage(state.page + 1);
        if (action === "last") setPage(state.totalPages);
      });
    });

    pageJumpInputs.forEach((input) => {
      input.addEventListener("change", () => jumpToInputPage(input));
      input.addEventListener("keydown", (event) => {
        if (event.key !== "Enter") return;
        event.preventDefault();
        jumpToInputPage(input);
      });
    });

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const actionButton = target.closest("[data-timing-action]");
      if (!(actionButton instanceof HTMLElement)) return;
      const action = actionButton.dataset.timingAction || "";
      if (action === "reset-session") {
        resetSessionTiming();
      }
      if (action === "reset-problem") {
        resetActiveProblemTiming();
      }
    });

    window.addEventListener("message", (event) => {
      if (event.source !== window || event.origin !== window.location.origin) return;
      const message = event.data;
      if (
        !message ||
        message.source !== extensionResponseSource ||
        message.version !== extensionProtocolVersion ||
        typeof message.requestId !== "string"
      ) {
        return;
      }
      const pending = pendingExtensionRequests.get(message.requestId);
      if (!pending) return;
      if (message.type === "ack") {
        pending.ack = true;
        return;
      }
      window.clearTimeout(pending.timeout);
      pendingExtensionRequests.delete(message.requestId);
      pending.resolve(message);
    });

    list?.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const link = target.closest("[data-link-slug]");
      if (link instanceof HTMLElement) {
        clicked[link.dataset.linkSlug || ""] = true;
        writeState();
        return;
      }
      if (target.closest(".leetcode-source-link")) return;
      if (target.closest(".leetcode-practice-panel")) {
        const actionButton = target.closest("[data-editor-action]");
        if (actionButton instanceof HTMLElement) {
          const slug = actionButton.dataset.slug || "";
          const panel = actionButton.closest(".leetcode-practice-panel");
          const textarea = panel?.querySelector("[data-editor-code]");
          if (!(textarea instanceof HTMLTextAreaElement)) return;
          if (actionButton.dataset.editorAction === "copy") {
            navigator.clipboard?.writeText(textarea.value);
            actionButton.textContent = "已复制";
            setTimeout(() => {
              actionButton.textContent = "复制";
            }, 1200);
          }
          if (actionButton.dataset.editorAction === "reset") {
            const problem = problems.find((item) => item.titleSlug === slug);
            if (!problem) return;
            const lang = preferredLang(problem, editorDrafts[slug]?.lang);
            editorDrafts[slug] = { lang, code: defaultTemplate(problem, lang) };
            writeState();
            render();
          }
          if (actionButton.dataset.editorAction === "height-mode") {
            editorAutoGrow = !editorAutoGrow;
            localStorage.setItem(editorHeightModeKey, editorAutoGrow ? "auto" : "fixed");
            list
              ?.querySelectorAll('[data-editor-action="height-mode"]')
              .forEach((button) => {
                button.textContent = `高度：${editorAutoGrow ? "自适应" : "固定"}`;
              });
            syncRenderedEditors();
          }
          if (actionButton.dataset.editorAction === "run-leetcode") {
            const problem = problems.find((item) => item.titleSlug === slug);
            if (!problem) return;
            runLeetcode(panel, actionButton, problem, textarea);
          }
          if (actionButton.dataset.editorAction === "submit-leetcode") {
            const problem = problems.find((item) => item.titleSlug === slug);
            if (!problem) return;
            submitLeetcode(panel, actionButton, problem, textarea);
          }
        }
        return;
      }
      const previewButton = target.closest("[data-preview]");
      if (previewButton instanceof HTMLElement) {
        const isOpen = previewButton.classList.contains("is-open");
        list.querySelectorAll("[data-preview].is-open").forEach((item) => {
          item.classList.remove("is-open");
          item.setAttribute("aria-expanded", "false");
        });
        previewButton.classList.toggle("is-open", !isOpen);
        previewButton.setAttribute("aria-expanded", String(!isOpen));
        return;
      }
      const button = target.closest("[data-action]");
      if (button instanceof HTMLElement) {
        const slug = button.dataset.slug || "";
        const action = button.dataset.action || "";
        const current = rowState(slug);
        const next = { ...current };
        if (action === "done") next.done = !next.done;
        if (action === "review") {
          next.review = !next.review;
          if (next.review) next.mastered = false;
        }
        if (action === "mastered") {
          next.mastered = !next.mastered;
          if (next.mastered) {
            next.done = true;
            next.review = false;
          }
        }
        progress[slug] = next;
        writeState();
        render();
        return;
      }

      const row = target.closest(".leetcode-row");
      if (!(row instanceof HTMLElement)) return;
      const slug = row.dataset.slug || "";
      state.expandedSlug = state.expandedSlug === slug ? "" : slug;
      render();
    });

    list?.addEventListener("change", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLSelectElement)) return;
      const slug = target.dataset.editorLang || "";
      if (!slug) return;
      const problem = problems.find((item) => item.titleSlug === slug);
      if (!problem) return;
      const lang = preferredLang(problem, target.value);
      editorDrafts[slug] = {
        lang,
        code: defaultTemplate(problem, lang),
      };
      writeState();
      render();
    });

    list?.addEventListener("input", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLTextAreaElement)) return;
      persistEditorTextarea(target);
    });

    list?.addEventListener(
      "scroll",
      (event) => {
        const target = event.target;
        if (!(target instanceof HTMLTextAreaElement)) return;
        const slug = target.dataset.editorCode || "";
        const panel = target.closest(".leetcode-practice-panel");
        const select = panel?.querySelector("[data-editor-lang]");
        const problem = problems.find((item) => item.titleSlug === slug);
        if (!problem) return;
        const lang =
          select instanceof HTMLSelectElement
            ? preferredLang(problem, select.value)
            : preferredLang(problem, editorDrafts[slug]?.lang);
        syncEditorHighlight(panel, target, lang);
      },
      true,
    );

    list?.addEventListener("keydown", (event) => {
      const target = event.target;
      if (target instanceof HTMLTextAreaElement && handleEditorKeydown(event, target)) {
        return;
      }
      if (!(target instanceof HTMLElement)) return;
      const previewButton = target.closest("[data-preview]");
      if (!(previewButton instanceof HTMLElement)) return;
      if (event.key !== "Enter" && event.key !== " ") return;
      event.preventDefault();
      previewButton.click();
    });

    document.addEventListener("keydown", (event) => {
      if (event.defaultPrevented) return;
      if (!isTextEntryTarget(document.activeElement) && event.key === "?") {
        event.preventDefault();
        openShortcutHelp();
        return;
      }
      const practiceDirection = practiceNavigationDirection(event);
      if (practiceDirection && !isTextEntryTarget(document.activeElement)) {
        event.preventDefault();
        navigatePractice(practiceDirection);
        return;
      }
      if (event.altKey || event.ctrlKey || event.metaKey) return;
      if (isEditableTarget(document.activeElement)) return;
      if (event.key === "ArrowLeft" && state.page > 1) {
        event.preventDefault();
        setPage(state.page - 1);
      }
      if (event.key === "ArrowRight" && state.page < state.totalPages) {
        event.preventDefault();
        setPage(state.page + 1);
      }
    });

    render();
    window.setInterval(syncTimingUi, 1000);
  </script>

