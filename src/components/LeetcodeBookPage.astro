---
import Header from "./Header.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { leetcodeBook } from "../book.config";
import {
  leetcodeCodeTemplateStats,
  leetcodeCodeTemplates,
} from "../data/leetcode-code-templates";
import {
  leetcodeImplementationReferences,
  leetcodeImplementationStats,
} from "../data/leetcode-implementation-references";
import {
  leetcodeByteDanceProblems,
  leetcodeByteDanceStats,
} from "../data/leetcode-bytedance";
import {
  leetcodeDataSource,
  leetcodeDataUpdatedAt,
  leetcodeDuplicateAudit,
  leetcodeProblems,
  leetcodeStats,
} from "../data/leetcode-problems";
import { pageUrl } from "../urls";

interface Props {
  lang?: "en" | "zh";
}

const { lang = "zh" } = Astro.props;
const base = import.meta.env.BASE_URL;
const book = leetcodeBook;
const isZh = lang === "zh";
const homePath = isZh ? `zh/${book.slug}/` : `${book.slug}/`;
const title = isZh ? book.zhTitle : book.title;
const description = isZh ? book.zhDescription : book.description;
const leetcodeTargetLimit = 888;
const syncedDedupedLimit = leetcodeStats.dedupedTop888;
const byteDanceBySlug = new Map(
  leetcodeByteDanceProblems.map((problem) => [problem.titleSlug, problem]),
);

function mergedByteDanceBuckets(problem) {
  const entry = byteDanceBySlug.get(problem.titleSlug);
  if (entry) return entry.buckets;
  const periods = problem.bytedancePeriods || {};
  return {
    all: problem.bytedance ? problem.frequencyRank : null,
    thirtyDays: null,
    threeMonths: periods.past3Months,
    sixMonths: periods.past6Months,
    moreThanSixMonths: periods.before6Months,
  };
}

function frequencyLabel(value) {
  if (value === null || value === undefined) return "字节补充";
  return `${Number(value).toFixed(1)}%`;
}

const leetcodeProblemsWithByteDance = leetcodeProblems.map((problem) => {
  const entry = byteDanceBySlug.get(problem.titleSlug);
  return {
    ...problem,
    bytedance: Boolean(entry || problem.bytedance),
    bytedanceBuckets: mergedByteDanceBuckets(problem),
    bytedanceRank: entry?.bytedanceRank ?? null,
    bytedanceSource: entry?.source ?? (problem.bytedance ? "legacyTop888" : null),
    bytedanceVerified: Boolean(entry) || problem.bytedanceVerified,
  };
});
const existingSlugs = new Set(leetcodeProblems.map((problem) => problem.titleSlug));
const leetcodeByteDanceSupplements = leetcodeByteDanceProblems
  .filter((problem) => !existingSlugs.has(problem.titleSlug))
  .map((problem, index) => ({
    topRank: null,
    frequencyRank: leetcodeTargetLimit + index + 1,
    hotRank: null,
    frontendId: problem.frontendId,
    titleCn: problem.titleCn,
    titleSlug: problem.titleSlug,
    url: problem.url,
    difficulty: problem.difficulty,
    acRate: problem.acRate,
    frequency: frequencyLabel(problem.frequency),
    bytedance: true,
    bytedanceVerified: problem.source === "companyFavorite",
    bytedancePeriods: {
      past3Months: null,
      past6Months: null,
      before6Months: null,
    },
    bytedanceBuckets: problem.buckets,
    bytedanceRank: problem.bytedanceRank,
    bytedanceSource: problem.source,
    hot100: false,
    paidOnly: problem.paidOnly,
    tags: problem.tags,
    statementPreview:
      "字节跳动企业题库补充题。题面预览需要后续同步，当前可点击题目链接打开力扣原题。",
    approachPreview:
      "按字节企业题库频率补充展示；先用官方模板练习，后续再同步题面、思路和 reference implementation。",
    followUps: [],
  }));
const mergedLeetcodeProblems = [
  ...leetcodeProblemsWithByteDance,
  ...leetcodeByteDanceSupplements,
];
const leetcodeProblemsWithReferences = mergedLeetcodeProblems.map((problem) => ({
  ...problem,
  codeTemplates: leetcodeCodeTemplates[problem.titleSlug] ?? [],
  implementationReferences:
    leetcodeImplementationReferences[problem.titleSlug] ?? [],
}));
const totalProblemCount = leetcodeProblemsWithReferences.length;
const shortcutRows = [
  {
    keys: "Option+J / Option+↓",
    zh: "下一题答题区",
    en: "Next problem editor",
  },
  {
    keys: "Option+K / Option+↑",
    zh: "上一题答题区",
    en: "Previous problem editor",
  },
  {
    keys: "Cmd+'",
    zh: "运行官方示例",
    en: "Run official examples",
  },
  {
    keys: "Cmd+Enter",
    zh: "完整提交到力扣",
    en: "Submit to LeetCode",
  },
  {
    keys: "← / →",
    zh: "翻页（未聚焦输入区时）",
    en: "Change page when not editing",
  },
  {
    keys: "?",
    zh: "打开快捷键帮助",
    en: "Open shortcut help",
  },
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={homePath}
  lang={lang}
  titleSuffix={title}
>
  <Header
    lang={lang}
    alternatePath={null}
    homePath={homePath}
    brandTitle={title}
    brandShortTitle={isZh ? book.zhShortTitle : book.shortTitle}
    compact
  />

  <main class="leetcode-shell mx-auto max-w-6xl px-4 py-0 md:px-8">
    <section class="leetcode-stats" aria-label={isZh ? "统计" : "Stats"}>
      <div>
        <span>{leetcodeTargetLimit}</span>
        <p>{isZh ? "Top888 目标" : "Top 888 target"}</p>
      </div>
      <div>
        <span>{syncedDedupedLimit}</span>
        <p>{isZh ? "去重后" : "Deduped"}</p>
      </div>
      <div>
        <span>{leetcodeStats.hot100}</span>
        <p>Hot 100</p>
      </div>
      <div>
        <span>{leetcodeStats.hot100OutsideTop888}</span>
        <p>{isZh ? "Hot100 补充" : "Hot 100 extras"}</p>
      </div>
      <div>
        <span>{leetcodeStats.duplicatesRemoved}</span>
        <p>{isZh ? "去重核对" : "Duplicate audit"}</p>
      </div>
      <div>
        <span>{leetcodeByteDanceStats.syncedAll}/{leetcodeByteDanceStats.targetAll}</span>
        <p>{isZh ? "字节题库" : "ByteDance"}</p>
      </div>
    </section>

    <section class="leetcode-hero">
      <div>
        <p class="leetcode-kicker">{book.coverKicker}</p>
        <h1 class="leetcode-title">{isZh ? book.zhTitle : book.title}</h1>
        <p class="leetcode-copy">
          {isZh
            ? "目标覆盖 Top888；合并 Hot100、重复题核对、字节企业题库、题意/思路/实现预览、本地状态和扩展提交。"
            : "Targets Top 888 with Hot 100, duplicate audit, ByteDance company lists, previews, local state, and extension submit."}
        </p>
        <div class="leetcode-actions">
          <a href={pageUrl(base, `${book.slug}/spec`)} class="leetcode-primary-link">
            {isZh ? "查看规格" : "Read spec"}
          </a>
          <a
            href="https://leetcode.cn/studyplan/top-100-liked/"
            target="_blank"
            rel="noopener noreferrer"
            class="leetcode-secondary-link"
          >
            Hot 100
          </a>
        </div>
      </div>
      <div class="book-cover" aria-label={`${title} cover`}>
        <div class="book-cover__kicker">{book.coverKicker}</div>
        <div class="book-cover__title" set:html={book.coverTitle} />
        <div class="book-cover__footer">{book.coverFooter}</div>
      </div>
    </section>

    <section class="leetcode-workspace" aria-label={isZh ? "题目列表" : "Problem list"}>
      <div class="leetcode-toolbar">
        <div class="leetcode-search">
          <label for="leetcode-search">{isZh ? "搜索" : "Search"}</label>
          <input id="leetcode-search" type="search" placeholder={isZh ? "题号、题名、标签" : "Id, title, tag"} />
        </div>

        <div class="leetcode-filter-panel" aria-label={isZh ? "筛选" : "Filters"}>
          <div class="leetcode-filter-cluster">
            <span>{isZh ? "范围" : "Scope"}</span>
            <div class="leetcode-filter-group" role="group" aria-label={isZh ? "范围筛选" : "Scope filters"}>
              <button type="button" class="is-active" data-filter="all">{isZh ? "全部" : "All"}</button>
              <button type="button" data-filter="hot100">Hot100</button>
              <button type="button" data-filter="companyFollowUps">{isZh ? "公司追问" : "Follow-ups"}</button>
            </div>
          </div>
          <div class="leetcode-filter-cluster">
            <span>{isZh ? "字节" : "ByteDance"}</span>
            <div class="leetcode-filter-group" role="group" aria-label={isZh ? "字节筛选" : "ByteDance filters"}>
              <button type="button" data-filter="bytedanceAll">{isZh ? "全部" : "All"}</button>
              <button type="button" data-filter="bytedanceThirtyDays">{isZh ? "近30天" : "30d"}</button>
              <button type="button" data-filter="bytedanceThreeMonths">{isZh ? "近3月" : "3m"}</button>
              <button type="button" data-filter="bytedanceSixMonths">{isZh ? "近6月" : "6m"}</button>
              <button type="button" data-filter="bytedanceMoreThanSixMonths">{isZh ? "6月前" : "Old"}</button>
            </div>
          </div>
          <div class="leetcode-filter-cluster">
            <span>{isZh ? "状态" : "State"}</span>
            <div class="leetcode-filter-group" role="group" aria-label={isZh ? "状态筛选" : "State filters"}>
              <button type="button" data-filter="unsolved">{isZh ? "未做" : "Unsolved"}</button>
              <button type="button" data-filter="review">{isZh ? "需思考" : "Review"}</button>
              <button type="button" data-filter="unmastered">{isZh ? "未熟练" : "Unmastered"}</button>
            </div>
          </div>
        </div>

        <div class="leetcode-page-size">
          <label for="leetcode-page-size">{isZh ? "每页" : "Page size"}</label>
          <select id="leetcode-page-size">
            <option value="10">10</option>
            <option value="20" selected>20</option>
            <option value="50">50</option>
            <option value="100">100</option>
            <option value="custom">{isZh ? "自定义" : "Custom"}</option>
          </select>
          <input
            id="leetcode-custom-size"
            type="number"
            min="1"
            max={totalProblemCount}
            inputmode="numeric"
            placeholder="32"
            hidden
          />
        </div>
      </div>

      <section class="leetcode-session-board" aria-label={isZh ? "刷题计时" : "Practice timing"}>
        <div class="leetcode-session-metric is-live">
          <span data-timing-active>00:00</span>
          <p>{isZh ? "当前题" : "Current"}</p>
        </div>
        <div class="leetcode-session-metric">
          <span data-timing-session>00:00</span>
          <p>{isZh ? "本次总耗时" : "Session"}</p>
        </div>
        <div class="leetcode-session-metric">
          <span data-timing-session-solved>0 题</span>
          <p>{isZh ? "本次 AC" : "Accepted"}</p>
        </div>
        <div class="leetcode-session-metric">
          <span data-timing-session-avg>--</span>
          <p>{isZh ? "本次均速" : "Average"}</p>
        </div>
        <div class="leetcode-session-metric">
          <span data-timing-today>0 题</span>
          <p>{isZh ? "今日/纪录" : "Today/Best"}</p>
        </div>
        <div class="leetcode-session-metric">
          <span data-timing-streak>0 天</span>
          <p>{isZh ? "连续" : "Streak"}</p>
        </div>
        <div class="leetcode-session-metric">
          <span data-timing-week>0 题</span>
          <p>{isZh ? "近7日" : "7 days"}</p>
        </div>
        <div class="leetcode-session-metric">
          <span data-timing-current-best>--</span>
          <p>{isZh ? "本题 PB" : "Problem PB"}</p>
        </div>
        <div class="leetcode-session-actions">
          <button type="button" data-timing-action="reset-session">{isZh ? "重开本次" : "Reset session"}</button>
          <button type="button" data-timing-action="reset-problem">{isZh ? "清本题" : "Clear problem"}</button>
        </div>
        <div class="leetcode-session-history">
          <span data-timing-timezone>{isZh ? "北京时间" : "Beijing time"}</span>
          <strong data-timing-milestone>{isZh ? "今天 AC 后自动进入日统计" : "Daily stats start after today's first Accepted"}</strong>
          <details>
            <summary>{isZh ? "日统计" : "Daily history"}</summary>
            <div data-timing-history-list></div>
          </details>
        </div>
      </section>

      <div class="leetcode-list-meta">
        <div class="leetcode-summary">
          <span id="leetcode-result-count"></span>
          <span>{isZh ? "数据日期" : "Data date"}: {leetcodeDataUpdatedAt}</span>
          <span>
            {isZh
              ? `力扣中国区按出题频率排序；字节题库来自 company favorite 同步，当前状态：${leetcodeByteDanceStats.sourceStatus}。`
              : leetcodeDataSource}
          </span>
          <span>
            {isZh
              ? `${leetcodeImplementationStats.references} 份公开 reference implementation 已同步`
              : `${leetcodeImplementationStats.references} public reference implementations synced`}
          </span>
          <span>
            {isZh
              ? `${leetcodeCodeTemplateStats.problems} 道题官方代码模板已同步`
              : `${leetcodeCodeTemplateStats.problems} problems with official code templates synced`}
          </span>
        </div>

        <nav
          class="leetcode-pagination leetcode-pagination-top"
          data-pagination
          aria-label={isZh ? "顶部分页" : "Top pagination"}
        >
          <button type="button" data-page-action="first">{isZh ? "首页" : "First"}</button>
          <button type="button" data-page-action="prev">{isZh ? "上一页" : "Prev"}</button>
          <label class="leetcode-page-jump">
            <span>{isZh ? "第" : "Page"}</span>
            <input data-page-jump type="number" min="1" inputmode="numeric" aria-label={isZh ? "跳转页码" : "Jump to page"} />
            <span data-page-indicator></span>
          </label>
          <button type="button" data-page-action="next">{isZh ? "下一页" : "Next"}</button>
          <button type="button" data-page-action="last">{isZh ? "末页" : "Last"}</button>
          <span class="leetcode-shortcut-tip" tabindex="0">
            {isZh ? "快捷键" : "Keys"}
            <span class="leetcode-shortcut-popover" role="tooltip">
              {shortcutRows.map((item) => (
                <span>
                  <kbd>{item.keys}</kbd>
                  <span>{isZh ? item.zh : item.en}</span>
                </span>
              ))}
            </span>
          </span>
        </nav>
      </div>

      <div class="leetcode-table-wrap">
        <div class="leetcode-table-head" aria-hidden="true">
          <span>Top</span>
          <span>Hot</span>
          <span>BD</span>
          <span>{isZh ? "题目" : "Problem"}</span>
          <span>{isZh ? "难度" : "Level"}</span>
          <span>{isZh ? "频率" : "Freq"}</span>
          <span>{isZh ? "字节" : "BD"}</span>
          <span>{isZh ? "状态" : "State"}</span>
        </div>
        <div id="leetcode-problem-list" class="leetcode-problem-list"></div>
      </div>

      <nav
        class="leetcode-pagination leetcode-pagination-bottom"
        data-pagination
        aria-label={isZh ? "底部分页" : "Bottom pagination"}
      >
        <button type="button" data-page-action="first">{isZh ? "首页" : "First"}</button>
        <button type="button" data-page-action="prev">{isZh ? "上一页" : "Prev"}</button>
        <label class="leetcode-page-jump">
          <span>{isZh ? "第" : "Page"}</span>
          <input data-page-jump type="number" min="1" inputmode="numeric" aria-label={isZh ? "跳转页码" : "Jump to page"} />
          <span data-page-indicator></span>
        </label>
        <button type="button" data-page-action="next">{isZh ? "下一页" : "Next"}</button>
        <button type="button" data-page-action="last">{isZh ? "末页" : "Last"}</button>
        <a class="leetcode-page-shortcut" href="#leetcode-shortcuts">{isZh ? "快捷键" : "Keys"}</a>
      </nav>

      {
        leetcodeDuplicateAudit.length > 0 && (
          <details class="leetcode-duplicate-audit">
            <summary>
              {isZh
                ? `去重核对：默认隐藏 ${leetcodeDuplicateAudit.length} 道明显重复题`
                : `Duplicate audit: ${leetcodeDuplicateAudit.length} hidden by default`}
            </summary>
            <div class="leetcode-duplicate-list">
              {leetcodeDuplicateAudit.map((item) => (
                <div class="leetcode-duplicate-row">
                  <span>#{item.duplicateRank}</span>
                  <a
                    href={`https://leetcode.cn/problems/${item.duplicateTitleSlug}/description/`}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {item.duplicateFrontendId}. {item.duplicateTitleCn}
                  </a>
                  <span>{isZh ? "保留" : "kept"}</span>
                  <a
                    href={`https://leetcode.cn/problems/${item.keptTitleSlug}/description/`}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    #{item.keptRank} {item.keptFrontendId}. {item.keptTitleCn}
                  </a>
                </div>
              ))}
            </div>
          </details>
        )
      }
    </section>

    <details class="leetcode-shortcuts" id="leetcode-shortcuts">
      <summary>{isZh ? "快捷键" : "Keyboard shortcuts"}</summary>
      <div class="leetcode-shortcut-grid">
        {shortcutRows.map((item) => (
          <div>
            <kbd>{item.keys}</kbd>
            <span>{isZh ? item.zh : item.en}</span>
          </div>
        ))}
      </div>
    </details>

  </main>

  <script type="application/json" id="leetcode-data" set:html={JSON.stringify(leetcodeProblemsWithReferences)}></script>

  <script>
    const progressKey = "leetcode-book-progress-v1";
    const clickedKey = "leetcode-book-clicked-v1";
    const editorKey = "leetcode-book-editor-v1";
    const editorHeightModeKey = "leetcode-book-editor-height-mode-v1";
    const timingKey = "leetcode-book-timing-v1";
    const dataNode = document.getElementById("leetcode-data");
    const problems = JSON.parse(dataNode?.textContent || "[]");
    const maxPageSize = problems.length || 20;
    const list = document.getElementById("leetcode-problem-list");
    const searchInput = document.getElementById("leetcode-search");
    const pageSizeSelect = document.getElementById("leetcode-page-size");
    const customSizeInput = document.getElementById("leetcode-custom-size");
    const resultCount = document.getElementById("leetcode-result-count");
    const pageActionButtons = Array.from(document.querySelectorAll("[data-page-action]"));
    const pageIndicators = Array.from(document.querySelectorAll("[data-page-indicator]"));
    const pageJumpInputs = Array.from(document.querySelectorAll("[data-page-jump]"));
    const filterButtons = Array.from(document.querySelectorAll("[data-filter]"));
    const shortcutHelp = document.getElementById("leetcode-shortcuts");
    const fallbackLanguages = [
      ["cpp", "C++"],
      ["python3", "Python3"],
      ["golang", "Go"],
      ["java", "Java"],
      ["typescript", "TypeScript"],
    ];
    const preferredLanguageOrder = [
      "cpp",
      "python3",
      "golang",
      "java",
      "typescript",
      "mysql",
      "javascript",
    ];
    const state = {
      filter: "all",
      page: 1,
      pageSize: 20,
      totalPages: 1,
      query: "",
      expandedSlug: "",
    };
    const extensionRequestSource = "books-leetcode-page";
    const extensionResponseSource = "books-leetcode-extension";
    const extensionProtocolVersion = 1;
    const extensionPingTimeoutMs = 2500;
    const extensionCheckTimeoutMs = 20000;
    const extensionRequestTimeoutMs = 30000;
    const submissionPollInitialDelayMs = 800;
    const submissionPollIntervalMs = 1500;
    const runPollAttempts = 24;
    const submitPollAttempts = 80;
    const editorMinVisibleLines = 18;
    const editorFixedVisibleLines = 14;
    const editorMaxAutoVisibleLines = 56;
    const editorIndentUnit = "    ";
    const editorClosingTokens = new Set(["}", "]", ")"]);
    const timingTimeZone = "Asia/Shanghai";
    const timingDayMs = 24 * 60 * 60 * 1000;
    const timingHistoryDays = 14;
    const timingDateFormatter = new Intl.DateTimeFormat("en-CA", {
      day: "2-digit",
      month: "2-digit",
      timeZone: timingTimeZone,
      year: "numeric",
    });
    const pendingExtensionRequests = new Map();
    const isChinesePage = document.documentElement.lang.startsWith("zh");
    let extensionRequestSequence = 0;

    function readJson(key, fallback) {
      try {
        return JSON.parse(localStorage.getItem(key) || JSON.stringify(fallback));
      } catch {
        return fallback;
      }
    }

    let progress = readJson(progressKey, {});
    let clicked = readJson(clickedKey, {});
    let editorDrafts = readJson(editorKey, {});
    let editorAutoGrow = localStorage.getItem(editorHeightModeKey) !== "fixed";
    let timing = readJson(timingKey, {});
    if (!timing || typeof timing !== "object") timing = {};
    timing.problems = timing.problems && typeof timing.problems === "object"
      ? timing.problems
      : {};
    timing.days = timing.days && typeof timing.days === "object"
      ? timing.days
      : {};
    const sessionTiming = {
      acceptedDurations: [],
      acceptedSlugs: new Set(),
      startedAt: Date.now(),
    };
    let activePracticeTimer = { slug: "", startedAt: 0 };
    let timingMilestone = "";

    function writeState() {
      localStorage.setItem(progressKey, JSON.stringify(progress));
      localStorage.setItem(clickedKey, JSON.stringify(clicked));
      localStorage.setItem(editorKey, JSON.stringify(editorDrafts));
    }

    function writeTiming() {
      localStorage.setItem(timingKey, JSON.stringify(timing));
    }

    function pad2(value) {
      return String(value).padStart(2, "0");
    }

    function localDateKey(date = new Date()) {
      const parts = Object.fromEntries(
        timingDateFormatter
          .formatToParts(date)
          .map((part) => [part.type, part.value]),
      );
      return [parts.year, parts.month, parts.day].join("-");
    }

    function dateKeyParts(dateKey) {
      const [year, month, day] = String(dateKey || "")
        .split("-")
        .map((part) => Number.parseInt(part, 10));
      if (!year || !month || !day) return null;
      return { day, month, year };
    }

    function shiftDateKey(dateKey, offsetDays) {
      const parts = dateKeyParts(dateKey);
      if (!parts) return localDateKey();
      const date = new Date(
        Date.UTC(parts.year, parts.month - 1, parts.day) +
          offsetDays * timingDayMs,
      );
      return [
        date.getUTCFullYear(),
        pad2(date.getUTCMonth() + 1),
        pad2(date.getUTCDate()),
      ].join("-");
    }

    function shortDateLabel(dateKey) {
      const parts = dateKeyParts(dateKey);
      if (!parts) return dateKey;
      return `${pad2(parts.month)}/${pad2(parts.day)}`;
    }

    function formatDuration(ms) {
      const totalSeconds = Math.max(0, Math.floor(Number(ms || 0) / 1000));
      const hours = Math.floor(totalSeconds / 3600);
      const minutes = Math.floor((totalSeconds % 3600) / 60);
      const seconds = totalSeconds % 60;
      if (hours > 0) return `${hours}:${pad2(minutes)}:${pad2(seconds)}`;
      return `${minutes}:${pad2(seconds)}`;
    }

    function formatProblemCount(count) {
      const value = Number(count || 0);
      return isChinesePage ? `${value} 题` : `${value} solved`;
    }

    function dayTiming(dateKey = localDateKey()) {
      if (!timing.days[dateKey] || typeof timing.days[dateKey] !== "object") {
        timing.days[dateKey] = {
          acceptedCount: 0,
          acceptedSlugs: [],
          bestMs: null,
          firstAcceptedAt: null,
          lastAcceptedAt: null,
          totalAcceptedMs: 0,
        };
      }
      const day = timing.days[dateKey];
      if (!Array.isArray(day.acceptedSlugs)) day.acceptedSlugs = [];
      day.acceptedCount = Number(day.acceptedCount || 0);
      day.totalAcceptedMs = Number(day.totalAcceptedMs || 0);
      day.bestMs = day.bestMs === null ? null : Number(day.bestMs || 0) || null;
      day.firstAcceptedAt = day.firstAcceptedAt || null;
      day.lastAcceptedAt = day.lastAcceptedAt || null;
      return day;
    }

    function dayUniqueCount(day) {
      return Array.isArray(day?.acceptedSlugs) ? day.acceptedSlugs.length : 0;
    }

    function dayAcceptedCount(day) {
      return Number(day?.acceptedCount || 0);
    }

    function dayAverageMs(day) {
      const acceptedCount = dayAcceptedCount(day);
      return acceptedCount ? Number(day?.totalAcceptedMs || 0) / acceptedCount : 0;
    }

    function validDayKeys() {
      return Object.keys(timing.days || {})
        .filter((dateKey) => /^\d{4}-\d{2}-\d{2}$/.test(dateKey))
        .sort();
    }

    function bestDayStats(excludeKey = "") {
      return validDayKeys().reduce(
        (best, dateKey) => {
          if (dateKey === excludeKey) return best;
          const day = timing.days[dateKey];
          const unique = dayUniqueCount(day);
          if (!unique) return best;
          const accepted = dayAcceptedCount(day);
          const averageMs = dayAverageMs(day);
          const isBetter =
            unique > best.unique ||
            (unique === best.unique && accepted > best.accepted) ||
            (unique === best.unique &&
              accepted === best.accepted &&
              averageMs > 0 &&
              (!best.averageMs || averageMs < best.averageMs));
          return isBetter
            ? { accepted, averageMs, dateKey, unique }
            : best;
        },
        { accepted: 0, averageMs: 0, dateKey: "", unique: 0 },
      );
    }

    function fastestDayStats(excludeKey = "") {
      return validDayKeys().reduce(
        (fastest, dateKey) => {
          if (dateKey === excludeKey) return fastest;
          const day = timing.days[dateKey];
          const averageMs = dayAverageMs(day);
          if (!averageMs) return fastest;
          return !fastest.averageMs || averageMs < fastest.averageMs
            ? { averageMs, dateKey }
            : fastest;
        },
        { averageMs: 0, dateKey: "" },
      );
    }

    function recentTimingStats(todayKey = localDateKey()) {
      const slugs = new Set();
      let accepted = 0;
      let activeDays = 0;
      let totalMs = 0;
      for (let index = 0; index < 7; index += 1) {
        const dateKey = shiftDateKey(todayKey, -index);
        const day = timing.days[dateKey];
        if (!day) continue;
        day.acceptedSlugs?.forEach((slug) => slugs.add(slug));
        accepted += dayAcceptedCount(day);
        totalMs += Number(day.totalAcceptedMs || 0);
        if (dayUniqueCount(day)) activeDays += 1;
      }
      return {
        accepted,
        activeDays,
        averageMs: accepted ? totalMs / accepted : 0,
        unique: slugs.size,
      };
    }

    function streakStats(todayKey = localDateKey()) {
      const todaySolved = dayUniqueCount(timing.days[todayKey]) > 0;
      let cursor = todaySolved ? todayKey : shiftDateKey(todayKey, -1);
      let count = 0;
      while (dayUniqueCount(timing.days[cursor]) > 0) {
        count += 1;
        cursor = shiftDateKey(cursor, -1);
      }
      return {
        count,
        pendingToday: !todaySolved && count > 0,
      };
    }

    function timingOverview() {
      const todayKey = localDateKey();
      const today = dayTiming(todayKey);
      return {
        bestDay: bestDayStats(),
        bestDayBeforeToday: bestDayStats(todayKey),
        fastestDayBeforeToday: fastestDayStats(todayKey),
        recent: recentTimingStats(todayKey),
        streak: streakStats(todayKey),
        today,
        todayKey,
        todayUnique: dayUniqueCount(today),
      };
    }

    function formatStreak(streak) {
      if (!streak.count) return isChinesePage ? "0 天" : "0 days";
      const suffix = streak.pendingToday
        ? (isChinesePage ? "待续" : "pending")
        : "";
      return isChinesePage
        ? `${streak.count} 天${suffix}`
        : `${streak.count} days${suffix ? ` ${suffix}` : ""}`;
    }

    function defaultTimingMilestone(overview) {
      const bestBefore = overview.bestDayBeforeToday;
      if (!overview.todayUnique) {
        if (overview.streak.pendingToday) {
          return isChinesePage
            ? `连续 ${overview.streak.count} 天待续，今天 AC 后续上`
            : `${overview.streak.count}-day streak pending today`;
        }
        return isChinesePage
          ? "今天 AC 后自动进入日统计"
          : "Daily stats start after today's first Accepted";
      }
      if (!bestBefore.unique || overview.todayUnique > bestBefore.unique) {
        return isChinesePage
          ? `今日新纪录 ${overview.todayUnique} 题`
          : `New daily record: ${overview.todayUnique}`;
      }
      if (overview.todayUnique === bestBefore.unique) {
        return isChinesePage
          ? `今日追平历史日记录 ${overview.todayUnique} 题`
          : `Tied daily record: ${overview.todayUnique}`;
      }
      return isChinesePage
        ? `距历史日记录还差 ${bestBefore.unique - overview.todayUnique} 题`
        : `${bestBefore.unique - overview.todayUnique} away from daily record`;
    }

    function acceptedTimingMilestone(result) {
      const messages = [];
      if (result.isNewDailyRecord) {
        messages.push(isChinesePage ? "今日新纪录" : "new daily record");
      } else if (result.tiedDailyRecord) {
        messages.push(isChinesePage ? "追平日记录" : "tied daily record");
      }
      if (result.isPersonalBest) {
        messages.push(isChinesePage ? "本题 PB" : "problem PB");
      }
      if (result.isFastestDayAverage) {
        messages.push(isChinesePage ? "均速新高" : "best daily pace");
      }
      if (result.streakCount > 1 && !result.streakPendingToday) {
        messages.push(
          isChinesePage
            ? `连续 ${result.streakCount} 天`
            : `${result.streakCount}-day streak`,
        );
      }
      if (!messages.length) {
        messages.push(
          isChinesePage
            ? `今日 ${result.todayUnique} 题`
            : `${result.todayUnique} today`,
        );
      }
      return messages.join(" · ");
    }

    function renderTimingHistory(overview) {
      return Array.from({ length: timingHistoryDays }, (_, index) => {
        const dateKey = shiftDateKey(overview.todayKey, -index);
        const day = timing.days[dateKey] || {};
        const unique = dayUniqueCount(day);
        const averageMs = dayAverageMs(day);
        const classes = [
          "leetcode-history-day",
          dateKey === overview.todayKey ? "is-today" : "",
          unique && unique === overview.bestDay.unique ? "is-best" : "",
          unique ? "" : "is-empty",
        ].filter(Boolean).join(" ");
        const label = dateKey === overview.todayKey
          ? (isChinesePage ? "今天" : "Today")
          : shortDateLabel(dateKey);
        const avgLabel = averageMs ? formatDuration(averageMs) : "--";
        const countLabel = isChinesePage ? `${unique}题` : `${unique}`;
        return `
          <span class="${classes}" title="${escapeHtml(dateKey)}">
            <b>${escapeHtml(label)}</b>
            <em>${escapeHtml(countLabel)}</em>
            <small>${escapeHtml(avgLabel)}</small>
          </span>
        `;
      }).join("");
    }

    function problemTiming(slug) {
      if (!slug) return {};
      if (!timing.problems[slug] || typeof timing.problems[slug] !== "object") {
        timing.problems[slug] = {
          acceptedCount: 0,
          bestMs: null,
          lastAcceptedAt: null,
          lastMs: null,
          totalAcceptedMs: 0,
        };
      }
      const record = timing.problems[slug];
      record.acceptedCount = Number(record.acceptedCount || 0);
      record.totalAcceptedMs = Number(record.totalAcceptedMs || 0);
      record.bestMs = record.bestMs === null ? null : Number(record.bestMs || 0);
      record.lastMs = record.lastMs === null ? null : Number(record.lastMs || 0);
      return record;
    }

    function storedProblemTiming(slug) {
      const record = slug ? timing.problems[slug] : null;
      return record && typeof record === "object" ? record : {};
    }

    function activePracticeElapsed() {
      if (!activePracticeTimer.slug || !activePracticeTimer.startedAt) return 0;
      return Date.now() - activePracticeTimer.startedAt;
    }

    function setTextAll(selector, value) {
      document.querySelectorAll(selector).forEach((node) => {
        node.textContent = value;
      });
    }

    function syncTimingUi() {
      const elapsed = activePracticeElapsed();
      const activeSlug = activePracticeTimer.slug;
      const activeRecord = activeSlug ? storedProblemTiming(activeSlug) : {};
      const sessionElapsed = Date.now() - sessionTiming.startedAt;
      const sessionAcceptedCount = sessionTiming.acceptedDurations.length;
      const sessionAverage = sessionAcceptedCount
        ? sessionTiming.acceptedDurations.reduce((sum, item) => sum + item, 0) /
          sessionAcceptedCount
        : 0;
      const overview = timingOverview();
      const todayBest = overview.bestDay.unique || "--";

      setTextAll("[data-timing-active]", formatDuration(elapsed));
      setTextAll("[data-timing-session]", formatDuration(sessionElapsed));
      setTextAll(
        "[data-timing-session-solved]",
        formatProblemCount(sessionTiming.acceptedSlugs.size),
      );
      setTextAll(
        "[data-timing-session-avg]",
        sessionAverage ? formatDuration(sessionAverage) : "--",
      );
      setTextAll("[data-timing-today]", `${overview.todayUnique} / ${todayBest}`);
      setTextAll("[data-timing-streak]", formatStreak(overview.streak));
      setTextAll("[data-timing-week]", formatProblemCount(overview.recent.unique));
      setTextAll(
        "[data-timing-current-best]",
        activeRecord.bestMs ? formatDuration(activeRecord.bestMs) : "--",
      );
      setTextAll("[data-timing-timezone]", isChinesePage ? "北京时间" : "Beijing time");
      setTextAll(
        "[data-timing-milestone]",
        timingMilestone || defaultTimingMilestone(overview),
      );
      document.querySelectorAll("[data-timing-history-list]").forEach((node) => {
        if (node instanceof HTMLElement) {
          node.innerHTML = renderTimingHistory(overview);
        }
      });

      document.querySelectorAll("[data-problem-active]").forEach((node) => {
        const slug = node instanceof HTMLElement ? node.dataset.problemActive : "";
        node.textContent =
          slug && slug === activeSlug ? formatDuration(elapsed) : "0:00";
      });
      document.querySelectorAll("[data-problem-best]").forEach((node) => {
        const slug = node instanceof HTMLElement ? node.dataset.problemBest : "";
        const record = slug ? storedProblemTiming(slug) : {};
        node.textContent = record.bestMs ? formatDuration(record.bestMs) : "--";
      });
      document.querySelectorAll("[data-problem-last]").forEach((node) => {
        const slug = node instanceof HTMLElement ? node.dataset.problemLast : "";
        const record = slug ? storedProblemTiming(slug) : {};
        node.textContent = record.lastMs ? formatDuration(record.lastMs) : "--";
      });
      document.querySelectorAll("[data-timing-action='reset-problem']").forEach((button) => {
        if (button instanceof HTMLButtonElement) {
          button.disabled = !activeSlug || !timing.problems[activeSlug];
        }
      });
    }

    function syncActivePracticeTimerAfterRender() {
      const hasPanel = Boolean(
        state.expandedSlug &&
          Array.from(list?.querySelectorAll("[data-editor-panel]") || []).some(
            (item) =>
              item instanceof HTMLElement &&
              item.dataset.editorPanel === state.expandedSlug,
          ),
      );
      const nextSlug = hasPanel ? state.expandedSlug : "";
      if (activePracticeTimer.slug !== nextSlug) {
        activePracticeTimer = {
          slug: nextSlug,
          startedAt: nextSlug ? Date.now() : 0,
        };
      }
      syncTimingUi();
    }

    function resetSessionTiming() {
      sessionTiming.acceptedDurations = [];
      sessionTiming.acceptedSlugs = new Set();
      sessionTiming.startedAt = Date.now();
      timingMilestone = "";
      if (activePracticeTimer.slug) {
        activePracticeTimer.startedAt = Date.now();
      }
      syncTimingUi();
    }

    function resetActiveProblemTiming() {
      const slug = activePracticeTimer.slug;
      if (!slug) return;
      delete timing.problems[slug];
      if (activePracticeTimer.startedAt) {
        activePracticeTimer.startedAt = Date.now();
      }
      writeTiming();
      syncTimingUi();
    }

    function recordAcceptedTiming(slug) {
      const elapsed = Math.max(0, activePracticeTimer.slug === slug
        ? Date.now() - activePracticeTimer.startedAt
        : 0);
      const todayKey = localDateKey();
      const beforeOverview = timingOverview();
      const beforeTodayUnique = beforeOverview.todayUnique;
      const record = problemTiming(slug);
      const previousBest = record.bestMs || null;
      const isPersonalBest = !previousBest || elapsed < previousBest;
      const nowIso = new Date().toISOString();
      record.acceptedCount += 1;
      record.totalAcceptedMs += elapsed;
      record.lastAcceptedAt = nowIso;
      record.lastMs = elapsed;
      record.bestMs = isPersonalBest ? elapsed : previousBest;

      const today = dayTiming(todayKey);
      today.acceptedCount += 1;
      today.totalAcceptedMs += elapsed;
      today.bestMs = !today.bestMs || elapsed < today.bestMs ? elapsed : today.bestMs;
      today.firstAcceptedAt = today.firstAcceptedAt || nowIso;
      today.lastAcceptedAt = nowIso;
      if (!today.acceptedSlugs.includes(slug)) today.acceptedSlugs.push(slug);

      sessionTiming.acceptedDurations.push(elapsed);
      sessionTiming.acceptedSlugs.add(slug);
      if (activePracticeTimer.slug === slug) {
        activePracticeTimer.startedAt = Date.now();
      }
      const afterOverview = timingOverview();
      const todayUnique = afterOverview.todayUnique;
      const bestBefore = beforeOverview.bestDayBeforeToday;
      const wasNewUnique = todayUnique > beforeTodayUnique;
      const isNewDailyRecord = wasNewUnique &&
        (!bestBefore.unique || todayUnique > bestBefore.unique);
      const tiedDailyRecord = wasNewUnique &&
        bestBefore.unique > 0 &&
        todayUnique === bestBefore.unique;
      const todayAverage = dayAverageMs(today);
      const fastestBefore = beforeOverview.fastestDayBeforeToday;
      const isFastestDayAverage = Boolean(
        todayAverage &&
          (!fastestBefore.averageMs || todayAverage < fastestBefore.averageMs),
      );
      timingMilestone = acceptedTimingMilestone({
        isFastestDayAverage,
        isNewDailyRecord,
        isPersonalBest,
        streakCount: afterOverview.streak.count,
        streakPendingToday: afterOverview.streak.pendingToday,
        tiedDailyRecord,
        todayUnique,
      });
      writeTiming();
      syncTimingUi();
      return {
        bestMs: record.bestMs,
        elapsed,
        isNewDailyRecord,
        isPersonalBest,
        milestone: timingMilestone,
        tiedDailyRecord,
      };
    }

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;");
    }

    function escapeToken(value) {
      return escapeHtml(value);
    }

    function isIdentifierStart(char) {
      return /[A-Za-z_$@]/.test(char);
    }

    function isIdentifierPart(char) {
      return /[A-Za-z0-9_$@]/.test(char);
    }

